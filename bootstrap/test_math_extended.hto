# H# Mathematics Module Test Suite
# Tests for matrix operations, statistics, and vector math

# Import the math module
import "bootstrap/math_extended";

print("========================================");
print("H# Mathematics Module Test Suite");
print("========================================");
print("");

let tests_passed = 0;
let tests_failed = 0;

# Helper function to check equality
fn assert_equals(test_name, actual, expected) {
    if (actual == expected) {
        print("[PASS] " + test_name);
        return true;
    } else {
        print("[FAIL] " + test_name);
        print("  Expected: " + str(expected));
        print("  Actual:   " + str(actual));
        return false;
    }
}

# Helper for approximate equality (floating point)
fn assert_approx_equals(test_name, actual, expected, tolerance) {
    let diff = actual - expected;
    if (diff < 0) {
        diff = -diff;
    }
    if (diff <= tolerance) {
        print("[PASS] " + test_name);
        return true;
    } else {
        print("[FAIL] " + test_name);
        print("  Expected: ~" + str(expected));
        print("  Actual:   " + str(actual));
        return false;
    }
}

# ============================================
# Matrix Creation Tests
# ============================================
print("--- Matrix Creation ---");

# Test create matrix
let mat = math_matrix_create(2, 3, 5);
if (len(mat) == 2 and len(mat[0]) == 3) {
    print("[PASS] math_matrix_create dimensions");
    tests_passed = tests_passed + 1;
} else {
    print("[FAIL] math_matrix_create dimensions");
    tests_failed = tests_failed + 1;
}

# Test matrix get/set
math_matrix_set(mat, 0, 0, 10);
let val = math_matrix_get(mat, 0, 0);
if (assert_equals("math_matrix_get/set", val, 10)) {
    tests_passed = tests_passed + 1;
} else {
    tests_failed = tests_failed + 1;
}

# Test identity matrix
let ident = math_matrix_identity(3);
let ident_val = math_matrix_get(ident, 1, 1);
if (assert_equals("math_matrix_identity diagonal", ident_val, 1)) {
    tests_passed = tests_passed + 1;
} else {
    tests_failed = tests_failed + 1;
}

let ident_off = math_matrix_get(ident, 0, 1);
if (assert_equals("math_matrix_identity off-diagonal", ident_off, 0)) {
    tests_passed = tests_passed + 1;
} else {
    tests_failed = tests_failed + 1;
}

# Test matrix dimensions
let rows = math_matrix_rows(mat);
let cols = math_matrix_cols(mat);
if (assert_equals("math_matrix_rows", rows, 2)) {
    tests_passed = tests_passed + 1;
} else {
    tests_failed = tests_failed + 1;
}

if (assert_equals("math_matrix_cols", cols, 3)) {
    tests_passed = tests_passed + 1;
} else {
    tests_failed = tests_failed + 1;
}

