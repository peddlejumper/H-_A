if (p50 >= 4 and p50 <= 7) {
    print("[PASS] percentile 50th");
    tests_passed = tests_passed + 1;
} else {
    print("[FAIL] percentile 50th: " + str(p50));
    tests_failed = tests_failed + 1;
}

# ============================================
# Advanced Statistics Tests
# ============================================
print("");
print("--- Advanced Statistics ---");

# Test correlation (perfect positive)
let x1 = [1, 2, 3, 4, 5];
let y1 = [2, 4, 6, 8, 10];
let corr1 = math_correlation(x1, y1);
if (assert_approx_equals("correlation perfect positive", corr1, 1, 0.001)) {
    tests_passed = tests_passed + 1;
} else {
    tests_failed = tests_failed + 1;
}

# Test correlation (perfect negative)
let y2 = [10, 8, 6, 4, 2];
let corr2 = math_correlation(x1, y2);
if (assert_approx_equals("correlation perfect negative", corr2, -1, 0.001)) {
    tests_passed = tests_passed + 1;
} else {
    tests_failed = tests_failed + 1;
}

# Test covariance
let cov = math_covariance(x1, y1);
if (cov > 0) {
    print("[PASS] covariance positive");
    tests_passed = tests_passed + 1;
} else {
    print("[FAIL] covariance");
    tests_failed = tests_failed + 1;
}

# Test linear regression
let lr = math_linear_regression(x1, y1);
let slope = lr[0];
let intercept = lr[1];
if (assert_approx_equals("linear regression slope", slope, 2, 0.001)) {
    tests_passed = tests_passed + 1;
} else {
    tests_failed = tests_failed + 1;
}

if (assert_approx_equals("linear regression intercept", intercept, 0, 0.001)) {
    tests_passed = tests_passed + 1;
} else {
    tests_failed = tests_failed + 1;
}

# Test prediction
let pred = math_predict(2, 0, 5);
if (assert_equals("predict", pred, 10)) {
    tests_passed = tests_passed + 1;
} else {
    tests_failed = tests_failed + 1;
}

