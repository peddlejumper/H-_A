# ═══════════════════════════════════════════════════════════════════════════
# 测试 58：Canvas 绘图控件
# ═══════════════════════════════════════════════════════════════════════════
print("── Test 58: Canvas ──");
let canvas = new Canvas();
canvas.init_canvas(400, 300);
assert(canvas != nullptr, "Canvas created");
assert(canvas.widget_type == "Canvas", "Canvas widget_type");
assert(canvas.width == 400, "Canvas width");
assert(canvas.height == 300, "Canvas height");

canvas.drawLine(0, 0, 100, 100, "#000000", 2);
assert(len(canvas.lines) == 1, "Canvas: 1 line");
assert(canvas.lines[0]["x1"] == 0, "Canvas: line x1");
assert(canvas.lines[0]["y1"] == 0, "Canvas: line y1");
assert(canvas.lines[0]["x2"] == 100, "Canvas: line x2");
assert(canvas.lines[0]["y2"] == 100, "Canvas: line y2");
assert(canvas.lines[0]["color"] == "#000000", "Canvas: line color");
assert(canvas.lines[0]["width"] == 2, "Canvas: line width");

canvas.drawRect(10, 20, 80, 60, "#FF0000", false, 1);
assert(len(canvas.rects) == 1, "Canvas: 1 rect");
assert(canvas.rects[0]["fill"] == false, "Canvas: rect outline");

canvas.fillRect(50, 50, 100, 80, "#00FF00");
assert(len(canvas.rects) == 2, "Canvas: 2 rects (fillRect added)");
assert(canvas.rects[1]["fill"] == true, "Canvas: fillRect fill=true");

canvas.drawCircle(150, 150, 50, "#0000FF", false, 2);
assert(len(canvas.circles) == 1, "Canvas: 1 circle");
assert(canvas.circles[0]["cx"] == 150, "Canvas: circle cx");
assert(canvas.circles[0]["cy"] == 150, "Canvas: circle cy");
assert(canvas.circles[0]["radius"] == 50, "Canvas: circle radius");

canvas.fillCircle(200, 200, 30, "#FF00FF");
assert(len(canvas.circles) == 2, "Canvas: 2 circles");
assert(canvas.circles[1]["fill"] == true, "Canvas: fillCircle fill=true");

canvas.drawText(10, 250, "Hello Canvas", "#333333", 14);
assert(len(canvas.texts) == 1, "Canvas: 1 text");
assert(canvas.texts[0]["text"] == "Hello Canvas", "Canvas: text content");
assert(canvas.texts[0]["color"] == "#333333", "Canvas: text color");
assert(canvas.texts[0]["size"] == 14, "Canvas: text size");

canvas.drawImage(0, 0, 100, 80, "test.png");
assert(len(canvas.images) == 1, "Canvas: 1 image");
assert(canvas.images[0]["path"] == "test.png", "Canvas: image path");

canvas.clear();
assert(len(canvas.lines) == 0, "Canvas: clear lines");
assert(len(canvas.rects) == 0, "Canvas: clear rects");
assert(len(canvas.circles) == 0, "Canvas: clear circles");
assert(len(canvas.texts) == 0, "Canvas: clear texts");
assert(len(canvas.images) == 0, "Canvas: clear images");

