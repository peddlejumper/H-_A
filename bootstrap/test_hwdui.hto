# ═══════════════════════════════════════════════════════════════════════════
# 测试 38：Window minimze/maximize/restore
# ═══════════════════════════════════════════════════════════════════════════
print("── Test 38: Window 状态 ──");
let state_win = hwdui_create_window("状态窗口", 400, 300);
state_win.set_pos(100, 100);

state_win.minimize();
assert(state_win.is_minimized == true, "Window minimize");

state_win.restore();
assert(state_win.x == 100, "Window restore x");
assert(state_win.y == 100, "Window restore y");
assert(state_win.width == 400, "Window restore w");
assert(state_win.height == 300, "Window restore h");
assert(state_win.is_minimized == false, "Window no longer minimized");

state_win.maximize();
assert(state_win.is_maximized == true, "Window maximize");
state_win.restore();
assert(state_win.is_maximized == false, "Window unmaximize");

# ═══════════════════════════════════════════════════════════════════════════
# 测试 39：Window get_client_area
# ═══════════════════════════════════════════════════════════════════════════
print("── Test 39: Window client_area ──");
let ca = state_win.get_client_area();
