assert(len(segs) == 1, "RichLabel: single segment");
assert(segs[0]["bold"] == false, "RichLabel: segment not bold");
assert(segs[0]["italic"] == false, "RichLabel: segment not italic");

# ═══════════════════════════════════════════════════════════════════════════
# Test 83: EventBus
# ═══════════════════════════════════════════════════════════════════════════
print("── Test 83: EventBus ──");
let bus = new EventBus();
bus.init_bus();
assert(bus != nullptr, "EventBus created");
assert(bus.hasListeners("test") == false, "EventBus: no listeners initially");

let event_count = 0;
let event_data = nullptr;
fn handler(evt, data) {
    event_count = event_count + 1;
    event_data = data;
    return 0;
}

bus.on("click", handler);
assert(bus.hasListeners("click") == true, "EventBus: hasListeners after on");

bus.emit("click", {"x": 10, "y": 20});
assert(event_count == 1, "EventBus: emit triggers handler");

bus.off("click", handler);
assert(bus.hasListeners("click") == false, "EventBus: no listeners after off");

let once_count = 0;
fn once_handler(evt, data) {
    once_count = once_count + 1;
    return 0;
}
bus.once("load", once_handler);
bus.emit("load", nullptr);
bus.emit("load", nullptr);
assert(once_count == 1, "EventBus: once fires only once");

bus.clear();
assert(bus.hasListeners("click") == false, "EventBus: clear all");

bus.on("topic", handler);
bus.clearEvent("topic");
assert(bus.hasListeners("topic") == false, "EventBus: clearEvent");

# ═══════════════════════════════════════════════════════════════════════════
# Test 84: Clipboard
# ═══════════════════════════════════════════════════════════════════════════
print("── Test 84: Clipboard ──");
let clip = new Clipboard();
clip.init_clipboard();
assert(clip != nullptr, "Clipboard created");
assert(clip.hasContent() == false, "Clipboard: empty initially");
assert(clip.getType() == "text", "Clipboard: default type text");

clip.copy("Hello World");
assert(clip.hasContent() == true, "Clipboard: has content after copy");
assert(clip.paste() == "Hello World", "Clipboard: paste returns content");

clip.copy("Second");
clip.copyWithType("Second", "html");
assert(clip.paste() == "Second", "Clipboard: paste second content");
assert(clip.getType() == "html", "Clipboard: type updated");

let info = clip.pasteWithType();
assert(info["content"] == "Second", "Clipboard: pasteWithType content");
assert(info["type"] == "html", "Clipboard: pasteWithType type");

assert(clip.getHistoryCount() == 2, "Clipboard: history has 2 entries");
clip.clearHistory();
assert(clip.getHistoryCount() == 0, "Clipboard: clearHistory");

clip.clear();
assert(clip.hasContent() == false, "Clipboard: clear");

# ═══════════════════════════════════════════════════════════════════════════
# Test 85: UndoRedo
# ═══════════════════════════════════════════════════════════════════════════
print("── Test 85: UndoRedo ──");
let ur = new UndoRedo();
ur.init_ur();
assert(ur != nullptr, "UndoRedo created");
assert(ur.canUndo() == false, "UndoRedo: cannot undo initially");
assert(ur.canRedo() == false, "UndoRedo: cannot redo initially");
assert(ur.getUndoCount() == 0, "UndoRedo: 0 undo items");
assert(ur.max_history == 50, "UndoRedo: default max_history");

let undo_count = 0;
let redo_count = 0;
fn do_undo() {
    undo_count = undo_count + 1;
    return 0;
}
fn do_redo() {
    redo_count = redo_count + 1;
    return 0;
}

ur.execute("Test action", do_undo, do_redo);
assert(ur.canUndo() == true, "UndoRedo: can undo after execute");
assert(ur.canRedo() == false, "UndoRedo: cannot redo after execute");
assert(ur.getUndoDescription() == "Test action", "UndoRedo: undo description");
assert(ur.getRedoDescription() == "", "UndoRedo: redo description empty");

ur.undo();
assert(undo_count == 1, "UndoRedo: undo executed");
assert(ur.canRedo() == true, "UndoRedo: can redo after undo");
assert(ur.getRedoDescription() == "Test action", "UndoRedo: redo description");

ur.redo();
assert(redo_count == 1, "UndoRedo: redo executed");

# Multiple undo
ur.execute("Action 1", do_undo, do_redo);
ur.execute("Action 2", do_undo, do_redo);
assert(ur.getUndoCount() == 3, "UndoRedo: 3 undo items");

ur.undo();
assert(ur.getUndoCount() == 2, "UndoRedo: 2 items after undo");

ur.undo();
assert(ur.getUndoCount() == 1, "UndoRedo: 1 item after undo");

ur.undo();
assert(ur.canUndo() == false, "UndoRedo: cannot undo after all undone");

ur.redo();
ur.redo();
ur.redo();
assert(ur.canRedo() == false, "UndoRedo: cannot redo after all redone");

# setMaxHistory
ur.setMaxHistory(5);
assert(ur.max_history == 5, "UndoRedo: setMaxHistory");

ur.clear();
assert(ur.canUndo() == false, "UndoRedo: clear");

