# ═══════════════════════════════════════════════════════════════════════════
# 测试 63：KeyboardHandler 键盘导航
# ═══════════════════════════════════════════════════════════════════════════
print("── Test 63: KeyboardHandler ──");
let kh = new KeyboardHandler();
kh.init_kh();
assert(kh != nullptr, "KeyboardHandler created");
assert(kh.enabled == true, "KeyboardHandler enabled");

let kw1 = new Button();
kw1.init_btn("Widget1");
let kw2 = new Button();
kw2.init_btn("Widget2");
let kw3 = new Button();
kw3.init_btn("Widget3");

kh.addWidget(kw1);
kh.addWidget(kw2);
kh.addWidget(kw3);
assert(len(kh.tab_order) == 3, "KeyboardHandler: 3 widgets");

kh.setCurrent(kw1);
assert(kh.getCurrent() == kw1, "KeyboardHandler: current is kw1");

let next_w = kh.next();
assert(next_w == kw2, "KeyboardHandler: next is kw2");
assert(kh.getCurrent() == kw2, "KeyboardHandler: current updated to kw2");

let prev_w = kh.prev();
assert(prev_w == kw1, "KeyboardHandler: prev is kw1");

# Wrap around
kh.setCurrent(kw3);
let wrap_next = kh.next();
assert(wrap_next == kw1, "KeyboardHandler: wrap next to first");

# Skip disabled
kw2.disable();
kh.setCurrent(kw1);
let skip_next = kh.next();
assert(skip_next == kw3, "KeyboardHandler: skip disabled widget");

kh.removeWidget(kw2);
assert(len(kh.tab_order) == 2, "KeyboardHandler: remove widget");

kh.clear();
assert(len(kh.tab_order) == 0, "KeyboardHandler: clear");

# ═══════════════════════════════════════════════════════════════════════════
# Test 64: Serializer
# ═══════════════════════════════════════════════════════════════════════════
print("── Test 64: Serializer ──");
let ser = new Serializer();
ser.init_serializer();
assert(ser != nullptr, "Serializer created");

let win = new Window();
win.init_win("Serialize Test");
let panel = new Panel();
panel.init_panel("vbox");
win.add_child(panel);
let btn = new Button();
btn.init_btn("OK");
panel.add_child(btn);

let ser_data = ser.serialize(win);
assert(ser_data != nullptr, "Serializer: serialize returns data");
assert(ser_data["widget_type"] == "Window", "Serializer: widget_type preserved");
assert(ser_data["children"] != nullptr, "Serializer: children serialized");
assert(len(ser_data["children"]) >= 1, "Serializer: has child panel");

let children = ser_data["children"];
let child0 = children[0];
assert(child0["widget_type"] == "Panel", "Serializer: child type preserved");
assert(child0["children"] != nullptr, "Serializer: grandchild serialized");
assert(len(child0["children"]) >= 1, "Serializer: has grandchild button");

let root_data = ser.serialize_root(win);
assert(root_data != nullptr, "Serializer: serialize_root works");

