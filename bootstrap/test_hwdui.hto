# Test 70: Accordion
# ═══════════════════════════════════════════════════════════════════════════
print("── Test 70: Accordion ──");
let accord = new Accordion();
accord.init_accordion();
assert(accord != nullptr, "Accordion created");

let acc_content1 = new Panel();
acc_content1.init_panel("vbox");
let acc_content2 = new Panel();
acc_content2.init_panel("vbox");

accord.addItem("Section 1", acc_content1);
accord.addItem("Section 2", acc_content2);
assert(len(accord.items) == 2, "Accordion: items added");
assert(acc_content1.visible == false, "Accordion: content1 hidden by default");
assert(acc_content2.visible == false, "Accordion: content2 hidden by default");

accord.toggleItem(0);
assert(accord.items[0].expanded == true, "Accordion: toggleItem expands");
assert(acc_content1.visible == true, "Accordion: content1 visible after toggle");

accord.toggleItem(1);
assert(accord.items[0].expanded == false, "Accordion: single mode collapses previous");
assert(accord.items[1].expanded == true, "Accordion: new item expanded");

accord.setAllowMultiple(true);
accord.toggleItem(0);
assert(accord.items[0].expanded == true, "Accordion: multiple mode allows both");
assert(accord.items[1].expanded == true, "Accordion: both expanded");

accord.expandItem(0);
assert(accord.items[0].expanded == true, "Accordion: expandItem works");

