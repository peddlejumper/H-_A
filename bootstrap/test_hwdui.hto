# ═══════════════════════════════════════════════════════════════════════════
# 测试 41：bring_to_front / send_to_back
# ═══════════════════════════════════════════════════════════════════════════
print("── Test 41: Z-ordering ──");
let zparent = new Panel();
zparent.init_panel("absolute");
let z1 = new Button();
z1.init_btn("Z1");
let z2 = new Button();
z2.init_btn("Z2");
let z3 = new Button();
z3.init_btn("Z3");
zparent.add_child(z1);
zparent.add_child(z2);
zparent.add_child(z3);

z1.bring_to_front();
let last_child = zparent.get_child_at(2);
assert(last_child == z1, "bring_to_front: z1 is last child");

z2.send_to_back();
let first_child = zparent.get_child_at(0);
assert(first_child == z2, "send_to_back: z2 is first child");

