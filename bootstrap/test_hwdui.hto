# 测试 6：Label 控件
# ═══════════════════════════════════════════════════════════════════════════
print("── Test 6: Label ──");
let lbl = new Label();
lbl.init_label("你好世界");
assert(lbl != nullptr, "Label created");
assert(lbl.widget_type == "Label", "Label widget_type");
assert(lbl.text == "你好世界", "Label text");
assert(lbl.font_size == 12, "Label font_size");
assert(lbl.text_align == "left", "Label text_align");

lbl.set_text("更新文本");
assert(lbl.text == "更新文本", "Label set_text");
assert(lbl.get_text() == "更新文本", "Label get_text");

lbl.set_font_size(16);
assert(lbl.font_size == 16, "Label set_font_size");

lbl.set_color("#FF0000");
assert(lbl.text_color == "#FF0000", "Label set_color");

lbl.set_alignment("center");
