# ═══════════════════════════════════════════════════════════════════════════
# 测试 18：ListBox 控件
# ═══════════════════════════════════════════════════════════════════════════
print("── Test 18: ListBox ──");
let lb = new ListBox();
lb.init_lb();
assert(lb != nullptr, "ListBox created");
assert(lb.widget_type == "ListBox", "ListBox widget_type");
assert(lb.get_item_count() == 0, "ListBox starts empty");

lb.add_item("苹果");
lb.add_item("香蕉");
lb.add_item("橙子");
assert(lb.get_item_count() == 3, "ListBox 3 items");
assert(lb.get_item(0) == "苹果", "ListBox get_item 0");
assert(lb.get_item(1) == "香蕉", "ListBox get_item 1");

lb.select_item(1);
assert(lb.get_selected_index() == 1, "ListBox select_item");
assert(lb.get_selected() == "香蕉", "ListBox get_selected");

lb.remove_item(2);
assert(lb.get_item_count() == 2, "ListBox after remove = 2");

lb.deselect_all();
assert(lb.get_selected_index() == -1, "ListBox deselect_all");

lb.clear_items();
assert(lb.get_item_count() == 0, "ListBox clear_items");

let new_list = ["A", "B", "C", "D"];
lb.set_items(new_list);
assert(lb.get_item_count() == 4, "ListBox set_items");

# ═══════════════════════════════════════════════════════════════════════════
# 测试 19：ComboBox 控件
# ═══════════════════════════════════════════════════════════════════════════
print("── Test 19: ComboBox ──");
let cmb = new ComboBox();
cmb.init_combo();
assert(cmb != nullptr, "ComboBox created");
assert(cmb.widget_type == "ComboBox", "ComboBox widget_type");
assert(cmb.is_dropped == false, "ComboBox not dropped");
assert(cmb.editable == false, "ComboBox not editable");

cmb.add_item("选项1");
cmb.add_item("选项2");
cmb.add_item("选项3");
assert(cmb.get_item_count() == 3, "ComboBox 3 items");

cmb.select_item(2);
assert(cmb.get_selected() == "选项3", "ComboBox get_selected");

cmb.set_editable(true);
assert(cmb.editable == true, "ComboBox set_editable");

cmb.drop_down();
assert(cmb.is_dropped == true, "ComboBox drop_down");
cmb.close_drop();
assert(cmb.is_dropped == false, "ComboBox close_drop");
cmb.toggle_drop();
assert(cmb.is_dropped == true, "ComboBox toggle_drop");

let idx = cmb.find_item("选项2");
assert(idx == 1, "ComboBox find_item");

cmb.clear_items();
assert(cmb.get_item_count() == 0, "ComboBox clear_items");

# ═══════════════════════════════════════════════════════════════════════════
# 测试 20：ScrollView 控件
# ═══════════════════════════════════════════════════════════════════════════
print("── Test 20: ScrollView ──");
let sv = new ScrollView();
sv.init_sv();
assert(sv != nullptr, "ScrollView created");
assert(sv.widget_type == "ScrollView", "ScrollView widget_type");
assert(sv.scroll_x == 0, "ScrollView scroll_x defaults 0");
assert(sv.scroll_y == 0, "ScrollView scroll_y defaults 0");

sv.set_content_size(500, 500);
assert(sv.content_width == 500, "ScrollView content_width");
assert(sv.content_height == 500, "ScrollView content_height");

sv.scroll_to(100, 200);
assert(sv.scroll_x == 100, "ScrollView scroll_to x");
assert(sv.scroll_y == 200, "ScrollView scroll_to y");

sv.scroll_by(50, -50);
assert(sv.scroll_x == 150, "ScrollView scroll_by x +50");
assert(sv.scroll_y == 150, "ScrollView scroll_by y -50");

sv.scroll_to(9999, 9999);
let max_x = 500 - 200;
let max_y = 500 - 200;
assert(sv.scroll_x == max_x, "ScrollView clamped to max x");
assert(sv.scroll_y == max_y, "ScrollView clamped to max y");

let pos = sv.get_scroll_pos();
assert(pos["x"] == max_x, "ScrollView get_scroll_pos x");
assert(pos["y"] == max_y, "ScrollView get_scroll_pos y");

# ═══════════════════════════════════════════════════════════════════════════
# 测试 21：TabControl 控件
# ═══════════════════════════════════════════════════════════════════════════
print("── Test 21: TabControl ──");
let tc = new TabControl();
tc.init_tc();
assert(tc != nullptr, "TabControl created");
assert(tc.widget_type == "TabControl", "TabControl widget_type");
assert(tc.active_tab == -1, "TabControl no active tab");

let tab_content_1 = new Label();
tab_content_1.init_label("第一页内容");
let tab_content_2 = new Label();
tab_content_2.init_label("第二页内容");

tc.add_tab("首页", tab_content_1);
assert(tc.get_tab_count() == 1, "TabControl 1 tab");
assert(tc.active_tab == 0, "TabControl first tab active");
assert(tc.get_tab_title(0) == "首页", "TabControl tab title");

tc.add_tab("设置", tab_content_2);
assert(tc.get_tab_count() == 2, "TabControl 2 tabs");

tc.select_tab(1);
assert(tc.active_tab == 1, "TabControl select_tab 1");

let active = tc.get_active_tab();
assert(active != nullptr, "TabControl get_active_tab");
assert(active["title"] == "设置", "TabControl active tab title");

let active_content = tc.get_active_content();
assert(active_content != nullptr, "TabControl get_active_content");
assert(active_content.text == "第二页内容", "TabControl active content text");

tc.set_tab_position("bottom");
assert(tc.tab_position == "bottom", "TabControl set_tab_position");

tc.set_tab_height(36);
assert(tc.tab_height == 36, "TabControl set_tab_height");

tc.remove_tab(0);
assert(tc.get_tab_count() == 1, "TabControl after remove = 1");

# ═══════════════════════════════════════════════════════════════════════════
# 测试 22：Separator 控件
# ═══════════════════════════════════════════════════════════════════════════
print("── Test 22: Separator ──");
let sep_h = new Separator();
sep_h.init_sep("horizontal");
assert(sep_h != nullptr, "Separator horizontal created");
assert(sep_h.widget_type == "Separator", "Separator widget_type");
assert(sep_h.sep_orientation == "horizontal", "Separator orientation h");
assert(sep_h.height == 2, "Separator h height");

let sep_v = new Separator();
sep_v.init_sep("vertical");
assert(sep_v != nullptr, "Separator vertical created");
assert(sep_v.width == 2, "Separator v width");

# ═══════════════════════════════════════════════════════════════════════════
# 测试 23：Widget 层级遍历
# ═══════════════════════════════════════════════════════════════════════════
print("── Test 23: 层级遍历 ──");

# Build a widget tree in a Window
let app_win = hwdui_create_window("应用窗口", 800, 600);
let vbox_panel = new Panel();
vbox_panel.init_panel("vbox");
vbox_panel.id = "main_vbox";

let top_label = new Label();
top_label.init_label("欢迎使用 HwdUI");
top_label.id = "welcome";
vbox_panel.add_child(top_label);

let btn_row = new Panel();
btn_row.init_panel("hbox");
btn_row.id = "btn_row";
let ok_btn = new Button();
ok_btn.init_btn("确定");
ok_btn.id = "ok_btn";
let cancel_btn = new Button();
cancel_btn.init_btn("取消");
cancel_btn.id = "cancel_btn";
btn_row.add_child(ok_btn);
btn_row.add_child(cancel_btn);

vbox_panel.add_child(btn_row);
app_win.add_child(vbox_panel);

let found_ok = app_win.find_by_id("ok_btn");
assert(found_ok != nullptr, "Tree find_by_id deep search");
assert(found_ok.id == "ok_btn", "Tree found correct widget");

let found_cancel = app_win.find_by_id("cancel_btn");
assert(found_cancel != nullptr, "Tree find_by_id cancel");

assert(app_win.get_root() == app_win, "get_root on Window returns self");
assert(ok_btn.get_root() == app_win, "get_root on child returns Window");

# ═══════════════════════════════════════════════════════════════════════════
# 测试 24：CSS 引擎 — Selector 选择器
# ═══════════════════════════════════════════════════════════════════════════
print("── Test 24: CSS Selector ──");

# Type selector
let sel_btn = hwdui_sel_type("Button");
assert(sel_btn != nullptr, "Selector created");
assert(sel_btn.matches(btn) == true, "Type selector matches Button");
assert(sel_btn.matches(lbl) == false, "Type selector does not match Label");

# Universal selector
let sel_all = hwdui_sel_universal();
assert(sel_all.matches(btn) == true, "Universal selector matches Button");
assert(sel_all.matches(lbl) == true, "Universal selector matches Label");
assert(sel_all.matches(tb) == true, "Universal selector matches TextBox");

# Class selector
btn.addClass("primary");
let sel_class = hwdui_sel_class("primary");
assert(sel_class.matches(btn) == true, "Class selector matches widget with class");
assert(sel_class.matches(lbl) == false, "Class selector does not match widget without class");

# Compound selector: type + class
let sel_type_class = hwdui_sel_type_class("Button", "primary");
assert(sel_type_class.matches(btn) == true, "Type+class selector matches");
assert(sel_type_class.matches(lbl) == false, "Type+class selector does not match wrong type");

# Pseudo selector
btn.setPseudoState("hover");
let sel_pseudo = hwdui_sel_type_pseudo("Button", "hover");
assert(sel_pseudo.matches(btn) == true, "Pseudo selector matches hover state");
btn.setPseudoState("normal");
assert(sel_pseudo.matches(btn) == false, "Pseudo selector does not match normal state");

# ID selector
btn.setCssId("submitBtn");
let sel_id = hwdui_sel_id("submitBtn");
assert(sel_id.matches(btn) == true, "ID selector matches");
assert(sel_id.matches(lbl) == false, "ID selector does not match wrong ID");

# Specificity
assert(sel_id.getSpecificity() > sel_class.getSpecificity(), "ID specificity > class specificity");
assert(sel_class.getSpecificity() > sel_btn.getSpecificity(), "Class specificity > type specificity");

# ═══════════════════════════════════════════════════════════════════════════
# 测试 25：CSS 引擎 — Class/ID 管理
# ═══════════════════════════════════════════════════════════════════════════
print("── Test 25: CSS Class/ID 管理 ──");
let css_widget = new Button();
css_widget.init_btn("CSS测试");

assert(css_widget.hasClass("test") == false, "hasClass false by default");
css_widget.addClass("test");
assert(css_widget.hasClass("test") == true, "hasClass true after addClass");

css_widget.addClass("featured");
assert(css_widget.hasClass("test") == true, "hasClass keeps existing class");
assert(css_widget.hasClass("featured") == true, "hasClass second class");

css_widget.removeClass("test");
assert(css_widget.hasClass("test") == false, "hasClass false after removeClass");
assert(css_widget.hasClass("featured") == true, "hasClass other class retained");

css_widget.toggleClass("active");
assert(css_widget.hasClass("active") == true, "toggleClass adds missing class");
css_widget.toggleClass("active");
assert(css_widget.hasClass("active") == false, "toggleClass removes existing class");

let classes = css_widget.getClasses();
assert(len(classes) == 1, "getClasses count");
assert(classes[0] == "featured", "getClasses content");

css_widget.setCssId("widget_001");
assert(css_widget.getCssId() == "widget_001", "setCssId/getCssId");

css_widget.setClasses(["a", "b", "c"]);
assert(css_widget.hasClass("a") == true, "setClasses bulk a");
assert(css_widget.hasClass("b") == true, "setClasses bulk b");
assert(css_widget.hasClass("c") == true, "setClasses bulk c");
assert(css_widget.hasClass("featured") == false, "setClasses replaces old classes");

# ═══════════════════════════════════════════════════════════════════════════
# 测试 26：CSS 引擎 — Stylesheet 样式表
# ═══════════════════════════════════════════════════════════════════════════
print("── Test 26: CSS Stylesheet ──");
hwdui_clear_all_stylesheets();

let sheet = hwdui_create_stylesheet("test_sheet");
assert(sheet != nullptr, "Stylesheet created");
assert(sheet.name == "test_sheet", "Stylesheet name");
assert(sheet.getRuleCount() == 0, "Stylesheet starts empty");

# Add rules
let btn_sel = hwdui_sel_type("Button");
sheet.addRule(btn_sel, [
    ["color", "#ff0000"],
    ["font-size", "14"],
    ["background-color", "#cccccc"]
]);
assert(sheet.getRuleCount() == 1, "Stylesheet addRule count");

# Get rule back
let rule0 = sheet.getRule(0);
assert(rule0 != nullptr, "getRule returns rule");
assert(rule0.selector == btn_sel, "Rule selector matches");

# Match rules
let test_btn = new Button();
test_btn.init_btn("匹配测试");
let matched = sheet.matchRules(test_btn);
assert(len(matched) == 1, "matchRules finds 1 rule for Button");

# Remove rule
sheet.removeRule(0);
assert(sheet.getRuleCount() == 0, "Stylesheet removeRule");

# Clear rules
sheet.addRule(btn_sel, [["color", "#000"]]);
sheet.addRule(btn_sel, [["font-size", "12"]]);
sheet.clearRules();
assert(sheet.getRuleCount() == 0, "Stylesheet clearRules");

# Remove stylesheet
hwdui_remove_stylesheet(sheet);

# ═══════════════════════════════════════════════════════════════════════════
# 测试 27：CSS 引擎 — 主题系统
# ═══════════════════════════════════════════════════════════════════════════
print("── Test 27: CSS Theme ──");
hwdui_clear_all_stylesheets();

let light = hwdui_theme_light();
assert(light != nullptr, "Light theme created");
assert(light.getRuleCount() > 0, "Light theme has rules");

hwdui_clear_all_stylesheets();

let dark = hwdui_theme_dark();
assert(dark != nullptr, "Dark theme created");
assert(dark.getRuleCount() > 0, "Dark theme has rules");

# ═══════════════════════════════════════════════════════════════════════════
# 测试 28：CSS 引擎 — 级联计算样式
# ═══════════════════════════════════════════════════════════════════════════
print("── Test 28: CSS Cascade ──");
hwdui_clear_all_stylesheets();

# 创建样式表：type → class → ID 逐层覆盖
let cascade_sheet = hwdui_create_stylesheet("cascade_test");

cascade_sheet.addRule(hwdui_sel_type("Button"), [
    ["background-color", "#aaa"],
    ["color", "#111"],
    ["font-size", "12"]
]);

cascade_sheet.addRule(hwdui_sel_type_class("Button", "primary"), [
    ["background-color", "#336699"],
    ["color", "#ffffff"]
]);

cascade_sheet.addRule(hwdui_sel_id("hero_btn"), [
    ["background-color", "#ff6600"],
    ["font-size", "18"]
]);

# 普通 Button：只匹配 type selector
let normal_btn = new Button();
normal_btn.init_btn("普通");
let normal_cs = normal_btn.getComputedStyle();
assert(normal_cs["background-color"] == "#aaa", "Cascade: type base bg");
assert(normal_cs["color"] == "#111", "Cascade: type base color");
assert(normal_cs["font-size"] == "12", "Cascade: type base font-size");

# primary Button：匹配 type + class
let primary_btn = new Button();
primary_btn.init_btn("主要");
primary_btn.addClass("primary");
let primary_cs = primary_btn.getComputedStyle();
assert(primary_cs["background-color"] == "#336699", "Cascade: class overrides bg");
assert(primary_cs["color"] == "#ffffff", "Cascade: class overrides color");
assert(primary_cs["font-size"] == "12", "Cascade: class inherits font-size from type");

# hero Button：匹配 type + id（最高特异性）
let hero_btn = new Button();
hero_btn.init_btn("英雄");
hero_btn.setCssId("hero_btn");
let hero_cs = hero_btn.getComputedStyle();
assert(hero_cs["background-color"] == "#ff6600", "Cascade: id overrides bg");
assert(hero_cs["font-size"] == "18", "Cascade: id overrides font-size");
assert(hero_cs["color"] == "#111", "Cascade: id inherits color from type");

# ═══════════════════════════════════════════════════════════════════════════
# 测试 29：CSS 引擎 — Inline Style 最高优先级
# ═══════════════════════════════════════════════════════════════════════════
print("── Test 29: CSS Inline Style ──");
hwdui_clear_all_stylesheets();

let inline_sheet = hwdui_create_stylesheet("inline_test");
inline_sheet.addRule(hwdui_sel_type("Button"), [
    ["background-color", "#aaa"],
    ["color", "#111"],
    ["border-radius", "4"]
]);

let inline_btn = new Button();
inline_btn.init_btn("内联");

# 没有内联样式时，使用样式表规则
let cs1 = inline_btn.getComputedStyle();
assert(cs1["background-color"] == "#aaa", "Inline: stylesheet base bg");

# 添加内联样式覆盖
inline_btn.setInlineStyle("background-color", "#ff0000");
inline_btn.setInlineStyle("border-radius", "8");
let cs2 = inline_btn.getComputedStyle();
assert(cs2["background-color"] == "#ff0000", "Inline: inline overrides bg");
assert(cs2["border-radius"] == "8", "Inline: inline overrides border-radius");
assert(cs2["color"] == "#111", "Inline: non-overridden keeps stylesheet value");

# 测试 setInlineStyles 批量设置
let inline_btn2 = new Button();
inline_btn2.init_btn("批量内联");
inline_btn2.setInlineStyles([
    ["background-color", "#00ff00"],
    ["color", "#ffffff"],
    ["font-size", "16"]
]);
let cs3 = inline_btn2.getComputedStyle();
assert(cs3["background-color"] == "#00ff00", "setInlineStyles bg");
assert(cs3["color"] == "#ffffff", "setInlineStyles color");
assert(cs3["font-size"] == "16", "setInlineStyles font-size");

# 删除内联样式
inline_btn2.removeInlineStyle("background-color");
let cs4 = inline_btn2.getComputedStyle();
assert(cs4["background-color"] == "#aaa", "removeInlineStyle falls back to stylesheet");

# ═══════════════════════════════════════════════════════════════════════════
# 测试 30：CSS 引擎 — 伪状态样式
# ═══════════════════════════════════════════════════════════════════════════
print("── Test 30: CSS Pseudo States ──");
hwdui_clear_all_stylesheets();

let pseudo_sheet = hwdui_create_stylesheet("pseudo_test");
pseudo_sheet.addRule(hwdui_sel_type("Button"), [
    ["background-color", "#cccccc"],
    ["color", "#333333"]
]);
pseudo_sheet.addRule(hwdui_sel_type_pseudo("Button", "hover"), [
    ["background-color", "#aaaaaa"],
    ["color", "#111111"]
]);
pseudo_sheet.addRule(hwdui_sel_type_pseudo("Button", "disabled"), [
    ["color", "#999999"],
    ["opacity", "0.5"]
]);

let pseudo_btn = new Button();
pseudo_btn.init_btn("伪状态测试");

# normal 状态
pseudo_btn.setPseudoState("normal");
let cs_n = pseudo_btn.getComputedStyle();
assert(cs_n["background-color"] == "#cccccc", "Pseudo: normal bg");
assert(cs_n["color"] == "#333333", "Pseudo: normal color");

# hover 状态
pseudo_btn.setPseudoState("hover");
let cs_h = pseudo_btn.getComputedStyle();
assert(cs_h["background-color"] == "#aaaaaa", "Pseudo: hover overrides bg");
assert(cs_h["color"] == "#111111", "Pseudo: hover overrides color");
assert(cs_h["opacity"] == nullptr, "Pseudo: hover does not get disabled opacity");

# disabled 状态
pseudo_btn.setPseudoState("disabled");
let cs_d = pseudo_btn.getComputedStyle();
assert(cs_d["background-color"] == "#cccccc", "Pseudo: disabled inherits type bg");
assert(cs_d["color"] == "#999999", "Pseudo: disabled overrides color");
assert(cs_d["opacity"] == "0.5", "Pseudo: disabled gets opacity");

# 恢复 normal
pseudo_btn.setPseudoState("normal");
assert(pseudo_btn.getPseudoState() == "normal", "getPseudoState returns normal");

# ═══════════════════════════════════════════════════════════════════════════
# 测试 31：CSS 引擎 — 兼容旧 set_style/get_style API
# ═══════════════════════════════════════════════════════════════════════════
print("── Test 31: CSS 兼容旧 API ──");
hwdui_clear_all_stylesheets();

let compat_btn = new Button();
compat_btn.init_btn("兼容按钮");
compat_btn.set_style("bg_color", "#336699");
compat_btn.set_style("border_radius", "4");
compat_btn.set_style("font_size", "14");

assert(compat_btn.styles["bg_color"] == "#336699", "Legacy: set_style bg_color");
assert(compat_btn.styles["border_radius"] == "4", "Legacy: set_style border_radius");
assert(compat_btn.styles["font_size"] == "14", "Legacy: set_style font_size");

assert(compat_btn.get_style("bg_color") == "#336699", "Legacy: get_style bg_color");
assert(compat_btn.get_style("border_radius") == "4", "Legacy: get_style border_radius");

# ═══════════════════════════════════════════════════════════════════════════
# 测试 32：CSS 引擎 — 80+ CSS 属性支持验证
# ═══════════════════════════════════════════════════════════════════════════
print("── Test 32: CSS 属性全覆盖 ──");
hwdui_clear_all_stylesheets();

let prop_sheet = hwdui_create_stylesheet("prop_test");
prop_sheet.addRule(hwdui_sel_type("Button"), [
    ["color", "#333"],
    ["background-color", "#fff"],
    ["border-color", "#999"],
    ["border-width", "2"],
    ["border-style", "solid"],
    ["border-radius", "6"],
    ["font-size", "14"],
    ["font-family", "Arial"],
    ["font-weight", "bold"],
    ["text-align", "center"],
    ["text-decoration", "none"],
    ["opacity", "1.0"],
    ["margin", "4"],
    ["padding", "8"],
    ["width", "120"],
    ["height", "36"],
    ["display", "block"],
    ["cursor", "pointer"],
    ["z-index", "10"],
    ["box-shadow", "0 2 4 rgba(0,0,0,0.2)"],
    ["transition", "all 0.3s ease"],
    ["transform", "none"]
]);

let prop_btn = new Button();
prop_btn.init_btn("属性测试");
let pcs = prop_btn.getComputedStyle();

assert(pcs["color"] == "#333", "Property: color");
assert(pcs["background-color"] == "#fff", "Property: background-color");
assert(pcs["border-color"] == "#999", "Property: border-color");
assert(pcs["border-width"] == "2", "Property: border-width");
assert(pcs["border-style"] == "solid", "Property: border-style");
assert(pcs["border-radius"] == "6", "Property: border-radius");
assert(pcs["font-size"] == "14", "Property: font-size");
assert(pcs["font-family"] == "Arial", "Property: font-family");
assert(pcs["font-weight"] == "bold", "Property: font-weight");
assert(pcs["text-align"] == "center", "Property: text-align");
assert(pcs["text-decoration"] == "none", "Property: text-decoration");
assert(pcs["opacity"] == "1.0", "Property: opacity");
assert(pcs["margin"] == "4", "Property: margin");
assert(pcs["padding"] == "8", "Property: padding");
assert(pcs["width"] == "120", "Property: width");
assert(pcs["height"] == "36", "Property: height");
assert(pcs["display"] == "block", "Property: display");
assert(pcs["cursor"] == "pointer", "Property: cursor");
assert(pcs["z-index"] == "10", "Property: z-index");
assert(pcs["box-shadow"] == "0 2 4 rgba(0,0,0,0.2)", "Property: box-shadow");
assert(pcs["transition"] == "all 0.3s ease", "Property: transition");

# getComputedStyleValue
assert(prop_btn.getComputedStyleValue("border-radius") == "6", "getComputedStyleValue");

# ═══════════════════════════════════════════════════════════════════════════
# 测试 33：CSS 引擎 — Margin/Padding 计算
# ═══════════════════════════════════════════════════════════════════════════
print("── Test 33: CSS Margin/Padding ──");
hwdui_clear_all_stylesheets();

let mp_sheet = hwdui_create_stylesheet("mp_test");
mp_sheet.addRule(hwdui_sel_type("Button"), [
    ["margin", "10"],
    ["margin-left", "20"],
    ["padding", "5"],
    ["padding-top", "15"]
]);

let mp_btn = new Button();
mp_btn.init_btn("间距测试");

let margin = hwdui_get_computed_margin(mp_btn);
assert(margin["left"] == "20", "Margin: left override");
assert(margin["top"] == "10", "Margin: top from shorthand");
assert(margin["right"] == "10", "Margin: right from shorthand");
assert(margin["bottom"] == "10", "Margin: bottom from shorthand");

let padding = hwdui_get_computed_padding(mp_btn);
assert(padding["top"] == "15", "Padding: top override");
assert(padding["left"] == "5", "Padding: left from shorthand");
assert(padding["right"] == "5", "Padding: right from shorthand");
assert(padding["bottom"] == "5", "Padding: bottom from shorthand");

# ═══════════════════════════════════════════════════════════════════════════
# 测试 34：CSS 引擎 — 多样式表叠加
# ═══════════════════════════════════════════════════════════════════════════
print("── Test 34: CSS 多样式表 ──");
hwdui_clear_all_stylesheets();

let s1 = hwdui_create_stylesheet("base");
s1.addRule(hwdui_sel_type("Label"), [
    ["color", "#111"],
    ["font-size", "12"],
    ["font-family", "serif"]
]);

let s2 = hwdui_create_stylesheet("override");
s2.addRule(hwdui_sel_type("Label"), [
    ["color", "#ff0000"],
    ["font-size", "16"]
]);

let multi_lbl = new Label();
multi_lbl.init_label("多样式表");

# s2 在 s1 之后注册，同特异性时后者覆盖前者
let mcs = multi_lbl.getComputedStyle();
assert(mcs["color"] == "#ff0000", "Multi-sheet: later sheet overrides color");
assert(mcs["font-size"] == "16", "Multi-sheet: later sheet overrides font-size");
assert(mcs["font-family"] == "serif", "Multi-sheet: base sheet provides font-family");

