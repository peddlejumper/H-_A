# ═══════════════════════════════════════════════════════════════════════════
# Test 69: DataBinding
# ═══════════════════════════════════════════════════════════════════════════
print("── Test 69: DataBinding ──");
let data_obj = {"name": "Alice", "age": 30};
let target_widget = {"text": ""};

let ctx = new DataContext();
ctx.init_context(data_obj);
assert(ctx != nullptr, "DataContext created");

let binding = new Binding();
binding.init_binding(data_obj, "name", target_widget, "text");
assert(binding != nullptr, "Binding created");

ctx.add_binding(binding);
ctx.update_all();
assert(target_widget["text"] == "Alice", "DataBinding: value propagated");

data_obj["name"] = "Bob";
ctx.update_all();
assert(target_widget["text"] == "Bob", "DataBinding: updated value");

# Converter
let conv_data = {"price": 100};
let conv_target = {"text": ""};
let conv_bind = new Binding();
conv_bind.init_binding(conv_data, "price", conv_target, "text");
fn dollars_to_yuan(price) {
    return price * 7.2;
}
conv_bind.setConverter(dollars_to_yuan);
conv_bind.update();
assert(conv_target["text"] == 720.0, "DataBinding: converter works");

