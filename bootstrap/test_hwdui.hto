# ═══════════════════════════════════════════════════════════════════════════
# 测试 7：TextBox 控件
# ═══════════════════════════════════════════════════════════════════════════
print("── Test 7: TextBox ──");
let tb = new TextBox();
tb.init_tb("初始文字");
assert(tb != nullptr, "TextBox created");
assert(tb.widget_type == "TextBox", "TextBox widget_type");
assert(tb.text == "初始文字", "TextBox text");
assert(tb.readonly == false, "TextBox not readonly");

tb.set_text("新文字");
assert(tb.text == "新文字", "TextBox set_text");
assert(tb.get_text() == "新文字", "TextBox get_text");
assert(tb.cursor_pos == len("新文字"), "TextBox cursor_pos after set_text");

tb.clear();
assert(tb.text == "", "TextBox clear");
assert(tb.cursor_pos == 0, "TextBox cursor after clear");

tb.append("追加");
assert(tb.text == "追加", "TextBox append");

tb.set_placeholder("请输入...");
assert(tb.placeholder == "请输入...", "TextBox set_placeholder");

tb.set_readonly(true);
assert(tb.readonly == true, "TextBox set_readonly");

tb.set_multiline(true);
assert(tb.multiline == true, "TextBox set_multiline");

tb.set_max_length(10);
assert(tb.max_length == 10, "TextBox set_max_length");

tb.set_password_mode(true);
assert(tb.is_password == true, "TextBox set_password_mode");

tb.set_text("abcd");
tb.select_all();
assert(tb.selection_start == 0, "TextBox select_all start");
assert(tb.selection_end == 4, "TextBox select_all end");

assert(tb.get_text_length() == 4, "TextBox get_text_length");

# ═══════════════════════════════════════════════════════════════════════════
# 测试 8：Panel 容器和布局
# ═══════════════════════════════════════════════════════════════════════════
print("── Test 8: Panel 布局 ──");
let panel = new Panel();
panel.init_panel("vbox");
assert(panel != nullptr, "Panel created");
assert(panel.widget_type == "Panel", "Panel widget_type");
assert(panel.layout_type == "vbox", "Panel layout_type vbox");

panel.set_spacing(8);
assert(panel.spacing == 8, "Panel set_spacing");

panel.set_layout_type("hbox");
assert(panel.layout_type == "hbox", "Panel set_layout_type hbox");

panel.set_layout_type("absolute");
assert(panel.layout_type == "absolute", "Panel layout_type absolute");

# add children
let child1 = new Label();
child1.init_label("子控件1");
child1.width = 100;
child1.height = 20;

let child2 = new Label();
child2.init_label("子控件2");
child2.width = 100;
child2.height = 20;

panel.add_child(child1);
panel.add_child(child2);
assert(panel.get_child_count() == 2, "Panel child count = 2");
assert(panel.has_child(child1) == true, "Panel has child1");
assert(panel.get_child_at(0) == child1, "Panel get_child_at 0");
assert(panel.get_child_at(1) == child2, "Panel get_child_at 1");

panel.remove_child(child1);
assert(panel.get_child_count() == 1, "Panel after remove = 1");
assert(panel.has_child(child1) == false, "Panel no longer has child1");
assert(child1.parent == nullptr, "Removed child parent nullptr");

panel.add_child(child1);
panel.remove_all_children();
assert(panel.get_child_count() == 0, "Panel after remove_all = 0");

# ═══════════════════════════════════════════════════════════════════════════
# 测试 9：VBox 布局
# ═══════════════════════════════════════════════════════════════════════════
print("── Test 9: VBox 布局 ──");
let vbox = new Panel();
vbox.init_panel("vbox");
vbox.width = 300;
vbox.height = 200;
vbox.set_padding(5, 5, 5, 5);

let a = new Button();
a.init_btn("A");
a.width = 100;
a.height = 30;
let b = new Button();
b.init_btn("B");
b.width = 100;
b.height = 40;

vbox.add_child(a);
vbox.add_child(b);
vbox.do_layout();

assert(a.x == 5, "VBox: child A x at padding");
assert(b.x == 5, "VBox: child B x at padding");
assert(a.y == 5, "VBox: child A y at top");
assert(b.y > a.y + a.height, "VBox: child B below A");

# ═══════════════════════════════════════════════════════════════════════════
# 测试 10：HBox 布局
# ═══════════════════════════════════════════════════════════════════════════
print("── Test 10: HBox 布局 ──");
let hbox = new Panel();
hbox.init_panel("hbox");
hbox.width = 300;
hbox.height = 200;
hbox.set_padding(5, 5, 5, 5);

let c = new Button();
c.init_btn("C");
c.width = 80;
c.height = 30;
let d = new Button();
d.init_btn("D");
d.width = 90;
d.height = 30;

hbox.add_child(c);
hbox.add_child(d);
hbox.do_layout();

assert(c.x == 5, "HBox: child C x at padding");
assert(d.x > c.x + c.width, "HBox: child D right of C");
assert(c.y == 5, "HBox: child C y at top");
assert(d.y == 5, "HBox: child D y at top");

# ═══════════════════════════════════════════════════════════════════════════
# 测试 11：事件系统
# ═══════════════════════════════════════════════════════════════════════════
print("── Test 11: 事件系统 ──");
let event_fired = false;

fn on_click_handler(widget) {
    event_fired = true;
}

let evt_btn = new Button();
evt_btn.init_btn("事件按钮");
evt_btn.onClick = on_click_handler;

evt_btn.click();
assert(event_fired == true, "Button click fires onClick callback");

let evt_btn2 = new Button();
evt_btn2.init_btn("空回调");
evt_btn2.click();  # 不应报错
assert(true, "Button click with nullptr callback handles gracefully");

# ═══════════════════════════════════════════════════════════════════════════
# 测试 12：find_by_id
# ═══════════════════════════════════════════════════════════════════════════
print("── Test 12: find_by_id ──");
let root = new Panel();
root.init_panel("absolute");

let deep = new Button();
deep.init_btn("深层按钮");
deep.id = "deep_btn";

let mid = new Panel();
mid.init_panel("vbox");
mid.id = "mid_panel";
mid.add_child(deep);

root.add_child(mid);

let found = root.find_by_id("deep_btn");
assert(found != nullptr, "find_by_id finds deep child");
assert(found.id == "deep_btn", "find_by_id returns correct widget");

let not_found = root.find_by_id("nonexistent");
assert(not_found == nullptr, "find_by_id returns nullptr for nonexistent");

