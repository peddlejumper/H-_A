# ═══════════════════════════════════════════════════════════════════════════
# 测试 60：Timer 定时器
# ═══════════════════════════════════════════════════════════════════════════
print("── Test 60: Timer ──");
let tick_count = 0;
fn on_timer_tick(timer) {
    tick_count = tick_count + 1;
}

let timer = new Timer();
timer.init_timer(100, on_timer_tick);
assert(timer != nullptr, "Timer created");
assert(timer.interval_ms == 100, "Timer interval");
assert(timer.running == false, "Timer not running by default");
assert(timer.repeats == true, "Timer repeats by default");

timer.start();
assert(timer.running == true, "Timer started");
assert(timer.isRunning() == true, "Timer isRunning");

timer._tick(50);
assert(tick_count == 0, "Timer: not fired at 50ms");
timer._tick(60);
assert(tick_count == 1, "Timer: fired at 110ms");
assert(timer.running == true, "Timer: still running after tick");

timer.setRepeats(false);
timer._tick(100);
assert(tick_count == 2, "Timer: fired again");
assert(timer.running == false, "Timer: stopped after single shot");

timer.setInterval(500);
assert(timer.interval_ms == 500, "Timer: setInterval");

timer.restart();
assert(timer.running == true, "Timer: restart");
timer.stop();
assert(timer.running == false, "Timer: stop");

hwdui_timer_stop_all();

