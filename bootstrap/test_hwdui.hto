# ═══════════════════════════════════════════════════════════════════════════
# test_hwdui.hto — HwdUI 库完整测试
# ═══════════════════════════════════════════════════════════════════════════

import "bootstrap/hwdui.hto";

let tests_passed = 0;
let tests_failed = 0;
let test_total = 0;

fn assert(condition, test_name) {
    test_total = test_total + 1;
    if (condition) {
        tests_passed = tests_passed + 1;
        return 0;
    }
    tests_failed = tests_failed + 1;
    print("  FAIL: " + test_name);
}

fn test_summary() {
    print("");
    print("═════════════════════════════════");
    print("Test Results: " + tests_passed + "/" + test_total + " passed");
    if (tests_failed == 0) {
        print("ALL TESTS PASSED ✓");
    } else {
        print("FAILURES: " + tests_failed);
    }
    print("═════════════════════════════════");
}

# ═══════════════════════════════════════════════════════════════════════════
# 测试 1：基础初始化
# ═══════════════════════════════════════════════════════════════════════════
print("── Test 1: 基础初始化 ──");
assert(hwdui_init() == true, "hwdui_init returns true");

# ═══════════════════════════════════════════════════════════════════════════
# 测试 2：Window 创建
# ═══════════════════════════════════════════════════════════════════════════
print("── Test 2: Window ──");
let win = hwdui_create_window("测试窗口", 800, 600);
assert(win != nullptr, "Window created");
assert(win.widget_type == "Window", "Window widget_type");
assert(win.title == "测试窗口", "Window title");
assert(win.width == 800, "Window width");
assert(win.height == 600, "Window height");
assert(win.visible == true, "Window visible");
assert(win.closable == true, "Window closable");
assert(win.resizable == true, "Window resizable");
assert(len(hwdui_get_active_windows()) == 1, "Active windows count = 1");

win.set_title("新标题");
assert(win.title == "新标题", "Window set_title");

win.center_on_screen(1920, 1080);
assert(win.x == (1920 - 800) / 2, "Window center x");
assert(win.y == (1080 - 600) / 2, "Window center y");
assert(win.centered == true, "Window centered flag");

# ═══════════════════════════════════════════════════════════════════════════
# 测试 3：zzwUI 基类方法
# ═══════════════════════════════════════════════════════════════════════════
print("── Test 3: zzwUI 基类 ──");

win.set_pos(10, 20);
assert(win.x == 10, "zzwUI set_pos x");
assert(win.y == 20, "zzwUI set_pos y");

win.set_size(640, 480);
assert(win.width == 640, "zzwUI set_size width");
assert(win.height == 480, "zzwUI set_size height");

win.set_bounds(0, 0, 1024, 768);
assert(win.x == 0, "zzwUI set_bounds x");
assert(win.y == 0, "zzwUI set_bounds y");
assert(win.width == 1024, "zzwUI set_bounds w");
assert(win.height == 768, "zzwUI set_bounds h");

win.set_min_size(400, 300);
assert(win._hwdui_min_w == 400, "zzwUI set_min_size w");
assert(win._hwdui_min_h == 300, "zzwUI set_min_size h");

win.set_max_size(2048, 1536);
assert(win._hwdui_max_w == 2048, "zzwUI set_max_size w");
assert(win._hwdui_max_h == 1536, "zzwUI set_max_size h");

win.set_padding(10, 5, 10, 5);
assert(win._hwdui_pad_left == 10, "zzwUI set_padding left");
assert(win._hwdui_pad_top == 5, "zzwUI set_padding top");

win.set_margin(3, 3, 3, 3);
assert(win._hwdui_margin_left == 3, "zzwUI set_margin left");

# ═══════════════════════════════════════════════════════════════════════════
# 测试 4：可见性和启用状态
# ═══════════════════════════════════════════════════════════════════════════
print("── Test 4: 可见性/启用 ──");
win.hide();
assert(win.visible == false, "Window hide");
win.show();
assert(win.visible == true, "Window show");
assert(win.is_visible() == true, "is_visible");

win.disable();
assert(win.enabled == false, "Window disable");
win.enable_w();
assert(win.enabled == true, "Window enable_w");
assert(win.is_enabled() == true, "is_enabled");

win.set_enabled(false);
assert(win.enabled == false, "set_enabled false");
win.set_enabled(true);
assert(win.enabled == true, "set_enabled true");

# ═══════════════════════════════════════════════════════════════════════════
# 测试 5：Button 控件
# ═══════════════════════════════════════════════════════════════════════════
print("── Test 5: Button ──");
let btn = new Button();
btn.init_btn("点击我");
assert(btn != nullptr, "Button created");
assert(btn.widget_type == "Button", "Button widget_type");
assert(btn.text == "点击我", "Button text");
assert(btn.width == 100, "Button default width");
assert(btn.height == 30, "Button default height");
assert(btn.is_toggle == false, "Button not toggle by default");

btn.set_text("新按钮");
assert(btn.text == "新按钮", "Button set_text");

btn.set_icon("★");
assert(btn.icon == "★", "Button set_icon");

btn.is_toggle = true;
btn.set_checked(true);
assert(btn.is_checked == true, "Button set_checked");
assert(btn.is_pressed() == true, "Button is_pressed");
btn.toggle();
assert(btn.is_checked == false, "Button toggle off");
btn.toggle();
assert(btn.is_checked == true, "Button toggle on");

btn.set_default(true);
assert(btn.is_default == true, "Button set_default");

