# ═══════════════════════════════════════════════════════════════════════════
# 测试 15：Slider 控件
# ═══════════════════════════════════════════════════════════════════════════
print("── Test 15: Slider ──");
let sld = new Slider();
sld.init_slider(0, 200, 50);
assert(sld != nullptr, "Slider created");
assert(sld.widget_type == "Slider", "Slider widget_type");
assert(sld.min_val == 0, "Slider min_val");
assert(sld.max_val == 200, "Slider max_val");
assert(sld.val == 50, "Slider val");
assert(sld.step == 1, "Slider step");

sld.set_value(100);
assert(sld.get_value() == 100, "Slider set_value 100");
sld.set_value(999);
assert(sld.get_value() == 200, "Slider clamped to max_val");
sld.set_value(-99);
assert(sld.get_value() == 0, "Slider clamped to min_val");

sld.set_range(10, 150);
assert(sld.min_val == 10, "Slider set_range min");
assert(sld.max_val == 150, "Slider set_range max");

sld.set_step(5);
assert(sld.step == 5, "Slider set_step");

sld.set_value(80);
let pct = sld.get_percentage();
# (80-10)/(150-10)*100 = 70/140*100 = 50
assert(pct == 50, "Slider get_percentage");

# ═══════════════════════════════════════════════════════════════════════════
# 测试 16：ProgressBar 控件
# ═══════════════════════════════════════════════════════════════════════════
print("── Test 16: ProgressBar ──");
let pb = new ProgressBar();
pb.init_pb(0, 100);
assert(pb != nullptr, "ProgressBar created");
assert(pb.widget_type == "ProgressBar", "ProgressBar widget_type");
assert(pb.val == 0, "ProgressBar starts at min");
assert(pb.is_complete() == false, "ProgressBar not complete");

pb.set_value(50);
assert(pb.get_value() == 50, "ProgressBar set_value");
pb.increment(25);
assert(pb.get_value() == 75, "ProgressBar increment 25");
pb.set_value(100);
assert(pb.is_complete() == true, "ProgressBar is_complete");

pb.set_range(0, 200);
assert(pb.min_val == 0, "ProgressBar set_range min");
assert(pb.max_val == 200, "ProgressBar set_range max");

pb.set_mode("indeterminate");
assert(pb.mode == "indeterminate", "ProgressBar set_mode");

