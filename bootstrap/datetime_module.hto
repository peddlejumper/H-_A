# H# Date and Time Module
# Provides date/time manipulation utilities built on top of host functions

# Constants (using let since const may not be supported)
let DATETIME_DEFAULT_FORMAT = "%Y-%m-%d %H:%M:%S";
let DATETIME_DATE_ONLY_FORMAT = "%Y-%m-%d";
let DATETIME_TIME_ONLY_FORMAT = "%H:%M:%S";

# Get current datetime as formatted string
fn datetime_now() {
    return date_now();
}

# Get current timestamp (seconds since epoch)
fn datetime_timestamp() {
    return date_timestamp();
}

# Format timestamp to human-readable string
fn datetime_format(timestamp, format_string) {
    if (format_string == nullptr) {
        format_string = DATETIME_DEFAULT_FORMAT;
    }
    return date_format(timestamp, format_string);
}

# Parse date string to components
fn datetime_parse(date_string) {
    return date_parse(date_string);
}

# Format current time with custom format
fn datetime_format_now(format_string) {
    let ts = datetime_timestamp();
    return datetime_format(ts, format_string);
}

# Extract year from parsed date components
fn datetime_get_year(parsed_date) {
    if (parsed_date == nullptr) {
        return 0;
    }
    # Access dictionary by key - using array-based dict representation
    let i = 0;
    while (i < len(parsed_date)) {
        let entry = parsed_date[i];
        if (len(entry) >= 2 and entry[0] == "year") {
            return entry[1];
        }
        i = i + 1;
    }
    return 0;
}

# Extract month from parsed date components
fn datetime_get_month(parsed_date) {
    if (parsed_date == nullptr) {
