fn lint_file(filepath) {
    # Lint a file and return results
    let source = read_file(filepath);
    if (source == nullptr) {
        print("Error: Could not read file: " + filepath);
        return nullptr;
    }
    
    let result = lint_analyze(source);
    
    print("Linting: " + filepath);
    lint_report();
    
    return result;
}

