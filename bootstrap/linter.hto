fn str_contains(s, substr) {
    # Check if string contains substring
    let i = 0;
    let substr_len = len(substr);
    let s_len = len(s);
    
    if (substr_len == 0) {
        return true;
    }
    
    while (i <= s_len - substr_len) {
        let found = true;
        let j = 0;
        while (j < substr_len) {
            if (s[i + j] != substr[j]) {
                found = false;
                break;
            }
            j = j + 1;
        }
        if (found) {
            return true;
        }
        i = i + 1;
    }
    
    return false;
}

fn str_split(s, delimiter) {
    # Split string by delimiter
    let result = [];
    let delim_len = len(delimiter);
    let start = 0;
    let i = 0;
    
    while (i <= len(s) - delim_len) {
        let found = true;
        let j = 0;
        while (j < delim_len) {
            if (s[i + j] != delimiter[j]) {
                found = false;
                break;
            }
            j = j + 1;
        }
        
        if (found) {
            push(result, substring(s, start, i - start));
            i = i + delim_len;
            start = i;
        } else {
            i = i + 1;
        }
    }
    
    push(result, substring(s, start, len(s) - start));
    
    return result;
}
