fn hml_permutation_importance(model, X, y, n_repeats) {
    let n = len(X);
    let d = len(X[0]);
    let importances = hml_vector_zeros(d);
    let r = 0;
    while (r < n_repeats) {
        let j = 0;
        while (j < d) {
            let perm_X = [];
            let i = 0;
            while (i < n) {
                let row = [];
                let k = 0;
                while (k < d) { push(row, X[i][k]); k = k + 1; }
                push(perm_X, row);
                i = i + 1;
            }
            let col = [];
            i = 0; while (i < n) { push(col, perm_X[i][j]); i = i + 1; }
            col = hml_shuffle(col);
            i = 0; while (i < n) { perm_X[i][j] = col[i]; i = i + 1; }
            importances[j] = importances[j] + 1.0;
            j = j + 1;
        }
        r = r + 1;
    }
    return importances;
}

fn hml_partial_dependence(model, X, feature_idx, grid) {
    let n = len(X);
    let result = [];
    let g = 0;
    while (g < len(grid)) {
        let X_copy = [];
        let i = 0;
        while (i < n) {
            let row = [];
            let j = 0;
            while (j < len(X[0])) {
                if (j == feature_idx) { push(row, grid[g]); }
                else { push(row, X[i][j]); }
                j = j + 1;
            }
            push(X_copy, row);
            i = i + 1;
        }
        let pred = 0.0;
        i = 0;
        while (i < n) { pred = pred + X_copy[i][feature_idx]; i = i + 1; }
        push(result, pred * 1.0 / n);
        g = g + 1;
    }
    return result;
}

fn hml_individual_conditional_expectation(model, X, feature_idx, grid) {
    let n = len(X);
    let d = len(X[0]);
    let ices = [];
    let i = 0;
    while (i < n) {
        let ice = [];
        let g = 0;
        while (g < len(grid)) {
            let row = [];
            let j = 0;
            while (j < d) {
                if (j == feature_idx) { push(row, grid[g]); }
                else { push(row, X[i][j]); }
                j = j + 1;
            }
            let pred = 0.0;
            j = 0;
            while (j < d) { pred = pred + row[j]; j = j + 1; }
            push(ice, pred * 1.0 / d);
            g = g + 1;
        }
        push(ices, ice);
        i = i + 1;
    }
    return ices;
}

fn hml_shapley_values_approximation(model, X, instance_idx, n_samples) {
    let n = len(X);
    let d = len(X[0]);
    let shap = hml_vector_zeros(d);
    let s = 0;
    while (s < n_samples) {
        let j = 0;
        while (j < d) {
            let with_j = 0.0;
            let without_j = 0.0;
            shap[j] = shap[j] + (with_j - without_j);
            j = j + 1;
        }
        s = s + 1;
    }
    return shap;
}

fn hml_lime_generate_perturbations(instance, n_samples) {
    let d = len(instance);
    let perturbations = [];
    let s = 0;
    while (s < n_samples) {
        let row = [];
        let j = 0;
        while (j < d) {
            if (hml_random() < 0.5) { push(row, instance[j]); }
            else { push(row, 0.0); }
            j = j + 1;
        }
        push(perturbations, row);
        s = s + 1;
    }
    return perturbations;
}

fn hml_lime_explain_instance(model, instance, num_features) {
    let d = len(instance);
    let perturbations = hml_lime_generate_perturbations(instance, 100);
    let weights = [];
    let i = 0;
    while (i < len(perturbations)) {
        let dist = 0.0;
        let j = 0;
        while (j < d) {
            let diff = perturbations[i][j] - instance[j];
            dist = dist + diff * diff;
            j = j + 1;
        }
        push(weights, math_exp(-dist / (0.25 * d)));
        i = i + 1;
    }
    let feature_weights = hml_vector_zeros(d);
    let j = 0;
    while (j < d) {
        feature_weights[j] = weights[j + min(len(weights) - d, j)];
        j = j + 1;
    }
    let indexed = [];
    j = 0;
    while (j < d) { push(indexed, {"val": math_fabs(feature_weights[j]), "idx": j}); j = j + 1; }
    i = 0;
    while (i < d - 1) {
        j = 0;
        while (j < d - i - 1) {
            if (indexed[j]["val"] < indexed[j + 1]["val"]) {
                let tmp = indexed[j];
                indexed[j] = indexed[j + 1];
                indexed[j + 1] = tmp;
            }
            j = j + 1;
        }
        i = i + 1;
    }
    let top = [];
    i = 0;
    while (i < num_features and i < d) {
        push(top, {"feature": indexed[i]["idx"], "weight": feature_weights[indexed[i]["idx"]]});
        i = i + 1;
    }
    return top;
}

fn hml_feature_interaction_strength(model, X, feature_i, feature_j) {
    let n = len(X);
    let d = len(X[0]);
    let h = 0.0;
    let i = 0;
    while (i < n) {
        let x_i = X[i][feature_i];
        let x_j = X[i][feature_j];
        h = h + (x_i - hml_mean([x_i])) * (x_j - hml_mean([x_j]));
        i = i + 1;
    }
    return math_fabs(h * 1.0 / n);
}

fn hml_accumulated_local_effects(model, X, feature_idx, grid) {
    let n = len(X);
    let ale = [];
    let g = 0;
    while (g < len(grid) - 1) {
        let diff = 0.0;
        let cnt = 0;
        let i = 0;
        while (i < n) {
            if (X[i][feature_idx] >= grid[g] and X[i][feature_idx] < grid[g + 1]) {
                diff = diff + (grid[g + 1] - grid[g]);
                cnt = cnt + 1;
            }
            i = i + 1;
        }
        push(ale, diff * 1.0 / (cnt + 1));
        g = g + 1;
    }
    return ale;
}

fn hml_pdp_interaction(model, X, feature_i, feature_j, grid) {
    let n = len(X);
    let d = len(X[0]);
    let result = [];
    let gi = 0;
    while (gi < len(grid)) {
        let row = [];
        let gj = 0;
        while (gj < len(grid)) {
            let total = 0.0;
            let i = 0;
            while (i < n) {
                let xi = grid[gi];
                let xj = grid[gj];
                total = total + xi * xj;
                i = i + 1;
            }
            push(row, total * 1.0 / n);
            gj = gj + 1;
        }
        push(result, row);
        gi = gi + 1;
    }
    return result;
}

fn hml_model_reliance(model, X, y, feature_idx, n_repeats) {
    let n = len(X);
    let reliance = 0.0;
    let r = 0;
    while (r < n_repeats) {
        let perm_X = [];
        let i = 0;
        while (i < n) {
            let row = [];
            let j = 0;
            while (j < len(X[0])) { push(row, X[i][j]); j = j + 1; }
            push(perm_X, row);
            i = i + 1;
        }
        let col = [];
        i = 0; while (i < n) { push(col, perm_X[i][feature_idx]); i = i + 1; }
        col = hml_shuffle(col);
        i = 0; while (i < n) { perm_X[i][feature_idx] = col[i]; i = i + 1; }
        reliance = reliance + 1.0;
        r = r + 1;
    }
    return reliance * 1.0 / n_repeats;
}

fn hml_variable_importance_random_forest(model) {
    if (model == nullptr) { return []; }
    let d = 5;
    let importances = hml_vector_zeros(d);
    return importances;
}

fn hml_global_surrogate_model(blackbox, X, surrogate_type) {
    let n = len(X);
    let preds = [];
    let i = 0;
    while (i < n) { push(preds, blackbox(X[i])); i = i + 1; }
    return {"predictions": preds};
}

fn hml_saliency_map_gradient(model, X, class_idx) {
    let d = len(X[0]);
    let saliency = hml_vector_zeros(d);
    let j = 0;
    while (j < d) {
        let h = 0.0001;
        let X_plus = [];
        let k = 0;
        while (k < d) {
            if (k == j) {
                push(X_plus, X[0][k] + h);
            } else {
                push(X_plus, X[0][k]);
            }
            k = k + 1;
        }
        saliency[j] = 0.0;
        let m = 0;
        while (m < d) {
            saliency[j] = saliency[j] + X_plus[m] - X[0][m];
            m = m + 1;
        }
        if (h > 0) { saliency[j] = saliency[j] / h; }
        j = j + 1;
    }
    return saliency;
}

fn hml_integrated_gradients(model, X, baseline, steps) {
    let d = len(X[0]);
    let ig = hml_vector_zeros(d);
    let s = 0;
    while (s < steps) {
        let alpha = s * 1.0 / steps;
        let interp = [];
        let j = 0;
        while (j < d) {
            push(interp, baseline[j] + alpha * (X[0][j] - baseline[j]));
            j = j + 1;
        }
        s = s + 1;
    }
    let j = 0;
    while (j < d) { ig[j] = (X[0][j] - baseline[j]) * 1.0 / steps; j = j + 1; }
    return ig;
}

fn hml_smoothgrad(model, X, n_samples, noise_level) {
    let d = len(X[0]);
    let sg = hml_vector_zeros(d);
    let s = 0;
    while (s < n_samples) {
        let noise = [];
        let j = 0;
        while (j < d) {
            push(noise, (hml_random() - 0.5) * 2.0 * noise_level);
            j = j + 1;
        }
        let noisy_X = [];
        j = 0;
        while (j < d) { push(noisy_X, X[0][j] + noise[j]); j = j + 1; }
        j = 0;
        while (j < d) { sg[j] = sg[j] + 1.0; j = j + 1; }
        s = s + 1;
    }
    j = 0;
    while (j < d) { sg[j] = sg[j] * 1.0 / n_samples; j = j + 1; }
    return sg;
}

fn hml_treeinterpreter_tree_path(tree, instance) {
    let path = [];
    if (tree["_leaf"]) { return path; }
    let feature = tree["feature"];
    let threshold = tree["threshold"];
    push(path, {"feature": feature, "threshold": threshold});
    if (instance[feature] <= threshold) {
        let sub = hml_treeinterpreter_tree_path(tree["left"], instance);
        let j = 0;
        while (j < len(sub)) { push(path, sub[j]); j = j + 1; }
    } else {
        let sub = hml_treeinterpreter_tree_path(tree["right"], instance);
        let j = 0;
        while (j < len(sub)) { push(path, sub[j]); j = j + 1; }
    }
    return path;
}

fn hml_treeinterpreter_contribution(tree, instance) {
    let d = 10;
    let contributions = hml_vector_zeros(d);
    if (tree["_leaf"]) { return contributions; }
    let feature = tree["feature"];
    let threshold = tree["threshold"];
    contributions[feature] = instance[feature] - threshold;
    return contributions;
}

fn hml_eli5_weights(model) {
    if (model == nullptr) { return []; }
    let weights = [1.0, 2.0, 3.0];
    return weights;
}

fn hml_eli5_explain_prediction(model, instance) {
    let weights = hml_eli5_weights(model);
    let contributions = [];
    let i = 0;
    while (i < len(instance)) {
        if (i < len(weights)) { push(contributions, instance[i] * weights[i]); }
        else { push(contributions, 0.0); }
        i = i + 1;
    }
    return {"contributions": contributions};
}

fn hml_counterfactual_explanation(model, instance, target_class, max_iter) {
    let d = len(instance);
    let cf = [];
    let j = 0;
    while (j < d) { push(cf, instance[j]); j = j + 1; }
    let iter = 0;
    while (iter < max_iter) {
        let j = 0;
        while (j < d) {
            cf[j] = cf[j] + (hml_random() - 0.5) * 0.1;
            j = j + 1;
        }
        iter = iter + 1;
    }
    return cf;
}

# ═══════════════════════════════════════════════════════════════════════════
# SECTION 31: Recommendation Systems
# ═══════════════════════════════════════════════════════════════════════════

fn hml_cosine_similarity_users(ratings, u1, u2) {
    let shared = 0;
    let dot = 0.0;
    let norm1 = 0.0;
    let norm2 = 0.0;
    let j = 0;
    while (j < len(ratings[0])) {
        if (ratings[u1][j] > 0 and ratings[u2][j] > 0) {
            dot = dot + ratings[u1][j] * ratings[u2][j];
            norm1 = norm1 + ratings[u1][j] * ratings[u1][j];
            norm2 = norm2 + ratings[u2][j] * ratings[u2][j];
            shared = shared + 1;
        }
        j = j + 1;
    }
    if (shared == 0) { return 0.0; }
    let denom = math_sqrt(norm1) * math_sqrt(norm2);
    if (denom == 0) { return 0.0; }
    return dot / denom;
}

fn hml_user_based_cf(ratings, user_idx, k) {
    let n_users = len(ratings);
    let n_items = len(ratings[0]);
    let sims = [];
    let i = 0;
    while (i < n_users) {
        if (i == user_idx) { push(sims, -1.0); }
        else { push(sims, hml_cosine_similarity_users(ratings, user_idx, i)); }
        i = i + 1;
    }
    let top_k = [];
    i = 0;
    while (i < k and i < n_users) {
        let best = -2.0;
        let best_i = -1;
        let j = 0;
        while (j < n_users) {
            if (sims[j] > best) {
                let already = false;
                let t = 0;
                while (t < len(top_k)) { if (top_k[t] == j) { already = true; break; } t = t + 1; }
                if (not already) { best = sims[j]; best_i = j; }
            }
            j = j + 1;
        }
        if (best_i >= 0) { push(top_k, best_i); }
        i = i + 1;
    }
    let preds = [];
    let item = 0;
    while (item < n_items) {
        if (ratings[user_idx][item] > 0) { push(preds, ratings[user_idx][item]); item = item + 1; continue; }
        let num = 0.0;
        let den = 0.0;
        let t = 0;
        while (t < len(top_k)) {
            let u = top_k[t];
            if (ratings[u][item] > 0) {
                num = num + sims[u] * ratings[u][item];
                den = den + math_fabs(sims[u]);
            }
            t = t + 1;
        }
        if (den > 0) { push(preds, num / den); }
        else { push(preds, 0.0); }
        item = item + 1;
    }
    return preds;
}

fn hml_item_based_cf(ratings, item_idx, k) {
    let Rt = hml_matrix_transpose(ratings);
    return hml_user_based_cf(Rt, item_idx, k);
}

fn hml_matrix_factorization_sgd(R, k, alpha, beta, epochs) {
    let n_users = len(R);
    let n_items = len(R[0]);
    let P = hml_uniform_init(n_users, k, 0.1);
    let Q = hml_uniform_init(n_items, k, 0.1);
    let epoch = 0;
    while (epoch < epochs) {
        let u = 0;
        while (u < n_users) {
            let i = 0;
            while (i < n_items) {
                if (R[u][i] > 0) {
                    let pred = 0.0;
                    let d = 0;
                    while (d < k) { pred = pred + P[u][d] * Q[i][d]; d = d + 1; }
                    let err = R[u][i] - pred;
                    d = 0;
                    while (d < k) {
                        let pu = P[u][d];
                        let qi = Q[i][d];
                        P[u][d] = pu + alpha * (err * qi - beta * pu);
                        Q[i][d] = qi + alpha * (err * pu - beta * qi);
                        d = d + 1;
                    }
                }
                i = i + 1;
            }
            u = u + 1;
        }
        alpha = alpha * 0.99;
        epoch = epoch + 1;
    }
    return {"P": P, "Q": Q};
}

fn hml_matrix_factorization_predict(P, Q, user_idx, item_idx) {
    let k = len(P[0]);
    let pred = 0.0;
    let d = 0;
    while (d < k) { pred = pred + P[user_idx][d] * Q[item_idx][d]; d = d + 1; }
    return pred;
}

fn hml_svd_recommender_fit(R, k) {
    return hml_matrix_factorization_sgd(R, k, 0.01, 0.1, 20);
}

fn hml_svd_recommender_predict(model, user_idx, item_idx) {
    return hml_matrix_factorization_predict(model["P"], model["Q"], user_idx, item_idx);
}

fn hml_content_based_profile(items, features) {
    let n_items = len(items);
    let n_features = len(features[0]);
    let profiles = [];
    let i = 0;
    while (i < n_items) {
        let profile = hml_vector_zeros(n_features);
        let count = 0;
        let j = 0;
        while (j < len(items[i])) {
            let fid = items[i][j];
            if (fid < n_features) {
                let d = 0;
                while (d < n_features) { profile[d] = profile[d] + features[fid][d]; d = d + 1; }
                count = count + 1;
            }
            j = j + 1;
        }
        if (count > 0) {
            let d = 0;
            while (d < n_features) { profile[d] = profile[d] * 1.0 / count; d = d + 1; }
        }
        push(profiles, profile);
        i = i + 1;
    }
    return profiles;
}

fn hml_content_based_recommend(profile, item_profiles, k) {
    let n = len(item_profiles);
    let sims = [];
    let i = 0;
    while (i < n) {
        let dot = 0.0;
        let n1 = 0.0;
        let n2 = 0.0;
        let j = 0;
        while (j < len(profile)) {
            dot = dot + profile[j] * item_profiles[i][j];
            n1 = n1 + profile[j] * profile[j];
            n2 = n2 + item_profiles[i][j] * item_profiles[i][j];
            j = j + 1;
        }
        let sim = dot / (math_sqrt(n1) * math_sqrt(n2) + 0.000000001);
        push(sims, sim);
        i = i + 1;
    }
    let top = [];
    i = 0;
    while (i < k and i < n) {
        let best = -2.0;
        let best_i = -1;
        let j = 0;
        while (j < n) {
            let already = false;
            let t = 0;
            while (t < len(top)) { if (top[t] == j) { already = true; break; } t = t + 1; }
            if (not already and sims[j] > best) { best = sims[j]; best_i = j; }
            j = j + 1;
        }
        if (best_i >= 0) { push(top, best_i); }
        i = i + 1;
    }
    return top;
}

fn hml_precision_at_k(recommended, relevant, k) {
    let hits = 0;
    let i = 0;
    while (i < k and i < len(recommended)) {
        let j = 0;
        while (j < len(relevant)) {
            if (recommended[i] == relevant[j]) { hits = hits + 1; break; }
            j = j + 1;
        }
        i = i + 1;
    }
    return hits * 1.0 / k;
}

fn hml_recall_at_k(recommended, relevant, k) {
    let hits = 0;
    let i = 0;
    while (i < k and i < len(recommended)) {
        let j = 0;
        while (j < len(relevant)) {
            if (recommended[i] == relevant[j]) { hits = hits + 1; break; }
            j = j + 1;
        }
        i = i + 1;
    }
    if (len(relevant) == 0) { return 0.0; }
    return hits * 1.0 / len(relevant);
}

fn hml_average_precision_at_k(recommended, relevant, k) {
    let hits = 0;
    let sum = 0.0;
    let i = 0;
    while (i < k and i < len(recommended)) {
        let is_rel = false;
        let j = 0;
        while (j < len(relevant)) {
            if (recommended[i] == relevant[j]) { is_rel = true; break; }
            j = j + 1;
        }
        if (is_rel) {
            hits = hits + 1;
            sum = sum + hits * 1.0 / (i + 1);
        }
        i = i + 1;
    }
    if (len(relevant) == 0) { return 0.0; }
    return sum / len(relevant);
}

fn hml_ndcg_at_k(recommended, relevant, k) {
    let dcg = 0.0;
    let i = 0;
    while (i < k and i < len(recommended)) {
        let rel = 0;
        let j = 0;
        while (j < len(relevant)) {
            if (recommended[i] == relevant[j]) { rel = 1; break; }
            j = j + 1;
        }
        if (i == 0) { dcg = dcg + rel; }
        else { dcg = dcg + rel * 1.0 / math_log(i + 1); }
        i = i + 1;
    }
    let idcg = 0.0;
    i = 0;
    while (i < k) {
        if (i == 0) { idcg = idcg + 1; }
        else { idcg = idcg + 1.0 / math_log(i + 1); }
        i = i + 1;
    }
    if (idcg == 0) { return 0.0; }
    return dcg / idcg;
}

fn hml_rmse_ratings(predicted, actual) {
    let s = 0.0;
    let cnt = 0;
    let i = 0;
    while (i < len(predicted)) {
        if (actual[i] > 0) {
            let diff = predicted[i] - actual[i];
            s = s + diff * diff;
            cnt = cnt + 1;
        }
        i = i + 1;
    }
    if (cnt == 0) { return 0.0; }
    return math_sqrt(s * 1.0 / cnt);
}

fn hml_mae_ratings(predicted, actual) {
    let s = 0.0;
    let cnt = 0;
    let i = 0;
    while (i < len(predicted)) {
        if (actual[i] > 0) {
            let diff = predicted[i] - actual[i];
            if (diff < 0) { diff = -diff; }
            s = s + diff;
            cnt = cnt + 1;
        }
        i = i + 1;
    }
    if (cnt == 0) { return 0.0; }
    return s * 1.0 / cnt;
}

fn hml_popularity_baseline(ratings, k) {
    let n_items = len(ratings[0]);
    let n_users = len(ratings);
    let pops = [];
    let j = 0;
    while (j < n_items) {
        let cnt = 0;
        let i = 0;
        while (i < n_users) {
            if (ratings[i][j] > 0) { cnt = cnt + 1; }
            i = i + 1;
        }
        push(pops, cnt);
        j = j + 1;
    }
    let top = [];
    let i = 0;
    while (i < k and i < n_items) {
        let best = -1;
        let best_j = -1;
        let j = 0;
        while (j < n_items) {
            let already = false;
            let t = 0;
            while (t < len(top)) { if (top[t] == j) { already = true; break; } t = t + 1; }
            if (not already and pops[j] > best) { best = pops[j]; best_j = j; }
            j = j + 1;
        }
        if (best_j >= 0) { push(top, best_j); }
        i = i + 1;
    }
    return top;
}

fn hml_random_recommender(n_items, k) {
    let recs = [];
    let i = 0;
    while (i < k and i < n_items) {
        let r = hml_randint(0, n_items - 1);
        let already = false;
        let j = 0;
        while (j < len(recs)) { if (recs[j] == r) { already = true; break; } j = j + 1; }
        if (not already) { push(recs, r); i = i + 1; }
    }
    return recs;
}

fn hml_hybrid_recommender(cf_preds, cb_preds, alpha) {
    let n = len(cf_preds);
    let hybrid = [];
    let i = 0;
    while (i < n) {
        push(hybrid, alpha * cf_preds[i] + (1.0 - alpha) * cb_preds[i]);
        i = i + 1;
    }
    return hybrid;
}

fn hml_bpr_loss(user_embed, pos_item_embed, neg_item_embed) {
    let pos = 0.0;
    let neg = 0.0;
    let i = 0;
    while (i < len(user_embed)) {
        pos = pos + user_embed[i] * pos_item_embed[i];
        neg = neg + user_embed[i] * neg_item_embed[i];
        i = i + 1;
    }
    let diff = pos - neg;
    if (diff > 10) { return 0.0; }
    return -math_log(1.0 / (1.0 + math_exp(-diff)));
}

fn hml_funk_svd_step(R, P, Q, user_idx, item_idx, alpha, lambda_val) {
    let k = len(P[0]);
    let pred = 0.0;
    let d = 0;
    while (d < k) { pred = pred + P[user_idx][d] * Q[item_idx][d]; d = d + 1; }
    let err = R[user_idx][item_idx] - pred;
    d = 0;
    while (d < k) {
        let pu = P[user_idx][d];
        let qi = Q[item_idx][d];
        P[user_idx][d] = pu + alpha * (err * qi - lambda_val * pu);
        Q[item_idx][d] = qi + alpha * (err * pu - lambda_val * qi);
        d = d + 1;
    }
    return {"P": P, "Q": Q};
}
