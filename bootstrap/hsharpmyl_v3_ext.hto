# SECTION 32: Graph Algorithms & Network Analysis
# ═══════════════════════════════════════════════════════════════════════════

fn hml_pagerank(adj_matrix, damping, max_iter) {
    let n = len(adj_matrix);
    let pr = hml_vector_zeros(n);
    let i = 0;
    while (i < n) { pr[i] = 1.0 / n; i = i + 1; }
    let iter = 0;
    while (iter < max_iter) {
        let new_pr = hml_vector_zeros(n);
        let sink_sum = 0.0;
        i = 0;
        while (i < n) {
            let out_deg = 0.0;
            let j = 0;
            while (j < n) { out_deg = out_deg + adj_matrix[i][j]; j = j + 1; }
            if (out_deg == 0) { sink_sum = sink_sum + pr[i]; }
            i = i + 1;
        }
        let j = 0;
        while (j < n) {
            let rank = 0.0;
            let i = 0;
            while (i < n) {
                let out_deg = 0.0;
                let k = 0;
                while (k < n) { out_deg = out_deg + adj_matrix[i][k]; k = k + 1; }
                if (out_deg > 0 and adj_matrix[i][j] > 0) {
                    rank = rank + pr[i] * 1.0 / out_deg;
                }
                i = i + 1;
            }
            new_pr[j] = (1.0 - damping) * 1.0 / n + damping * (rank + sink_sum * 1.0 / n);
            j = j + 1;
        }
        pr = new_pr;
        iter = iter + 1;
    }
    return pr;
}

fn hml_hits_authority(adj_matrix, max_iter) {
    let n = len(adj_matrix);
    let auth = hml_vector_ones(n);
    let hub = hml_vector_ones(n);
    let iter = 0;
    while (iter < max_iter) {
        let new_auth = hml_vector_zeros(n);
        let new_hub = hml_vector_zeros(n);
        let i = 0;
        while (i < n) {
            let j = 0;
            while (j < n) {
                if (adj_matrix[j][i] > 0) { new_auth[i] = new_auth[i] + hub[j]; }
                if (adj_matrix[i][j] > 0) { new_hub[i] = new_hub[i] + auth[j]; }
                j = j + 1;
            }
            i = i + 1;
        }
        let auth_sum = 0.0;
        let hub_sum = 0.0;
        i = 0;
        while (i < n) { auth_sum = auth_sum + new_auth[i] * new_auth[i]; hub_sum = hub_sum + new_hub[i] * new_hub[i]; i = i + 1; }
        let a_norm = math_sqrt(auth_sum) + 0.000000001;
        let h_norm = math_sqrt(hub_sum) + 0.000000001;
        i = 0;
        while (i < n) { auth[i] = new_auth[i] / a_norm; hub[i] = new_hub[i] / h_norm; i = i + 1; }
        iter = iter + 1;
    }
    return auth;
}

fn hml_hits_hub(adj_matrix, max_iter) {
    let n = len(adj_matrix);
    let auth = hml_vector_ones(n);
    let hub = hml_vector_ones(n);
    let iter = 0;
    while (iter < max_iter) {
        let new_auth = hml_vector_zeros(n);
        let new_hub = hml_vector_zeros(n);
        let i = 0;
        while (i < n) {
            let j = 0;
            while (j < n) {
                if (adj_matrix[j][i] > 0) { new_auth[i] = new_auth[i] + hub[j]; }
                if (adj_matrix[i][j] > 0) { new_hub[i] = new_hub[i] + auth[j]; }
                j = j + 1;
            }
            i = i + 1;
        }
        let auth_sq = 0.0; let hub_sq = 0.0;
        i = 0;
        while (i < n) { auth_sq = auth_sq + new_auth[i] * new_auth[i]; hub_sq = hub_sq + new_hub[i] * new_hub[i]; i = i + 1; }
        let an = math_sqrt(auth_sq) + 0.000000001;
        let hn = math_sqrt(hub_sq) + 0.000000001;
        i = 0;
        while (i < n) { auth[i] = new_auth[i] / an; hub[i] = new_hub[i] / hn; i = i + 1; }
        iter = iter + 1;
    }
    return hub;
}

fn hml_degree_centrality(adj_matrix) {
    let n = len(adj_matrix);
    let centrality = hml_vector_zeros(n);
    let i = 0;
    while (i < n) {
        let j = 0;
        while (j < n) { centrality[i] = centrality[i] + adj_matrix[i][j] + adj_matrix[j][i]; j = j + 1; }
        centrality[i] = centrality[i] * 1.0 / (2.0 * (n - 1));
        i = i + 1;
    }
    return centrality;
}

fn hml_betweenness_centrality(adj_matrix) {
    let n = len(adj_matrix);
    let bc = hml_vector_zeros(n);
    let s = 0;
    while (s < n) {
        let dist = [];
        let i = 0;
        while (i < n) { push(dist, 1000000000); i = i + 1; }
        dist[s] = 0;
        let sigma = hml_vector_zeros(n);
        sigma[s] = 1.0;
        let queue = [s];
        while (len(queue) > 0) {
            let v = queue[0];
            let new_q = [];
            let i = 1;
            while (i < len(queue)) { push(new_q, queue[i]); i = i + 1; }
            queue = new_q;
            let w = 0;
            while (w < n) {
                if (adj_matrix[v][w] > 0) {
                    if (dist[w] == 1000000000) {
                        push(queue, w);
                        dist[w] = dist[v] + 1;
                    }
                    if (dist[w] == dist[v] + 1) {
                        sigma[w] = sigma[w] + sigma[v];
                    }
                }
                w = w + 1;
            }
        }
        s = s + 1;
    }
    return bc;
}

fn hml_closeness_centrality(adj_matrix) {
    let n = len(adj_matrix);
    let cc = hml_vector_zeros(n);
    let s = 0;
    while (s < n) {
        let dist = [];
        let i = 0;
        while (i < n) { push(dist, 1000000000); i = i + 1; }
        dist[s] = 0;
        let queue = [s];
        while (len(queue) > 0) {
            let v = queue[0];
            let new_q = [];
            let i = 1;
            while (i < len(queue)) { push(new_q, queue[i]); i = i + 1; }
            queue = new_q;
            let w = 0;
            while (w < n) {
                if (adj_matrix[v][w] > 0 and dist[w] == 1000000000) {
                    push(queue, w);
                    dist[w] = dist[v] + 1;
                }
                w = w + 1;
            }
        }
        let total = 0.0;
        let i = 0;
        while (i < n) {
            if (i != s and dist[i] < 100000000) { total = total + dist[i]; }
            i = i + 1;
        }
        if (total > 0) { cc[s] = (n - 1) * 1.0 / total; }
        s = s + 1;
    }
    return cc;
}

fn hml_eigenvector_centrality(adj_matrix, max_iter) {
    let n = len(adj_matrix);
    let ec = hml_vector_ones(n);
    let iter = 0;
    while (iter < max_iter) {
        let new_ec = hml_vector_zeros(n);
        let i = 0;
        while (i < n) {
            let j = 0;
            while (j < n) { new_ec[i] = new_ec[i] + adj_matrix[i][j] * ec[j]; j = j + 1; }
            i = i + 1;
        }
        let norm = 0.0;
        i = 0;
        while (i < n) { norm = norm + new_ec[i] * new_ec[i]; i = i + 1; }
        norm = math_sqrt(norm) + 0.000000001;
        i = 0;
        while (i < n) { ec[i] = new_ec[i] / norm; i = i + 1; }
        iter = iter + 1;
    }
    return ec;
}

fn hml_graph_modularity(adj_matrix, communities) {
    let n = len(adj_matrix);
    let m = 0.0;
    let i = 0;
    while (i < n) {
        let j = 0;
        while (j < n) { m = m + adj_matrix[i][j]; j = j + 1; }
        i = i + 1;
    }
    m = m * 0.5;
    if (m == 0) { return 0.0; }
    let Q = 0.0;
    i = 0;
    while (i < n) {
        let j = 0;
        while (j < n) {
            if (communities[i] == communities[j]) {
                let ki = 0.0;
                let kj = 0.0;
                let k = 0;
                while (k < n) { ki = ki + adj_matrix[i][k]; kj = kj + adj_matrix[j][k]; k = k + 1; }
                Q = Q + adj_matrix[i][j] - (ki * kj) * 1.0 / (2.0 * m);
            }
            j = j + 1;
        }
        i = i + 1;
    }
    return Q * 1.0 / (2.0 * m);
}

fn hml_louvain_community_detection(adj_matrix) {
    let n = len(adj_matrix);
    let communities = [];
    let i = 0;
    while (i < n) { push(communities, i); i = i + 1; }
    let improved = true;
    while (improved) {
        improved = false;
        let i = 0;
        while (i < n) {
            let best_community = communities[i];
            let best_q = -1000000000;
            let neighbor_communities = [];
            let j = 0;
            while (j < n) {
                if (adj_matrix[i][j] > 0) { push(neighbor_communities, communities[j]); }
                j = j + 1;
            }
            let j = 0;
            while (j < len(neighbor_communities)) {
                let old = communities[i];
                communities[i] = neighbor_communities[j];
                let q = hml_graph_modularity(adj_matrix, communities);
                if (q > best_q) { best_q = q; best_community = neighbor_communities[j]; improved = true; }
                communities[i] = old;
                j = j + 1;
            }
            communities[i] = best_community;
            i = i + 1;
        }
    }
    return communities;
}

fn hml_graph_laplacian(adj_matrix) {
    let n = len(adj_matrix);
    let L = hml_matrix_zeros(n, n);
    let i = 0;
    while (i < n) {
        let deg = 0.0;
        let j = 0;
        while (j < n) { deg = deg + adj_matrix[i][j]; j = j + 1; }
        let j = 0;
        while (j < n) {
            if (i == j) { L[i][j] = deg; }
            else { L[i][j] = -adj_matrix[i][j]; }
            j = j + 1;
        }
        i = i + 1;
    }
    return L;
}

fn hml_shortest_path_dijkstra(adj_matrix, start) {
    let n = len(adj_matrix);
    let dist = [];
    let visited = [];
    let i = 0;
    while (i < n) { push(dist, 1000000000); push(visited, false); i = i + 1; }
    dist[start] = 0;
    i = 0;
    while (i < n) {
        let u = -1;
        let min_d = 1000000000;
        let j = 0;
        while (j < n) {
            if (not visited[j] and dist[j] < min_d) { min_d = dist[j]; u = j; }
            j = j + 1;
        }
        if (u == -1) { break; }
        visited[u] = true;
        let v = 0;
        while (v < n) {
            if (adj_matrix[u][v] > 0 and not visited[v]) {
                let new_d = dist[u] + adj_matrix[u][v];
                if (new_d < dist[v]) { dist[v] = new_d; }
            }
            v = v + 1;
        }
        i = i + 1;
    }
    return dist;
}

fn hml_shortest_path_floyd_warshall(adj_matrix) {
    let n = len(adj_matrix);
    let dist = hml_matrix_zeros(n, n);
    let i = 0;
    while (i < n) {
        let j = 0;
        while (j < n) {
            if (i == j) { dist[i][j] = 0; }
            else if (adj_matrix[i][j] > 0) { dist[i][j] = adj_matrix[i][j]; }
            else { dist[i][j] = 1000000000; }
            j = j + 1;
        }
        i = i + 1;
    }
    let k = 0;
    while (k < n) {
        i = 0;
        while (i < n) {
            let j = 0;
            while (j < n) {
                let through_k = dist[i][k] + dist[k][j];
                if (through_k < dist[i][j]) { dist[i][j] = through_k; }
                j = j + 1;
            }
            i = i + 1;
        }
        k = k + 1;
    }
    return dist;
}

fn hml_minimum_spanning_tree_prim(adj_matrix) {
    let n = len(adj_matrix);
    let key = [];
    let parent = [];
    let in_mst = [];
    let i = 0;
    while (i < n) { push(key, 1000000000); push(parent, -1); push(in_mst, false); i = i + 1; }
    key[0] = 0;
    let i = 0;
    while (i < n) {
        let u = -1;
        let min_key = 1000000000;
        let j = 0;
        while (j < n) {
            if (not in_mst[j] and key[j] < min_key) { min_key = key[j]; u = j; }
            j = j + 1;
        }
        if (u == -1) { break; }
        in_mst[u] = true;
        let v = 0;
        while (v < n) {
            if (adj_matrix[u][v] > 0 and not in_mst[v] and adj_matrix[u][v] < key[v]) {
                key[v] = adj_matrix[u][v];
                parent[v] = u;
            }
            v = v + 1;
        }
        i = i + 1;
    }
    let mst = [];
    i = 1;
    while (i < n) {
        if (parent[i] >= 0) {
            push(mst, {"from": parent[i], "to": i, "weight": adj_matrix[parent[i]][i]});
        }
        i = i + 1;
    }
    return mst;
}

fn hml_triangle_count(adj_matrix) {
    let n = len(adj_matrix);
    let count = 0;
    let i = 0;
    while (i < n) {
        let j = i + 1;
        while (j < n) {
            if (adj_matrix[i][j] > 0) {
                let k = j + 1;
                while (k < n) {
                    if (adj_matrix[i][k] > 0 and adj_matrix[j][k] > 0) { count = count + 1; }
                    k = k + 1;
                }
            }
            j = j + 1;
        }
        i = i + 1;
    }
    return count;
}

fn hml_clustering_coefficient(adj_matrix) {
    let n = len(adj_matrix);
    let total = 0.0;
    let i = 0;
    while (i < n) {
        let neighbors = [];
        let j = 0;
        while (j < n) { if (adj_matrix[i][j] > 0) { push(neighbors, j); } j = j + 1; }
        let k = len(neighbors);
        if (k < 2) { i = i + 1; continue; }
        let edges = 0;
        let a = 0;
        while (a < k) {
            let b = a + 1;
            while (b < k) {
                if (adj_matrix[neighbors[a]][neighbors[b]] > 0) { edges = edges + 1; }
                b = b + 1;
            }
            a = a + 1;
        }
        total = total + (2.0 * edges) * 1.0 / (k * (k - 1));
        i = i + 1;
    }
    return total * 1.0 / n;
}

fn hml_graph_diameter(adj_matrix) {
    let n = len(adj_matrix);
    let dist = hml_shortest_path_floyd_warshall(adj_matrix);
    let diameter = 0.0;
    let i = 0;
    while (i < n) {
        let j = 0;
        while (j < n) {
            if (dist[i][j] < 100000000 and dist[i][j] > diameter) { diameter = dist[i][j]; }
            j = j + 1;
        }
        i = i + 1;
    }
    return diameter;
}

fn hml_connected_components(adj_matrix) {
    let n = len(adj_matrix);
    let visited = [];
    let i = 0;
    while (i < n) { push(visited, false); i = i + 1; }
    let components = [];
    i = 0;
    while (i < n) {
        if (visited[i]) { i = i + 1; continue; }
        let comp = [];
        let stack = [i];
        visited[i] = true;
        while (len(stack) > 0) {
            let v = stack[len(stack) - 1];
            let new_stack = [];
            let j = 0;
            while (j < len(stack) - 1) { push(new_stack, stack[j]); j = j + 1; }
            stack = new_stack;
            push(comp, v);
            let w = 0;
            while (w < n) {
                if (adj_matrix[v][w] > 0 and not visited[w]) { visited[w] = true; push(stack, w); }
                w = w + 1;
            }
        }
        push(components, comp);
        i = i + 1;
    }
    return components;
}

fn hml_graph_random_walk(adj_matrix, start, steps) {
    let n = len(adj_matrix);
    let walk = [start];
    let current = start;
    let step = 0;
    while (step < steps) {
        let neighbors = [];
        let j = 0;
        while (j < n) { if (adj_matrix[current][j] > 0) { push(neighbors, j); } j = j + 1; }
        if (len(neighbors) == 0) { break; }
        let next = neighbors[hml_randint(0, len(neighbors) - 1)];
        push(walk, next);
        current = next;
        step = step + 1;
    }
    return walk;
}

fn hml_node2vec_random_walk(adj_matrix, start, walk_length, p, q) {
    let n = len(adj_matrix);
    let walk = [start];
    let current = start;
    let prev = -1;
    let step = 0;
    while (step < walk_length) {
        let neighbors = [];
        let j = 0;
        while (j < n) { if (adj_matrix[current][j] > 0) { push(neighbors, j); } j = j + 1; }
        if (len(neighbors) == 0) { break; }
        let weights = [];
        let total = 0.0;
        let j = 0;
        while (j < len(neighbors)) {
            let w = 1.0;
            if (prev >= 0) {
                if (neighbors[j] == prev) { w = 1.0 / p; }
                else if (adj_matrix[neighbors[j]][prev] > 0) { w = 1.0; }
                else { w = 1.0 / q; }
            }
            push(weights, w);
            total = total + w;
            j = j + 1;
        }
        let r = hml_random() * total;
        let cum = 0.0;
        let next = neighbors[0];
        j = 0;
        while (j < len(neighbors)) {
            cum = cum + weights[j];
            if (r <= cum) { next = neighbors[j]; break; }
            j = j + 1;
        }
        push(walk, next);
        prev = current;
        current = next;
        step = step + 1;
    }
    return walk;
}

fn hml_graph_convolution(adj_matrix, features, W) {
    let n = len(adj_matrix);
    let d = len(features[0]);
    let out_d = len(W[0]);
    let D_hat = hml_vector_zeros(n);
    let i = 0;
    while (i < n) {
        let j = 0;
        while (j < n) { D_hat[i] = D_hat[i] + adj_matrix[i][j]; j = j + 1; }
        D_hat[i] = D_hat[i] + 1.0;
        i = i + 1;
    }
    let output = [];
    i = 0;
    while (i < n) {
        let row = [];
        let j = 0;
        while (j < out_d) {
            let s = 0.0;
            let k = 0;
            while (k < n) {
                let a_ik = 0.0;
                if (i == k) { a_ik = 1.0; }
                else { a_ik = adj_matrix[i][k]; }
                let norm = a_ik / (math_sqrt(D_hat[i]) * math_sqrt(D_hat[k]));
                let l = 0;
                while (l < d) { s = s + norm * features[k][l] * W[l][j]; l = l + 1; }
                k = k + 1;
            }
            push(row, s);
            j = j + 1;
        }
        push(output, row);
        i = i + 1;
    }
    return output;
}

# ═══════════════════════════════════════════════════════════════════════════
# SECTION 33: Advanced Time Series & Survival Analysis
# ═══════════════════════════════════════════════════════════════════════════

fn hml_arima_fit(data, p, d, q) {
    let n = len(data);
    let diff_data = data;
    let diff_order = d;
    while (diff_order > 0) {
        let dd = [];
        let i = 1;
        while (i < len(diff_data)) { push(dd, diff_data[i] - diff_data[i - 1]); i = i + 1; }
        diff_data = dd;
        diff_order = diff_order - 1;
    }
    let ar = hml_vector_zeros(p);
    let ma = hml_vector_zeros(q);
    let i = 0;
    while (i < p) { if (i < len(diff_data)) { ar[i] = diff_data[i] * 0.1; } i = i + 1; }
    i = 0;
    while (i < q) { ma[i] = 0.1; i = i + 1; }
    return {"ar": ar, "ma": ma, "d": d, "last_values": data};
}

fn hml_arima_predict(model, steps) {
    let ar = model["ar"];
    let p = len(ar);
    let last = model["last_values"];
    let preds = [];
    let s = 0;
    while (s < steps) {
        let pred = 0.0;
        let i = 0;
        while (i < p) {
            let idx = len(last) - p + i + s;
            if (idx >= 0 and idx < len(last)) { pred = pred + ar[i] * last[idx]; }
            i = i + 1;
        }
        push(preds, pred);
        s = s + 1;
    }
    return preds;
}

fn hml_garch_fit(returns, p, q) {
    let n = len(returns);
    let omega = hml_var(returns) * 0.1;
    let alpha = hml_vector_zeros(q);
    let beta = hml_vector_zeros(p);
    if (q > 0) { alpha[0] = 0.1; }
    if (p > 0) { beta[0] = 0.8; }
    return {"omega": omega, "alpha": alpha, "beta": beta, "last_return": returns[n - 1], "last_var": hml_var(returns)};
}

fn hml_garch_predict(model, steps) {
    let omega = model["omega"];
    let alpha = model["alpha"];
    let beta = model["beta"];
    let last_var = model["last_var"];
    let preds = [];
    let s = 0;
    while (s < steps) {
        let sigma2 = omega;
        let i = 0;
        while (i < len(alpha)) { sigma2 = sigma2 + alpha[i] * last_var; i = i + 1; }
        i = 0;
        while (i < len(beta)) { sigma2 = sigma2 + beta[i] * last_var; i = i + 1; }
        push(preds, sigma2);
        last_var = sigma2;
        s = s + 1;
    }
    return preds;
}

fn hml_change_point_detection(data, penalty) {
    let n = len(data);
    let cp = [];
    let i = 1;
    while (i < n - 1) {
        let left = [];
        let j = 0; while (j < i) { push(left, data[j]); j = j + 1; }
        let right = [];
        j = i; while (j < n) { push(right, data[j]); j = j + 1; }
        let m1 = hml_mean(left);
        let m2 = hml_mean(right);
        let diff = math_fabs(m1 - m2);
        if (diff > penalty * hml_std(data)) { push(cp, i); }
        i = i + 1;
    }
    return cp;
}

fn hml_granger_causality_test(X, Y, max_lag) {
    let n = len(X);
    let result = [];
    let lag = 1;
    while (lag <= max_lag) {
        let ssr_restricted = 0.0;
        let ssr_unrestricted = 0.0;
        let i = lag;
        while (i < n) {
            let pred_r = 0.0;
            let j = 1;
            while (j <= lag) { pred_r = pred_r + Y[i - j]; j = j + 1; }
            pred_r = pred_r * 1.0 / lag;
            let resid_r = Y[i] - pred_r;
            ssr_restricted = ssr_restricted + resid_r * resid_r;
            let pred_u = 0.0;
            j = 1;
            while (j <= lag) { pred_u = pred_u + Y[i - j] + X[i - j]; j = j + 1; }
            pred_u = pred_u * 1.0 / (2.0 * lag);
            let resid_u = Y[i] - pred_u;
            ssr_unrestricted = ssr_unrestricted + resid_u * resid_u;
            i = i + 1;
        }
        let f_stat = 0.0;
        if (ssr_unrestricted > 0) {
            f_stat = ((ssr_restricted - ssr_unrestricted) * 1.0 / lag) / (ssr_unrestricted * 1.0 / (n - 2 * lag - 1));
        }
        push(result, f_stat);
        lag = lag + 1;
    }
    return result;
}

fn hml_survival_kaplan_meier(times, events) {
    let n = len(times);
    let pairs = [];
    let i = 0;
    while (i < n) { push(pairs, {"time": times[i], "event": events[i]}); i = i + 1; }
    i = 0;
    while (i < n - 1) {
        let j = 0;
        while (j < n - i - 1) {
            if (pairs[j]["time"] > pairs[j + 1]["time"]) {
                let tmp = pairs[j];
                pairs[j] = pairs[j + 1];
                pairs[j + 1] = tmp;
            }
            j = j + 1;
        }
        i = i + 1;
    }
    let unique_times = [pairs[0]["time"]];
    i = 1;
    while (i < n) {
        if (pairs[i]["time"] != unique_times[len(unique_times) - 1]) {
            push(unique_times, pairs[i]["time"]);
        }
        i = i + 1;
    }
    let survival = [];
    let at_risk = n;
    let surv = 1.0;
    let ti = 0;
    while (ti < len(unique_times)) {
        let t = unique_times[ti];
        let deaths = 0;
        i = 0;
        while (i < n) {
            if (pairs[i]["time"] == t and pairs[i]["event"] == 1) { deaths = deaths + 1; }
            i = i + 1;
        }
        if (deaths > 0) { surv = surv * (1.0 - deaths * 1.0 / at_risk); }
        let censored = 0;
        i = 0;
        while (i < n) {
            if (pairs[i]["time"] == t and pairs[i]["event"] == 0) { censored = censored + 1; }
            i = i + 1;
        }
        at_risk = at_risk - deaths - censored;
        push(survival, {"time": t, "survival": surv});
        ti = ti + 1;
    }
    return {"curve": survival, "times": unique_times};
}

fn hml_survival_kaplan_meier_survival(model, time) {
    let curve = model["curve"];
    let surv = 1.0;
    let i = 0;
    while (i < len(curve)) {
        if (curve[i]["time"] <= time) { surv = curve[i]["survival"]; }
        i = i + 1;
    }
    return surv;
}

fn hml_survival_cox_ph_fit(X, times, events) {
    let n = len(X);
    let d = len(X[0]);
    let coef = hml_vector_zeros(d);
    let i = 0;
    while (i < n) {
        let j = 0;
        while (j < d) {
            coef[j] = coef[j] + X[i][j] * times[i] * events[i];
            j = j + 1;
        }
        i = i + 1;
    }
    let total_events = 0;
    i = 0;
    while (i < n) { total_events = total_events + events[i]; i = i + 1; }
    if (total_events > 0) {
        let j = 0;
        while (j < d) { coef[j] = coef[j] * 1.0 / total_events; j = j + 1; }
    }
    return {"coefficients": coef};
}

fn hml_survival_cox_ph_hazard(model, X) {
    let coef = model["coefficients"];
    let d = len(coef);
    let log_hazard = 0.0;
    let j = 0;
    while (j < d) { log_hazard = log_hazard + coef[j] * X[j]; j = j + 1; }
    return math_exp(log_hazard);
}

fn hml_survival_nelson_aalen(times, events) {
    let n = len(times);
    let pairs = [];
    let i = 0;
    while (i < n) { push(pairs, {"time": times[i], "event": events[i]}); i = i + 1; }
    i = 0;
    while (i < n - 1) {
        let j = 0;
        while (j < n - i - 1) {
            if (pairs[j]["time"] > pairs[j + 1]["time"]) {
                let tmp = pairs[j];
                pairs[j] = pairs[j + 1];
                pairs[j + 1] = tmp;
            }
            j = j + 1;
        }
        i = i + 1;
    }
    let unique_times = [pairs[0]["time"]];
    i = 1;
    while (i < n) {
        if (pairs[i]["time"] != unique_times[len(unique_times) - 1]) {
            push(unique_times, pairs[i]["time"]);
        }
        i = i + 1;
    }
    let cum_hazard = 0.0;
    let at_risk = n;
    let curve = [];
    let ti = 0;
    while (ti < len(unique_times)) {
        let t = unique_times[ti];
        let deaths = 0;
        i = 0;
        while (i < n) {
            if (pairs[i]["time"] == t and pairs[i]["event"] == 1) { deaths = deaths + 1; }
            i = i + 1;
        }
        let censored = 0;
        i = 0;
        while (i < n) {
            if (pairs[i]["time"] == t and pairs[i]["event"] == 0) { censored = censored + 1; }
            i = i + 1;
        }
        if (at_risk > 0) { cum_hazard = cum_hazard + deaths * 1.0 / at_risk; }
        at_risk = at_risk - deaths - censored;
        push(curve, {"time": t, "cumulative_hazard": cum_hazard});
        ti = ti + 1;
    }
    return {"curve": curve, "times": unique_times};
}

fn hml_survival_log_rank_test(group1_times, group1_events, group2_times, group2_events) {
    let all_times = [];
    let all_events = [];
    let groups = [];
    let i = 0;
    while (i < len(group1_times)) { push(all_times, group1_times[i]); push(all_events, group1_events[i]); push(groups, 0); i = i + 1; }
    i = 0;
    while (i < len(group2_times)) { push(all_times, group2_times[i]); push(all_events, group2_events[i]); push(groups, 1); i = i + 1; }
    let n = len(all_times);
    let sorted = [];
    i = 0;
    while (i < n) { push(sorted, {"time": all_times[i], "event": all_events[i], "group": groups[i]}); i = i + 1; }
    i = 0;
    while (i < n - 1) {
        let j = 0;
        while (j < n - i - 1) {
            if (sorted[j]["time"] > sorted[j + 1]["time"]) {
                let tmp = sorted[j];
                sorted[j] = sorted[j + 1];
                sorted[j + 1] = tmp;
            }
            j = j + 1;
        }
        i = i + 1;
    }
    let obs_g1 = 0;
    let exp_g1 = 0.0;
    let at_risk_g1 = len(group1_times);
    let at_risk_g2 = len(group2_times);
    i = 0;
    while (i < n) {
        let deaths_total = 0;
        let deaths_g1 = 0;
        let t = sorted[i]["time"];
        while (i < n and sorted[i]["time"] == t) {
            if (sorted[i]["event"] == 1) { deaths_total = deaths_total + 1; if (sorted[i]["group"] == 0) { deaths_g1 = deaths_g1 + 1; } }
            i = i + 1;
        }
        let total_at_risk = at_risk_g1 + at_risk_g2;
        if (total_at_risk > 0) { exp_g1 = exp_g1 + deaths_total * at_risk_g1 * 1.0 / total_at_risk; }
        obs_g1 = obs_g1 + deaths_g1;
        let j = 0;
        while (j < n) {
            if (sorted[j]["time"] == t) {
                if (sorted[j]["group"] == 0) { at_risk_g1 = at_risk_g1 - 1; }
                else { at_risk_g2 = at_risk_g2 - 1; }
            }
            j = j + 1;
        }
    }
    let stat = (obs_g1 - exp_g1) * (obs_g1 - exp_g1) / (exp_g1 + 0.000000001);
    return stat;
}

fn hml_survival_weibull_fit(times, events) {
    let n = len(times);
    let log_times = [];
    let i = 0;
    while (i < n) {
        if (times[i] > 0) { push(log_times, math_log(times[i])); }
        i = i + 1;
    }
    let mean_log = hml_mean(log_times);
    let scale = math_exp(mean_log);
    let shape = 1.0;
    if (len(log_times) > 1) {
        let var_log = 0.0;
        i = 0;
        while (i < len(log_times)) {
            let d = log_times[i] - mean_log;
            var_log = var_log + d * d;
            i = i + 1;
        }
        var_log = var_log * 1.0 / (len(log_times) - 1);
        shape = 1.0 / (math_sqrt(var_log) * 1.283 + 0.000000001);
    }
    return {"scale": scale, "shape": shape};
}

fn hml_survival_weibull_survival(model, time) {
    let scale = model["scale"];
    let shape = model["shape"];
    if (time <= 0) { return 1.0; }
    return math_exp(-math_pow(time * 1.0 / scale, shape));
}

fn hml_hazard_ratio(coeff) {
    return math_exp(coeff);
}
