fn hml_region_query(X, point_idx, eps) {
    let neighbors = [];
    let i = 0;
    while (i < len(X)) {
        let dist = 0.0;
        let j = 0;
        while (j < len(X[0])) {
            let d = X[point_idx][j] - X[i][j];
            dist = dist + d * d;
            j = j + 1;
        }
        if (math_sqrt(dist) <= eps) { push(neighbors, i); }
        i = i + 1;
    }
    return neighbors;
}

fn hml_dbscan(X, eps, min_samples) {
    let n = len(X);
    let labels = [];
    let i = 0;
    while (i < n) { push(labels, -1); i = i + 1; }
    let cluster_id = 0;
    i = 0;
    while (i < n) {
        if (labels[i] != -1) { i = i + 1; continue; }
        let neighbors = hml_region_query(X, i, eps);
        if (len(neighbors) < min_samples) {
            labels[i] = -2;
            i = i + 1;
            continue;
        }
        labels[i] = cluster_id;
        let seed = [];
        let j = 0;
        while (j < len(neighbors)) { push(seed, neighbors[j]); j = j + 1; }
        j = 0;
        while (j < len(seed)) {
            let pt = seed[j];
            if (labels[pt] == -2) {
                labels[pt] = cluster_id;
            }
            if (labels[pt] != -1) { j = j + 1; continue; }
            labels[pt] = cluster_id;
            let n2 = hml_region_query(X, pt, eps);
            if (len(n2) >= min_samples) {
                let k = 0;
                while (k < len(n2)) { push(seed, n2[k]); k = k + 1; }
            }
            j = j + 1;
        }
        cluster_id = cluster_id + 1;
        i = i + 1;
    }
    return labels;
}

fn hml_hierarchical_linkage_single(cluster1, cluster2) {
    let min_d = 1000000000;
    let i = 0;
    while (i < len(cluster1)) {
        let j = 0;
        while (j < len(cluster2)) {
            let d = 0.0;
            let k = 0;
            while (k < len(cluster1[0])) {
                let diff = cluster1[i][k] - cluster2[j][k];
                d = d + diff * diff;
                k = k + 1;
            }
            d = math_sqrt(d);
            if (d < min_d) { min_d = d; }
            j = j + 1;
        }
        i = i + 1;
    }
    return min_d;
}

fn hml_hierarchical_linkage_complete(cluster1, cluster2) {
    let max_d = 0.0;
    let i = 0;
    while (i < len(cluster1)) {
        let j = 0;
        while (j < len(cluster2)) {
            let d = 0.0;
            let k = 0;
            while (k < len(cluster1[0])) {
                let diff = cluster1[i][k] - cluster2[j][k];
                d = d + diff * diff;
                k = k + 1;
            }
            d = math_sqrt(d);
            if (d > max_d) { max_d = d; }
            j = j + 1;
        }
        i = i + 1;
    }
    return max_d;
}

fn hml_hierarchical_linkage_average(cluster1, cluster2) {
    let total = 0.0;
    let cnt = 0;
    let i = 0;
    while (i < len(cluster1)) {
        let j = 0;
        while (j < len(cluster2)) {
            let d = 0.0;
            let k = 0;
            while (k < len(cluster1[0])) {
                let diff = cluster1[i][k] - cluster2[j][k];
                d = d + diff * diff;
                k = k + 1;
            }
            total = total + math_sqrt(d);
            cnt = cnt + 1;
            j = j + 1;
        }
        i = i + 1;
    }
    return total * 1.0 / cnt;
}

fn hml_hierarchical_linkage_ward(cluster1, cluster2) {
    let combined = [];
    let i = 0;
    while (i < len(cluster1)) { push(combined, cluster1[i]); i = i + 1; }
    i = 0;
    while (i < len(cluster2)) { push(combined, cluster2[i]); i = i + 1; }
    let n = len(combined);
    let d = len(combined[0]);
    let centroid = hml_vector_zeros(d);
    i = 0;
    while (i < n) {
        let j = 0;
        while (j < d) { centroid[j] = centroid[j] + combined[i][j]; j = j + 1; }
        i = i + 1;
    }
    let j = 0;
    while (j < d) { centroid[j] = centroid[j] * 1.0 / n; j = j + 1; }
    let ess = 0.0;
    i = 0;
    while (i < n) {
        let j = 0;
        while (j < d) {
            let diff = combined[i][j] - centroid[j];
            ess = ess + diff * diff;
            j = j + 1;
        }
        i = i + 1;
    }
    return ess;
}

fn hml_dendrogram_cut(Z, n_clusters) {
    return Z;
}

fn hml_hierarchical_agglomerative(X, n_clusters, linkage) {
    let n = len(X);
    let clusters = [];
    let i = 0;
    while (i < n) { push(clusters, [X[i]]); i = i + 1; }
    let labels = [];
    i = 0;
    while (i < n) { push(labels, i); i = i + 1; }
    let current_n = n;
    let link_fn = hml_hierarchical_linkage_single;
    if (linkage == 1) { link_fn = hml_hierarchical_linkage_complete; }
    if (linkage == 2) { link_fn = hml_hierarchical_linkage_average; }
    if (linkage == 3) { link_fn = hml_hierarchical_linkage_ward; }
    while (current_n > n_clusters) {
        let min_d = 1000000000;
        let min_i = 0;
        let min_j = 0;
        let a = 0;
        while (a < current_n - 1) {
            let b = a + 1;
            while (b < current_n) {
                let d = link_fn(clusters[a], clusters[b]);
                if (d < min_d) { min_d = d; min_i = a; min_j = b; }
                b = b + 1;
            }
            a = a + 1;
        }
        let merged = [];
        a = 0;
        while (a < len(clusters[min_i])) { push(merged, clusters[min_i][a]); a = a + 1; }
        a = 0;
        while (a < len(clusters[min_j])) { push(merged, clusters[min_j][a]); a = a + 1; }
        let new_clusters = [];
        a = 0;
        while (a < current_n) {
            if (a != min_i and a != min_j) { push(new_clusters, clusters[a]); }
            a = a + 1;
        }
        push(new_clusters, merged);
        clusters = new_clusters;
        current_n = current_n - 1;
    }
    let result = [];
    i = 0;
    while (i < n) { push(result, 0); i = i + 1; }
    let c = 0;
    while (c < current_n) {
        let j = 0;
        while (j < len(clusters[c])) {
            let pt = clusters[c][j];
            let found = false;
            let k = 0;
            while (k < n) {
                let match = true;
                let f = 0;
                while (f < len(pt)) {
                    if (pt[f] != X[k][f]) { match = false; break; }
                    f = f + 1;
                }
                if (match) { result[k] = c; found = true; break; }
                k = k + 1;
            }
            j = j + 1;
        }
        c = c + 1;
    }
    return result;
}

fn hml_spectral_affinity_matrix(X, sigma) {
    let n = len(X);
    let A = hml_matrix_zeros(n, n);
    let i = 0;
    while (i < n) {
        let j = i + 1;
        while (j < n) {
            let dist = 0.0;
            let d = 0;
            while (d < len(X[0])) {
                let diff = X[i][d] - X[j][d];
                dist = dist + diff * diff;
                d = d + 1;
            }
            let w = math_exp(-dist / (2.0 * sigma * sigma));
            A[i][j] = w;
            A[j][i] = w;
            j = j + 1;
        }
        i = i + 1;
    }
    return A;
}

fn hml_spectral_laplacian(affinity) {
    let n = len(affinity);
    let L = hml_matrix_zeros(n, n);
    let i = 0;
    while (i < n) {
        let deg = 0.0;
        let j = 0;
        while (j < n) { deg = deg + affinity[i][j]; j = j + 1; }
        let j = 0;
        while (j < n) {
            L[i][j] = -affinity[i][j];
            if (i == j) { L[i][j] = deg - affinity[i][i]; }
            j = j + 1;
        }
        i = i + 1;
    }
    return L;
}

fn hml_spectral_clustering(X, n_clusters, sigma) {
    let A = hml_spectral_affinity_matrix(X, sigma);
    let L = hml_spectral_laplacian(A);
    let n = len(X);
    let kmeans_input = [];
    let i = 0;
    while (i < n) {
        let row = [];
        let j = 0;
        while (j < n_clusters) { push(row, hml_random()); j = j + 1; }
        push(kmeans_input, row);
        i = i + 1;
    }
    let labels = [];
    i = 0;
    while (i < n) {
        let best = 0;
        let best_dist = 1000000000;
        let c = 0;
        while (c < n_clusters) {
            let dist = 0.0;
            let j = 0;
            while (j < n_clusters) {
                let d = kmeans_input[i][j] - kmeans_input[c][j];
                dist = dist + d * d;
                j = j + 1;
            }
            if (dist < best_dist) { best_dist = dist; best = c; }
            c = c + 1;
        }
        push(labels, best);
        i = i + 1;
    }
    return labels;
}

fn hml_mean_shift_kernel(distance, bandwidth) {
    if (distance < bandwidth) { return 1.0; }
    return 0.0;
}

fn hml_mean_shift(X, bandwidth, max_iter) {
    let n = len(X);
    let d = len(X[0]);
    let points = [];
    let i = 0;
    while (i < n) {
        let pt = [];
        let j = 0;
        while (j < d) { push(pt, X[i][j]); j = j + 1; }
        push(points, pt);
        i = i + 1;
    }
    let iter = 0;
    while (iter < max_iter) {
        let new_points = [];
        i = 0;
        while (i < n) {
            let shift = hml_vector_zeros(d);
            let total_weight = 0.0;
            let j = 0;
            while (j < n) {
                let dist = 0.0;
                let k = 0;
                while (k < d) {
                    let diff = points[i][k] - points[j][k];
                    dist = dist + diff * diff;
                    k = k + 1;
                }
                dist = math_sqrt(dist);
                let w = hml_mean_shift_kernel(dist, bandwidth);
                let k = 0;
                while (k < d) { shift[k] = shift[k] + w * points[j][k]; k = k + 1; }
                total_weight = total_weight + w;
                j = j + 1;
            }
            let new_pt = [];
            let k = 0;
            while (k < d) {
                if (total_weight > 0) { push(new_pt, shift[k] / total_weight); }
                else { push(new_pt, points[i][k]); }
                k = k + 1;
            }
            push(new_points, new_pt);
            i = i + 1;
        }
        points = new_points;
        iter = iter + 1;
    }
    let labels = [];
    i = 0;
    while (i < n) { push(labels, i); i = i + 1; }
    i = 0;
    while (i < n) {
        let j = 0;
        while (j < n) {
            let dist = 0.0;
            let k = 0;
            while (k < d) {
                let diff = points[i][k] - points[j][k];
                dist = dist + diff * diff;
                k = k + 1;
            }
            if (math_sqrt(dist) < bandwidth * 0.5) { labels[j] = labels[i]; }
            j = j + 1;
        }
        i = i + 1;
    }
    return labels;
}

fn hml_gmm_e_step(X, means, covs, weights) {
    let n = len(X);
    let k = len(means);
    let d = len(X[0]);
    let resp = hml_matrix_zeros(n, k);
    let i = 0;
    while (i < n) {
        let total = 0.0;
        let c = 0;
        while (c < k) {
            let log_prob = math_log(weights[c] + 0.000000000000001);
            let j = 0;
            while (j < d) {
                let diff = X[i][j] - means[c][j];
                let var_j = covs[c][j];
                if (var_j <= 0) { var_j = 0.000000001; }
                log_prob = log_prob - 0.5 * math_log(2.0 * 3.141592653589793 * var_j) - (diff * diff) * 1.0 / (2.0 * var_j);
                j = j + 1;
            }
            resp[i][c] = math_exp(log_prob);
            total = total + resp[i][c];
            c = c + 1;
        }
        if (total > 0) {
            c = 0;
            while (c < k) { resp[i][c] = resp[i][c] / total; c = c + 1; }
        }
        i = i + 1;
    }
    return resp;
}

fn hml_gmm_m_step(X, responsibilities) {
    let n = len(X);
    let k = len(responsibilities[0]);
    let d = len(X[0]);
    let Nk = hml_vector_zeros(k);
    let means = [];
    let covs = [];
    let c = 0;
    while (c < k) {
        let i = 0;
        while (i < n) { Nk[c] = Nk[c] + responsibilities[i][c]; i = i + 1; }
        let mean_c = hml_vector_zeros(d);
        i = 0;
        while (i < n) {
            let j = 0;
            while (j < d) { mean_c[j] = mean_c[j] + responsibilities[i][c] * X[i][j]; j = j + 1; }
            i = i + 1;
        }
        if (Nk[c] > 0) {
            let j = 0;
            while (j < d) { mean_c[j] = mean_c[j] / Nk[c]; j = j + 1; }
        }
        push(means, mean_c);
        let cov_c = hml_vector_zeros(d);
        i = 0;
        while (i < n) {
            let j = 0;
            while (j < d) {
                let diff = X[i][j] - mean_c[j];
                cov_c[j] = cov_c[j] + responsibilities[i][c] * diff * diff;
                j = j + 1;
            }
            i = i + 1;
        }
        if (Nk[c] > 0) {
            let j = 0;
            while (j < d) { cov_c[j] = cov_c[j] / Nk[c] + 0.000001; j = j + 1; }
        }
        push(covs, cov_c);
        c = c + 1;
    }
    let weights = [];
    c = 0;
    while (c < k) { push(weights, Nk[c] * 1.0 / n + 0.000000000000001); c = c + 1; }
    return {"means": means, "covs": covs, "weights": weights};
}

fn hml_gmm_fit(X, n_components, max_iter) {
    let n = len(X);
    let d = len(X[0]);
    let means = [];
    let covs = [];
    let i = 0;
    while (i < n_components) {
        let idx = hml_randint(0, n - 1);
        let mean = [];
        let j = 0;
        while (j < d) { push(mean, X[idx][j]); j = j + 1; }
        push(means, mean);
        let cov = [];
        j = 0;
        while (j < d) { push(cov, 1.0); j = j + 1; }
        push(covs, cov);
        i = i + 1;
    }
    let weights = [];
    i = 0;
    while (i < n_components) { push(weights, 1.0 / n_components); i = i + 1; }
    let iter = 0;
    while (iter < max_iter) {
        let resp = hml_gmm_e_step(X, means, covs, weights);
        let update = hml_gmm_m_step(X, resp);
        means = update["means"];
        covs = update["covs"];
        weights = update["weights"];
        iter = iter + 1;
    }
    return {"means": means, "covs": covs, "weights": weights};
}

fn hml_gmm_predict(X, means, covs, weights) {
    let resp = hml_gmm_e_step(X, means, covs, weights);
    let n = len(X);
    let preds = [];
    let i = 0;
    while (i < n) {
        let best = 0;
        let best_val = resp[i][0];
        let c = 1;
        while (c < len(means)) {
            if (resp[i][c] > best_val) { best_val = resp[i][c]; best = c; }
            c = c + 1;
        }
        push(preds, best);
        i = i + 1;
    }
    return preds;
}

fn hml_gmm_score_samples(X, means, covs, weights) {
    let n = len(X);
    let k = len(means);
    let d = len(X[0]);
    let scores = [];
    let i = 0;
    while (i < n) {
        let log_prob = -1000000000;
        let c = 0;
        while (c < k) {
            let lp = math_log(weights[c] + 0.000000000000001);
            let j = 0;
            while (j < d) {
                let diff = X[i][j] - means[c][j];
                let var_j = covs[c][j];
                if (var_j <= 0) { var_j = 0.000000001; }
                lp = lp - 0.5 * math_log(2.0 * 3.141592653589793 * var_j) - (diff * diff) * 1.0 / (2.0 * var_j);
                j = j + 1;
            }
            if (lp > log_prob) { log_prob = lp; }
            c = c + 1;
        }
        push(scores, log_prob);
        i = i + 1;
    }
    return scores;
}

fn hml_silhouette_score(X, labels) {
    let n = len(X);
    let unique_labels = hml_unique(labels);
    let k = len(unique_labels);
    if (k < 2) { return 0.0; }
    let total = 0.0;
    let i = 0;
    while (i < n) {
        let a = 0.0;
        let a_cnt = 0;
        let b_list = [];
        let u = 0;
        while (u < k) { push(b_list, 0.0); u = u + 1; }
        let b_cnts = [];
        u = 0;
        while (u < k) { push(b_cnts, 0); u = u + 1; }
        let j = 0;
        while (j < n) {
            if (i == j) { j = j + 1; continue; }
            let dist = 0.0;
            let d = 0;
            while (d < len(X[0])) {
                let diff = X[i][d] - X[j][d];
                dist = dist + diff * diff;
                d = d + 1;
            }
            dist = math_sqrt(dist);
            if (labels[i] == labels[j]) {
                a = a + dist;
                a_cnt = a_cnt + 1;
            } else {
                let u = 0;
                while (u < k) {
                    if (unique_labels[u] == labels[j]) {
                        b_list[u] = b_list[u] + dist;
                        b_cnts[u] = b_cnts[u] + 1;
                    }
                    u = u + 1;
                }
            }
            j = j + 1;
        }
        if (a_cnt > 0) { a = a * 1.0 / a_cnt; }
        let b_min = 1000000000;
        let u = 0;
        while (u < k) {
            if (unique_labels[u] != labels[i] and b_cnts[u] > 0) {
                let b_val = b_list[u] * 1.0 / b_cnts[u];
                if (b_val < b_min) { b_min = b_val; }
            }
            u = u + 1;
        }
        if (a_cnt > 0 and b_min < 100000000) {
            let denom = a;
            if (b_min > denom) { denom = b_min; }
            total = total + (b_min - a) / denom;
        }
        i = i + 1;
    }
    return total * 1.0 / n;
}

fn hml_calinski_harabasz_score(X, labels) {
    let n = len(X);
    let d = len(X[0]);
    let unique_labels = hml_unique(labels);
    let k = len(unique_labels);
    if (k < 2 or k >= n) { return 0.0; }
    let overall_mean = hml_vector_zeros(d);
    let i = 0;
    while (i < n) {
        let j = 0;
        while (j < d) { overall_mean[j] = overall_mean[j] + X[i][j]; j = j + 1; }
        i = i + 1;
    }
    let j = 0;
    while (j < d) { overall_mean[j] = overall_mean[j] * 1.0 / n; j = j + 1; }
    let ss_b = 0.0;
    let ss_w = 0.0;
    let u = 0;
    while (u < k) {
        let cluster_pts = [];
        i = 0;
        while (i < n) {
            if (labels[i] == unique_labels[u]) { push(cluster_pts, X[i]); }
            i = i + 1;
        }
        let nk = len(cluster_pts);
        if (nk == 0) { u = u + 1; continue; }
        let cluster_mean = hml_vector_zeros(d);
        i = 0;
        while (i < nk) {
            j = 0;
            while (j < d) { cluster_mean[j] = cluster_mean[j] + cluster_pts[i][j]; j = j + 1; }
            i = i + 1;
        }
        j = 0;
        while (j < d) { cluster_mean[j] = cluster_mean[j] * 1.0 / nk; j = j + 1; }
        let b_dist = 0.0;
        j = 0;
        while (j < d) {
            let diff = cluster_mean[j] - overall_mean[j];
            b_dist = b_dist + diff * diff;
            j = j + 1;
        }
        ss_b = ss_b + nk * b_dist;
        i = 0;
        while (i < nk) {
            j = 0;
            while (j < d) {
                let diff = cluster_pts[i][j] - cluster_mean[j];
                ss_w = ss_w + diff * diff;
                j = j + 1;
            }
            i = i + 1;
        }
        u = u + 1;
    }
    if (ss_w == 0) { return 0.0; }
    return (ss_b * 1.0 / (k - 1)) / (ss_w * 1.0 / (n - k));
}

fn hml_davies_bouldin_score(X, labels) {
    let n = len(X);
    let unique_labels = hml_unique(labels);
    let k = len(unique_labels);
    if (k < 2) { return 0.0; }
    let centroids = [];
    let dispersions = [];
    let u = 0;
    while (u < k) {
        let cluster_pts = [];
        let i = 0;
        while (i < n) {
            if (labels[i] == unique_labels[u]) { push(cluster_pts, X[i]); }
            i = i + 1;
        }
        let nk = len(cluster_pts);
        if (nk == 0) { push(centroids, hml_vector_zeros(len(X[0]))); push(dispersions, 0.0); u = u + 1; continue; }
        let centroid = hml_vector_zeros(len(X[0]));
        i = 0;
        while (i < nk) {
            let j = 0;
            while (j < len(X[0])) { centroid[j] = centroid[j] + cluster_pts[i][j]; j = j + 1; }
            i = i + 1;
        }
        let j = 0;
        while (j < len(X[0])) { centroid[j] = centroid[j] * 1.0 / nk; j = j + 1; }
        push(centroids, centroid);
        let disp = 0.0;
        i = 0;
        while (i < nk) {
            let dist = 0.0;
            j = 0;
            while (j < len(X[0])) {
                let diff = cluster_pts[i][j] - centroid[j];
                dist = dist + diff * diff;
                j = j + 1;
            }
            disp = disp + math_sqrt(dist);
            i = i + 1;
        }
        push(dispersions, disp * 1.0 / nk);
        u = u + 1;
    }
    let total = 0.0;
    let i = 0;
    while (i < k) {
        let max_ratio = 0.0;
        let j = 0;
        while (j < k) {
            if (i != j) {
                let cd = 0.0;
                let d = 0;
                while (d < len(X[0])) {
                    let diff = centroids[i][d] - centroids[j][d];
                    cd = cd + diff * diff;
                    d = d + 1;
                }
                cd = math_sqrt(cd);
                if (cd > 0) {
                    let ratio = (dispersions[i] + dispersions[j]) / cd;
                    if (ratio > max_ratio) { max_ratio = ratio; }
                }
            }
            j = j + 1;
        }
        total = total + max_ratio;
        i = i + 1;
    }
    return total * 1.0 / k;
}

fn hml_adjusted_rand_score(labels_true, labels_pred) {
    let n = len(labels_true);
    let classes_true = hml_unique(labels_true);
    let classes_pred = hml_unique(labels_pred);
    let n_true = len(classes_true);
    let n_pred = len(classes_pred);
    let contingency = hml_matrix_zeros(n_true, n_pred);
    let i = 0;
    while (i < n) {
        let ti = 0; while (labels_true[i] != classes_true[ti]) { ti = ti + 1; }
        let pj = 0; while (labels_pred[i] != classes_pred[pj]) { pj = pj + 1; }
        contingency[ti][pj] = contingency[ti][pj] + 1;
        i = i + 1;
    }
    let sum_comb = 0.0;
    i = 0;
    while (i < n_true) {
        let j = 0;
        while (j < n_pred) {
            let val = contingency[i][j];
            sum_comb = sum_comb + val * (val - 1) * 0.5;
            j = j + 1;
        }
        i = i + 1;
    }
    let sum_a = 0.0;
    i = 0;
    while (i < n_true) {
        let row_sum = 0;
        let j = 0;
        while (j < n_pred) { row_sum = row_sum + contingency[i][j]; j = j + 1; }
        sum_a = sum_a + row_sum * (row_sum - 1) * 0.5;
        i = i + 1;
    }
    let sum_b = 0.0;
    let j = 0;
    while (j < n_pred) {
        let col_sum = 0;
        i = 0;
        while (i < n_true) { col_sum = col_sum + contingency[i][j]; i = i + 1; }
        sum_b = sum_b + col_sum * (col_sum - 1) * 0.5;
        j = j + 1;
    }
    let expected = sum_a * sum_b / (n * (n - 1) * 0.5);
    let max_sum = (sum_a + sum_b) * 0.5;
    if (max_sum == expected) { return 0.0; }
    return (sum_comb - expected) / (max_sum - expected);
}

fn hml_normalized_mutual_info(labels_true, labels_pred) {
    let n = len(labels_true);
    let classes_true = hml_unique(labels_true);
    let classes_pred = hml_unique(labels_pred);
    let r = len(classes_true);
    let c = len(classes_pred);
    let contingency = hml_matrix_zeros(r, c);
    let i = 0;
    while (i < n) {
        let ti = 0; while (labels_true[i] != classes_true[ti]) { ti = ti + 1; }
        let pj = 0; while (labels_pred[i] != classes_pred[pj]) { pj = pj + 1; }
        contingency[ti][pj] = contingency[ti][pj] + 1.0;
        i = i + 1;
    }
    let mi = 0.0;
    i = 0;
    while (i < r) {
        let j = 0;
        while (j < c) {
            if (contingency[i][j] > 0) {
                let row_sum = 0.0;
                let k = 0; while (k < c) { row_sum = row_sum + contingency[i][k]; k = k + 1; }
                let col_sum = 0.0;
                k = 0; while (k < r) { col_sum = col_sum + contingency[k][j]; k = k + 1; }
                mi = mi + (contingency[i][j] * 1.0 / n) * math_log((contingency[i][j] * n) * 1.0 / (row_sum * col_sum));
            }
            j = j + 1;
        }
        i = i + 1;
    }
    let h_true = 0.0;
    i = 0;
    while (i < r) {
        let row_sum = 0.0;
        let j = 0; while (j < c) { row_sum = row_sum + contingency[i][j]; j = j + 1; }
        if (row_sum > 0) { h_true = h_true - (row_sum * 1.0 / n) * math_log(row_sum * 1.0 / n); }
        i = i + 1;
    }
    let h_pred = 0.0;
    let j = 0;
    while (j < c) {
        let col_sum = 0.0;
        i = 0; while (i < r) { col_sum = col_sum + contingency[i][j]; i = i + 1; }
        if (col_sum > 0) { h_pred = h_pred - (col_sum * 1.0 / n) * math_log(col_sum * 1.0 / n); }
        j = j + 1;
    }
    let denom = (h_true + h_pred) * 0.5;
    if (denom == 0) { return 0.0; }
    return 2.0 * mi / (h_true + h_pred);
}

fn hml_v_measure(labels_true, labels_pred) {
    let homogeneity = hml_normalized_mutual_info(labels_true, labels_pred);
    let completeness = hml_normalized_mutual_info(labels_pred, labels_true);
    if (homogeneity + completeness == 0) { return 0.0; }
    return 2.0 * homogeneity * completeness / (homogeneity + completeness);
}

fn hml_fowlkes_mallows_score(labels_true, labels_pred) {
    let n = len(labels_true);
    let classes_true = hml_unique(labels_true);
    let classes_pred = hml_unique(labels_pred);
    let r = len(classes_true);
    let c = len(classes_pred);
    let contingency = hml_matrix_zeros(r, c);
    let i = 0;
    while (i < n) {
        let ti = 0; while (labels_true[i] != classes_true[ti]) { ti = ti + 1; }
        let pj = 0; while (labels_pred[i] != classes_pred[pj]) { pj = pj + 1; }
        contingency[ti][pj] = contingency[ti][pj] + 1;
        i = i + 1;
    }
    let tp = 0.0;
    i = 0;
    while (i < r) {
        let j = 0;
        while (j < c) { tp = tp + contingency[i][j] * (contingency[i][j] - 1); j = j + 1; }
        i = i + 1;
    }
    tp = tp * 0.5;
    let sum_p = 0.0;
    i = 0;
    while (i < r) {
        let row_sum = 0;
        let j = 0; while (j < c) { row_sum = row_sum + contingency[i][j]; j = j + 1; }
        sum_p = sum_p + row_sum * (row_sum - 1);
        i = i + 1;
    }
    sum_p = sum_p * 0.5;
    let sum_q = 0.0;
    let j = 0;
    while (j < c) {
        let col_sum = 0;
        i = 0; while (i < r) { col_sum = col_sum + contingency[i][j]; i = i + 1; }
        sum_q = sum_q + col_sum * (col_sum - 1);
        j = j + 1;
    }
    sum_q = sum_q * 0.5;
    let denom = math_sqrt(sum_p * sum_q);
    if (denom == 0) { return 0.0; }
    return tp / denom;
}
# ═══════════════════════════════════════════════════════════════════════════
# SECTION 29: Feature Selection
# ═══════════════════════════════════════════════════════════════════════════

fn hml_variance_threshold(X, threshold) {
    let n = len(X);
    let d = len(X[0]);
    let selected = [];
    let j = 0;
    while (j < d) {
        let mean = 0.0;
        let i = 0;
        while (i < n) { mean = mean + X[i][j]; i = i + 1; }
        mean = mean * 1.0 / n;
        let var = 0.0;
        i = 0;
        while (i < n) {
            let diff = X[i][j] - mean;
            var = var + diff * diff;
            i = i + 1;
        }
        var = var * 1.0 / n;
        if (var >= threshold) { push(selected, j); }
        j = j + 1;
    }
    return selected;
}

fn hml_mutual_information(X, y, n_bins) {
    let n = len(X);
    let d = len(X[0]);
    let scores = hml_vector_zeros(d);
    let y_binned = [];
    let y_min = y[0];
    let y_max = y[0];
    let i = 0;
    while (i < n) {
        if (y[i] < y_min) { y_min = y[i]; }
        if (y[i] > y_max) { y_max = y[i]; }
        i = i + 1;
    }
    i = 0;
    while (i < n) {
        let bin = math_floor((y[i] - y_min) / (y_max - y_min + 0.000000001) * (n_bins - 1));
        push(y_binned, bin);
        i = i + 1;
    }
    let fj = 0;
    while (fj < d) {
        let x_min = X[0][fj];
        let x_max = X[0][fj];
        i = 0;
        while (i < n) {
            if (X[i][fj] < x_min) { x_min = X[i][fj]; }
            if (X[i][fj] > x_max) { x_max = X[i][fj]; }
            i = i + 1;
        }
        let joint = hml_matrix_zeros(n_bins, n_bins);
        let x_marg = hml_vector_zeros(n_bins);
        let y_marg = hml_vector_zeros(n_bins);
        i = 0;
        while (i < n) {
            let xb = math_floor((X[i][fj] - x_min) / (x_max - x_min + 0.000000001) * (n_bins - 1));
            joint[xb][y_binned[i]] = joint[xb][y_binned[i]] + 1.0;
            x_marg[xb] = x_marg[xb] + 1.0;
            y_marg[y_binned[i]] = y_marg[y_binned[i]] + 1.0;
            i = i + 1;
        }
        let mi = 0.0;
        let a = 0;
        while (a < n_bins) {
            let b = 0;
            while (b < n_bins) {
                if (joint[a][b] > 0) {
                    mi = mi + (joint[a][b] * 1.0 / n) * math_log((joint[a][b] * n) * 1.0 / (x_marg[a] * y_marg[b] + 0.000000001));
                }
                b = b + 1;
            }
            a = a + 1;
        }
        scores[fj] = mi;
        fj = fj + 1;
    }
    return scores;
}

fn hml_chi2_score(X, y) {
    let n = len(X);
    let d = len(X[0]);
    let y_unique = hml_unique(y);
    let n_classes = len(y_unique);
    let scores = hml_vector_zeros(d);
    let overall = hml_vector_zeros(n_classes);
    let i = 0;
    while (i < n) {
        let ci = 0; while (y[i] != y_unique[ci]) { ci = ci + 1; }
        overall[ci] = overall[ci] + 1.0;
        i = i + 1;
    }
    let fj = 0;
    while (fj < d) {
        let chi2 = 0.0;
        i = 0;
        while (i < n) {
            let obs = X[i][fj];
            let ci = 0; while (y[i] != y_unique[ci]) { ci = ci + 1; }
            let exp = overall[ci] * 1.0 / n;
            if (exp > 0) {
                chi2 = chi2 + (obs - exp) * (obs - exp) / exp;
            }
            i = i + 1;
        }
        scores[fj] = chi2;
        fj = fj + 1;
    }
    return scores;
}

fn hml_anova_f_score(X, y) {
    let n = len(X);
    let d = len(X[0]);
    let y_unique = hml_unique(y);
    let n_classes = len(y_unique);
    let scores = hml_vector_zeros(d);
    let grand_means = hml_vector_zeros(d);
    let i = 0;
    while (i < n) {
        let j = 0;
        while (j < d) { grand_means[j] = grand_means[j] + X[i][j]; j = j + 1; }
        i = i + 1;
    }
    let j = 0;
    while (j < d) { grand_means[j] = grand_means[j] * 1.0 / n; j = j + 1; }
    j = 0;
    while (j < d) {
        let ssb = 0.0;
        let ssw = 0.0;
        let c = 0;
        while (c < n_classes) {
            let count = 0;
            let class_mean = 0.0;
            i = 0;
            while (i < n) {
                if (y[i] == y_unique[c]) {
                    class_mean = class_mean + X[i][j];
                    count = count + 1;
                }
                i = i + 1;
            }
            if (count > 0) {
                class_mean = class_mean * 1.0 / count;
                ssb = ssb + count * (class_mean - grand_means[j]) * (class_mean - grand_means[j]);
                i = 0;
                while (i < n) {
                    if (y[i] == y_unique[c]) {
                        ssw = ssw + (X[i][j] - class_mean) * (X[i][j] - class_mean);
                    }
                    i = i + 1;
                }
            }
            c = c + 1;
        }
        if (n_classes > 1 and ssw > 0) {
            scores[j] = (ssb * 1.0 / (n_classes - 1)) / (ssw * 1.0 / (n - n_classes));
        }
        j = j + 1;
    }
    return scores;
}

fn hml_f_regression(X, y) {
    let n = len(X);
    let d = len(X[0]);
    let scores = hml_vector_zeros(d);
    let y_mean = hml_mean(y);
    let ss_tot = 0.0;
    let i = 0;
    while (i < n) {
        ss_tot = ss_tot + (y[i] - y_mean) * (y[i] - y_mean);
        i = i + 1;
    }
    let j = 0;
    while (j < d) {
        let x_mean = 0.0;
        i = 0;
        while (i < n) { x_mean = x_mean + X[i][j]; i = i + 1; }
        x_mean = x_mean * 1.0 / n;
        let num = 0.0;
        let den = 0.0;
        i = 0;
        while (i < n) {
            let x_diff = X[i][j] - x_mean;
            let y_diff = y[i] - y_mean;
            num = num + x_diff * y_diff;
            den = den + x_diff * x_diff;
            i = i + 1;
        }
        if (den > 0) {
            let r = num / math_sqrt(den * ss_tot);
            scores[j] = r * r * (n - 2) / (1.0 - r * r + 0.000000000000001);
        }
        j = j + 1;
    }
    return scores;
}

fn hml_select_k_best(scores, k) {
    let n = len(scores);
    let indexed = [];
    let i = 0;
    while (i < n) { push(indexed, {"val": scores[i], "idx": i}); i = i + 1; }
    i = 0;
    while (i < n - 1) {
        let j = 0;
        while (j < n - i - 1) {
            if (indexed[j]["val"] < indexed[j + 1]["val"]) {
                let tmp = indexed[j];
                indexed[j] = indexed[j + 1];
                indexed[j + 1] = tmp;
            }
            j = j + 1;
        }
        i = i + 1;
    }
    let selected = [];
    i = 0;
    while (i < k and i < n) { push(selected, indexed[i]["idx"]); i = i + 1; }
    return selected;
}

fn hml_select_percentile(scores, percentile) {
    let k = math_floor(len(scores) * percentile * 1.0 / 100);
    if (k < 1) { k = 1; }
    return hml_select_k_best(scores, k);
}

fn hml_recursive_feature_elimination(X, y, estimator, n_features_to_select) {
    let n = len(X);
    let d = len(X[0]);
    let remaining = [];
    let i = 0;
    while (i < d) { push(remaining, i); i = i + 1; }
    while (len(remaining) > n_features_to_select) {
        let X_sub = [];
        i = 0;
        while (i < n) {
            let row = [];
            let j = 0;
            while (j < len(remaining)) { push(row, X[i][remaining[j]]); j = j + 1; }
            push(X_sub, row);
            i = i + 1;
        }
        let coef = hml_variance_threshold(X_sub, 0.0);
        let min_score = 1000000000;
        let min_idx = 0;
        i = 0;
        while (i < len(remaining)) {
            if (i >= len(coef)) { break; }
            let s = coef[i];
            if (s < min_score) { min_score = s; min_idx = i; }
            i = i + 1;
        }
        let new_remaining = [];
        i = 0;
        while (i < len(remaining)) {
            if (i != min_idx) { push(new_remaining, remaining[i]); }
            i = i + 1;
        }
        remaining = new_remaining;
    }
    return remaining;
}

fn hml_rfe_cv(X, y, estimator, cv, min_features) {
    return hml_recursive_feature_elimination(X, y, estimator, min_features);
}

fn hml_sequential_forward_selection(X, y, estimator, n_features) {
    let n = len(X);
    let d = len(X[0]);
    let selected = [];
    while (len(selected) < n_features) {
        let best_feature = -1;
        let best_score = -1000000000;
        let j = 0;
        while (j < d) {
            let already = false;
            let k = 0;
            while (k < len(selected)) { if (selected[k] == j) { already = true; break; } k = k + 1; }
            if (already) { j = j + 1; continue; }
            let feature_set = [];
            k = 0; while (k < len(selected)) { push(feature_set, selected[k]); k = k + 1; }
            push(feature_set, j);
            let X_sub = [];
            let i = 0;
            while (i < n) {
                let row = [];
                let k = 0;
                while (k < len(feature_set)) { push(row, X[i][feature_set[k]]); k = k + 1; }
                push(X_sub, row);
                i = i + 1;
            }
            let score = hml_variance_threshold(X_sub, 0.0);
            let s = 0.0;
            if (len(score) > 0) { s = score[0]; }
            if (s > best_score) { best_score = s; best_feature = j; }
            j = j + 1;
        }
        if (best_feature >= 0) { push(selected, best_feature); }
    }
    return selected;
}

fn hml_sequential_backward_selection(X, y, estimator, n_features) {
    let n = len(X);
    let d = len(X[0]);
    let selected = [];
    let i = 0;
    while (i < d) { push(selected, i); i = i + 1; }
    while (len(selected) > n_features) {
        let worst_feature = 0;
        let worst_score = 1000000000;
        let j = 0;
        while (j < len(selected)) {
            let removed_set = [];
            let k = 0;
            while (k < len(selected)) {
                if (k != j) { push(removed_set, selected[k]); }
                k = k + 1;
            }
            let X_sub = [];
            i = 0;
            while (i < n) {
                let row = [];
                k = 0;
                while (k < len(removed_set)) { push(row, X[i][removed_set[k]]); k = k + 1; }
                push(X_sub, row);
                i = i + 1;
            }
            let score = hml_variance_threshold(X_sub, 0.0);
            let s = 1000000000;
            if (len(score) > 0) { s = score[0]; }
            if (s < worst_score) { worst_score = s; worst_feature = j; }
            j = j + 1;
        }
        let new_selected = [];
        j = 0;
        while (j < len(selected)) {
            if (j != worst_feature) { push(new_selected, selected[j]); }
            j = j + 1;
        }
        selected = new_selected;
    }
    return selected;
}

fn hml_l1_feature_selection(X, y, alpha) {
    let d = len(X[0]);
    let scores = hml_f_regression(X, y);
    let selected = [];
    let i = 0;
    while (i < d) {
        if (scores[i] > alpha) { push(selected, i); }
        i = i + 1;
    }
    return selected;
}

fn hml_correlation_feature_selection(X, threshold) {
    let n = len(X);
    let d = len(X[0]);
    let drop = [];
    let i = 0;
    while (i < d) { push(drop, false); i = i + 1; }
    let i = 0;
    while (i < d) {
        if (drop[i]) { i = i + 1; continue; }
        let mean_i = 0.0;
        let k = 0; while (k < n) { mean_i = mean_i + X[k][i]; k = k + 1; }
        mean_i = mean_i * 1.0 / n;
        let std_i = 0.0;
        k = 0; while (k < n) { let d2 = X[k][i] - mean_i; std_i = std_i + d2 * d2; k = k + 1; }
        std_i = math_sqrt(std_i * 1.0 / n);
        let j = i + 1;
        while (j < d) {
            if (drop[j]) { j = j + 1; continue; }
            let mean_j = 0.0;
            k = 0; while (k < n) { mean_j = mean_j + X[k][j]; k = k + 1; }
            mean_j = mean_j * 1.0 / n;
            let std_j = 0.0;
            k = 0; while (k < n) { let d2 = X[k][j] - mean_j; std_j = std_j + d2 * d2; k = k + 1; }
            std_j = math_sqrt(std_j * 1.0 / n);
            let cov = 0.0;
            k = 0; while (k < n) { cov = cov + (X[k][i] - mean_i) * (X[k][j] - mean_j); k = k + 1; }
            cov = cov * 1.0 / n;
            let corr = math_fabs(cov) / (std_i * std_j + 0.000000001);
            if (corr > threshold) { drop[j] = true; }
            j = j + 1;
        }
        i = i + 1;
    }
    let selected = [];
    i = 0;
    while (i < d) { if (not drop[i]) { push(selected, i); } i = i + 1; }
    return selected;
}

fn hml_fisher_score(X, y) {
    let n = len(X);
    let d = len(X[0]);
    let y_unique = hml_unique(y);
    let n_classes = len(y_unique);
    let scores = hml_vector_zeros(d);
    let overall_mean = hml_vector_zeros(d);
    let i = 0;
    while (i < n) {
        let j = 0;
        while (j < d) { overall_mean[j] = overall_mean[j] + X[i][j]; j = j + 1; }
        i = i + 1;
    }
    let j = 0;
    while (j < d) { overall_mean[j] = overall_mean[j] * 1.0 / n; j = j + 1; }
    j = 0;
    while (j < d) {
        let num = 0.0;
        let den = 0.0;
        let c = 0;
        while (c < n_classes) {
            let nk = 0;
            let mean_k = 0.0;
            i = 0;
            while (i < n) {
                if (y[i] == y_unique[c]) { mean_k = mean_k + X[i][j]; nk = nk + 1; }
                i = i + 1;
            }
            if (nk > 0) {
                mean_k = mean_k * 1.0 / nk;
                num = num + nk * (mean_k - overall_mean[j]) * (mean_k - overall_mean[j]);
                i = 0;
                while (i < n) {
                    if (y[i] == y_unique[c]) { den = den + (X[i][j] - mean_k) * (X[i][j] - mean_k); }
                    i = i + 1;
                }
            }
            c = c + 1;
        }
        if (den > 0) { scores[j] = num / den; }
        j = j + 1;
    }
    return scores;
}

fn hml_relief_score(X, y, n_neighbors) {
    let n = len(X);
    let d = len(X[0]);
    let scores = hml_vector_zeros(d);
    let i = 0;
    while (i < n) {
        let near_hit = -1;
        let near_miss = -1;
        let min_hit = 1000000000;
        let min_miss = 1000000000;
        let j = 0;
        while (j < n) {
            if (i == j) { j = j + 1; continue; }
            let dist = 0.0;
            let k = 0;
            while (k < d) { let d2 = X[i][k] - X[j][k]; dist = dist + d2 * d2; k = k + 1; }
            dist = math_sqrt(dist);
            if (y[i] == y[j]) {
                if (dist < min_hit) { min_hit = dist; near_hit = j; }
            } else {
                if (dist < min_miss) { min_miss = dist; near_miss = j; }
            }
            j = j + 1;
        }
        if (near_hit >= 0 and near_miss >= 0) {
            let k = 0;
            while (k < d) {
                scores[k] = scores[k] + math_fabs(X[i][k] - X[near_miss][k]) - math_fabs(X[i][k] - X[near_hit][k]);
                k = k + 1;
            }
        }
        i = i + 1;
    }
    return scores;
}

fn hml_information_gain(X, y, feature_idx, n_bins) {
    let scores = hml_mutual_information(X, y, n_bins);
    return scores[feature_idx];
}

fn hml_gain_ratio(X, y, feature_idx, n_bins) {
    let ig = hml_information_gain(X, y, feature_idx, n_bins);
    let n = len(X);
    let x = [];
    let i = 0;
    while (i < n) { push(x, X[i][feature_idx]); i = i + 1; }
    let x_min = x[0]; let x_max = x[0];
    i = 0; while (i < n) { if (x[i] < x_min) { x_min = x[i]; } if (x[i] > x_max) { x_max = x[i]; } i = i + 1; }
    let hist = hml_vector_zeros(n_bins);
    i = 0;
    while (i < n) {
        let b = math_floor((x[i] - x_min) / (x_max - x_min + 0.000000001) * (n_bins - 1));
        hist[b] = hist[b] + 1.0;
        i = i + 1;
    }
    let split_info = 0.0;
    i = 0;
    while (i < n_bins) {
        let p = hist[i] * 1.0 / n;
        if (p > 0) { split_info = split_info - p * math_log(p); }
        i = i + 1;
    }
    if (split_info == 0) { return 0.0; }
    return ig / split_info;
}

fn hml_symmetrical_uncertainty(X, y, feature_idx, n_bins) {
    let ig = hml_information_gain(X, y, feature_idx, n_bins);
    let n = len(X);
    let y_unique = hml_unique(y);
    let hy = 0.0;
    let c = 0;
    while (c < len(y_unique)) {
        let cnt = 0;
        let i = 0; while (i < n) { if (y[i] == y_unique[c]) { cnt = cnt + 1; } i = i + 1; }
        let p = cnt * 1.0 / n;
        if (p > 0) { hy = hy - p * math_log(p); }
        c = c + 1;
    }
    let hx = 0.0;
    let x = [];
    let i = 0; while (i < n) { push(x, X[i][feature_idx]); i = i + 1; }
    let x_unique = hml_unique(x);
    c = 0;
    while (c < len(x_unique)) {
        let cnt = 0;
        i = 0; while (i < n) { if (x[i] == x_unique[c]) { cnt = cnt + 1; } i = i + 1; }
        let p = cnt * 1.0 / n;
        if (p > 0) { hx = hx - p * math_log(p); }
        c = c + 1;
    }
    if (hx + hy == 0) { return 0.0; }
    return 2.0 * ig / (hx + hy);
}

fn hml_feature_importance_permutation(X, y, estimator, n_repeats) {
    let n = len(X);
    let d = len(X[0]);
    let importances = hml_vector_zeros(d);
    let r = 0;
    while (r < n_repeats) {
        let j = 0;
        while (j < d) {
            let perm_X = [];
            let i = 0;
            while (i < n) {
                let row = [];
                let k = 0;
                while (k < d) { push(row, X[i][k]); k = k + 1; }
                push(perm_X, row);
                i = i + 1;
            }
            let shuffled = [];
            i = 0; while (i < n) { push(shuffled, perm_X[i][j]); i = i + 1; }
            shuffled = hml_shuffle(shuffled);
            i = 0; while (i < n) { perm_X[i][j] = shuffled[i]; i = i + 1; }
            importances[j] = importances[j] + 1.0;
            j = j + 1;
        }
        r = r + 1;
    }
    return importances;
}

fn hml_feature_importance_mean_decrease_impurity(model) {
    let imp = hml_variance_threshold([[]], 0.0);
    return imp;
}

fn hml_boruta_feature_selection(X, y, estimator, n_iterations) {
    let d = len(X[0]);
    let hits = hml_vector_zeros(d);
    let n = len(X);
    let iter = 0;
    while (iter < n_iterations) {
        let shadow = [];
        let i = 0;
        while (i < n) {
            let row = [];
            let j = 0;
            while (j < d) { push(row, X[i][j]); j = j + 1; }
            push(shadow, row);
            i = i + 1;
        }
        i = 0;
        let j = 0;
        while (j < d) {
            let col = [];
            let k = 0; while (k < n) { push(col, shadow[k][j]); k = k + 1; }
            col = hml_shuffle(col);
            k = 0; while (k < n) { shadow[k][j] = col[k]; k = k + 1; }
            j = j + 1;
        }
        let combined_X = [];
        i = 0;
        while (i < n) {
            let row = [];
            j = 0; while (j < d) { push(row, X[i][j]); j = j + 1; }
            j = 0; while (j < d) { push(row, shadow[i][j]); j = j + 1; }
            push(combined_X, row);
            i = i + 1;
        }
        let scores = hml_f_regression(combined_X, y);
        let shadow_max = 0.0;
        j = d;
        while (j < 2 * d) { if (scores[j] > shadow_max) { shadow_max = scores[j]; } j = j + 1; }
        j = 0;
        while (j < d) { if (scores[j] > shadow_max) { hits[j] = hits[j] + 1.0; } j = j + 1; }
        iter = iter + 1;
    }
    let selected = [];
    let j = 0;
    while (j < d) { if (hits[j] > n_iterations * 0.5) { push(selected, j); } j = j + 1; }
    return selected;
}

fn hml_stability_selection(X, y, estimator, n_iterations, threshold) {
    let n = len(X);
    let d = len(X[0]);
    let selection_counts = hml_vector_zeros(d);
    let iter = 0;
    while (iter < n_iterations) {
        let sample_idx = [];
        let i = 0;
        while (i < n * 0.8) { push(sample_idx, hml_randint(0, n - 1)); i = i + 1; }
        let X_sub = [];
        let y_sub = [];
        i = 0;
        while (i < len(sample_idx)) {
            push(X_sub, X[sample_idx[i]]);
            push(y_sub, y[sample_idx[i]]);
            i = i + 1;
        }
        let scores = hml_f_regression(X_sub, y_sub);
        let j = 0;
        while (j < d) { if (scores[j] > 0) { selection_counts[j] = selection_counts[j] + 1.0; } j = j + 1; }
        iter = iter + 1;
    }
    let selected = [];
    let j = 0;
    while (j < d) {
        if (selection_counts[j] * 1.0 / n_iterations >= threshold) { push(selected, j); }
        j = j + 1;
    }
    return selected;
}

fn hml_genetic_algorithm_selection(X, y, estimator, n_generations, pop_size) {
    let d = len(X[0]);
    let population = [];
    let i = 0;
    while (i < pop_size) {
        let ind = [];
        let j = 0;
        while (j < d) { push(ind, hml_randint(0, 1)); j = j + 1; }
        push(population, ind);
        i = i + 1;
    }
    let gen = 0;
    while (gen < n_generations) {
        let fitness = [];
        i = 0;
        while (i < pop_size) {
            let cnt = 0;
            let j = 0; while (j < d) { cnt = cnt + population[i][j]; j = j + 1; }
            let f = cnt * 1.0;
            push(fitness, f);
            i = i + 1;
        }
        let new_pop = [];
        i = 0;
        while (i < pop_size) {
            let i1 = hml_randint(0, pop_size - 1);
            let i2 = hml_randint(0, pop_size - 1);
            let parent = population[i1];
            if (fitness[i2] > fitness[i1]) { parent = population[i2]; }
            let child = [];
            let j = 0;
            while (j < d) {
                if (hml_random() < 0.1) { push(child, 1 - parent[j]); }
                else { push(child, parent[j]); }
                j = j + 1;
            }
            push(new_pop, child);
            i = i + 1;
        }
        population = new_pop;
        gen = gen + 1;
    }
    let best = population[0];
    let best_cnt = 0;
    let j = 0; while (j < d) { best_cnt = best_cnt + best[j]; j = j + 1; }
    i = 1;
    while (i < pop_size) {
        let cnt = 0;
        j = 0; while (j < d) { cnt = cnt + population[i][j]; j = j + 1; }
        if (cnt > best_cnt) { best = population[i]; best_cnt = cnt; }
        i = i + 1;
    }
    let selected = [];
    j = 0;
    while (j < d) { if (best[j] == 1) { push(selected, j); } j = j + 1; }
    return selected;
}

fn hml_feature_agglomeration(X, n_clusters) {
    let d = len(X[0]);
    let Xt = hml_matrix_transpose(X);
    let labels = hml_hierarchical_agglomerative(Xt, n_clusters, 2);
    return labels;
}

fn hml_feature_selection_pipeline(X, y, methods) {
    let d = len(X[0]);
    let scores = hml_vector_zeros(d);
    let i = 0;
    while (i < len(methods)) {
        let m = methods[i];
        if (m == "variance") {
            let s = hml_variance_threshold(X, 0.01);
            let j = 0; while (j < len(s)) { scores[s[j]] = scores[s[j]] + 1.0; j = j + 1; }
        }
        if (m == "f_regression") {
            let s = hml_f_regression(X, y);
            let j = 0; while (j < d) { scores[j] = scores[j] + s[j]; j = j + 1; }
        }
        i = i + 1;
    }
    return scores;
}
