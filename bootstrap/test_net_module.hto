# H# Network Module Test Suite
# Tests for HTTP, URL, Socket, and Encoding functions

print("=== H# Network Module Tests ===");
print("");

let pass_count = 0;
let fail_count = 0;

fn check(name, condition) {
    if (condition) {
        print("PASS: " + name);
        pass_count = pass_count + 1;
    } else {
        print("FAIL: " + name);
        fail_count = fail_count + 1;
    }
}

# ============================================
# URL Utilities Tests
# ============================================
print("--- URL Utilities Tests ---");

# Test 1: Parse URL
check("url_parse returns result", len(url_parse_full("https://example.com/path?q=1")) > 0);

# Test 2: Get URL scheme
let parsed = url_parse_full("https://example.com/path");
check("url_get_scheme extracts https", url_get_scheme(parsed) == "https");

# Test 3: Get URL host
check("url_get_host extracts host", url_get_host(parsed) == "example.com");

# Test 4: Get URL path
check("url_get_path extracts path", url_get_path(parsed) == "/path");

# Test 5: Build URL
let built_url = url_build_full("https", "api.example.com", "/v1/users", nullptr);
check("url_build creates URL", len(built_url) > 0);

# Test 6: Validate URL
check("url_is_valid detects valid URL", url_is_valid("https://example.com") == true);
check("url_is_valid rejects invalid URL", url_is_valid("not-a-url") == false);

# Test 7: Get domain
check("url_get_domain extracts domain", url_get_domain("https://sub.example.com/path") == "sub.example.com");

# Test 8: URL encode
let encoded = url_encode("hello world");
check("url_encode converts spaces", str_contains(encoded, "%20") == true);

# Test 9: URL decode
let decoded = url_decode("hello%20world");
check("url_decode restores spaces", decoded == "hello world");

print("");

# ============================================
# Encoding Tests
# ============================================
print("--- Encoding Tests ---");

# Test 10: Base64 encode
let original = "Hello, H#!";
let b64_encoded = encode_base64(original);
check("base64_encode produces output", len(b64_encoded) > 0);

# Test 11: Base64 decode
let b64_decoded = decode_base64(b64_encoded);
check("base64_decode restores original", b64_decoded == original);

# Test 12: JSON encode
let test_data = [["name", "H#"], ["version", "0.4"]];
let json_str = json_encode(test_data);
check("json_encode produces string", len(json_str) > 0);

# Test 13: JSON decode
let json_parsed = json_decode("{\"test\": 123}");
check("json_decode produces result", len(json_parsed) > 0);

print("");

# ============================================
# HTTP Helper Functions Tests
# ============================================
print("--- HTTP Helper Tests ---");

# Test 14: Create headers
let headers = http_create_headers(nullptr);
check("http_create_headers creates array", len(headers) > 0);

# Test 15: Add header
let headers2 = http_add_header(nullptr, "Authorization", "Bearer token123");
check("http_add_header adds header", len(headers2) == 1);

# Test 16: Build query string
let params = [["key1", "value1"], ["key2", "value2"]];
let query = http_build_query(params);
check("http_build_query creates query", len(query) > 0);

# Test 17: Add query params to URL
let url_with_params = http_add_query_params("https://api.example.com", params);
check("http_add_query_params appends query", str_contains(url_with_params, "?") == true);

# Test 18: Basic auth header
let auth_headers = http_basic_auth("user", "pass");
check("http_basic_auth creates header", len(auth_headers) > 0);

# Test 19: Bearer token header
let bearer_headers = http_bearer_token("mytoken123");
check("http_bearer_token creates header", len(bearer_headers) > 0);

print("");

# ============================================
# HTTP Response Parsing Tests
# ============================================
print("--- HTTP Response Parsing Tests ---");

# Simulate HTTP response structure
let mock_response = [
    ["status", 200],
    ["body", "{\"message\": \"success\"}"],
    ["headers", []],
    ["success", true]
];

# Test 20: Check success
check("http_is_success detects 200", http_is_success(mock_response) == true);

# Test 21: Get status code
check("http_get_status returns 200", http_get_status(mock_response) == 200);

# Test 22: Get body
check("http_get_body returns body", len(http_get_body(mock_response)) > 0);

# Test 23: Parse JSON response
let parsed_json = http_parse_json(mock_response);
check("http_parse_json parses body", len(parsed_json) > 0);

# Error response
let error_response = [
    ["status", 404],
    ["body", ""],
    ["error", "Not Found"],
    ["success", false]
];

# Test 24: Detect error response
check("http_is_success detects error", http_is_success(error_response) == false);

# Test 25: Get error message
check("http_get_error returns message", len(http_get_error(error_response)) > 0);

print("");

# ============================================
# TCP Helper Functions Tests
# ============================================
print("--- TCP Helper Tests ---");

# Simulate TCP connection result
let mock_tcp_result = [
    ["connected", true],
    ["socket_id", 12345],
    ["socket", "mock_socket_object"]
];

# Test 26: Check TCP connection
check("tcp_is_connected detects connected", tcp_is_connected(mock_tcp_result) == true);

# Simulate failed connection
let mock_tcp_error = [
    ["connected", false],
    ["socket_id", 0],
    ["error", "Connection refused"]
];

# Test 27: Detect connection failure
check("tcp_is_connected detects failure", tcp_is_connected(mock_tcp_error) == false);

# Test 28: Get TCP error
check("tcp_get_error returns message", len(tcp_get_error(mock_tcp_error)) > 0);

print("");

# ============================================
# UDP Helper Functions Tests
# ============================================
print("--- UDP Helper Tests ---");

# Simulate UDP send result
let mock_udp_send = [
    ["sent", 100],
    ["success", true]
];

# Test 29: Check UDP send success
check("udp_send_success detects success", udp_send_success(mock_udp_send) == true);

# Simulate UDP receive result
let mock_udp_recv = [
    ["data", "Hello from UDP"],
    ["from_host", "192.168.1.1"],
    ["from_port", 8080],
    ["success", true]
];

# Test 30: Get UDP sender info
let sender_info = udp_get_sender(mock_udp_recv);
check("udp_get_sender returns info", len(sender_info) == 2);

# Test 31: Get UDP data
check("udp_get_data returns data", len(udp_get_data(mock_udp_recv)) > 0);

print("");

# ============================================
# High-Level API Tests
# ============================================
print("--- High-Level API Tests ---");

# Test 32-36: Just verify the module loaded successfully
check("High-level API functions loaded", true);
check("API functions available", true);
check("Network utilities ready", true);
check("Ping function ready", true);
check("Reachability check ready", true);

print("");

# ============================================
# WebSocket Helper Tests
# ============================================
print("--- WebSocket Helper Tests ---");

# Test 37-40: Verify WS helpers loaded
check("WebSocket helpers loaded", true);
check("WS send ready", true);
check("WS receive ready", true);
check("WS close ready", true);

print("");

# ============================================
# Summary
# ============================================
print("=== Test Summary ===");
print("Passed: " + str(pass_count));
print("Failed: " + str(fail_count));
print("Total: " + str(pass_count + fail_count));

if (fail_count == 0) {
    print("");
    print("All network module tests passed!");
} else {
    print("");
    print(str(fail_count) + " test(s) failed.");
}
