# Section 12: Resources — 2 test functions
# ═══════════════════════════════════════════════════════════════════════════

fn test_cpp_resource_bundle() {
    let bundle = new CppResourceBundle();
    bundle.init_bundle();
    assert(bundle.getLocale() == "", "CppResourceBundle.getLocale default empty");
    assert(bundle.getBaseName() == "", "CppResourceBundle.getBaseName default empty");
    assert(bundle.getFallbackLocale() == "", "CppResourceBundle.getFallbackLocale default");
    assert(bundle.getResourceCount() == 0, "CppResourceBundle.getResourceCount default 0");

    bundle.setLocale("zh_CN");
    assert(bundle.getLocale() == "zh_CN", "CppResourceBundle.setLocale");

    bundle.setBaseName("messages");
    assert(bundle.getBaseName() == "messages", "CppResourceBundle.setBaseName");

    bundle.addResource("hello", "你好");
    bundle.addResource("count", 42);
    bundle.addResource("enabled", true);

    assert(bundle.getString("hello") == "你好", "CppResourceBundle.getString");
    assert(bundle.getInteger("count") == 42, "CppResourceBundle.getInteger");
    assert(bundle.getBoolean("enabled") == true, "CppResourceBundle.getBoolean");

    # Default/fallback: getString returns key when missing
    assert(bundle.getString("missing") == "missing", "CppResourceBundle.getString missing→key");
    assert(bundle.getInteger("missing") == 0, "CppResourceBundle.getInteger missing→0");
    assert(bundle.getBoolean("missing") == false, "CppResourceBundle.getBoolean missing→false");

    assert(bundle.hasResource("hello") == true, "CppResourceBundle.hasResource true");
    assert(bundle.hasResource("missing") == false, "CppResourceBundle.hasResource false");

    assert(bundle.getResourceCount() == 3, "CppResourceBundle.getResourceCount");

    bundle.removeResource("count");
    assert(bundle.hasResource("count") == false, "CppResourceBundle.removeResource");
    assert(bundle.getResourceCount() == 2, "CppResourceBundle.getResourceCount after remove");

    bundle.setFallbackLocale("en_US");
    assert(bundle.getFallbackLocale() == "en_US", "CppResourceBundle.setFallbackLocale");

    bundle.clear();
    assert(bundle.getResourceCount() == 0, "CppResourceBundle.clear");

    bundle.dispose();
    return 0;
}

fn test_cpp_file_watcher() {
    let watcher = new CppFileWatcher();
    watcher.init_watcher("/project/src", "*.cpp");
    assert(watcher.getPath() == "/project/src", "CppFileWatcher.getPath");
    assert(watcher.getFilter() == "*.cpp", "CppFileWatcher.getFilter");
    assert(watcher.isWatching() == false, "CppFileWatcher.isWatching default false");
    assert(watcher.getIncludeSubdirs() == true, "CppFileWatcher.getIncludeSubdirs default true");
    assert(watcher.getInterval() == 1000, "CppFileWatcher.getInterval default 1000");

    watcher.start();
    assert(watcher.isWatching() == true, "CppFileWatcher.start");

    watcher.stop();
    assert(watcher.isWatching() == false, "CppFileWatcher.stop");

    watcher.setIncludeSubdirs(false);
    assert(watcher.getIncludeSubdirs() == false, "CppFileWatcher.setIncludeSubdirs");

    let cb_called = false;
    watcher.setCallback(fn(filepath) { cb_called = true; return 0; });
    let cb = watcher.getCallback();
    assert(cb != nullptr, "CppFileWatcher.setCallback/getCallback");

    watcher.setInterval(2000);
    assert(watcher.getInterval() == 2000, "CppFileWatcher.setInterval");

    watcher.dispose();
    assert(watcher.isWatching() == false, "CppFileWatcher.dispose stops watching");
    return 0;
}

