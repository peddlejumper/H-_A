import "bootstrap/hwdui_cpp.hto";

let _test_count = 0;
let _pass_count = 0;

fn assert(condition, msg) {
    _test_count = _test_count + 1;
    if (condition) {
        _pass_count = _pass_count + 1;
        print("  PASS: " + msg);
    } else {
        print("  FAIL: " + msg);
    }
    return 0;
}

