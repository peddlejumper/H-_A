fn test_cpp_cmake_target() {
    let t = new CppCMakeTarget();
    t.init_target("QtCore", "shared_library");
    assert(t.getName() == "QtCore", "CppCMakeTarget.getName");
    assert(t.getType() == "shared_library", "CppCMakeTarget.getType");
    assert(t.getVersion() == "1.0.0", "CppCMakeTarget.getVersion default");
    assert(t.getScope() == "compile", "CppCMakeTarget.getScope default");

    t.setVersion("6.5.0");
    assert(t.getVersion() == "6.5.0", "CppCMakeTarget.setVersion");

    t.addSource("main.cpp");
    t.addSource("core.cpp");
    assert(len(t.getSources()) == 2, "CppCMakeTarget.addSource/getSources");

    t.addHeader("core.h");
    t.addHeader("types.h");
    assert(len(t.getHeaders()) == 2, "CppCMakeTarget.addHeader/getHeaders");

    t.addDependency("QtWidgets");
    t.addDependency("QtNetwork");
    assert(len(t.getDependencies()) == 2, "CppCMakeTarget.addDependency/getDependencies");

    t.addLinkLib("pthread");
    t.addLinkLib("dl");
    assert(len(t.getLinkLibs()) == 2, "CppCMakeTarget.addLinkLib/getLinkLibs");

    t.addCompileDef("NDEBUG");
    t.addCompileDef("QT_CORE_LIB");
    assert(len(t.getCompileDefs()) == 2, "CppCMakeTarget.addCompileDef/getCompileDefs");

    t.addCompileOpt("-O2");
    t.addCompileOpt("-Wall");
    assert(len(t.getCompileOpts()) == 2, "CppCMakeTarget.addCompileOpt/getCompileOpts");

    assert(t.isInstalled() == false, "CppCMakeTarget.isInstalled default");
    t.setInstalled(true);
    assert(t.isInstalled() == true, "CppCMakeTarget.setInstalled");

    t.setScope("runtime");
    assert(t.getScope() == "runtime", "CppCMakeTarget.setScope");

    assert(t.getId() == "QtCore:6.5.0", "CppCMakeTarget.getId");

    t.dispose();
    return 0;
}

fn test_cpp_cmake_manager() {
    let cm = new CppCMakeManager();
    cm.init_cmake();
    assert(cm.getLocalRepo() == "", "CppCMakeManager.getLocalRepo default");
    assert(cm.getTargetCount() == 0, "CppCMakeManager.getTargetCount default");

    cm.addRepository("https://repo.example.com");
    cm.addRepository("https://cdn.repo.example.com");
    let repos = cm.getRepositories();
    assert(len(repos) == 2, "CppCMakeManager.addRepository/getRepositories");

    let t1 = new CppCMakeTarget();
    t1.init_target("MyLib", "library");
    t1.setVersion("2.0.0");
    cm.install(t1);
    assert(t1.isInstalled() == true, "CppCMakeManager.install marks installed");
    assert(cm.getTargetCount() == 1, "CppCMakeManager.getTargetCount");

    let found = cm.getTarget("MyLib");
    assert(found != nullptr, "CppCMakeManager.getTarget");
    assert(found.getVersion() == "2.0.0", "CppCMakeManager.getTarget version");

    let installed = cm.getInstalledTargets();
    assert(len(installed) == 1, "CppCMakeManager.getInstalledTargets");

    cm.setLocalRepo("/home/user/.cmake");
    assert(cm.getLocalRepo() == "/home/user/.cmake", "CppCMakeManager.setLocalRepo");

    let pkg = cm.findPackage("MyLib");
    assert(pkg != nullptr, "CppCMakeManager.findPackage");

    let resolved = cm.resolve("MyLib");
    assert(resolved != nullptr, "CppCMakeManager.resolve");

    cm.uninstall("MyLib");
    assert(cm.getTargetCount() == 0, "CppCMakeManager.uninstall");

    cm.dispose();
    return 0;
}

fn test_cpp_project() {
    let proj = new CppProject();
    proj.init_project("MyApp", "application");
    assert(proj.getName() == "MyApp", "CppProject.getName");
    assert(proj.getProjectType() == "application", "CppProject.getProjectType");
    assert(proj.getBuildSystem() == "cmake", "CppProject.getBuildSystem default");
    assert(proj.getGroupId() == "com.example", "CppProject.getGroupId default");
    assert(proj.getArtifactId() == "MyApp", "CppProject.getArtifactId default");
    assert(proj.getVersion() == "1.0.0", "CppProject.getVersion default");
    assert(proj.getMainClass() == "", "CppProject.getMainClass default");
    assert(proj.getCppVersion() == "c++17", "CppProject.getCppVersion default");
    assert(proj.getOutputDir() == "", "CppProject.getOutputDir default");

    proj.setBuildSystem("meson");
    assert(proj.getBuildSystem() == "meson", "CppProject.setBuildSystem");

    proj.setGroupId("com.mycompany");
    assert(proj.getGroupId() == "com.mycompany", "CppProject.setGroupId");

    proj.setArtifactId("myapp-core");
    assert(proj.getArtifactId() == "myapp-core", "CppProject.setArtifactId");

    proj.setVersion("2.1.0");
    assert(proj.getVersion() == "2.1.0", "CppProject.setVersion");

    proj.setMainClass("com.mycompany.Main");
    assert(proj.getMainClass() == "com.mycompany.Main", "CppProject.setMainClass");

    proj.setCppVersion("c++20");
    assert(proj.getCppVersion() == "c++20", "CppProject.setCppVersion");

    proj.addDependency({"name": "QtCore", "version": "6.5"});
    proj.addDependency({"name": "boost", "version": "1.80"});
    let deps = proj.getDependencies();
    assert(len(deps) == 2, "CppProject.addDependency/getDependencies");

    proj.addPlugin("cpp-linter");
    proj.addPlugin("code-formatter");
    let plugins = proj.getPlugins();
    assert(len(plugins) == 2, "CppProject.addPlugin/getPlugins");

    proj.addSourceDir("src/");
    proj.addSourceDir("include/");
    let dirs = proj.getSourceDirs();
    assert(len(dirs) == 2, "CppProject.addSourceDir/getSourceDirs");

    proj.setOutputDir("build/");
    assert(proj.getOutputDir() == "build/", "CppProject.setOutputDir");

    let target = new CppCMakeTarget();
    target.init_target("MyApp", "executable");
    proj.addTarget(target);
    let targets = proj.getTargets();
    assert(len(targets) == 1, "CppProject.addTarget/getTargets");

    proj.dispose();
    return 0;
}

fn test_cpp_module() {
    let mod = new CppModule();
    mod.init_module("backend");
    assert(mod.getName() == "backend", "CppModule.getName");
    assert(mod.getProjectCount() == 0, "CppModule.getProjectCount default 0");
    assert(mod.getBuildConfig() == "debug", "CppModule.getBuildConfig default debug");
    assert(mod.getModuleType() == "library", "CppModule.getModuleType default library");

    let proj1 = new CppProject();
    proj1.init_project("api", "library");
    let proj2 = new CppProject();
    proj2.init_project("core", "library");

    mod.addProject(proj1);
    mod.addProject(proj2);
    assert(mod.getProjectCount() == 2, "CppModule.addProject");

    let found = mod.getProject("api");
    assert(found != nullptr, "CppModule.getProject existing");
    assert(found.getName() == "api", "CppModule.getProject name match");

    let missing = mod.getProject("nonexistent");
    assert(missing == nullptr, "CppModule.getProject missing");

    mod.setBuildConfig("release");
    assert(mod.getBuildConfig() == "release", "CppModule.setBuildConfig");

    mod.removeProject("api");
    assert(mod.getProjectCount() == 1, "CppModule.removeProject");

    let projs = mod.getProjects();
    assert(len(projs) == 1, "CppModule.getProjects");

    mod.setModuleType("executable");
    assert(mod.getModuleType() == "executable", "CppModule.setModuleType");

    mod.dispose();
    assert(mod.getProjectCount() == 0, "CppModule.dispose");
    return 0;
}

