# Section 5: Data Binding — 4 test functions
# ═══════════════════════════════════════════════════════════════════════════

fn test_cpp_binding() {
    let src = {"value": 42};
    let tgt = {"display": 0};
    let b = new CppBinding();
    b.init_binding(src, "value", tgt, "display");

    assert(b.getSource() == src, "CppBinding.getSource");
    assert(b.getSourcePath() == "value", "CppBinding.getSourcePath");
    assert(b.getTarget() == tgt, "CppBinding.getTarget");
    assert(b.getTargetPath() == "display", "CppBinding.getTargetPath");
    assert(b.getMode() == "twoWay", "CppBinding.getMode default twoWay");
    assert(b.isActive() == true, "CppBinding.isActive default true");

    b.setMode("oneWay");
    assert(b.getMode() == "oneWay", "CppBinding.setMode");

    b.updateTarget();
    assert(tgt["display"] == 42, "CppBinding.updateTarget");

    b.updateSource();

    let conv_called = false;
    b.setConverter(fn(val, param) { conv_called = true; return val; return 0; });
    assert(b.getConverter() != nullptr, "CppBinding.setConverter/getConverter");

    b.setConverterParam({"key": "val"});
    b.setFallbackValue(-1);
    assert(b.getFallbackValue() == -1, "CppBinding.setFallbackValue/getFallbackValue");

    b.setActive(false);
    assert(b.isActive() == false, "CppBinding.setActive");

    let notifier_val = nullptr;
    b.setPropertyNotifier(fn(prop) { notifier_val = prop; return 0; });
    assert(b.getPropertyNotifier() != nullptr, "CppBinding.setPropertyNotifier/getPropertyNotifier");

    b.dispose();
    assert(b.getSource() == nullptr, "CppBinding.dispose");
    assert(b.isActive() == false, "CppBinding.dispose inactive");
    return 0;
}

fn test_cpp_multi_binding() {
    let tgt = {"result": 0};
    let src1 = {"a": 10};
    let src2 = {"b": 20};
    let b1 = new CppBinding();
    b1.init_binding(src1, "a", tgt, "result");
    let b2 = new CppBinding();
    b2.init_binding(src2, "b", tgt, "result");

    let mb = new CppMultiBinding();
    mb.init_multi(tgt, "result");
    assert(mb.getTarget() == tgt, "CppMultiBinding.getTarget");
    assert(mb.getTargetPath() == "result", "CppMultiBinding.getTargetPath");
    assert(mb.getBindingCount() == 0, "CppMultiBinding.getBindingCount default 0");
    assert(mb.getConverter() == nullptr, "CppMultiBinding.getConverter default null");

    mb.addBinding(b1);
    mb.addBinding(b2);
    assert(mb.getBindingCount() == 2, "CppMultiBinding.addBinding");
    let bindings = mb.getBindings();
    assert(len(bindings) == 2, "CppMultiBinding.getBindings");

    mb.setConverter(fn(vals) { return len(vals); return 0; });
    assert(mb.getConverter() != nullptr, "CppMultiBinding.setConverter");

    mb.updateTarget();
    let vals = mb.getValues();
    assert(len(vals) == 2, "CppMultiBinding.updateTarget/getValues");

    mb.removeBinding(b1);
    assert(mb.getBindingCount() == 1, "CppMultiBinding.removeBinding");

    mb.dispose();
    assert(mb.getBindingCount() == 0, "CppMultiBinding.dispose");
    return 0;
}

fn test_cpp_binding_manager() {
    let mgr = new CppBindingManager();
    mgr.init_binding_mgr();
    assert(mgr.getBindingCount() == 0, "CppBindingManager.getBindingCount default");
    assert(mgr.isDeferred() == false, "CppBindingManager.isDeferred default");

    let src = {"val": 1};
    let tgt = {"display": 0};
    let b = new CppBinding();
    b.init_binding(src, "val", tgt, "display");

    mgr.addBinding(b);
    assert(mgr.getBindingCount() == 1, "CppBindingManager.addBinding");

    mgr.updateAll();
    assert(tgt["display"] == 1, "CppBindingManager.updateAll");

    let for_src = mgr.getBindingsForSource(src);
    assert(len(for_src) == 1, "CppBindingManager.getBindingsForSource");

    let for_tgt = mgr.getBindingsForTarget(tgt);
    assert(len(for_tgt) == 1, "CppBindingManager.getBindingsForTarget");

    mgr.deferUpdates();
    assert(mgr.isDeferred() == true, "CppBindingManager.deferUpdates");
    let old_val = tgt["display"];
    src["val"] = 99;
    mgr.updateAll(); # should not execute due to deferred
    assert(tgt["display"] == old_val, "CppBindingManager.updateAll deferred");

    mgr.flushDeferred();
    assert(mgr.isDeferred() == false, "CppBindingManager.flushDeferred");
    mgr.updateAll();
    assert(tgt["display"] == 99, "CppBindingManager.flushDeferred then updateAll");

    mgr.removeBinding(b);
    assert(mgr.getBindingCount() == 0, "CppBindingManager.removeBinding");

    mgr.clear();
    mgr.dispose();
    assert(mgr.getBindingCount() == 0, "CppBindingManager.dispose");
    return 0;
}

fn test_cpp_binding_expression() {
    let src = {"count": 5};
    let tgt = {"label": ""};
    let b = new CppBinding();
    b.init_binding(src, "count", tgt, "label");

    let expr = new CppBindingExpression();
    expr.init_expr(b, tgt, "label");
    assert(expr.getBinding() == b, "CppBindingExpression.getBinding");
    assert(expr.getTarget() == tgt, "CppBindingExpression.getTarget");
    assert(expr.getTargetProperty() == "label", "CppBindingExpression.getTargetProperty");
    assert(expr.isDirty() == false, "CppBindingExpression.isDirty default");
    assert(expr.getExpression() == "", "CppBindingExpression.getExpression default");
    assert(expr.getLastValue() == nullptr, "CppBindingExpression.getLastValue default");

    expr.setExpression("count * 2");
    assert(expr.getExpression() == "count * 2", "CppBindingExpression.setExpression");

    expr.markDirty();
    assert(expr.isDirty() == true, "CppBindingExpression.markDirty");

    expr.refresh();
    assert(expr.isDirty() == false, "CppBindingExpression.refresh");

    expr.dispose();
    assert(expr.getBinding() == nullptr, "CppBindingExpression.dispose");
    return 0;
}

