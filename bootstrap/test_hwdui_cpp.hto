# Section 3: Event Bridge — 4 test functions
# ═══════════════════════════════════════════════════════════════════════════

fn test_cpp_event() {
    let evt = new CppEvent();
    evt.init_event("clicked", "CppEventListener");
    assert(evt.getName() == "clicked", "CppEvent.getName");
    assert(evt.getListenerType() == "CppEventListener", "CppEvent.getListenerType");
    assert(evt.getListenerCount() == 0, "CppEvent.getListenerCount default 0");
    assert(evt.isStatic() == false, "CppEvent.isStatic default");
    assert(evt.isRemote() == false, "CppEvent.isRemote default");
    assert(evt.isSignal() == false, "CppEvent.isSignal default");

    evt.setStatic(true);
    assert(evt.isStatic() == true, "CppEvent.setStatic");

    evt.setRemote(true);
    assert(evt.isRemote() == true, "CppEvent.setRemote");

    evt.setRemoteEndpoint("ws://192.168.1.1:8080");
    assert(evt.getRemoteEndpoint() == "ws://192.168.1.1:8080", "CppEvent.setRemoteEndpoint/getRemoteEndpoint");

    let listener1 = new CppEventListener();
    listener1.init_listener("clicked", fn(sender, args) { return 0; });
    let listener2 = new CppEventListener();
    listener2.init_listener("clicked", fn(sender, args) { return 0; });

    evt.addListener(listener1);
    evt.addListener(listener2);
    assert(evt.getListenerCount() == 2, "CppEvent.addListener/getListenerCount");

    let listeners = evt.getListeners();
    assert(len(listeners) == 2, "CppEvent.getListeners");

    evt.removeListener(listener1);
    assert(evt.getListenerCount() == 1, "CppEvent.removeListener");

    evt.clearListeners();
    assert(evt.getListenerCount() == 0, "CppEvent.clearListeners");

    evt.setSignal(true);
    assert(evt.isSignal() == true, "CppEvent.setSignal/isSignal");
    return 0;
}

fn test_cpp_event_listener() {
    let count = 0;
    let l = new CppEventListener();
    l.init_listener("click", fn(sender, args) { count = count + 1; return 0; });
    assert(l.getEventName() == "click", "CppEventListener.getEventName");
    assert(l.isActive() == true, "CppEventListener.isActive default true");
    assert(l.isOneShot() == false, "CppEventListener.isOneShot default false");

    l.setId(42);
    assert(l.getId() == 42, "CppEventListener.setId/getId");

    l.onEvent(nullptr, {});
    assert(count == 1, "CppEventListener.onEvent calls callback");

    # Test setActive false → callback not called
    let count2 = 0;
    let l2 = new CppEventListener();
    l2.init_listener("hover", fn(sender, args) { count2 = count2 + 1; return 0; });
    l2.setActive(false);
    l2.onEvent(nullptr, {});
    assert(count2 == 0, "CppEventListener.setActive false blocks onEvent");

    # Test oneshot deactivates after one call
    let count3 = 0;
    let l3 = new CppEventListener();
    l3.init_listener("once", fn(sender, args) { count3 = count3 + 1; return 0; });
    l3.setOneShot(true);
    l3.onEvent(nullptr, {});
    assert(count3 == 1, "CppEventListener oneshot first call");
    assert(l3.isActive() == false, "CppEventListener oneshot deactivates");
    l3.onEvent(nullptr, {});
    assert(count3 == 1, "CppEventListener oneshot blocked on second call");
    return 0;
}

fn test_cpp_cross_event_bus() {
    let bus = new CppCrossEventBus();
    bus.init_cross_bus();
    assert(bus.getEventCount() == 0, "CppCrossEventBus.getEventCount default 0");
    assert(bus.isBridgeEnabled() == false, "CppCrossEventBus.isBridgeEnabled default false");

    let call_count = 0;
    let listener = bus.subscribe("dataReady", fn(sender, args) { call_count = call_count + 1; return 0; });
    assert(listener != nullptr, "CppCrossEventBus.subscribe returns listener");
    assert(bus.getListenerCount() == 1, "CppCrossEventBus.getListenerCount after subscribe");

    bus.publish("dataReady", nullptr, {});
    assert(call_count == 1, "CppCrossEventBus.publish calls callback");

    bus.publish("nonExistent", nullptr, {});
    # no crash expected

    assert(bus.getEventCount() == 1, "CppCrossEventBus.getEventCount 1");

    bus.enableBridge();
    assert(bus.isBridgeEnabled() == true, "CppCrossEventBus.enableBridge");

    bus.disableBridge();
    assert(bus.isBridgeEnabled() == false, "CppCrossEventBus.disableBridge");

    let evt = bus.getEvent("dataReady");
    assert(evt != nullptr, "CppCrossEventBus.getEvent");

    bus.clearEvent("dataReady");
    assert(bus.getEventCount() == 0, "CppCrossEventBus.clearEvent");

    # re-subscribe and test clear
    bus.subscribe("reload", fn(sender, args) { return 0; });
    bus.clear();
    assert(bus.getEventCount() == 0, "CppCrossEventBus.clear");
    assert(bus.getListenerCount() == 0, "CppCrossEventBus.clear resets counter");
    return 0;
}

fn test_cpp_ui_dispatcher() {
    let d = new CppUIDispatcher();
    d.init_dispatcher();
    assert(d.getQueueSize() == 0, "CppUIDispatcher.getQueueSize default 0");
    assert(d.isProcessing() == false, "CppUIDispatcher.isProcessing default false");
    assert(d.getMainThread() == 0, "CppUIDispatcher.getMainThread default 0");

    d.setMainThread(1);
    assert(d.getMainThread() == 1, "CppUIDispatcher.setMainThread");

    let counter = 0;
    d.invokeLater(fn() { counter = counter + 1; return 0; });
    d.invokeLater(fn() { counter = counter + 2; return 0; });
    assert(d.getQueueSize() == 2, "CppUIDispatcher.invokeLater");

    d.processQueue();
    assert(counter == 3, "CppUIDispatcher.processQueue executes callbacks");
    assert(d.getQueueSize() == 0, "CppUIDispatcher.processQueue clears done items");

    d.invokeLater(fn() { return 0; });
    assert(d.getQueueSize() == 1, "CppUIDispatcher.invokeLater after process");

    d.clear();
    assert(d.getQueueSize() == 0, "CppUIDispatcher.clear");
    return 0;
}

