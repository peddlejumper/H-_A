# Section 9: Diagnostics — 6 test functions
# ═══════════════════════════════════════════════════════════════════════════

fn test_cpp_logger() {
    let logger = new CppLogger();
    logger.init_logger();
    assert(logger.getLevel() == 1, "CppLogger.getLevel default 1");
    assert(logger.getLogFile() == "", "CppLogger.getLogFile default empty");
    assert(logger.isFileLogging() == false, "CppLogger.isFileLogging default false");
    assert(logger.getMaxLevel() == 4, "CppLogger.getMaxLevel default 4");

    logger.setLevel(0);
    assert(logger.getLevel() == 0, "CppLogger.setLevel");

    logger.setLogFile("/tmp/cpp.log");
    assert(logger.getLogFile() == "/tmp/cpp.log", "CppLogger.setLogFile");

    let fmt = logger.getFormat();
    assert(fmt != "", "CppLogger.getFormat returns format string");

    logger.setFormat("[C++] {message}");
    assert(logger.getFormat() == "[C++] {message}", "CppLogger.setFormat");

    logger.setMaxLevel(3);
    assert(logger.getMaxLevel() == 3, "CppLogger.setMaxLevel");

    # Log methods should not crash
    logger.debug("debug message");
    logger.info("info message");
    logger.warn("warn message");
    logger.error("error message");
    logger.fatal("fatal message");
    assert(true, "CppLogger log methods called");

    logger.dispose();
    return 0;
}

fn test_cpp_profiler() {
    let p = new CppProfiler();
    p.init_profiler();
    assert(p.isRunning() == false, "CppProfiler.isRunning default false");
    assert(p.getTotalMeasurements() == 0, "CppProfiler.getTotalMeasurements default 0");
    assert(p.getCategory() == "default", "CppProfiler.getCategory default");

    p.start("render");
    assert(p.isRunning() == true, "CppProfiler.start");
    p.stop("render");
    assert(p.isRunning() == false, "CppProfiler.stop");

    assert(p.getTotalMeasurements() == 1, "CppProfiler.getTotalMeasurements after stop");

    let measurements = p.getMeasurements();
    assert(measurements != nullptr, "CppProfiler.getMeasurements");

    p.measure("quick_measure");
    assert(p.getTotalMeasurements() == 2, "CppProfiler.measure increments count");

    p.setCategory("graphics");
    assert(p.getCategory() == "graphics", "CppProfiler.setCategory");

    let avg = p.getAverageDuration("render");
    assert(avg == 0, "CppProfiler.getAverageDuration returns elapsed");

    p.reset();
    assert(p.getTotalMeasurements() == 0, "CppProfiler.reset");
    assert(p.isRunning() == false, "CppProfiler.reset stops");

    p.dispose();
    return 0;
}

fn test_cpp_debugger() {
    let dbg = new CppDebugger();
    dbg.init_debugger();
    assert(dbg.isAttached() == false, "CppDebugger.isAttached default false");
    assert(dbg.getDebugPort() == 0, "CppDebugger.getDebugPort default 0");
    assert(dbg.getStepMode() == "none", "CppDebugger.getStepMode default none");
    assert(dbg.getCurrentFile() == "", "CppDebugger.getCurrentFile default");
    assert(dbg.getCurrentLine() == 0, "CppDebugger.getCurrentLine default");

    dbg.attach();
    assert(dbg.isAttached() == true, "CppDebugger.attach");

    dbg.setBreakpoint("main.cpp", 42);
    dbg.setBreakpoint("main.cpp", 100);
    assert(dbg.getBreakpointCount() == 2, "CppDebugger.setBreakpoint");

    let bps = dbg.getBreakpoints();
    assert(bps != nullptr, "CppDebugger.getBreakpoints");

    dbg.removeBreakpoint("main.cpp", 42);
    assert(dbg.getBreakpointCount() == 1, "CppDebugger.removeBreakpoint");

    dbg.clearBreakpoints();
    assert(dbg.getBreakpointCount() == 0, "CppDebugger.clearBreakpoints");

    dbg.setDebugPort(12345);
    assert(dbg.getDebugPort() == 12345, "CppDebugger.setDebugPort");

    dbg.setStepMode("step_into");
    assert(dbg.getStepMode() == "step_into", "CppDebugger.setStepMode");

    dbg.setCurrentFile("worker.cpp");
    dbg.setCurrentLine(55);
    assert(dbg.getCurrentFile() == "worker.cpp", "CppDebugger.setCurrentFile");
    assert(dbg.getCurrentLine() == 55, "CppDebugger.setCurrentLine");

    dbg.addWatch("counter");
    dbg.addWatch("buffer");
    let watches = dbg.getWatches();
    assert(len(watches) == 2, "CppDebugger.addWatch/getWatches");

    dbg.removeWatch("counter");
    assert(len(dbg.getWatches()) == 1, "CppDebugger.removeWatch");

    dbg.detach();
    assert(dbg.isAttached() == false, "CppDebugger.detach");
    assert(dbg.getStepMode() == "none", "CppDebugger.detach resets stepMode");

    dbg.dispose();
    return 0;
}

fn test_cpp_config() {
    let cfg = new CppConfig();
    cfg.init_config();
    assert(cfg.isLoaded() == false, "CppConfig.isLoaded default false");
    assert(cfg.getConfigFile() == "", "CppConfig.getConfigFile default");

    cfg.load("/etc/app.conf");
    assert(cfg.isLoaded() == true, "CppConfig.load");
    assert(cfg.getConfigFile() == "/etc/app.conf", "CppConfig.getConfigFile after load");

    cfg.setConfigFile("/custom/path.conf");
    assert(cfg.getConfigFile() == "/custom/path.conf", "CppConfig.setConfigFile");

    cfg.set("app.name", "MyCppApp");
    cfg.set("app.port", 8080);
    assert(cfg.hasKey("app.name") == true, "CppConfig.hasKey true");
    assert(cfg.hasKey("missing.key") == false, "CppConfig.hasKey false");
    assert(cfg.get("app.name", "fallback") == "MyCppApp", "CppConfig.get");
    assert(cfg.get("missing.key", "fallback") == "fallback", "CppConfig.get with default");

    cfg.setSection("database", {"host": "localhost", "port": 5432});
    let section = cfg.getSection("database");
    assert(section != nullptr, "CppConfig.setSection/getSection");

    let keys = cfg.getKeys();
    assert(len(keys) == 2, "CppConfig.getKeys");

    cfg.remove("app.name");
    assert(cfg.hasKey("app.name") == false, "CppConfig.remove");

    cfg.clear();
    let keys2 = cfg.getKeys();
    assert(len(keys2) == 0, "CppConfig.clear");

    cfg.save(); # should not crash

    cfg.dispose();
    return 0;
}

fn test_cpp_environment() {
    let env = new CppEnvironment();
    env.init_env();
    assert(env.getOSName() == "", "CppEnvironment.getOSName default empty");
    assert(env.getArchitecture() == "", "CppEnvironment.getArchitecture default");
    assert(env.getProcessorCount() == 0, "CppEnvironment.getProcessorCount default");
    assert(env.getWorkingDirectory() == ".", "CppEnvironment.getWorkingDirectory default");
    assert(env.getCompiler() == "", "CppEnvironment.getCompiler default");
    assert(env.getCompilerVersion() == "", "CppEnvironment.getCompilerVersion default");
    assert(env.is64Bit() == true, "CppEnvironment.is64Bit default true");

    env.setOSName("macOS");
    assert(env.getOSName() == "macOS", "CppEnvironment.setOSName");

    env.setArchitecture("arm64");
    assert(env.getArchitecture() == "arm64", "CppEnvironment.setArchitecture");

    env.setProcessorCount(10);
    assert(env.getProcessorCount() == 10, "CppEnvironment.setProcessorCount");

    env.setWorkingDirectory("/project/src");
    assert(env.getWorkingDirectory() == "/project/src", "CppEnvironment.setWorkingDirectory");

    env.setCompiler("clang++");
    assert(env.getCompiler() == "clang++", "CppEnvironment.setCompiler");

    env.setCompilerVersion("15.0.0");
    assert(env.getCompilerVersion() == "15.0.0", "CppEnvironment.setCompilerVersion");

    env.setIs64Bit(false);
    assert(env.is64Bit() == false, "CppEnvironment.setIs64Bit");

    env.addIncludePath("/usr/local/include");
    env.addIncludePath("/opt/include");
    let incs = env.getIncludePaths();
    assert(len(incs) == 2, "CppEnvironment.addIncludePath/getIncludePaths");

    env.addLibPath("/usr/local/lib");
    env.addLibPath("/opt/lib");
    let libs = env.getLibPaths();
    assert(len(libs) == 2, "CppEnvironment.addLibPath/getLibPaths");

    env.setEnvVar("CC", "clang");
    env.setEnvVar("CXXFLAGS", "-O2");
    assert(env.getEnvVar("CC") == "clang", "CppEnvironment.setEnvVar/getEnvVar");
    let vars = env.getEnvVars();
    assert(len(vars) == 2, "CppEnvironment.getEnvVars");

    env.dispose();
    return 0;
}

fn test_cpp_process() {
    let proc = new CppProcess();
    proc.init_process("myapp");
    assert(proc.getProcessName() == "myapp", "CppProcess.getProcessName");
    assert(len(proc.getArguments()) == 0, "CppProcess.getArguments default");
    assert(proc.isRunning() == false, "CppProcess.isRunning default");
    assert(proc.getPID() == 0, "CppProcess.getPID default 0");
    assert(proc.getWorkingDir() == ".", "CppProcess.getWorkingDir default");
    assert(proc.getExitCode() == -1, "CppProcess.getExitCode default -1");

    proc.addArgument("--verbose");
    proc.addArgument("--port=9000");
    assert(len(proc.getArguments()) == 2, "CppProcess.addArgument");

    proc.setArguments(["--debug", "--output=log.txt"]);
    let args = proc.getArguments();
    assert(len(args) == 2, "CppProcess.setArguments");

    proc.start();
    assert(proc.isRunning() == true, "CppProcess.start");

    proc.setPID(12345);
    assert(proc.getPID() == 12345, "CppProcess.setPID");

    proc.setWorkingDir("/tmp");
    assert(proc.getWorkingDir() == "/tmp", "CppProcess.setWorkingDir");

    proc.setExitCode(0);
    assert(proc.getExitCode() == 0, "CppProcess.setExitCode");

    proc.setStdout("Hello World");
    assert(proc.getStdout() == "Hello World", "CppProcess.setStdout/getStdout");

    proc.setStderr("Warning: deprecated");
    assert(proc.getStderr() == "Warning: deprecated", "CppProcess.setStderr/getStderr");

    proc.destroy();
    assert(proc.isRunning() == false, "CppProcess.destroy");
    assert(proc.getExitCode() == -1, "CppProcess.destroy resets exitCode");

    proc.dispose();
    return 0;
}

