fn test_cpp_type_info() {
    let ti = new CppTypeInfo();
    ti.init_cpp_type("MyClass", "my_ns", "libmy.so");
    assert(ti.getTypeName() == "MyClass", "CppTypeInfo.getTypeName");
    assert(ti.getNamespace() == "my_ns", "CppTypeInfo.getNamespace");
    assert(ti.getSharedLib() == "libmy.so", "CppTypeInfo.getSharedLib");
    assert(ti.getFullName() == "my_ns::MyClass", "CppTypeInfo.getFullName");

    ti.setPrimitive(true);
    assert(ti.isPrimitive() == true, "CppTypeInfo.setPrimitive/isPrimitive");
    ti.setPrimitive(false);

    assert(ti.isTemplate() == false, "CppTypeInfo.isTemplate default");
    ti.setTemplate(true);
    assert(ti.isTemplate() == true, "CppTypeInfo.setTemplate");

    ti.setEnum(true);
    assert(ti.isEnum() == true, "CppTypeInfo.setEnum/isEnum");
    ti.setPOD(true);
    assert(ti.isPOD() == true, "CppTypeInfo.setPOD/isPOD");
    ti.setAbstract(true);
    assert(ti.isAbstract() == true, "CppTypeInfo.setAbstract/isAbstract");

    ti.addTemplateArg("T");
    ti.addTemplateArg("U");
    let targs = ti.getTemplateArgs();
    assert(len(targs) == 2, "CppTypeInfo.addTemplateArg/getTemplateArgs");

    ti.setBaseClass("BaseClass");
    assert(ti.getBaseClass() == "BaseClass", "CppTypeInfo.setBaseClass/getBaseClass");

    ti.addInclude("<string>");
    ti.addInclude("<vector>");
    let incs = ti.getIncludes();
    assert(len(incs) == 2, "CppTypeInfo.addInclude/getIncludes");

    ti.addModifier("final");
    ti.addModifier("export");
    let mods = ti.getModifiers();
    assert(len(mods) == 2, "CppTypeInfo.addModifier/getModifiers");

    ti.setMangledName("_ZN5my_ns7MyClassE");
    assert(ti.getMangledName() == "_ZN5my_ns7MyClassE", "CppTypeInfo.setMangledName/getMangledName");

    # Full name without namespace
    let ti2 = new CppTypeInfo();
    ti2.init_cpp_type("GlobalClass", "", "");
    assert(ti2.getFullName() == "GlobalClass", "CppTypeInfo.getFullName no namespace");
    return 0;
}

fn test_cpp_type_mapper() {
    let tm = new CppTypeMapper();
    tm.init_mapper();

    assert(tm.toCpp("int") == "int", "CppTypeMapper.toCpp: int→int");
    assert(tm.toCpp("float") == "double", "CppTypeMapper.toCpp: float→double");
    assert(tm.toCpp("string") == "std::string", "CppTypeMapper.toCpp: string→std::string");
    assert(tm.toCpp("bool") == "bool", "CppTypeMapper.toCpp: bool→bool");
    assert(tm.toCpp("list") == "std::vector", "CppTypeMapper.toCpp: list→std::vector");
    assert(tm.toCpp("dict") == "std::map", "CppTypeMapper.toCpp: dict→std::map");
    assert(tm.toCpp("int64") == "int64_t", "CppTypeMapper.toCpp: int64→int64_t");
    assert(tm.toCpp("size") == "size_t", "CppTypeMapper.toCpp: size→size_t");
    assert(tm.toCpp("ptr") == "void*", "CppTypeMapper.toCpp: ptr→void*");
    assert(tm.toCpp("unknown_type") == "void*", "CppTypeMapper.toCpp: unknown→void*");

    assert(tm.toHSharp("int") == "int", "CppTypeMapper.toHSharp: int→int");
    assert(tm.toHSharp("double") == "float", "CppTypeMapper.toHSharp: double→float");
    assert(tm.toHSharp("std::string") == "string", "CppTypeMapper.toHSharp: std::string→string");
    assert(tm.toHSharp("std::vector") == "list", "CppTypeMapper.toHSharp: std::vector→list");
    assert(tm.toHSharp("void*") == "ptr", "CppTypeMapper.toHSharp: void*→ptr");
    assert(tm.toHSharp("unknown_cpp") == "object", "CppTypeMapper.toHSharp: unknown→object");

    assert(tm.isPrimitive("int") == true, "CppTypeMapper.isPrimitive: int=true");
    assert(tm.isPrimitive("double") == true, "CppTypeMapper.isPrimitive: double=true");
    assert(tm.isPrimitive("std::string") == false, "CppTypeMapper.isPrimitive: std::string=false");
    assert(tm.isPrimitive("std::vector") == false, "CppTypeMapper.isPrimitive: vector=false");

    tm.register("MyType", "my::MyType", false);
    assert(tm.toCpp("MyType") == "my::MyType", "CppTypeMapper: custom register");
    assert(tm.toHSharp("my::MyType") == "MyType", "CppTypeMapper: custom reverse");

    let prims = tm.getPrimitiveTypes();
    assert(prims != nullptr, "CppTypeMapper.getPrimitiveTypes");

    let cnt = tm.getMappingCount();
    assert(cnt > 0, "CppTypeMapper.getMappingCount > 0");
    return 0;
}

fn test_cpp_value() {
    let v = new CppValue();
    v.init_value(42, "int");
    assert(v.getValue() == 42, "CppValue.getValue");
    assert(v.getTypeName() == "int", "CppValue.getTypeName");
    assert(v.isNull() == false, "CppValue.isNull false");
    assert(v.asInt() == 42, "CppValue.asInt");
    assert(v.asFloat() == 42.0, "CppValue.asFloat int→float");

    let v2 = new CppValue();
    v2.init_value(nullptr, "void*");
    assert(v2.isNull() == true, "CppValue.isNull true");
    assert(v2.asInt() == 0, "CppValue.asInt nullptr→0");
    assert(v2.asFloat() == 0.0, "CppValue.asFloat nullptr→0.0");
    assert(v2.asString() == "", "CppValue.asString nullptr→empty");
    assert(v2.asBool() == false, "CppValue.asBool nullptr→false");
    assert(len(v2.asList()) == 0, "CppValue.asList nullptr→empty list");

    let v3 = new CppValue();
    v3.init_value("hello", "std::string");
    assert(v3.asString() == "hello", "CppValue.asString");

    let v4 = new CppValue();
    v4.init_value(true, "bool");
    v4.setPrimitive(true);
    assert(v4.asBool() == true, "CppValue.asBool true");

    v4.setNull();
    assert(v4.isNull() == true, "CppValue.setNull");

    let v5 = new CppValue();
    v5.initFromValue(99);
    assert(v5.getTypeName() == "auto", "CppValue.initFromValue typeName");
    assert(v5.asInt() == 99, "CppValue.initFromValue value");

    let orig = new CppValue();
    orig.init_value(77, "int");
    let cloned = orig.clone();
    assert(cloned != nullptr, "CppValue.clone not null");
    assert(cloned.asInt() == 77, "CppValue.clone value preserved");
    assert(cloned.getTypeName() == "int", "CppValue.clone type preserved");
    return 0;
}

fn test_cpp_invoke() {
    let inv = new CppInvoke();
    inv.init_invoke("getSize");
    assert(inv.getMethodName() == "getSize", "CppInvoke.getMethodName");
    assert(inv.getArgCount() == 0, "CppInvoke.getArgCount default 0");
    assert(inv.isStatic() == false, "CppInvoke.isStatic default false");

    inv.setStatic(true);
    assert(inv.isStatic() == true, "CppInvoke.setStatic");

    inv.setTimeout(5000);
    assert(inv.getTimeout() == 5000, "CppInvoke.setTimeout/getTimeout");

    inv.setGetter("width");
    assert(inv.getPropertyName() == "width", "CppInvoke.setGetter/getPropertyName");

    let inv2 = new CppInvoke();
    inv2.init_invoke("setName");
    inv2.setSetter("name", "Alice");
    let args2 = inv2.getArgs();
    assert(len(args2) == 1, "CppInvoke.setSetter args count");
    assert(args2[0] == "Alice", "CppInvoke.setSetter args value");

    let inv3 = new CppInvoke();
    inv3.init_invoke("compute");
    inv3.addArg(10);
    inv3.addArg(20);
    assert(inv3.getArgCount() == 2, "CppInvoke.addArg/getArgCount");
    assert(inv3.getArg(0) == 10, "CppInvoke.getArg 0");
    assert(inv3.getArg(1) == 20, "CppInvoke.getArg 1");
    assert(inv3.getArg(99) == nullptr, "CppInvoke.getArg out of bounds");

    let test_obj = {};
    inv3.setOwnerObject(test_obj);
    assert(inv3.getOwnerObject() == test_obj, "CppInvoke.setOwnerObject/getOwnerObject");

    let inv4 = new CppInvoke();
    inv4.init_invoke("setSize");
    inv4.setArgs([640, 480]);
    assert(len(inv4.getArgs()) == 2, "CppInvoke.setArgs/getArgs");

    let inv5 = new CppInvoke();
    inv5.init_invoke("setPosition");
    inv5.setSetterArgs([100, 200]);
    assert(len(inv5.getArgs()) == 2, "CppInvoke.setSetterArgs");
    return 0;
}

fn test_cpp_result() {
    let r = new CppResult();
    r.init_result();
    assert(r.isSuccess() == false, "CppResult.isSuccess default false");
    assert(r.isException() == false, "CppResult.isException default false");

    r.setSuccess(42);
    assert(r.isSuccess() == true, "CppResult.setSuccess");
    assert(r.getValue() == 42, "CppResult.getValue after success");

    r.setError("Segfault", "RuntimeException");
    assert(r.isSuccess() == false, "CppResult.setError clears success");
    assert(r.getError() == "Segfault", "CppResult.getError");
    assert(r.getErrorType() == "RuntimeException", "CppResult.getErrorType");
    assert(r.isException() == true, "CppResult.isException after error");

    r.setCallId(7);
    assert(r.getCallId() == 7, "CppResult.setCallId/getCallId");

    r.setDuration(150);
    assert(r.getDuration() == 150, "CppResult.setDuration/getDuration");

    r.setStackTrace("frame1\nframe2");
    assert(r.getStackTrace() == "frame1\nframe2", "CppResult.setStackTrace/getStackTrace");

    # unwrap on error returns nullptr
    let val = r.unwrap();
    assert(val == nullptr, "CppResult.unwrap on error→nullptr");

    # expect on error still returns value
    let v2 = r.expect("custom error msg");
    assert(v2 == nullptr, "CppResult.expect on error");

    # success unwrap
    let r2 = new CppResult();
    r2.init_result();
    r2.setSuccess("done");
    assert(r2.unwrap() == "done", "CppResult.unwrap on success");
    return 0;
}

