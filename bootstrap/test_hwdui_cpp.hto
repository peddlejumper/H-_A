fn test_cpp_control_bridge() {
    let hw = {"width": 640, "height": 480, "title": "Test Window"};
    let cw = {};
    let bridge = new ZzwUICppControlBridge();
    bridge.init_bridge(hw, cw);

    assert(bridge.getHWidget() == hw, "ZzwUICppControlBridge.getHWidget");
    assert(bridge.getCppControl() == cw, "ZzwUICppControlBridge.getCppControl");
    assert(bridge.isEnabled() == true, "ZzwUICppControlBridge.isEnabled default");

    bridge.bindProperty("width", "width");
    bridge.bindProperty("height", "height");
    let pb = bridge.getPropertyBindings();
    assert(len(pb) == 2, "ZzwUICppControlBridge.bindProperty/getPropertyBindings");

    bridge.bindEvent("clicked", "clicked");
    bridge.bindEvent("resized", "resized");
    let eb = bridge.getEventBindings();
    assert(len(eb) == 2, "ZzwUICppControlBridge.bindEvent/getEventBindings");

    bridge.setSyncDirection("hsharp_to_cpp");
    assert(bridge.getSyncDirection() == "hsharp_to_cpp", "ZzwUICppControlBridge.setSyncDirection");

    bridge.syncToCpp();
    bridge.syncToHSharp();
    bridge.syncBoth();

    bridge.unbindProperty("width");
    assert(len(bridge.getPropertyBindings()) == 1, "ZzwUICppControlBridge.unbindProperty");

    bridge.unbindEvent("clicked");
    assert(len(bridge.getEventBindings()) == 1, "ZzwUICppControlBridge.unbindEvent");

    bridge.unbindAll();
    assert(len(bridge.getPropertyBindings()) == 0, "ZzwUICppControlBridge.unbindAll properties");
    assert(len(bridge.getEventBindings()) == 0, "ZzwUICppControlBridge.unbindAll events");

    bridge.setEnabled(false);
    assert(bridge.isEnabled() == false, "ZzwUICppControlBridge.setEnabled");

    bridge.dispose();
    assert(bridge.getHWidget() == nullptr, "ZzwUICppControlBridge.dispose");
    assert(bridge.isEnabled() == false, "ZzwUICppControlBridge.dispose disabled");
    return 0;
}

fn test_cpp_window_bridge() {
    let hw = {"title": "MyApp", "width": 800, "height": 600, "x": 100, "y": 50};
    let cw = {"title": "MyApp", "width": 800, "height": 600, "x": 100, "y": 50};
    let wb = new CppWindowBridge();
    wb.init_win_bridge(hw, cw);

    assert(wb.getHWindow() == hw, "CppWindowBridge.getHWindow");
    assert(wb.getCppWindow() == cw, "CppWindowBridge.getCppWindow");
    assert(wb.isTitleBound() == false, "CppWindowBridge.isTitleBound default");
    assert(wb.isSizeBound() == false, "CppWindowBridge.isSizeBound default");
    assert(wb.isPositionBound() == false, "CppWindowBridge.isPositionBound default");
    assert(wb.isVisibilityBound() == false, "CppWindowBridge.isVisibilityBound default");
    assert(wb.isStateBound() == false, "CppWindowBridge.isStateBound default");

    wb.bindTitle();
    assert(wb.isTitleBound() == true, "CppWindowBridge.bindTitle");

    wb.bindSize();
    assert(wb.isSizeBound() == true, "CppWindowBridge.bindSize");

    wb.bindPosition();
    assert(wb.isPositionBound() == true, "CppWindowBridge.bindPosition");

    wb.bindVisibility();
    assert(wb.isVisibilityBound() == true, "CppWindowBridge.bindVisibility");

    wb.bindState();
    assert(wb.isStateBound() == true, "CppWindowBridge.bindState");

    wb.syncTitle();
    wb.syncSize();
    wb.syncPosition();
    wb.syncAll();

    wb.unbindAll();
    assert(wb.isTitleBound() == false, "CppWindowBridge.unbindAll");
    assert(wb.isSizeBound() == false, "CppWindowBridge.unbindAll size");
    assert(wb.isPositionBound() == false, "CppWindowBridge.unbindAll position");

    wb.dispose();
    assert(wb.getHWindow() == nullptr, "CppWindowBridge.dispose");
    return 0;
}

fn test_cpp_ui_host() {
    let parent = {};
    let host = new CppUIHost();
    host.init_host(parent);
    assert(host.isActive() == false, "CppUIHost.isActive default false");
    assert(host.getLayoutEngine() == "zzwUI", "CppUIHost.getLayoutEngine default");
    assert(host.getRenderer() == "default", "CppUIHost.getRenderer default");

    host.activate();
    assert(host.isActive() == true, "CppUIHost.activate");

    let w1 = {"id": "btn1"};
    let w2 = {"id": "btn2"};
    host.hostWidget(w1, "Button");
    host.hostWidget(w2, "Label");
    assert(host.getWidgetCount() == 2, "CppUIHost.hostWidget/getWidgetCount");

    let widgets = host.getWidgets();
    assert(len(widgets) == 2, "CppUIHost.getWidgets");

    host.removeWidget(w1);
    assert(host.getWidgetCount() == 1, "CppUIHost.removeWidget");

    host.setLayoutEngine("Qt");
    assert(host.getLayoutEngine() == "Qt", "CppUIHost.setLayoutEngine");

    host.setRenderer("OpenGL");
    assert(host.getRenderer() == "OpenGL", "CppUIHost.setRenderer");

    host.deactivate();
    assert(host.isActive() == false, "CppUIHost.deactivate");

    host.clear();
    assert(host.getWidgetCount() == 0, "CppUIHost.clear");

    host.dispose();
    assert(host.isActive() == false, "CppUIHost.dispose");
    return 0;
}

fn test_cpp_control_factory() {
    let cf = new CppControlFactory();
    cf.init_factory();

    let cpp_type = cf.getCppType("Button");
    assert(cpp_type == "QPushButton", "CppControlFactory.getCppType Button");
    assert(cf.getCppType("Label") == "QLabel", "CppControlFactory.getCppType Label");

    assert(cf.getFramework("Button") == "Qt", "CppControlFactory.getFramework");

    assert(cf.hasType("Button") == true, "CppControlFactory.hasType true");
    assert(cf.hasType("NonExistent") == false, "CppControlFactory.hasType false");

    let types = cf.getSupportedTypes();
    assert(len(types) > 0, "CppControlFactory.getSupportedTypes");

    let frameworks = cf.getSupportedFrameworks();
    assert(len(frameworks) > 0, "CppControlFactory.getSupportedFrameworks");

    let ctrl = cf.createControl("Button");
    assert(ctrl != nullptr, "CppControlFactory.createControl");
    assert(ctrl["__type__"] == "QPushButton", "CppControlFactory.createControl type");

    let null_ctrl = cf.createControl("NonExistent");
    assert(null_ctrl == nullptr, "CppControlFactory.createControl non-existent");

    let init_count = cf.getTypeCount();
    cf.removeType("Button");
    assert(cf.hasType("Button") == false, "CppControlFactory.removeType");
    assert(cf.getTypeCount() == init_count - 1, "CppControlFactory.getTypeCount after remove");

    cf.clear();
    assert(cf.getTypeCount() == 0, "CppControlFactory.clear");
    return 0;
}

