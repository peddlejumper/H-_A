fn test_cpp_qml() {
    let qml = new CppQML();
    qml.init_qml();
    assert(qml.getRootElement() == "", "CppQML.getRootElement default empty");
    assert(qml.getContent() == "", "CppQML.getContent default empty");
    assert(qml.getControllerClass() == "", "CppQML.getControllerClass default empty");

    qml.setRootElement("ApplicationWindow");
    assert(qml.getRootElement() == "ApplicationWindow", "CppQML.setRootElement");

    qml.setContent("Rectangle { width: 100; height: 100 }");
    assert(qml.getContent() == "Rectangle { width: 100; height: 100 }", "CppQML.setContent");

    qml.addResource("window.title", "My QML App");
    qml.addResource("button.text", "Click Me");
    let resources = qml.getResources();
    assert(resources["window.title"] == "My QML App", "CppQML.addResource/getResources");

    let namespaces = qml.getNamespaces();
    assert(namespaces != nullptr, "CppQML.getNamespaces");

    qml.addNamespace("qt", "http://qt-project.org");
    qml.addNamespace("custom", "http://example.com/qml");
    assert(len(qml.getNamespaces()) == 2, "CppQML.addNamespace");

    qml.setControllerClass("MainController");
    assert(qml.getControllerClass() == "MainController", "CppQML.setControllerClass");

    qml.addImport("QtQuick 2.15");
    qml.addImport("QtQuick.Controls 2.15");
    let imports = qml.getImports();
    assert(len(imports) == 2, "CppQML.addImport/getImports");

    qml.dispose();
    return 0;
}

fn test_cpp_style_bridge() {
    let sb = new CppStyleBridge();
    sb.init_style_bridge();
    assert(sb.getMappingCount() == 12, "CppStyleBridge.getMappingCount default 12");

    # toQt: hwd → qt mapping
    let qt_prop = sb.toQt("background");
    assert(qt_prop == "background-color", "CppStyleBridge.toQt: background→background-color");
    assert(sb.toQt("color") == "color", "CppStyleBridge.toQt: color→color");
    assert(sb.toQt("fontSize") == "font-size", "CppStyleBridge.toQt: fontSize→font-size");
    assert(sb.toQt("borderRadius") == "border-radius", "CppStyleBridge.toQt: borderRadius→border-radius");

    # toHwdUI: qt → hwd mapping
    let hwd_prop = sb.toHwdUI("background-color");
    assert(hwd_prop == "background", "CppStyleBridge.toHwdUI: background-color→background");
    assert(sb.toHwdUI("color") == "color", "CppStyleBridge.toHwdUI: color→color");
    assert(sb.toHwdUI("font-size") == "fontSize", "CppStyleBridge.toHwdUI: font-size→fontSize");

    # non-existent
    assert(sb.toHwdUI("nonexistent-prop") == nullptr, "CppStyleBridge.toHwdUI non-existent");

    # add custom mapping
    sb.addMapping("shadow", "box-shadow");
    assert(sb.getMappingCount() == 13, "CppStyleBridge.addMapping");
    assert(sb.toQt("shadow") == "box-shadow", "CppStyleBridge.addMapping toQt");

    # getMappings and getReverseMappings
    let mappings = sb.getMappings();
    assert(len(mappings) == 13, "CppStyleBridge.getMappings");

    let rev = sb.getReverseMappings();
    assert(rev != nullptr, "CppStyleBridge.getReverseMappings");

    # removeMapping
    sb.removeMapping("shadow");
    assert(sb.getMappingCount() == 12, "CppStyleBridge.removeMapping");
    assert(sb.toQt("shadow") == nullptr, "CppStyleBridge.removeMapping cleared");

    sb.clear();
    assert(sb.getMappingCount() == 0, "CppStyleBridge.clear");

    sb.dispose();
    return 0;
}

