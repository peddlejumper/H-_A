fn test_cpp_global_init() {
    let result = cpp_init();
    assert(result == true, "cpp_init returns true");
    assert(cpp_is_ready() == true, "cpp_is_ready after init");

    cpp_shutdown();
    assert(cpp_is_ready() == false, "cpp_is_ready after shutdown");

    # Re-init for subsequent tests
    cpp_init();
    assert(cpp_is_ready() == true, "cpp_is_ready after re-init");
    return 0;
}

