fn test_cpp_service_host() {
    let host = new CppServiceHost();
    host.init_host("MyService", 8080);
    assert(host.getHostName() == "MyService", "CppServiceHost.getHostName");
    assert(host.getPort() == 8080, "CppServiceHost.getPort");
    assert(host.isRunning() == false, "CppServiceHost.isRunning default");
    assert(host.getMaxConnections() == 100, "CppServiceHost.getMaxConnections default");
    assert(host.getProtocol() == "tcp", "CppServiceHost.getProtocol default");

    host.start();
    assert(host.isRunning() == true, "CppServiceHost.start");

    host.registerService("echo", {"name": "echo", "version": "1.0"});
    assert(host.hasService("echo") == true, "CppServiceHost.registerService/hasService");
    assert(host.hasService("missing") == false, "CppServiceHost.hasService false");

    let svc = host.getService("echo");
    assert(svc != nullptr, "CppServiceHost.getService");

    assert(host.getServiceCount() == 1, "CppServiceHost.getServiceCount");

    host.unregisterService("echo");
    assert(host.hasService("echo") == false, "CppServiceHost.unregisterService");
    assert(host.getServiceCount() == 0, "CppServiceHost.getServiceCount after unregister");

    host.setMaxConnections(500);
    assert(host.getMaxConnections() == 500, "CppServiceHost.setMaxConnections");

    host.addEndpoint("http://localhost:8080");
    host.addEndpoint("https://api.example.com");
    let eps = host.getEndpoints();
    assert(len(eps) == 2, "CppServiceHost.addEndpoint/getEndpoints");

    host.setProtocol("https");
    assert(host.getProtocol() == "https", "CppServiceHost.setProtocol");

    host.stop();
    assert(host.isRunning() == false, "CppServiceHost.stop");

    host.dispose();
    assert(host.isRunning() == false, "CppServiceHost.dispose");
    return 0;
}

fn test_cpp_rpc_client() {
    let client = new CppRPCClient();
    client.init_client("http://localhost:9000");
    assert(client.getEndpoint() == "http://localhost:9000", "CppRPCClient.getEndpoint");
    assert(client.getTimeout() == 30000, "CppRPCClient.getTimeout default");
    assert(client.getAuthToken() == "", "CppRPCClient.getAuthToken default");
    assert(client.isConnected() == false, "CppRPCClient.isConnected default");

    client.setTimeout(10000);
    assert(client.getTimeout() == 10000, "CppRPCClient.setTimeout");

    client.setAuthToken("bearer-token-123");
    assert(client.getAuthToken() == "bearer-token-123", "CppRPCClient.setAuthToken");

    client.connect();
    assert(client.isConnected() == true, "CppRPCClient.connect");

    assert(client.getCallCount() == 0, "CppRPCClient.getCallCount default 0");
    let result = client.call("ping", {});
    assert(result != nullptr, "CppRPCClient.call returns result");
    assert(client.getCallCount() == 1, "CppRPCClient.call increments count");
    assert(result.getCallId() == 1, "CppRPCClient.call assigns callId");

    let serializer = {};
    client.setSerializer(serializer);
    assert(client.getSerializer() == serializer, "CppRPCClient.setSerializer/getSerializer");

    client.disconnect();
    assert(client.isConnected() == false, "CppRPCClient.disconnect");

    client.dispose();
    assert(client.isConnected() == false, "CppRPCClient.dispose");
    assert(client.getSerializer() == nullptr, "CppRPCClient.dispose clears serializer");
    return 0;
}

fn test_cpp_rpc_message() {
    let msg = new CppRPCMessage();
    msg.init_message("getUser");
    assert(msg.getMethod() == "getUser", "CppRPCMessage.getMethod");
    assert(msg.getParamCount() == 0, "CppRPCMessage.getParamCount default 0");
    assert(msg.getId() == 0, "CppRPCMessage.getId default 0");
    assert(msg.isRequest() == true, "CppRPCMessage.isRequest default true");
    assert(msg.isNotification() == false, "CppRPCMessage.isNotification default false");
    assert(msg.getCorrelationId() == "", "CppRPCMessage.getCorrelationId default");
    assert(msg.getTimestamp() == 0, "CppRPCMessage.getTimestamp default");

    msg.addParam("user_123");
    msg.addParam(42);
    assert(msg.getParamCount() == 2, "CppRPCMessage.addParam");
    assert(msg.getParam(0) == "user_123", "CppRPCMessage.getParam 0");
    assert(msg.getParam(1) == 42, "CppRPCMessage.getParam 1");
    assert(msg.getParam(99) == nullptr, "CppRPCMessage.getParam out of bounds");

    msg.setId(100);
    assert(msg.getId() == 100, "CppRPCMessage.setId");

    msg.setNotification(true);
    assert(msg.isNotification() == true, "CppRPCMessage.setNotification");

    msg.setCorrelationId("corr-abc-123");
    assert(msg.getCorrelationId() == "corr-abc-123", "CppRPCMessage.setCorrelationId");

    msg.setTimestamp(1620000000);
    assert(msg.getTimestamp() == 1620000000, "CppRPCMessage.setTimestamp");

    let params = msg.getParams();
    assert(len(params) == 2, "CppRPCMessage.getParams");

    msg.setParams([1, 2, 3]);
    assert(len(msg.getParams()) == 3, "CppRPCMessage.setParams");

    msg.dispose();
    assert(len(msg.getParams()) == 0, "CppRPCMessage.dispose");
    return 0;
}

fn test_cpp_rpc_response() {
    let resp = new CppRPCResponse();
    resp.init_response();
    assert(resp.getMessageId() == 0, "CppRPCResponse.getMessageId default");
    assert(resp.isSuccess() == false, "CppRPCResponse.isSuccess default");
    assert(resp.getResult() == nullptr, "CppRPCResponse.getResult default");
    assert(resp.getErrorCode() == 0, "CppRPCResponse.getErrorCode default");
    assert(resp.getError() == "", "CppRPCResponse.getError default");
    assert(resp.getCorrelationId() == "", "CppRPCResponse.getCorrelationId default");
    assert(resp.getDuration() == 0, "CppRPCResponse.getDuration default");

    resp.setMessageId(55);
    assert(resp.getMessageId() == 55, "CppRPCResponse.setMessageId");

    resp.setSuccess(true);
    assert(resp.isSuccess() == true, "CppRPCResponse.setSuccess");

    resp.setResult({"status": "ok"});
    assert(resp.getResult() != nullptr, "CppRPCResponse.setResult/getResult");

    resp.setError(404, "Not Found");
    assert(resp.getErrorCode() == 404, "CppRPCResponse.setError code");
    assert(resp.getError() == "Not Found", "CppRPCResponse.setError message");

    resp.setCorrelationId("corr-xyz");
    assert(resp.getCorrelationId() == "corr-xyz", "CppRPCResponse.setCorrelationId");

    resp.setDuration(350);
    assert(resp.getDuration() == 350, "CppRPCResponse.setDuration");

    resp.dispose();
    assert(resp.getResult() == nullptr, "CppRPCResponse.dispose");
    return 0;
}

fn test_cpp_rpc_context() {
    let ctx = new CppRPCContext();
    ctx.init_context();
    assert(ctx.getRequest() == nullptr, "CppRPCContext.getRequest default");
    assert(ctx.getResponse() == nullptr, "CppRPCContext.getResponse default");
    assert(ctx.isAuthenticated() == false, "CppRPCContext.isAuthenticated default");
    assert(ctx.getPrincipal() == "", "CppRPCContext.getPrincipal default");
    assert(ctx.getUserData() == nullptr, "CppRPCContext.getUserData default");
    assert(ctx.getSessionId() == "", "CppRPCContext.getSessionId default");

    ctx.setAuthenticated(true);
    assert(ctx.isAuthenticated() == true, "CppRPCContext.setAuthenticated");

    ctx.setPrincipal("admin");
    assert(ctx.getPrincipal() == "admin", "CppRPCContext.setPrincipal");

    ctx.setUserData({"role": "admin", "permissions": ["read", "write"]});
    let ud = ctx.getUserData();
    assert(ud != nullptr, "CppRPCContext.setUserData/getUserData");

    ctx.setSessionId("session-abc-123");
    assert(ctx.getSessionId() == "session-abc-123", "CppRPCContext.setSessionId/getSessionId");

    ctx.dispose();
    assert(ctx.getRequest() == nullptr, "CppRPCContext.dispose");
    assert(ctx.getUserData() == nullptr, "CppRPCContext.dispose user_data");
    return 0;
}

fn test_cpp_socket_channel() {
    let ch = new CppSocketChannel();
    ch.init_channel("localhost", 9090);
    assert(ch.getHost() == "localhost", "CppSocketChannel.getHost");
    assert(ch.getPort() == 9090, "CppSocketChannel.getPort");
    assert(ch.isConnected() == false, "CppSocketChannel.isConnected default");
    assert(ch.getSocketType() == "unix", "CppSocketChannel.getSocketType default");
    assert(ch.getBufferSize() == 4096, "CppSocketChannel.getBufferSize default");
    assert(ch.isSSL() == false, "CppSocketChannel.isSSL default");

    ch.connect();
    assert(ch.isConnected() == true, "CppSocketChannel.connect");

    ch.disconnect();
    assert(ch.isConnected() == false, "CppSocketChannel.disconnect");

    ch.setSSL(true);
    assert(ch.isSSL() == true, "CppSocketChannel.setSSL");

    ch.setSocketType("tcp");
    assert(ch.getSocketType() == "tcp", "CppSocketChannel.setSocketType");

    ch.setBufferSize(8192);
    assert(ch.getBufferSize() == 8192, "CppSocketChannel.setBufferSize");

    ch.dispose();
    assert(ch.isConnected() == false, "CppSocketChannel.dispose");
    return 0;
}

fn test_cpp_mapped_buffer() {
    let buf = new CppMappedBuffer();
    buf.init_buffer("shared_data", 1024);
    assert(buf.getName() == "shared_data", "CppMappedBuffer.getName");
    assert(buf.getSize() == 1024, "CppMappedBuffer.getSize");
    assert(buf.isOpen() == false, "CppMappedBuffer.isOpen default");
    assert(buf.getAccess() == "read_write", "CppMappedBuffer.getAccess default");
    assert(buf.getFilePath() == "", "CppMappedBuffer.getFilePath default");
    assert(buf.isAnonymous() == false, "CppMappedBuffer.isAnonymous default");

    buf.open();
    assert(buf.isOpen() == true, "CppMappedBuffer.open");

    buf.close();
    assert(buf.isOpen() == false, "CppMappedBuffer.close");

    buf.setAccess("read_only");
    assert(buf.getAccess() == "read_only", "CppMappedBuffer.setAccess");

    buf.setFilePath("/tmp/shared.bin");
    assert(buf.getFilePath() == "/tmp/shared.bin", "CppMappedBuffer.setFilePath");

    buf.setAnonymous(true);
    assert(buf.isAnonymous() == true, "CppMappedBuffer.setAnonymous");

    buf.dispose();
    assert(buf.isOpen() == false, "CppMappedBuffer.dispose");
    return 0;
}

# ═══════════════════════════════════════════════════════════════════════════
# Section 7: Serialization — 5 test functions
# ═══════════════════════════════════════════════════════════════════════════

fn test_cpp_serializer() {
    let tm = new CppTypeMapper();
    tm.init_mapper();
    let ser = new CppSerializer();
    ser.init_serializer(tm);

    assert(ser.getFormat() == "json", "CppSerializer.getFormat default json");
    assert(ser.getIndent() == false, "CppSerializer.getIndent default false");
    assert(ser.getMapper() == tm, "CppSerializer.getMapper");

    ser.setFormat("messagepack");
    assert(ser.getFormat() == "messagepack", "CppSerializer.setFormat");

    ser.setIndent(true);
    assert(ser.getIndent() == true, "CppSerializer.setIndent");

    let result = ser.serialize(42);
    assert(result != nullptr, "CppSerializer.serialize value");
    assert(result["value"] == 42, "CppSerializer.serialize preserves value");

    let null_result = ser.serialize(nullptr);
    assert(null_result["__type__"] == "nullptr", "CppSerializer.serialize nullptr");

    let obj = {"a": 1, "b": 2};
    let sobj = ser.serializeObject(obj);
    assert(sobj != nullptr, "CppSerializer.serializeObject");
    assert(sobj["a"] == 1, "CppSerializer.serializeObject preserves keys");

    let ser_null_obj = ser.serializeObject(nullptr);
    assert(ser_null_obj == nullptr, "CppSerializer.serializeObject nullptr");

    let lst = [1, 2, 3];
    let slst = ser.serializeList(lst);
    assert(len(slst) == 3, "CppSerializer.serializeList");

    let ser_null_lst = ser.serializeList(nullptr);
    assert(len(ser_null_lst) == 0, "CppSerializer.serializeList nullptr");

    assert(ser.serializeListLength(lst) == 3, "CppSerializer.serializeListLength");
    assert(ser.serializeListLength(nullptr) == 0, "CppSerializer.serializeListLength nullptr");

    let handler_called = false;
    ser.addTypeHandler("custom", fn(d) { handler_called = true; return d; return 0; });
    let th = ser.getTypeHandler("custom");
    assert(th != nullptr, "CppSerializer.addTypeHandler/getTypeHandler");

    ser.dispose();
    assert(ser.getMapper() == nullptr, "CppSerializer.dispose");
    return 0;
}

fn test_cpp_deserializer() {
    let tm = new CppTypeMapper();
    tm.init_mapper();
    let deser = new CppDeserializer();
    deser.init_deserializer(tm);

    assert(deser.getFormat() == "json", "CppDeserializer.getFormat default json");
    assert(deser.isStrict() == false, "CppDeserializer.isStrict default false");
    assert(deser.getMapper() == tm, "CppDeserializer.getMapper");

    deser.setFormat("messagepack");
    assert(deser.getFormat() == "messagepack", "CppDeserializer.setFormat");

    deser.setStrict(true);
    assert(deser.isStrict() == true, "CppDeserializer.setStrict");

    let result = deser.deserialize(nullptr);
    assert(result == nullptr, "CppDeserializer.deserialize nullptr");

    let simple = deser.deserialize({"__type__": "string", "value": "hello"});
    assert(simple == "hello", "CppDeserializer.deserialize string");

    let obj_result = deser.deserializeObject({"a": 1});
    assert(obj_result != nullptr, "CppDeserializer.deserializeObject");

    let list_result = deser.deserializeList(nullptr);
    assert(len(list_result) == 0, "CppDeserializer.deserializeList nullptr");

    let h_called = false;
    deser.addTypeHandler("MyType", fn(d) { h_called = true; return d; return 0; });
    assert(deser.getTypeHandler("MyType") != nullptr, "CppDeserializer.addTypeHandler/getTypeHandler");

    deser.dispose();
    assert(deser.getMapper() == nullptr, "CppDeserializer.dispose");
    return 0;
}

fn test_cpp_messagepack() {
    let mp = new CppMessagePack();
    mp.init_pack();
    assert(mp.getPacked() == nullptr, "CppMessagePack.getPacked default null");
    assert(mp.getUnpacked() == nullptr, "CppMessagePack.getUnpacked default null");
    assert(mp.packSize() == 0, "CppMessagePack.packSize default 0");
    assert(mp.unpackedSize() == 0, "CppMessagePack.unpackedSize default 0");

    let data = {"a": 1, "b": 2};
    let packed = mp.pack(data);
    assert(packed != nullptr, "CppMessagePack.pack returns data");
    assert(mp.getPacked() == data, "CppMessagePack.getPacked after pack");
    assert(mp.packSize() == 1, "CppMessagePack.packSize after pack");

    let unpacked = mp.unpack(data);
    assert(unpacked != nullptr, "CppMessagePack.unpack returns data");
    assert(mp.getUnpacked() == data, "CppMessagePack.getUnpacked after unpack");
    assert(mp.unpackedSize() == 1, "CppMessagePack.unpackedSize after unpack");

    mp.dispose();
    assert(mp.getPacked() == nullptr, "CppMessagePack.dispose");
    assert(mp.getUnpacked() == nullptr, "CppMessagePack.dispose unpacked");
    return 0;
}

fn test_cpp_json() {
    let json = new CppJSON();
    json.init_json();

    assert(json.stringify(nullptr) == "null", "CppJSON.stringify null→\"null\"");
    assert(json.stringify(true) == "true", "CppJSON.stringify true→\"true\"");
    assert(json.stringify(false) == "false", "CppJSON.stringify false→\"false\"");
    assert(json.stringify(42) == "\"42\"", "CppJSON.stringify number");

    let parsed = json.parse("{}");
    assert(parsed != nullptr, "CppJSON.parse simple json");

    let null_parse = json.parse(nullptr);
    assert(null_parse == nullptr, "CppJSON.parse nullptr");

    json.setIndent(2);
    json.setStrict(true);

    json.dispose();
    return 0;
}

fn test_cpp_type_converter() {
    let tc = new CppTypeConverter();
    tc.init_converter();

    assert(tc.canConvert("int", "double") == true, "CppTypeConverter.canConvert int→double");
    assert(tc.canConvert("string", "bool") == true, "CppTypeConverter.canConvert string→bool");
    assert(tc.canConvert("int", "custom") == false, "CppTypeConverter.canConvert false");

    let result = tc.convert(5, "int", "double");
    # conversion happens — validate non-null
    assert(true, "CppTypeConverter.convert int→double");

    let bool_result = tc.convert("true", "string", "bool");
    assert(bool_result == true, "CppTypeConverter.convert string→bool true");

    let str_result = tc.convert(true, "bool", "string");
    assert(str_result == "true", "CppTypeConverter.convert bool→string");

    let converter = tc.getConverter("int", "double");
    assert(converter != nullptr, "CppTypeConverter.getConverter");

    assert(tc.getConverter("nonexistent", "type") == nullptr, "CppTypeConverter.getConverter missing");

    let init_count = tc.getConverterCount();
    assert(init_count > 0, "CppTypeConverter.getConverterCount > 0");

    # register custom converter
    tc.register("int", "custom_int", fn(val) { return val * 100; return 0; });
    assert(tc.getConverterCount() == init_count + 1, "CppTypeConverter.register custom");

    tc.removeConverter("int", "custom_int");
    assert(tc.getConverterCount() == init_count, "CppTypeConverter.removeConverter");

    tc.clear();
    assert(tc.getConverterCount() == 0, "CppTypeConverter.clear");

    tc.dispose();
    return 0;
}

# ═══════════════════════════════════════════════════════════════════════════
# Section 8: Async — 4 test functions (ThreadPool split to separate)
# ═══════════════════════════════════════════════════════════════════════════

fn test_cpp_future() {
    let f = new CppFuture();
    f.init_future();
    assert(f.getId() == 0, "CppFuture.getId default 0");
    assert(f.getStatus() == "created", "CppFuture.getStatus default created");
    assert(f.isDone() == false, "CppFuture.isDone default false");
    assert(f.isFaulted() == false, "CppFuture.isFaulted default false");
    assert(f.isCancelled() == false, "CppFuture.isCancelled default false");

    f.setId(1);
    assert(f.getId() == 1, "CppFuture.setId");

    f.complete("result_value");
    assert(f.isDone() == true, "CppFuture.complete sets isDone");
    assert(f.getStatus() == "completed", "CppFuture.getStatus after complete");
    assert(f.getResult() == "result_value", "CppFuture.getResult");

    # Test fail
    let f2 = new CppFuture();
    f2.init_future();
    f2.fail("exception_message");
    assert(f2.isFaulted() == true, "CppFuture.fail sets isFaulted");
    assert(f2.isDone() == true, "CppFuture.fail sets isDone");
    assert(f2.getStatus() == "faulted", "CppFuture.getStatus after fail");
    assert(f2.getException() == "exception_message", "CppFuture.getException");

    # Test cancel
    let f3 = new CppFuture();
    f3.init_future();
    f3.cancel();
    assert(f3.isCancelled() == true, "CppFuture.cancel sets isCancelled");
    assert(f3.isDone() == true, "CppFuture.cancel sets isDone");
    assert(f3.getStatus() == "cancelled", "CppFuture.getStatus after cancel");

    # Test callback
    let cb_called = false;
    let f4 = new CppFuture();
    f4.init_future();
    f4.addCallback(fn(fut) { cb_called = true; return 0; });
    # Callback not called yet (not done)
    # complete should trigger callback
    f4.complete("ok");
    assert(cb_called == true, "CppFuture.addCallback called on complete");

    # Remove callback test
    let f5 = new CppFuture();
    f5.init_future();
    let dummy_cb = fn(fut) { return 0; };
    f5.addCallback(dummy_cb);
    f5.removeCallback(dummy_cb);
    let cbs = f5.getCallbacks();
    assert(len(cbs) == 0, "CppFuture.removeCallback");

    f5.complete("val");
    # no crash expected

    f.dispose();
    return 0;
}

fn test_cpp_thread_pool() {
    let pool = new CppThreadPool();
    pool.init_pool();
    assert(pool.getCorePoolSize() == 2, "CppThreadPool.getCorePoolSize default 2");
    assert(pool.getMaxPoolSize() == 8, "CppThreadPool.getMaxPoolSize default 8");
    assert(pool.isRunning() == false, "CppThreadPool.isRunning default false");
    assert(pool.getQueueType() == "fifo", "CppThreadPool.getQueueType default fifo");

    pool.setCorePoolSize(4);
    assert(pool.getCorePoolSize() == 4, "CppThreadPool.setCorePoolSize");

    pool.setMaxPoolSize(16);
    assert(pool.getMaxPoolSize() == 16, "CppThreadPool.setMaxPoolSize");

    let executed = false;
    pool.execute(fn() { executed = true; return 0; });
    assert(executed == true, "CppThreadPool.execute runs task");

    let future = pool.submit(fn() { return 42; return 0; });
    assert(future != nullptr, "CppThreadPool.submit returns future");
    assert(pool.getFutureCount() == 1, "CppThreadPool.getFutureCount");

    pool.setQueueType("lifo");
    assert(pool.getQueueType() == "lifo", "CppThreadPool.setQueueType");

    pool.cancelAll();
    assert(pool.getFutureCount() == 0, "CppThreadPool.cancelAll");

    pool.shutdown();
    assert(pool.isRunning() == false, "CppThreadPool.shutdown");

    pool.dispose();
    return 0;
}

fn test_cpp_cancellation_token() {
    let token = new CppCancellationToken();
    token.init_token();
    assert(token.isCancelled() == false, "CppCancellationToken.isCancelled default false");

    let cancel_called = 0;
    token.setOnCancel(fn() { cancel_called = cancel_called + 1; return 0; });
    token.setOnCancel(fn() { cancel_called = cancel_called + 1; return 0; });

    let callbacks = token.getOnCancel();
    assert(len(callbacks) == 2, "CppCancellationToken.getOnCancel");

    token.cancel();
    assert(token.isCancelled() == true, "CppCancellationToken.cancel");
    assert(cancel_called == 2, "CppCancellationToken.cancel calls onCancel");

    token.reset();
    assert(token.isCancelled() == false, "CppCancellationToken.reset");
    assert(len(token.getOnCancel()) == 0, "CppCancellationToken.reset clears callbacks");

    token.dispose();
    return 0;
}

fn test_cpp_async_result() {
    let ar = new CppAsyncResult();
    ar.init_async();
    assert(ar.getFuture() == nullptr, "CppAsyncResult.getFuture default null");
    assert(ar.isCompleted() == false, "CppAsyncResult.isCompleted default false");
    assert(ar.getAsyncState() == nullptr, "CppAsyncResult.getAsyncState default null");
    assert(ar.getResultId() == 0, "CppAsyncResult.getResultId default 0");
    assert(ar.getWaitHandle() == nullptr, "CppAsyncResult.getWaitHandle default null");

    ar.setCompleted(true);
    assert(ar.isCompleted() == true, "CppAsyncResult.setCompleted");

    ar.setAsyncState({"progress": 75});
    let state = ar.getAsyncState();
    assert(state != nullptr, "CppAsyncResult.setAsyncState/getAsyncState");

    ar.setResultId(42);
    assert(ar.getResultId() == 42, "CppAsyncResult.setResultId");

    let handle = {};
    ar.setWaitHandle(handle);
    assert(ar.getWaitHandle() == handle, "CppAsyncResult.setWaitHandle/getWaitHandle");

    ar.dispose();
    assert(ar.getFuture() == nullptr, "CppAsyncResult.dispose");
    assert(ar.getWaitHandle() == nullptr, "CppAsyncResult.dispose wait_handle");
    return 0;
}

