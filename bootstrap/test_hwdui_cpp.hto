fn test_cpp_object() {
    let obj = new CppObject();
    obj.init_object(100, "MyClass");
    assert(obj.getObjectId() == 100, "CppObject.getObjectId");
    assert(obj.getTypeName() == "MyClass", "CppObject.getTypeName");
    assert(obj.isDisposed() == false, "CppObject.isDisposed default");

    obj.setObjectId(200);
    assert(obj.getObjectId() == 200, "CppObject.setObjectId");

    obj.setProperty("width", 640);
    obj.setProperty("title", "Hello");
    assert(obj.getProperty("width") == 640, "CppObject.setProperty/getProperty");
    assert(obj.getProperty("title") == "Hello", "CppObject.setProperty/getProperty string");
    assert(obj.hasProperty("width") == true, "CppObject.hasProperty true");
    assert(obj.hasProperty("nonexistent") == false, "CppObject.hasProperty false");

    obj.addCachedMethod("doWork");
    obj.addCachedMethod("compute");
    assert(obj.hasMethod("doWork") == true, "CppObject.hasMethod true");
    assert(obj.hasMethod("compute") == true, "CppObject.hasMethod true cached");
    assert(obj.hasMethod("missing") == false, "CppObject.hasMethod false");

    assert(obj.isRemote() == false, "CppObject.isRemote default false");
    obj.setRemoteEndpoint("tcp://192.168.1.1:9000");
    assert(obj.getRemoteEndpoint() == "tcp://192.168.1.1:9000", "CppObject.setRemoteEndpoint/getRemoteEndpoint");

    obj.setMetadata("version", 2);
    obj.setMetadata("author", "dev");
    assert(obj.getMetadata("version") == 2, "CppObject.setMetadata/getMetadata");
    assert(obj.getMetadata("author") == "dev", "CppObject.setMetadata/getMetadata string");

    let methods = obj.getCachedMethods();
    assert(len(methods) == 2, "CppObject.getCachedMethods");

    let getters = obj.getCachedGetters();
    assert(len(getters) == 0, "CppObject.getCachedGetters default empty");

    obj.addCachedGetter("visible");
    obj.addCachedGetter("enabled");
    assert(len(obj.getCachedGetters()) == 2, "CppObject.addCachedGetter/getCachedGetters");

    obj.clearMetadata();
    assert(obj.getMetadata("version") == nullptr, "CppObject.clearMetadata");

    obj.dispose();
    assert(obj.isDisposed() == true, "CppObject.dispose");
    return 0;
}

fn test_cpp_object_cache() {
    let cache = new CppObjectCache();
    cache.init_cache();
    assert(cache.getCount() == 0, "CppObjectCache.getCount default 0");

    let obj1 = new CppObject();
    obj1.init_object(0, "Widget");
    let id1 = cache.add(obj1);
    assert(id1 == 1, "CppObjectCache.add returns id 1");
    assert(cache.getCount() == 1, "CppObjectCache.getCount after add");

    let obj2 = new CppObject();
    obj2.init_object(0, "Button");
    let id2 = cache.add(obj2);
    assert(id2 == 2, "CppObjectCache.add returns id 2");

    let retrieved = cache.get(id1);
    assert(retrieved != nullptr, "CppObjectCache.get");
    assert(retrieved.getTypeName() == "Widget", "CppObjectCache.get type correct");

    let by_type = cache.getByType("Widget");
    assert(len(by_type) == 1, "CppObjectCache.getByType");

    let by_type2 = cache.getByType("Button");
    assert(len(by_type2) == 1, "CppObjectCache.getByType Button");

    let by_type3 = cache.getByType("NonExistent");
    assert(len(by_type3) == 0, "CppObjectCache.getByType non-existent");

    assert(cache.contains(id1) == true, "CppObjectCache.contains true");
    assert(cache.contains(999) == false, "CppObjectCache.contains false");

    let all = cache.getAll();
    assert(len(all) == 2, "CppObjectCache.getAll");

    assert(cache.getNextId() == 2, "CppObjectCache.getNextId");

    cache.remove(id1);
    assert(cache.contains(id1) == false, "CppObjectCache.remove");
    assert(cache.getCount() == 1, "CppObjectCache.getCount after remove");

    cache.clear();
    assert(cache.getCount() == 0, "CppObjectCache.clear");
    return 0;
}

fn test_cpp_shared_lib() {
    let lib = new CppSharedLib();
    lib.init_lib("QtCore", "6.5.0", "/usr/lib/libQt6Core.so");
    assert(lib.getName() == "QtCore", "CppSharedLib.getName");
    assert(lib.getVersion() == "6.5.0", "CppSharedLib.getVersion");
    assert(lib.getPath() == "/usr/lib/libQt6Core.so", "CppSharedLib.getPath");
    assert(lib.isLoaded() == false, "CppSharedLib.isLoaded default false");

    lib.setLoaded(true);
    assert(lib.isLoaded() == true, "CppSharedLib.setLoaded");

    assert(lib.isModule() == false, "CppSharedLib.isModule default false");
    lib.setModuleName("QtCore");
    assert(lib.getModuleName() == "QtCore", "CppSharedLib.setModuleName/getModuleName");

    let ti = new CppTypeInfo();
    ti.init_cpp_type("QString", "Qt", "QtCore");
    lib.addType(ti);
    assert(lib.getTypeCount() == 1, "CppSharedLib.addType/getTypeCount");

    let found = lib.getType("QString");
    assert(found != nullptr, "CppSharedLib.getType");
    assert(found.getTypeName() == "QString", "CppSharedLib.getType correct");

    let not_found = lib.getType("NonExistent");
    assert(not_found == nullptr, "CppSharedLib.getType missing");

    lib.addDependency("QtGui");
    lib.addDependency("QtWidgets");
    assert(lib.getDependencyCount() == 2, "CppSharedLib.addDependency/getDependencyCount");

    let deps = lib.getDependencies();
    assert(len(deps) == 2, "CppSharedLib.getDependencies");

    lib.removeType("QString");
    assert(lib.getTypeCount() == 0, "CppSharedLib.removeType");

    # add back and clear
    lib.addType(ti);
    lib.clear();
    assert(lib.getTypeCount() == 0, "CppSharedLib.clear types");
    assert(lib.getDependencyCount() == 0, "CppSharedLib.clear deps");
    return 0;
}

fn test_cpp_lib_loader() {
    let loader = new CppLibLoader();
    loader.init_loader();
    assert(loader.getLoadedCount() == 0, "CppLibLoader.getLoadedCount default 0");
    assert(loader.getLibCount() == 0, "CppLibLoader.getLibCount default 0");

    let lib1 = new CppSharedLib();
    lib1.init_lib("QtCore", "6.5", "/usr/lib/libQtCore.so");
    let lib2 = new CppSharedLib();
    lib2.init_lib("QtGui", "6.5", "/usr/lib/libQtGui.so");

    loader.register(lib1);
    loader.register(lib2);
    assert(loader.getLib("QtCore") != nullptr, "CppLibLoader.register/getLib");

    assert(loader.isLoaded("QtCore") == false, "CppLibLoader.isLoaded false");
    let loaded = loader.load("QtCore");
    assert(loaded != nullptr, "CppLibLoader.load returns lib");
    assert(loader.isLoaded("QtCore") == true, "CppLibLoader.isLoaded true");
    assert(loader.getLoadedCount() == 1, "CppLibLoader.getLoadedCount after load");

    loader.load("QtGui");
    assert(loader.getLoadedCount() == 2, "CppLibLoader.getLoadedCount 2");

    let all_libs = loader.getAllLibs();
    assert(len(all_libs) == 2, "CppLibLoader.getAllLibs");

    loader.unload("QtCore");
    assert(loader.isLoaded("QtCore") == false, "CppLibLoader.unload");
    assert(loader.getLoadedCount() == 1, "CppLibLoader.getLoadedCount after unload");

    assert(loader.getLibCount() == 2, "CppLibLoader.getLibCount registered");

    loader.clear();
    assert(loader.getLoadedCount() == 0, "CppLibLoader.clear");
    return 0;
}

fn test_cpp_constructor() {
    let ctor = new CppConstructor();
    ctor.init_ctor();
    assert(ctor.getParamCount() == 0, "CppConstructor.getParamCount default");
    assert(ctor.isDefault() == false, "CppConstructor.isDefault default");
    assert(ctor.isCopy() == false, "CppConstructor.isCopy default");
    assert(ctor.isMove() == false, "CppConstructor.isMove default");
    assert(ctor.isExplicit() == false, "CppConstructor.isExplicit default");

    ctor.addParam("int", "x");
    ctor.addParam("double", "y");
    assert(ctor.getParamCount() == 2, "CppConstructor.addParam");

    assert(ctor.getParamType(0) == "int", "CppConstructor.getParamType 0");
    assert(ctor.getParamType(1) == "double", "CppConstructor.getParamType 1");
    assert(ctor.getParamType(99) == "", "CppConstructor.getParamType out of bounds");

    let types = ctor.getParamTypes();
    assert(len(types) == 2, "CppConstructor.getParamTypes");
    let names = ctor.getParamNames();
    assert(len(names) == 2, "CppConstructor.getParamNames");

    ctor.setDefault(true);
    assert(ctor.isDefault() == true, "CppConstructor.setDefault");

    let ctor2 = new CppConstructor();
    ctor2.init_ctor();
    ctor2.setCopy(true);
    assert(ctor2.isCopy() == true, "CppConstructor.setCopy");

    let ctor3 = new CppConstructor();
    ctor3.init_ctor();
    ctor3.setMove(true);
    assert(ctor3.isMove() == true, "CppConstructor.setMove");

    let ctor4 = new CppConstructor();
    ctor4.init_ctor();
    ctor4.setExplicit(true);
    assert(ctor4.isExplicit() == true, "CppConstructor.setExplicit");
    return 0;
}

fn test_cpp_method() {
    let m = new CppMethod();
    m.init_method("calculate", "int");
    assert(m.getName() == "calculate", "CppMethod.getName");
    assert(m.getReturnType() == "int", "CppMethod.getReturnType");
    assert(m.getParamCount() == 0, "CppMethod.getParamCount default 0");
    assert(m.isStatic() == false, "CppMethod.isStatic default");
    assert(m.isVirtual() == false, "CppMethod.isVirtual default");
    assert(m.isConst() == false, "CppMethod.isConst default");
    assert(m.isNoexcept() == false, "CppMethod.isNoexcept default");
    assert(m.getVisibility() == "public", "CppMethod.getVisibility default public");

    m.addParam("int", "a");
    m.addParam("int", "b");
    assert(m.getParamCount() == 2, "CppMethod.addParam/getParamCount");
    assert(m.getParamType(0) == "int", "CppMethod.getParamType 0");
    assert(m.getParamType(1) == "int", "CppMethod.getParamType 1");

    let types = m.getParamTypes();
    assert(len(types) == 2, "CppMethod.getParamTypes");
    let names = m.getParamNames();
    assert(len(names) == 2, "CppMethod.getParamNames");

    m.setStatic(true);
    assert(m.isStatic() == true, "CppMethod.setStatic");

    m.setVirtual(true);
    assert(m.isVirtual() == true, "CppMethod.setVirtual");

    m.setConst(true);
    assert(m.isConst() == true, "CppMethod.setConst");

    m.setNoexcept(true);
    assert(m.isNoexcept() == true, "CppMethod.setNoexcept");

    m.setVisibility("protected");
    assert(m.getVisibility() == "protected", "CppMethod.setVisibility");

    m.addAnnotation("[[nodiscard]]");
    m.addAnnotation("[[deprecated]]");
    assert(m.hasAnnotation("[[nodiscard]]") == true, "CppMethod.hasAnnotation true");
    assert(m.hasAnnotation("[[maybe_unused]]") == false, "CppMethod.hasAnnotation false");

    let annos = m.getAnnotations();
    assert(len(annos) == 2, "CppMethod.getAnnotations");
    return 0;
}

fn test_cpp_field() {
    let f = new CppField();
    f.init_field("m_value", "int");
    assert(f.getName() == "m_value", "CppField.getName");
    assert(f.getType() == "int", "CppField.getType");
    assert(f.isStatic() == false, "CppField.isStatic default");
    assert(f.isConst() == false, "CppField.isConst default");
    assert(f.isMutable() == false, "CppField.isMutable default");
    assert(f.isVolatile() == false, "CppField.isVolatile default");
    assert(f.getVisibility() == "public", "CppField.getVisibility default");

    f.setStatic(true);
    assert(f.isStatic() == true, "CppField.setStatic");

    f.setConst(true);
    assert(f.isConst() == true, "CppField.setConst");

    f.setMutable(true);
    assert(f.isMutable() == true, "CppField.setMutable");

    f.setVolatile(true);
    assert(f.isVolatile() == true, "CppField.setVolatile");

    f.setDefaultValue(0);
    assert(f.getDefaultValue() == 0, "CppField.setDefaultValue/getDefaultValue");

    f.setVisibility("private");
    assert(f.getVisibility() == "private", "CppField.setVisibility");

    f.setPointer(true);
    assert(f.isPointer() == true, "CppField.setPointer/isPointer");

    f.setReference(true);
    assert(f.isReference() == true, "CppField.setReference/isReference");
    return 0;
}

