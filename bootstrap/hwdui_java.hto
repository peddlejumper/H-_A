# Section 7: 序列化层 — 跨运行时类型转换
# ═══════════════════════════════════════════════════════════════════════════

class JavaSerializer {
    let type_mapper = nullptr;
    let format = "json";
    let indent = false;
    let date_format = "ISO8601";
    let include_null = false;
    let custom_serializers = {};

    fn init_serializer(mapper) {
        self.type_mapper = mapper;
        self.format = "json";
        self.indent = false;
        self.date_format = "ISO8601";
        self.include_null = false;
        self.custom_serializers = {};
        return 0;
    }

    fn setFormat(f) { self.format = f; return 0; }
    fn setIndent(v) { self.indent = v; return 0; }
    fn setDateFormat(f) { self.date_format = f; return 0; }
    fn setIncludeNull(v) { self.include_null = v; return 0; }

    fn registerCustomSerializer(type_name, serializer) {
        self.custom_serializers[type_name] = serializer;
        return 0;
    }

    fn serialize(value, type_name) {
        if (value == nullptr) {
            return {"__type__": "null", "value": nullptr};
        }
        let custom = self.custom_serializers[type_name];
        if (custom != nullptr) {
            return custom(value);
        }
        return {"__type__": type_name, "value": value};
    }

    fn serializeObject(obj) {
        if (obj == nullptr) { return nullptr; }
        let result = {};
        for k in obj {
            let val = obj[k];
            if (val == nullptr and self.include_null == false) {
                continue;
            }
            result[k] = val;
        }
        return result;
    }

    fn serializeList(lst) {
        if (lst == nullptr) { return []; }
        let result = [];
        let i = 0;
        while (i < len(lst)) {
            push(result, lst[i]);
            i = i + 1;
        }
        return result;
    }

    fn getFormat() { return self.format; }
    fn isIndent() { return self.indent; }
}


class JavaDeserializer {
    let type_mapper = nullptr;
    let format = "json";
    let strict = false;
    let custom_deserializers = {};

    fn init_deserializer(mapper) {
        self.type_mapper = mapper;
        self.format = "json";
        self.strict = false;
        self.custom_deserializers = {};
        return 0;
    }

    fn setFormat(f) { self.format = f; return 0; }
    fn setStrict(v) { self.strict = v; return 0; }

    fn registerCustomDeserializer(type_name, deserializer) {
        self.custom_deserializers[type_name] = deserializer;
        return 0;
    }

    fn deserialize(data) {
        if (data == nullptr) { return nullptr; }
        let jtype = data["__type__"];
        if (jtype == nullptr) { return data; }
        let custom = self.custom_deserializers[jtype];
        if (custom != nullptr) {
            return custom(data);
        }
        return data["value"];
    }

    fn deserializeToType(data, target_type) {
        let value = self.deserialize(data);
        return value;
    }

    fn getFormat() { return self.format; }
    fn isStrict() { return self.strict; }
}


