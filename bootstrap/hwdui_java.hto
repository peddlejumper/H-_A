class JavaMavenArtifact {
    let group_id = "";
    let artifact_id = "";
    let version = "";
    let scope = "compile";
    let description = "";
    let dependencies = [];
    let is_installed = false;
    let install_path = "";

    fn init_artifact(group, artifact, ver) {
        self.group_id = group;
        self.artifact_id = artifact;
        self.version = ver;
        self.scope = "compile";
        self.description = "";
        self.dependencies = [];
        self.is_installed = false;
        self.install_path = "";
        return 0;
    }

    fn setScope(s) { self.scope = s; return 0; }
    fn setDescription(desc) { self.description = desc; return 0; }
    fn addDependency(group, artifact, ver) {
        push(self.dependencies, {"group": group, "artifact": artifact, "version": ver});
        return 0;
    }
    fn setInstalled(v) { self.is_installed = v; return 0; }
    fn setInstallPath(path) { self.install_path = path; return 0; }

    fn getGroupId() { return self.group_id; }
    fn getArtifactId() { return self.artifact_id; }
    fn getId() { return self.group_id + ":" + self.artifact_id; }
    fn getVersion() { return self.version; }
    fn getScope() { return self.scope; }
    fn getDescription() { return self.description; }
    fn getDependencies() { return self.dependencies; }
    fn isInstalled() { return self.is_installed; }
    fn getInstallPath() { return self.install_path; }
}


class JavaMavenManager {
    let artifacts = {};
    let repositories = [];
    let local_repo = "";

    fn init_maven() {
        self.artifacts = {};
        self.repositories = [];
        self.local_repo = "";
        self._add_default_repos();
        return 0;
    }

    fn _add_default_repos() {
        push(self.repositories, "https://repo1.maven.org/maven2");
        return 0;
    }

    fn addRepository(repo) {
        push(self.repositories, repo);
        return 0;
    }

    fn removeRepository(repo) {
        let new_repos = [];
        let i = 0;
        while (i < len(self.repositories)) {
            if (self.repositories[i] != repo) {
                push(new_repos, self.repositories[i]);
            }
            i = i + 1;
        }
        self.repositories = new_repos;
        return 0;
    }

    fn install(artifact) {
        let key = artifact.getId();
        artifact.setInstalled(true);
        self.artifacts[key] = artifact;
        return artifact;
    }

    fn uninstall(artifact_id) {
        self.artifacts[artifact_id] = nullptr;
        return 0;
    }

    fn isInstalled(artifact_id) {
        let art = self.artifacts[artifact_id];
        if (art != nullptr) {
            return art.isInstalled();
        }
        return false;
    }

    fn getArtifact(artifact_id) {
        return self.artifacts[artifact_id];
    }

    fn getInstalledArtifacts() {
        let installed = [];
        for k in self.artifacts {
            let art = self.artifacts[k];
            if (art != nullptr and art.isInstalled()) {
                push(installed, art);
            }
        }
        return installed;
    }

    fn setLocalRepo(path) { self.local_repo = path; return 0; }
    fn getLocalRepo() { return self.local_repo; }
    fn getRepositories() { return self.repositories; }
    fn getArtifactCount() {
        let count = 0;
        for k in self.artifacts {
            if (self.artifacts[k] != nullptr) {
                count = count + 1;
            }
        }
        return count;
    }
}


class JavaProject {
    let name = "";
    let project_type = "";
    let build_tool = "maven";
    let group_id = "";
    let artifact_id = "";
    let version = "";
    let dependencies = [];
    let plugins = [];
    let source_dirs = [];
    let main_class = "";
    let java_version = "17";

    fn init_project(name, proj_type) {
        self.name = name;
        self.project_type = proj_type;
        self.build_tool = "maven";
        self.group_id = "com.example";
        self.artifact_id = name;
        self.version = "1.0.0";
        self.dependencies = [];
        self.plugins = [];
        self.source_dirs = [];
        self.main_class = "";
        self.java_version = "17";
        return 0;
    }

    fn addDependency(artifact) { push(self.dependencies, artifact); return 0; }
    fn addPlugin(plugin_name, plugin_ver) {
        push(self.plugins, {"name": plugin_name, "version": plugin_ver});
        return 0;
    }
    fn addSourceDir(dir) { push(self.source_dirs, dir); return 0; }
    fn setBuildTool(tool) { self.build_tool = tool; return 0; }
    fn setGroupId(g) { self.group_id = g; return 0; }
    fn setArtifactId(a) { self.artifact_id = a; return 0; }
    fn setVersion(v) { self.version = v; return 0; }
    fn setMainClass(mc) { self.main_class = mc; return 0; }
    fn setJavaVersion(jv) { self.java_version = jv; return 0; }

    fn getName() { return self.name; }
    fn getProjectType() { return self.project_type; }
    fn getBuildTool() { return self.build_tool; }
    fn getGroupId() { return self.group_id; }
    fn getArtifactId() { return self.artifact_id; }
    fn getVersion() { return self.version; }
    fn getDependencies() { return self.dependencies; }
    fn getPlugins() { return self.plugins; }
    fn getSourceDirs() { return self.source_dirs; }
    fn getMainClass() { return self.main_class; }
    fn getJavaVersion() { return self.java_version; }
}


class JavaModule {
    let name = "";
    let projects = [];
    let build_config = "";

    fn init_module(name) {
        self.name = name;
        self.projects = [];
        self.build_config = "debug";
        return 0;
    }

    fn addProject(project) {
        push(self.projects, project);
        return 0;
    }

    fn removeProject(name) {
        let new_projects = [];
        let i = 0;
        while (i < len(self.projects)) {
            if (self.projects[i].getName() != name) {
                push(new_projects, self.projects[i]);
            }
            i = i + 1;
        }
        self.projects = new_projects;
        return 0;
    }

    fn getProject(name) {
        let i = 0;
        while (i < len(self.projects)) {
            if (self.projects[i].getName() == name) {
                return self.projects[i];
            }
            i = i + 1;
        }
        return nullptr;
    }

    fn getProjectCount() { return len(self.projects); }
    fn getProjects() { return self.projects; }
    fn getName() { return self.name; }
    fn setBuildConfig(c) { self.build_config = c; return 0; }
    fn getBuildConfig() { return self.build_config; }
}


