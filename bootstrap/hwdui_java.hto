# ═══════════════════════════════════════════════════════════════════════════
# hwdui_java.hto — H# zzwUI ↔ Java 协同开发库
# ═══════════════════════════════════════════════════════════════════════════
# 提供 H# 与 Java/JVM 运行时之间的完整互操作基础设施：
# - 类型映射与值转换
# - 对象代理与反射调用
# - 跨运行时事件总线
# - zzwUI 控件 ↔ JavaFX/Swing 控件桥接
# - 双向数据绑定
# - RPC 远程过程调用
# - 序列化与反序列化
# - 异步任务桥接
# - 诊断与配置
# ═══════════════════════════════════════════════════════════════════════════

import "bootstrap/hwdui.hto";

# ═══════════════════════════════════════════════════════════════════════════
# Section 1: 核心互操作层 — 类型映射、值包装、调用代理
# ═══════════════════════════════════════════════════════════════════════════

class JavaTypeInfo {
    let type_name = "";
    let package_name = "";
    let jar_source = "";
    let is_primitive = false;
    let is_array = false;
    let is_generic = false;
    let generic_args = [];
    let super_class = "";
    let interfaces = [];
    let is_enum = false;
    let is_annotation = false;
    let is_interface = false;
    let modifiers = [];
    let full_name = "";
    let jvm_signature = "";

    fn init_j_type(name, pkg, jar) {
        self.type_name = name;
        self.package_name = pkg;
        self.jar_source = jar;
        self.is_primitive = false;
        self.is_array = false;
        self.is_generic = false;
        self.generic_args = [];
        self.super_class = "";
        self.interfaces = [];
        self.is_enum = false;
        self.is_annotation = false;
        self.is_interface = false;
        self.modifiers = [];
        self.full_name = pkg + "." + name;
        if (pkg == "") {
            self.full_name = name;
        }
        self.jvm_signature = "L" + self.full_name + ";";
        return 0;
    }

    fn setPrimitive(v) { self.is_primitive = v; return 0; }
    fn setArray(v) { self.is_array = v; return 0; }
    fn setGeneric(v) { self.is_generic = v; return 0; }
    fn addGenericArg(arg) { push(self.generic_args, arg); return 0; }
    fn setSuperClass(sc) { self.super_class = sc; return 0; }
    fn addInterface(iface) { push(self.interfaces, iface); return 0; }
    fn setEnum(v) { self.is_enum = v; return 0; }
    fn setAnnotation(v) { self.is_annotation = v; return 0; }
    fn setInterface(v) { self.is_interface = v; return 0; }
    fn addModifier(mod) { push(self.modifiers, mod); return 0; }
    fn setJVMSignature(sig) { self.jvm_signature = sig; return 0; }

    fn getFullName() { return self.full_name; }
    fn getTypeName() { return self.type_name; }
    fn getPackageName() { return self.package_name; }
    fn getJarSource() { return self.jar_source; }
    fn isPrimitive() { return self.is_primitive; }
    fn isArray() { return self.is_array; }
    fn isEnum() { return self.is_enum; }
    fn isAnnotation() { return self.is_annotation; }
    fn isGeneric() { return self.is_generic; }
    fn isInterface() { return self.is_interface; }
    fn getSuperClass() { return self.super_class; }
    fn getInterfaces() { return self.interfaces; }
    fn getGenericArgs() { return self.generic_args; }
    fn getModifiers() { return self.modifiers; }
}


class JavaTypeMapper {
    let type_map = {};
    let reverse_map = {};
    let primitive_types = [];

    fn init_mapper() {
        self.type_map = {};
        self.reverse_map = {};
        self.primitive_types = [];
        self._register_defaults();
        return 0;
    }

    fn _register_defaults() {
        self.register("int", "int", true);
        self.register("float", "double", true);
        self.register("bool", "boolean", true);
        self.register("string", "java.lang.String", false);
        self.register("null", "java.lang.Object", false);
        self.register("list", "java.util.ArrayList", false);
        self.register("dict", "java.util.HashMap", false);
        self.register("long", "long", true);
        self.register("short", "short", true);
        self.register("byte", "byte", true);
        self.register("char", "char", true);
        self.register("int64", "java.lang.Long", false);
        self.register("int32", "java.lang.Integer", false);
        self.register("float64", "java.lang.Double", false);
        self.register("bool_obj", "java.lang.Boolean", false);
        self.register("void", "void", true);
        return 0;
    }

    fn register(htype, jtype, prim) {
        self.type_map[htype] = {"java": jtype, "primitive": prim};
        self.reverse_map[jtype] = htype;
        if (prim) {
            push(self.primitive_types, jtype);
        }
        return 0;
    }

    fn unregister(jtype) {
        let htype = self.reverse_map[jtype];
        if (htype != nullptr) {
            self.type_map[htype] = nullptr;
        }
        self.reverse_map[jtype] = nullptr;
        return 0;
    }

    fn toJava(htype) {
        let info = self.type_map[htype];
        if (info != nullptr) {
            return info["java"];
        }
        return "java.lang.Object";
    }

    fn toHSharp(jtype) {
        let htype = self.reverse_map[jtype];
        if (htype != nullptr) {
            return htype;
        }
        return "object";
    }

    fn isPrimitive(jtype) {
        let i = 0;
        while (i < len(self.primitive_types)) {
            if (self.primitive_types[i] == jtype) {
                return true;
            }
            i = i + 1;
        }
        return false;
    }

    fn getTypeInfo(jtype) {
        let info = new JavaTypeInfo();
        let parts = self._splitTypeName(jtype);
        info.init_j_type(parts["name"], parts["package"], "");
        return info;
    }

    fn _splitTypeName(full_name) {
        let last_dot = -1;
        let i = 0;
        while (i < len(full_name)) {
            if (full_name[i] == ".") {
                last_dot = i;
            }
            i = i + 1;
        }
        if (last_dot < 0) {
            return {"package": "", "name": full_name};
        }
        let pkg = "";
        i = 0;
        while (i < last_dot) {
            pkg = pkg + full_name[i];
            i = i + 1;
        }
        let nm = "";
        i = last_dot + 1;
        while (i < len(full_name)) {
            nm = nm + full_name[i];
            i = i + 1;
        }
        return {"package": pkg, "name": nm};
    }

    fn registerCustom(htype, jtype) {
        self.register(htype, jtype, false);
        return 0;
    }

    fn clear() {
        self.type_map = {};
        self.reverse_map = {};
        self.primitive_types = [];
        return 0;
    }
}


class JavaValue {
    let value = nullptr;
    let type_name = "java.lang.Object";
    let is_null = true;
    let is_primitive = false;
    let array_dim = 0;

    fn init_jval(val, tn) {
        self.value = val;
        self.type_name = tn;
        self.is_null = (val == nullptr);
        self.is_primitive = false;
        self.array_dim = 0;
        return 0;
    }

    fn setPrimitive(p) { self.is_primitive = p; return 0; }
    fn setArrayDim(d) { self.array_dim = d; return 0; }

    fn getValue() { return self.value; }
    fn getTypeName() { return self.type_name; }
    fn isNull() { return self.is_null; }
    fn isPrimitive() { return self.is_primitive; }
    fn getArrayDim() { return self.array_dim; }

    fn asInt() {
        if (self.is_null) { return 0; }
        return self.value;
    }

    fn asFloat() {
        if (self.is_null) { return 0.0; }
        return self.value;
    }

    fn asBool() {
        if (self.is_null) { return false; }
        return self.value;
    }

    fn asString() {
        if (self.is_null) { return ""; }
        return self.value;
    }

    fn asList() {
        if (self.is_null) { return []; }
        return self.value;
    }

    fn asDict() {
        if (self.is_null) { return {}; }
        return self.value;
    }
}


class JavaInvoke {
    let target = nullptr;
    let method_name = "";
    let args = [];
    let type_args = [];
    let is_static = false;
    let is_getter = false;
    let is_setter = false;
    let property_name = "";
    let timeout_ms = 30000;
    let call_id = 0;

    fn init_invoke(method, arg_list) {
        self.method_name = method;
        self.args = arg_list;
        self.type_args = [];
        self.is_static = false;
        self.is_getter = false;
        self.is_setter = false;
        self.timeout_ms = 30000;
        self.call_id = 0;
        return 0;
    }

    fn setTarget(t) { self.target = t; return 0; }
    fn setStatic(v) { self.is_static = v; return 0; }
    fn addTypeArg(ta) { push(self.type_args, ta); return 0; }
    fn setTimeout(ms) { self.timeout_ms = ms; return 0; }

    fn setGetter(prop_name) {
        self.is_getter = true;
        self.property_name = prop_name;
        return 0;
    }

    fn setSetter(prop_name, value) {
        self.is_setter = true;
        self.property_name = prop_name;
        self.args = [value];
        return 0;
    }

    fn getMethodName() { return self.method_name; }
    fn getArgs() { return self.args; }
    fn getArgCount() { return len(self.args); }
    fn isStatic() { return self.is_static; }
    fn isGetter() { return self.is_getter; }
    fn isSetter() { return self.is_setter; }
    fn getPropertyName() { return self.property_name; }
    fn getTimeout() { return self.timeout_ms; }
}


class JavaResult {
    let value = nullptr;
    let success = false;
    let error_message = "";
    let error_type = "";
    let stack_trace = "";
    let call_id = 0;
    let duration_ms = 0;
    let is_exception = false;

    fn init_result() {
        self.value = nullptr;
        self.success = false;
        self.error_message = "";
        self.error_type = "";
        self.stack_trace = "";
        self.call_id = 0;
        self.duration_ms = 0;
        self.is_exception = false;
        return 0;
    }

    fn setSuccess(val) {
        self.value = val;
        self.success = true;
        return 0;
    }

    fn setError(msg, etype) {
        self.error_message = msg;
        self.error_type = etype;
        self.success = false;
        self.is_exception = true;
        return 0;
    }

    fn setStackTrace(trace) { self.stack_trace = trace; return 0; }
    fn setCallId(id) { self.call_id = id; return 0; }
    fn setDuration(ms) { self.duration_ms = ms; return 0; }

    fn isSuccess() { return self.success; }
    fn isException() { return self.is_exception; }
    fn getValue() { return self.value; }
    fn getError() { return self.error_message; }
    fn getErrorType() { return self.error_type; }
    fn getCallId() { return self.call_id; }
    fn getStackTrace() { return self.stack_trace; }
    fn getDuration() { return self.duration_ms; }

    fn unwrap() {
        if (self.success == false) {
            print("JavaError: " + self.error_message);
            return nullptr;
        }
        return self.value;
    }

    fn expect(msg) {
        if (self.success == false) {
            print("JavaError: " + msg + " - " + self.error_message);
        }
        return self.value;
    }
}


# ═══════════════════════════════════════════════════════════════════════════
# Section 2: 对象桥接层 — 对象代理、类型描述、JAR
# ═══════════════════════════════════════════════════════════════════════════

class JavaObject {
    let object_id = 0;
    let type_name = "";
    let is_disposed = false;
    let properties = {};
    let cached_methods = [];
    let cached_getters = [];
    let is_remote = false;
    let remote_endpoint = "";
    let metadata = {};

    fn init_jobj(obj_id, tn) {
        self.object_id = obj_id;
        self.type_name = tn;
        self.is_disposed = false;
        self.properties = {};
        self.cached_methods = [];
        self.cached_getters = [];
        self.is_remote = false;
        self.remote_endpoint = "";
        self.metadata = {};
        return 0;
    }

    fn getObjectId() { return self.object_id; }
    fn getTypeName() { return self.type_name; }
    fn isDisposed() { return self.is_disposed; }

    fn setProperty(name, value) {
        self.properties[name] = value;
        return 0;
    }

    fn getProperty(name) {
        return self.properties[name];
    }

    fn hasProperty(name) {
        return self.properties[name] != nullptr;
    }

    fn cacheMethod(method_name) {
        push(self.cached_methods, method_name);
        return 0;
    }

    fn hasMethod(method_name) {
        let i = 0;
        while (i < len(self.cached_methods)) {
            if (self.cached_methods[i] == method_name) {
                return true;
            }
            i = i + 1;
        }
        return false;
    }

    fn cacheGetter(prop_name) {
        push(self.cached_getters, prop_name);
        return 0;
    }

    fn setRemote(endpoint) {
        self.is_remote = true;
        self.remote_endpoint = endpoint;
        return 0;
    }

    fn isRemote() { return self.is_remote; }
    fn getRemoteEndpoint() { return self.remote_endpoint; }

    fn dispose() {
        self.is_disposed = true;
        self.properties = {};
        self.cached_methods = [];
        self.cached_getters = [];
        return 0;
    }

    fn setMetadata(key, value) {
        self.metadata[key] = value;
        return 0;
    }

    fn getMetadata(key) {
        return self.metadata[key];
    }
}


class JavaObjectCache {
    let objects = {};
    let id_counter = 0;
    let max_cached = 1000;
    let lru_queue = [];

    fn init_cache() {
        self.objects = {};
        self.id_counter = 0;
        self.max_cached = 1000;
        self.lru_queue = [];
        return 0;
    }

    fn add(obj) {
        let obj_id = self._next_id();
        obj.object_id = obj_id;
        self.objects[obj_id] = obj;
        push(self.lru_queue, obj_id);
        if (len(self.lru_queue) > self.max_cached) {
            let oldest = self.lru_queue[0];
            let new_q = [];
            let i = 1;
            while (i < len(self.lru_queue)) {
                push(new_q, self.lru_queue[i]);
                i = i + 1;
            }
            self.lru_queue = new_q;
            self.objects[oldest] = nullptr;
        }
        return obj_id;
    }

    fn get(obj_id) {
        let obj = self.objects[obj_id];
        if (obj != nullptr) {
            self._touch(obj_id);
        }
        return obj;
    }

    fn remove(obj_id) {
        let obj = self.objects[obj_id];
        if (obj != nullptr) {
            obj.dispose();
        }
        self.objects[obj_id] = nullptr;
        let new_q = [];
        let i = 0;
        while (i < len(self.lru_queue)) {
            if (self.lru_queue[i] != obj_id) {
                push(new_q, self.lru_queue[i]);
            }
            i = i + 1;
        }
        self.lru_queue = new_q;
        return 0;
    }

    fn clear() {
        for k in self.objects {
            let obj = self.objects[k];
            if (obj != nullptr) {
                obj.dispose();
            }
        }
        self.objects = {};
        self.lru_queue = [];
        self.id_counter = 0;
        return 0;
    }

    fn getCount() {
        let count = 0;
        for k in self.objects {
            if (self.objects[k] != nullptr) {
                count = count + 1;
            }
        }
        return count;
    }

    fn contains(obj_id) {
        return self.objects[obj_id] != nullptr;
    }

    fn _next_id() {
        self.id_counter = self.id_counter + 1;
        return self.id_counter;
    }

    fn _touch(obj_id) {
        let new_q = [];
        let i = 0;
        while (i < len(self.lru_queue)) {
            if (self.lru_queue[i] != obj_id) {
                push(new_q, self.lru_queue[i]);
            }
            i = i + 1;
        }
        push(new_q, obj_id);
        self.lru_queue = new_q;
        return 0;
    }
}


class JavaJarInfo {
    let name = "";
    let version = "";
    let path = "";
    let types = [];
    let dependencies = [];
    let is_loaded = false;
    let is_module = false;
    let module_name = "";

    fn init_jar(name, ver, path) {
        self.name = name;
        self.version = ver;
        self.path = path;
        self.types = [];
        self.dependencies = [];
        self.is_loaded = false;
        self.is_module = false;
        self.module_name = "";
        return 0;
    }

    fn addType(type_info) {
        push(self.types, type_info);
        return 0;
    }

    fn addDependency(dep_name) {
        push(self.dependencies, dep_name);
        return 0;
    }

    fn getType(type_name) {
        let i = 0;
        while (i < len(self.types)) {
            let t = self.types[i];
            if (t.getFullName() == type_name or t.getTypeName() == type_name) {
                return t;
            }
            i = i + 1;
        }
        return nullptr;
    }

    fn getTypeCount() { return len(self.types); }
    fn getDependencyCount() { return len(self.dependencies); }
    fn getName() { return self.name; }
    fn getVersion() { return self.version; }
    fn getPath() { return self.path; }
    fn isLoaded() { return self.is_loaded; }
    fn setLoaded(v) { self.is_loaded = v; return 0; }
    fn setModule(v) { self.is_module = v; return 0; }
    fn setModuleName(name) { self.module_name = name; return 0; }
    fn isModule() { return self.is_module; }
    fn getModuleName() { return self.module_name; }
}


class JavaClassLoader {
    let jars = {};
    let loaded_count = 0;
    let classpath_entries = [];

    fn init_loader() {
        self.jars = {};
        self.loaded_count = 0;
        self.classpath_entries = [];
        return 0;
    }

    fn addClassPathEntry(path) {
        push(self.classpath_entries, path);
        return 0;
    }

    fn register(jar) {
        self.jars[jar.name] = jar;
        return 0;
    }

    fn getJar(name) {
        return self.jars[name];
    }

    fn load(name) {
        let jar = self.jars[name];
        if (jar != nullptr) {
            jar.setLoaded(true);
            self.loaded_count = self.loaded_count + 1;
        }
        return jar;
    }

    fn unload(name) {
        let jar = self.jars[name];
        if (jar != nullptr) {
            jar.setLoaded(false);
            self.loaded_count = self.loaded_count - 1;
        }
        return 0;
    }

    fn isLoaded(name) {
        let jar = self.jars[name];
        if (jar != nullptr) {
            return jar.isLoaded();
        }
        return false;
    }

    fn getLoadedCount() { return self.loaded_count; }
    fn getJarCount() {
        let count = 0;
        for k in self.jars {
            count = count + 1;
        }
        return count;
    }

    fn clear() {
        self.jars = {};
        self.loaded_count = 0;
        return 0;
    }
}


class JavaConstructor {
    let type_name = "";
    let params = [];
    let param_names = [];
    let visibility = "public";

    fn init_ctor(tn) {
        self.type_name = tn;
        self.params = [];
        self.param_names = [];
        self.visibility = "public";
        return 0;
    }

    fn addParam(ptype, pname) {
        push(self.params, ptype);
        push(self.param_names, pname);
        return 0;
    }

    fn getParamCount() { return len(self.params); }
    fn getParams() { return self.params; }
    fn getParamNames() { return self.param_names; }
    fn getParamType(index) {
        if (index >= 0 and index < len(self.params)) {
            return self.params[index];
        }
        return "";
    }
}


class JavaMethod {
    let name = "";
    let return_type = "void";
    let params = [];
    let param_names = [];
    let is_static = false;
    let is_synchronized = false;
    let is_native = false;
    let visibility = "public";
    let annotations = [];
    let throws_exceptions = [];

    fn init_method(name, ret_type) {
        self.name = name;
        self.return_type = ret_type;
        self.params = [];
        self.param_names = [];
        self.is_static = false;
        self.is_synchronized = false;
        self.is_native = false;
        self.visibility = "public";
        self.annotations = [];
        self.throws_exceptions = [];
        return 0;
    }

    fn addParam(ptype, pname) {
        push(self.params, ptype);
        push(self.param_names, pname);
        return 0;
    }

    fn setStatic(v) { self.is_static = v; return 0; }
    fn setSynchronized(v) { self.is_synchronized = v; return 0; }
    fn setNative(v) { self.is_native = v; return 0; }
    fn setVisibility(v) { self.visibility = v; return 0; }
    fn addAnnotation(anno) { push(self.annotations, anno); return 0; }
    fn addThrows(ex) { push(self.throws_exceptions, ex); return 0; }

    fn getName() { return self.name; }
    fn getReturnType() { return self.return_type; }
    fn getParamCount() { return len(self.params); }
    fn getParams() { return self.params; }
    fn getParamNames() { return self.param_names; }
    fn isStatic() { return self.is_static; }
    fn isSynchronized() { return self.is_synchronized; }
    fn isNative() { return self.is_native; }
    fn getVisibility() { return self.visibility; }
    fn hasAnnotation(name) {
        let i = 0;
        while (i < len(self.annotations)) {
            if (self.annotations[i] == name) {
                return true;
            }
            i = i + 1;
        }
        return false;
    }
}


class JavaField {
    let name = "";
    let type_name = "";
    let is_static = false;
    let is_final = false;
    let is_transient = false;
    let is_volatile = false;
    let visibility = "public";

    fn init_field(name, tn) {
        self.name = name;
        self.type_name = tn;
        self.is_static = false;
        self.is_final = false;
        self.is_transient = false;
        self.is_volatile = false;
        self.visibility = "public";
        return 0;
    }

    fn setStatic(v) { self.is_static = v; return 0; }
    fn setFinal(v) { self.is_final = v; return 0; }
    fn setTransient(v) { self.is_transient = v; return 0; }
    fn setVolatile(v) { self.is_volatile = v; return 0; }
    fn setVisibility(v) { self.visibility = v; return 0; }

    fn getName() { return self.name; }
    fn getType() { return self.type_name; }
    fn isStatic() { return self.is_static; }
    fn isFinal() { return self.is_final; }
    fn isTransient() { return self.is_transient; }
    fn isVolatile() { return self.is_volatile; }
}


# ═══════════════════════════════════════════════════════════════════════════
# Section 3: 事件桥接层 — 跨运行时事件总线
# ═══════════════════════════════════════════════════════════════════════════

class JavaEvent {
    let name = "";
    let listener_type = "";
    let is_static = false;
    let listeners = [];
    let is_remote = false;

    fn init_event(name, listener) {
        self.name = name;
        self.listener_type = listener;
        self.is_static = false;
        self.listeners = [];
        self.is_remote = false;
        return 0;
    }

    fn addListener(listener) {
        push(self.listeners, listener);
        return 0;
    }

    fn removeListener(listener) {
        let new_listeners = [];
        let i = 0;
        while (i < len(self.listeners)) {
            if (self.listeners[i] != listener) {
                push(new_listeners, self.listeners[i]);
            }
            i = i + 1;
        }
        self.listeners = new_listeners;
        return 0;
    }

    fn getListenerCount() { return len(self.listeners); }
    fn getListeners() { return self.listeners; }
    fn getName() { return self.name; }
    fn getListenerType() { return self.listener_type; }
    fn setStatic(v) { self.is_static = v; return 0; }
    fn isStatic() { return self.is_static; }
    fn setRemote(v) { self.is_remote = v; return 0; }
    fn isRemote() { return self.is_remote; }
}


class JavaEventListener {
    let listener_id = 0;
    let event_name = "";
    let callback = nullptr;
    let is_oneshot = false;
    let filter_fn = nullptr;
    let is_active = true;

    fn init_listener(event_name, cb) {
        self.event_name = event_name;
        self.callback = cb;
        self.is_oneshot = false;
        self.filter_fn = nullptr;
        self.is_active = true;
        self.listener_id = 0;
        return 0;
    }

    fn setOneShot(v) { self.is_oneshot = v; return 0; }
    fn setFilter(filter_fn) { self.filter_fn = filter_fn; return 0; }
    fn setActive(v) { self.is_active = v; return 0; }
    fn setId(id) { self.listener_id = id; return 0; }

    fn getId() { return self.listener_id; }
    fn getEventName() { return self.event_name; }
    fn isActive() { return self.is_active; }
    fn isOneShot() { return self.is_oneshot; }

    fn onEvent(sender, args) {
        if (self.is_active == false) { return 0; }
        if (self.filter_fn != nullptr) {
            if (self.filter_fn(sender, args) == false) {
                return 0;
            }
        }
        if (self.callback != nullptr) {
            self.callback(sender, args);
        }
        if (self.is_oneshot) {
            self.is_active = false;
        }
        return 0;
    }
}


class JavaCrossEventBus {
    let events = {};
    let remote_events = {};
    let listener_counter = 0;
    let bridge_enabled = false;

    fn init_cross_bus() {
        self.events = {};
        self.remote_events = {};
        self.listener_counter = 0;
        self.bridge_enabled = false;
        return 0;
    }

    fn subscribe(event_name, callback) {
        let evt = self.events[event_name];
        if (evt == nullptr) {
            evt = new JavaEvent();
            evt.init_event(event_name, "java.util.EventListener");
            self.events[event_name] = evt;
        }
        let listener = new JavaEventListener();
        listener.init_listener(event_name, callback);
        self.listener_counter = self.listener_counter + 1;
        listener.setId(self.listener_counter);
        evt.addListener(listener);
        return listener;
    }

    fn unsubscribe(event_name, listener) {
        let evt = self.events[event_name];
        if (evt != nullptr) {
            evt.removeListener(listener);
        }
        return 0;
    }

    fn publish(event_name, sender, args) {
        let evt = self.events[event_name];
        if (evt == nullptr) { return 0; }
        let listeners = evt.getListeners();
        let i = 0;
        while (i < len(listeners)) {
            listeners[i].onEvent(sender, args);
            i = i + 1;
        }
        return 0;
    }

    fn subscribeRemote(event_name, callback) {
        return self.subscribe(event_name, callback);
    }

    fn publishRemote(event_name, data) {
        let evt = self.remote_events[event_name];
        if (evt == nullptr) {
            evt = new JavaEvent();
            evt.init_event(event_name, "java.util.EventListener");
            evt.setRemote(true);
            self.remote_events[event_name] = evt;
        }
        return self.publish(event_name, nullptr, data);
    }

    fn enableBridge() {
        self.bridge_enabled = true;
        return 0;
    }

    fn disableBridge() {
        self.bridge_enabled = false;
        return 0;
    }

    fn isBridgeEnabled() { return self.bridge_enabled; }

    fn getEventCount() {
        let count = 0;
        for k in self.events {
            count = count + 1;
        }
        for k in self.remote_events {
            count = count + 1;
        }
        return count;
    }

    fn clear() {
        self.events = {};
        self.remote_events = {};
        self.listener_counter = 0;
        return 0;
    }

    fn clearEvent(event_name) {
        let new_events = {};
        for k in self.events {
            if (k != event_name) {
                new_events[k] = self.events[k];
            }
        }
        self.events = new_events;
        let new_remote = {};
        for k in self.remote_events {
            if (k != event_name) {
                new_remote[k] = self.remote_events[k];
            }
        }
        self.remote_events = new_remote;
        return 0;
    }
}


class JavaUIDispatcher {
    let invoke_queue = [];
    let is_processing = false;
    let main_thread_id = 0;
    let sync_context = nullptr;

    fn init_dispatcher() {
        self.invoke_queue = [];
        self.is_processing = false;
        self.main_thread_id = 0;
        self.sync_context = nullptr;
        return 0;
    }

    fn invoke(action) {
        push(self.invoke_queue, {"action": action, "sync": true, "result": nullptr, "done": false});
        return 0;
    }

    fn invokeLater(action) {
        push(self.invoke_queue, {"action": action, "sync": false, "result": nullptr, "done": false});
        return 0;
    }

    fn processQueue() {
        if (self.is_processing) { return 0; }
        self.is_processing = true;
        let i = 0;
        while (i < len(self.invoke_queue)) {
            let item = self.invoke_queue[i];
            if (item["done"] == false and item["action"] != nullptr) {
                item["action"]();
                item["done"] = true;
            }
            i = i + 1;
        }
        let new_q = [];
        i = 0;
        while (i < len(self.invoke_queue)) {
            if (self.invoke_queue[i]["done"] == false) {
                push(new_q, self.invoke_queue[i]);
            }
            i = i + 1;
        }
        self.invoke_queue = new_q;
        self.is_processing = false;
        return 0;
    }

    fn getQueueSize() { return len(self.invoke_queue); }
    fn clear() { self.invoke_queue = []; return 0; }
}


