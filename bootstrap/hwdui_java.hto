    fn init_context(req, resp) {
        self.request = req;
        self.response = resp;
        self.user_data = nullptr;
        self.is_authenticated = false;
        self.principal = "";
        return 0;
    }

    fn setAuthenticated(v) { self.is_authenticated = v; return 0; }
    fn setPrincipal(p) { self.principal = p; return 0; }
    fn setUserData(data) { self.user_data = data; return 0; }

    fn getRequest() { return self.request; }
    fn getResponse() { return self.response; }
    fn isAuthenticated() { return self.is_authenticated; }
    fn getPrincipal() { return self.principal; }
    fn getUserData() { return self.user_data; }
}


class JavaSocketChannel {
    let host = "";
    let port = 0;
    let is_connected = false;
    let buffer_size = 4096;
    let onMessage = nullptr;
    let onConnected = nullptr;
    let onDisconnected = nullptr;
    let use_ssl = false;

    fn init_channel(host, port) {
        self.host = host;
        self.port = port;
        self.is_connected = false;
        self.buffer_size = 4096;
        self.onMessage = nullptr;
        self.onConnected = nullptr;
        self.onDisconnected = nullptr;
        self.use_ssl = false;
        return 0;
    }

    fn setBufferSize(size) { self.buffer_size = size; return 0; }
    fn setOnMessage(callback) { self.onMessage = callback; return 0; }
    fn setOnConnected(callback) { self.onConnected = callback; return 0; }
    fn setOnDisconnected(callback) { self.onDisconnected = callback; return 0; }
    fn setSSL(v) { self.use_ssl = v; return 0; }

    fn connect() {
        self.is_connected = true;
        if (self.onConnected != nullptr) {
            self.onConnected(self);
        }
        return 0;
    }

    fn disconnect() {
        self.is_connected = false;
        if (self.onDisconnected != nullptr) {
            self.onDisconnected(self);
        }
        return 0;
    }

    fn send(data) {
        if (self.is_connected == false) { return false; }
        return true;
    }

    fn isConnected() { return self.is_connected; }
    fn getHost() { return self.host; }
    fn getPort() { return self.port; }
    fn isSSL() { return self.use_ssl; }
}


class JavaMappedByteBuffer {
