        self.os_name = "";
        self.java_version = "";
        self.java_vendor = "";
        self.is_64bit = true;
        self.machine_name = "";
        self.user_name = "";
        self.processor_count = 0;
        self.working_directory = ".";
        self.classpath = "";
        self.system_properties = {};
        return 0;
    }

    fn setOSName(v) { self.os_name = v; return 0; }
    fn setJavaVersion(v) { self.java_version = v; return 0; }
    fn setJavaVendor(v) { self.java_vendor = v; return 0; }
    fn setIs64Bit(v) { self.is_64bit = v; return 0; }
    fn setMachineName(v) { self.machine_name = v; return 0; }
    fn setUserName(v) { self.user_name = v; return 0; }
    fn setProcessorCount(v) { self.processor_count = v; return 0; }
    fn setWorkingDirectory(v) { self.working_directory = v; return 0; }
    fn setClassPath(v) { self.classpath = v; return 0; }

    fn setSystemProperty(key, value) {
        self.system_properties[key] = value;
        return 0;
    }

    fn getSystemProperty(key) {
        return self.system_properties[key];
    }

    fn getOSName() { return self.os_name; }
    fn getJavaVersion() { return self.java_version; }
    fn getJavaVendor() { return self.java_vendor; }
    fn is64Bit() { return self.is_64bit; }
    fn getMachineName() { return self.machine_name; }
    fn getUserName() { return self.user_name; }
    fn getProcessorCount() { return self.processor_count; }
    fn getWorkingDirectory() { return self.working_directory; }
    fn getClassPath() { return self.classpath; }

    fn getSystemProperties() {
        let props = [];
        for k in self.system_properties {
            push(props, {"key": k, "value": self.system_properties[k]});
        }
        return props;
    }
}


class JavaProcess {
    let process_id = 0;
    let process_name = "";
    let start_time = 0;
    let exit_code = -1;
    let is_running = false;
    let arguments = [];
    let working_dir = "";
    let redirect_output = false;
    let onExit = nullptr;

    fn init_process(name, args) {
        self.process_name = name;
        self.arguments = args;
        self.process_id = 0;
        self.start_time = 0;
        self.exit_code = -1;
        self.is_running = false;
        self.working_dir = ".";
        self.redirect_output = false;
        self.onExit = nullptr;
        return 0;
    }

    fn start() {
        self.is_running = true;
        self.start_time = 0;
        return 0;
    }

    fn destroy() {
        self.is_running = false;
        self.exit_code = -1;
        return 0;
    }

    fn waitFor() {
        return self.exit_code;
    }

    fn setWorkingDir(dir) { self.working_dir = dir; return 0; }
    fn setRedirectOutput(v) { self.redirect_output = v; return 0; }
    fn setOnExit(callback) { self.onExit = callback; return 0; }

    fn getProcessId() { return self.process_id; }
    fn getProcessName() { return self.process_name; }
    fn isRunning() { return self.is_running; }
    fn getExitCode() { return self.exit_code; }
    fn getArguments() { return self.arguments; }
    fn getWorkingDir() { return self.working_dir; }
}


