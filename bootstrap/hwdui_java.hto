class JavaFXML {
    let fxml_content = "";
    let namespaces = {};
    let resources = {};
    let root_element = "";
    let controller_class = "";

    fn init_fxml() {
        self.fxml_content = "";
        self.namespaces = {};
        self.resources = {};
        self.root_element = "";
        self.controller_class = "";
        self._add_default_namespaces();
        return 0;
    }

    fn _add_default_namespaces() {
        self.namespaces["fx"] = "http://javafx.com/fxml";
        return 0;
    }

    fn addNamespace(prefix, uri) {
        self.namespaces[prefix] = uri;
        return 0;
    }

    fn setRootElement(element) {
        self.root_element = element;
        return 0;
    }

    fn setControllerClass(cls) {
        self.controller_class = cls;
        return 0;
    }

    fn addResource(key, value) {
        self.resources[key] = value;
        return 0;
    }

    fn getResource(key) {
        return self.resources[key];
    }

    fn setContent(fxml) {
        self.fxml_content = fxml;
        return 0;
    }

    fn getContent() { return self.fxml_content; }
    fn getRootElement() { return self.root_element; }
    fn getControllerClass() { return self.controller_class; }
    fn getResources() { return self.resources; }
    fn getNamespaces() { return self.namespaces; }

    fn clear() {
        self.fxml_content = "";
        self.resources = {};
        self.root_element = "";
        return 0;
    }
}


class JavaFXMLLoader {
    let fxml = nullptr;
    let parsed_elements = [];
    let controller = nullptr;

    fn init_loader(fxml) {
        self.fxml = fxml;
        self.parsed_elements = [];
        self.controller = nullptr;
        return 0;
    }

    fn load() {
        if (self.fxml == nullptr) { return []; }
        return self.parsed_elements;
    }

    fn setController(ctrl) { self.controller = ctrl; return 0; }
    fn getController() { return self.controller; }
    fn getElements() { return self.parsed_elements; }
    fn getElementCount() { return len(self.parsed_elements); }
}


class JavaStyleBridge {
    let hwidget_styles = {};
    let java_styles = {};
    let mapped_properties = [];

    fn init_style_bridge() {
        self.hwidget_styles = {};
        self.java_styles = {};
        self.mapped_properties = [];
        self._register_mappings();
        return 0;
    }

    fn _register_mappings() {
        push(self.mapped_properties, {"hwdui": "bg_color", "java": "-fx-background-color"});
        push(self.mapped_properties, {"hwdui": "fg_color", "java": "-fx-text-fill"});
        push(self.mapped_properties, {"hwdui": "border_color", "java": "-fx-border-color"});
        push(self.mapped_properties, {"hwdui": "border_width", "java": "-fx-border-width"});
        push(self.mapped_properties, {"hwdui": "font_size", "java": "-fx-font-size"});
        push(self.mapped_properties, {"hwdui": "font_family", "java": "-fx-font-family"});
        push(self.mapped_properties, {"hwdui": "padding", "java": "-fx-padding"});
        return 0;
    }

    fn addMapping(hwdui_prop, java_prop) {
        push(self.mapped_properties, {"hwdui": hwdui_prop, "java": java_prop});
        return 0;
    }

    fn toJavaFX(hwdui_styles) {
        let javafx = {};
        let i = 0;
        while (i < len(self.mapped_properties)) {
            let mapping = self.mapped_properties[i];
            let hprop = mapping["hwdui"];
            let jprop = mapping["java"];
            let val = hwdui_styles[hprop];
            if (val != nullptr) {
                javafx[jprop] = val;
            }
            i = i + 1;
        }
        return javafx;
    }

    fn toHwdUI(javafx_styles) {
        let hwdui = {};
        let i = 0;
        while (i < len(self.mapped_properties)) {
            let mapping = self.mapped_properties[i];
            let hprop = mapping["hwdui"];
            let jprop = mapping["java"];
            let val = javafx_styles[jprop];
            if (val != nullptr) {
                hwdui[hprop] = val;
            }
            i = i + 1;
        }
        return hwdui;
    }

    fn getMappings() { return self.mapped_properties; }
    fn getMappingCount() { return len(self.mapped_properties); }
}


