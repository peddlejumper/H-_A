# Section 13: 全局函数与初始化
# ═══════════════════════════════════════════════════════════════════════════

let _j_mapper = new JavaTypeMapper();
let _j_cache = new JavaObjectCache();
let _j_event_bus = new JavaCrossEventBus();
let _j_binding_mgr = new JavaBindingManager();
let _j_serializer = new JavaSerializer(_j_mapper);
let _j_deserializer = new JavaDeserializer(_j_mapper);
let _j_type_converter = new JavaTypeConverter();
let _j_logger = new JavaLogger();
let _j_profiler = new JavaProfiler();
let _j_config = new JavaConfig();
let _j_env = new JavaEnvironment();
let _j_class_loader = new JavaClassLoader();
let _j_control_factory = new JavaControlFactory();
let _j_style_bridge = new JavaStyleBridge();
let _j_fxml = new JavaFXML();
let _j_resource_bundle = new JavaResourceBundle();
let _j_maven = new JavaMavenManager();
let _j_executor = new JavaExecutorService();
let _j_is_initialized = false;

_j_mapper.init_mapper();
_j_cache.init_cache();
_j_event_bus.init_cross_bus();
_j_binding_mgr.init_binding_mgr();
_j_serializer.init_serializer(_j_mapper);
_j_deserializer.init_deserializer(_j_mapper);
_j_type_converter.init_converter();
_j_logger.init_logger();
_j_profiler.init_profiler();
_j_config.init_config();
_j_env.init_env();
_j_class_loader.init_loader();
_j_control_factory.init_factory();
_j_style_bridge.init_style_bridge();
_j_fxml.init_fxml();
_j_resource_bundle.init_bundle();
_j_maven.init_maven();
_j_executor.init_executor();

fn java_init() {
    _j_is_initialized = true;
    _j_logger.info("java_init: H# ↔ Java interop initialized");
    _j_logger.info("java_init: " + "type mappings, object cache, event bus, bindings ready");
    return true;
}

fn java_shutdown() {
    _j_cache.clear();
    _j_event_bus.clear();
    _j_binding_mgr.clear();
    _j_config.clear();
    _j_executor.cancelAll();
    _j_is_initialized = false;
    _j_logger.info("java_shutdown: H# ↔ Java interop shut down");
    return 0;
}

fn java_is_ready() {
    return _j_is_initialized;
}

fn java_get_mapper() { return _j_mapper; }
fn java_get_cache() { return _j_cache; }
fn java_get_event_bus() { return _j_event_bus; }
fn java_get_binding_manager() { return _j_binding_mgr; }
fn java_get_serializer() { return _j_serializer; }
fn java_get_deserializer() { return _j_deserializer; }
fn java_get_type_converter() { return _j_type_converter; }
fn java_get_logger() { return _j_logger; }
fn java_get_profiler() { return _j_profiler; }
fn java_get_config() { return _j_config; }
fn java_get_env() { return _j_env; }
fn java_get_class_loader() { return _j_class_loader; }
fn java_get_control_factory() { return _j_control_factory; }
fn java_get_style_bridge() { return _j_style_bridge; }
fn java_get_fxml() { return _j_fxml; }
fn java_get_resource_bundle() { return _j_resource_bundle; }
fn java_get_maven() { return _j_maven; }
fn java_get_executor() { return _j_executor; }
fn java_get_version() { return "1.0.0"; }

fn java_summary() {
    print("");
    print("══════════════════════════════════════════════");
    print("  H# zzwUI ↔ Java 协同开发库 v1.0");
    print("══════════════════════════════════════════════");
    print("  Core: TypeMapper, JavaValue, Invoke/Result");
    print("  Objects: Proxy, Cache, JAR, Method, Field");
    print("  Events: CrossEventBus, UIDispatcher, Listener");
    print("  UI Bridge: ControlBridge, WindowBridge, Host");
    print("  Data: Binding, MultiBinding, BindingManager");
    print("  RPC: ServiceHost, Client, Message, Socket");
    print("  Serialization: Serializer, Deserializer, JSON");
    print("  Async: Future, Executor, ThreadPool, Token");
    print("  Diagnostics: Logger, Profiler, Debugger, Config");
    print("  Project: Maven, Project, Module, FXML");
    print("══════════════════════════════════════════════");
    return 0;
}

java_summary();