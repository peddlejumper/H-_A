# Section 4: UI 桥接层 — zzwUI 控件 ↔ JavaFX/Swing 控件
# ═══════════════════════════════════════════════════════════════════════════

class ZzwUIJavaControlBridge {
    let hwidget = nullptr;
    let java_control = nullptr;
    let bridge_id = 0;
    let property_bindings = [];
    let event_bindings = [];
    let is_syncing = false;
    let sync_direction = "both";
    let enabled = true;

    fn init_bridge(hw, jctrl) {
        self.hwidget = hw;
        self.java_control = jctrl;
        self.property_bindings = [];
        self.event_bindings = [];
        self.is_syncing = false;
        self.sync_direction = "both";
        self.enabled = true;
        self.bridge_id = 0;
        return 0;
    }

    fn setSyncDirection(dir) {
        self.sync_direction = dir;
        return 0;
    }

    fn setEnabled(v) {
        self.enabled = v;
        return 0;
    }

    fn isEnabled() { return self.enabled; }

    fn bindProperty(hprop, jprop) {
        push(self.property_bindings, {"hsharp": hprop, "java": jprop});
        return 0;
    }

    fn bindEvent(hevent, jevent) {
        push(self.event_bindings, {"hsharp": hevent, "java": jevent});
        return 0;
    }

    fn syncToJava() {
        if (self.enabled == false) { return 0; }
        if (self.sync_direction == "hsharp_to_java" or self.sync_direction == "both") {
            self.is_syncing = true;
            let i = 0;
            while (i < len(self.property_bindings)) {
                let binding = self.property_bindings[i];
                let hprop = binding["hsharp"];
                let jprop = binding["java"];
                let val = self.hwidget[hprop];
                if (val != nullptr) {
                    self.java_control[jprop] = val;
                }
                i = i + 1;
            }
            self.is_syncing = false;
        }
        return 0;
    }

    fn syncToHSharp() {
        if (self.enabled == false) { return 0; }
        if (self.sync_direction == "java_to_hsharp" or self.sync_direction == "both") {
            self.is_syncing = true;
            let i = 0;
            while (i < len(self.property_bindings)) {
                let binding = self.property_bindings[i];
                let hprop = binding["hsharp"];
                let jprop = binding["java"];
                let val = self.java_control[jprop];
                if (val != nullptr) {
                    self.hwidget[hprop] = val;
                }
                i = i + 1;
            }
            self.is_syncing = false;
        }
        return 0;
    }

    fn syncBoth() {
        self.syncToJava();
        self.syncToHSharp();
        return 0;
    }

    fn getHWidget() { return self.hwidget; }
    fn getJavaControl() { return self.java_control; }
    fn getPropertyBindings() { return self.property_bindings; }
    fn getEventBindings() { return self.event_bindings; }

    fn unbindProperty(hprop) {
        let new_bindings = [];
        let i = 0;
        while (i < len(self.property_bindings)) {
            if (self.property_bindings[i]["hsharp"] != hprop) {
                push(new_bindings, self.property_bindings[i]);
            }
            i = i + 1;
        }
        self.property_bindings = new_bindings;
        return 0;
    }

    fn unbindAll() {
        self.property_bindings = [];
        self.event_bindings = [];
        return 0;
    }

    fn dispose() {
        self.unbindAll();
        self.hwidget = nullptr;
        self.java_control = nullptr;
        self.enabled = false;
        return 0;
    }
}


class JavaWindowBridge {
    let hwindow = nullptr;
    let java_window = nullptr;
    let title_binding = false;
    let size_binding = false;
    let position_binding = false;
    let visibility_binding = false;
    let state_binding = false;

    fn init_win_bridge(hw, jw) {
        self.hwindow = hw;
        self.java_window = jw;
        self.title_binding = false;
        self.size_binding = false;
        self.position_binding = false;
        self.visibility_binding = false;
        self.state_binding = false;
        return 0;
    }

    fn bindTitle() {
        self.title_binding = true;
        return 0;
    }

    fn bindSize() {
        self.size_binding = true;
        return 0;
    }

    fn bindPosition() {
        self.position_binding = true;
        return 0;
    }

    fn bindVisibility() {
        self.visibility_binding = true;
        return 0;
    }

    fn bindState() {
        self.state_binding = true;
        return 0;
    }

    fn syncTitle() {
        if (self.title_binding and self.hwindow != nullptr and self.java_window != nullptr) {
            self.hwindow["title"] = self.java_window["title"];
        }
        return 0;
    }

    fn syncSize() {
        if (self.size_binding and self.hwindow != nullptr and self.java_window != nullptr) {
            self.hwindow["width"] = self.java_window["width"];
            self.hwindow["height"] = self.java_window["height"];
        }
        return 0;
    }

    fn syncPosition() {
        if (self.position_binding and self.hwindow != nullptr and self.java_window != nullptr) {
            self.hwindow["x"] = self.java_window["x"];
            self.hwindow["y"] = self.java_window["y"];
        }
        return 0;
    }

    fn syncAll() {
        self.syncTitle();
        self.syncSize();
        self.syncPosition();
        return 0;
    }

    fn getHWindow() { return self.hwindow; }
    fn getJavaWindow() { return self.java_window; }
    fn isTitleBound() { return self.title_binding; }
    fn isSizeBound() { return self.size_binding; }
    fn isPositionBound() { return self.position_binding; }
}


class JavaUIHost {
    let hosted_widgets = [];
    let java_parent = nullptr;
    let is_active = false;
    let layout_engine = "zzwUI";

    fn init_host(parent) {
        self.hosted_widgets = [];
        self.java_parent = parent;
        self.is_active = false;
        self.layout_engine = "zzwUI";
        return 0;
    }

    fn hostWidget(widget) {
        push(self.hosted_widgets, widget);
        if (self.java_parent != nullptr) {
            self.java_parent["children"] = self.hosted_widgets;
        }
        return 0;
    }

    fn removeWidget(widget) {
        let new_widgets = [];
        let i = 0;
        while (i < len(self.hosted_widgets)) {
            if (self.hosted_widgets[i] != widget) {
                push(new_widgets, self.hosted_widgets[i]);
            }
            i = i + 1;
        }
        self.hosted_widgets = new_widgets;
        return 0;
    }

    fn activate() {
        self.is_active = true;
        return 0;
    }

    fn deactivate() {
        self.is_active = false;
        return 0;
    }

    fn isActive() { return self.is_active; }

    fn doLayout() {
        let i = 0;
        while (i < len(self.hosted_widgets)) {
            let w = self.hosted_widgets[i];
            if (w.do_layout != nullptr) {
                w.do_layout();
            }
            i = i + 1;
        }
        return 0;
    }

    fn getWidgetCount() { return len(self.hosted_widgets); }
    fn getHostedWidgets() { return self.hosted_widgets; }
    fn setLayoutEngine(engine) { self.layout_engine = engine; return 0; }
    fn getLayoutEngine() { return self.layout_engine; }

    fn clear() {
        self.hosted_widgets = [];
        return 0;
    }
}


class JavaControlFactory {
    let control_map = {};
    let default_ctor = nullptr;

    fn init_factory() {
        self.control_map = {};
        self.default_ctor = nullptr;
        self._register_defaults();
        return 0;
    }

    fn _register_defaults() {
        self.register("Button", "javafx.scene.control.Button");
        self.register("Label", "javafx.scene.control.Label");
        self.register("TextBox", "javafx.scene.control.TextField");
        self.register("TextArea", "javafx.scene.control.TextArea");
        self.register("CheckBox", "javafx.scene.control.CheckBox");
        self.register("RadioButton", "javafx.scene.control.RadioButton");
        self.register("Slider", "javafx.scene.control.Slider");
        self.register("ProgressBar", "javafx.scene.control.ProgressBar");
        self.register("ListView", "javafx.scene.control.ListView");
        self.register("ComboBox", "javafx.scene.control.ComboBox");
        self.register("ScrollView", "javafx.scene.control.ScrollPane");
        self.register("TabControl", "javafx.scene.control.TabPane");
        self.register("TreeView", "javafx.scene.control.TreeView");
        self.register("Menu", "javafx.scene.control.MenuBar");
        self.register("ImageView", "javafx.scene.image.ImageView");
        self.register("Pane", "javafx.scene.layout.Pane");
        self.register("Grid", "javafx.scene.layout.GridPane");
        self.register("HBox", "javafx.scene.layout.HBox");
        self.register("VBox", "javafx.scene.layout.VBox");
        self.register("BorderPane", "javafx.scene.layout.BorderPane");
        self.register("FlowPane", "javafx.scene.layout.FlowPane");
        self.register("SplitPane", "javafx.scene.control.SplitPane");
        self.register("ToggleButton", "javafx.scene.control.ToggleButton");
        self.register("PasswordField", "javafx.scene.control.PasswordField");
        return 0;
    }

    fn register(hwidget_type, jtype) {
        self.control_map[hwidget_type] = jtype;
        return 0;
    }

    fn getJavaType(hwidget_type) {
        return self.control_map[hwidget_type];
    }

    fn createControl(hwidget_type) {
        let jtype = self.control_map[hwidget_type];
        if (jtype == nullptr) {
            return nullptr;
        }
        return {"__type__": jtype, "widget_type": hwidget_type};
    }

    fn getSupportedTypes() {
        let types = [];
        for k in self.control_map {
            push(types, k);
        }
        return types;
    }

    fn hasType(hwidget_type) {
        return self.control_map[hwidget_type] != nullptr;
    }
}


# ═══════════════════════════════════════════════════════════════════════════
# Section 5: 数据绑定层 — 双向绑定
# ═══════════════════════════════════════════════════════════════════════════

class JavaBinding {
    let source = nullptr;
    let source_path = "";
    let target = nullptr;
    let target_path = "";
    let mode = "twoWay";
    let converter = nullptr;
    let converter_parameter = nullptr;
    let is_active = true;
    let update_source_trigger = "propertyChanged";
    let fallback_value = nullptr;
    let target_null_value = nullptr;

    fn init_binding(src, src_path, tgt, tgt_path) {
        self.source = src;
        self.source_path = src_path;
        self.target = tgt;
        self.target_path = tgt_path;
        self.mode = "twoWay";
        self.converter = nullptr;
        self.converter_parameter = nullptr;
        self.is_active = true;
        self.update_source_trigger = "propertyChanged";
        self.fallback_value = nullptr;
        self.target_null_value = nullptr;
        return 0;
    }

    fn setMode(m) { self.mode = m; return 0; }
    fn setConverter(c) { self.converter = c; return 0; }
    fn setConverterParameter(p) { self.converter_parameter = p; return 0; }
    fn setActive(v) { self.is_active = v; return 0; }
    fn setUpdateSourceTrigger(t) { self.update_source_trigger = t; return 0; }
    fn setFallbackValue(v) { self.fallback_value = v; return 0; }
    fn setTargetNullValue(v) { self.target_null_value = v; return 0; }

    fn getMode() { return self.mode; }
    fn isActive() { return self.is_active; }
    fn getSource() { return self.source; }
    fn getSourcePath() { return self.source_path; }
    fn getTarget() { return self.target; }
    fn getTargetPath() { return self.target_path; }

    fn updateSource() {
        if (self.is_active == false) { return 0; }
        if (self.mode == "oneWay") { return 0; }
        let val = self.target[self.target_path];
        if (val == nullptr and self.target_null_value != nullptr) {
            val = self.target_null_value;
        }
        if (self.converter != nullptr) {
            val = self.converter(val, self.converter_parameter);
        }
        self.source[self.source_path] = val;
        return 0;
    }

    fn updateTarget() {
        if (self.is_active == false) { return 0; }
        if (self.mode == "oneWayToSource") { return 0; }
        let val = self.source[self.source_path];
        if (val == nullptr) {
            val = self.fallback_value;
        }
        if (self.converter != nullptr) {
            val = self.converter(val, self.converter_parameter);
        }
        self.target[self.target_path] = val;
        return 0;
    }

    fn update() {
        self.updateTarget();
        return 0;
    }
}


class JavaMultiBinding {
    let bindings = [];
    let target = nullptr;
    let target_path = "";
    let converter = nullptr;
    let is_active = true;

    fn init_multi_binding(tgt, tgt_path) {
        self.bindings = [];
        self.target = tgt;
        self.target_path = tgt_path;
        self.converter = nullptr;
        self.is_active = true;
        return 0;
    }

    fn addBinding(binding) {
        push(self.bindings, binding);
        return 0;
    }

    fn removeBinding(binding) {
        let new_bindings = [];
        let i = 0;
        while (i < len(self.bindings)) {
            if (self.bindings[i] != binding) {
                push(new_bindings, self.bindings[i]);
            }
            i = i + 1;
        }
        self.bindings = new_bindings;
        return 0;
    }

    fn setConverter(c) { self.converter = c; return 0; }
    fn setActive(v) { self.is_active = v; return 0; }

    fn update() {
        if (self.is_active == false) { return 0; }
        let values = [];
        let i = 0;
        while (i < len(self.bindings)) {
            let b = self.bindings[i];
            let val = b.source[b.source_path];
            push(values, val);
            i = i + 1;
        }
        if (self.converter != nullptr) {
            let result = self.converter(values);
            self.target[self.target_path] = result;
        }
        return 0;
    }

    fn getBindingCount() { return len(self.bindings); }
}


class JavaBindingManager {
    let bindings = [];
    let is_updating = false;
    let defer_updates = false;

    fn init_binding_mgr() {
        self.bindings = [];
        self.is_updating = false;
        self.defer_updates = false;
        return 0;
    }

    fn addBinding(binding) {
        push(self.bindings, binding);
        return 0;
    }

    fn removeBinding(binding) {
        let new_bindings = [];
        let i = 0;
        while (i < len(self.bindings)) {
            if (self.bindings[i] != binding) {
                push(new_bindings, self.bindings[i]);
            }
            i = i + 1;
        }
        self.bindings = new_bindings;
        return 0;
    }

    fn updateAll() {
        if (self.defer_updates) { return 0; }
        self.is_updating = true;
        let i = 0;
        while (i < len(self.bindings)) {
            self.bindings[i].update();
            i = i + 1;
        }
        self.is_updating = false;
        return 0;
    }

    fn updateSource(binding) {
        binding.updateSource();
        return 0;
    }

    fn updateTarget(binding) {
        binding.updateTarget();
        return 0;
    }

    fn setDeferUpdates(v) {
        self.defer_updates = v;
        if (v == false) {
            self.updateAll();
        }
        return 0;
    }

    fn getBindingCount() { return len(self.bindings); }
    fn isUpdating() { return self.is_updating; }

    fn clear() {
        self.bindings = [];
        return 0;
    }

    fn getBindingsForSource(source) {
        let result = [];
        let i = 0;
        while (i < len(self.bindings)) {
            if (self.bindings[i].getSource() == source) {
                push(result, self.bindings[i]);
            }
            i = i + 1;
        }
        return result;
    }

    fn getBindingsForTarget(target) {
        let result = [];
        let i = 0;
        while (i < len(self.bindings)) {
            if (self.bindings[i].getTarget() == target) {
                push(result, self.bindings[i]);
            }
            i = i + 1;
        }
        return result;
    }
}


class JavaBindingExpression {
    let binding = nullptr;
    let target = nullptr;
    let target_property = "";
    let is_dirty = false;

    fn init_expr(binding, tgt, tgt_prop) {
        self.binding = binding;
        self.target = tgt;
        self.target_property = tgt_prop;
        self.is_dirty = false;
        return 0;
    }

    fn markDirty() {
        self.is_dirty = true;
        return 0;
    }

    fn isDirty() { return self.is_dirty; }

    fn refresh() {
        if (self.binding != nullptr) {
            self.binding.updateTarget();
        }
        self.is_dirty = false;
        return 0;
    }

    fn getBinding() { return self.binding; }
    fn getTarget() { return self.target; }
    fn getTargetProperty() { return self.target_property; }
}


# ═══════════════════════════════════════════════════════════════════════════
# Section 6: RPC/服务层 — 远程过程调用
# ═══════════════════════════════════════════════════════════════════════════

class JavaServiceHost {
    let services = {};
    let endpoints = [];
    let is_running = false;
    let port = 0;
    let host_name = "";
    let max_connections = 100;
    let active_connections = 0;

    fn init_host(name, port) {
        self.services = {};
        self.endpoints = [];
        self.is_running = false;
        self.port = port;
        self.host_name = name;
        self.max_connections = 100;
        self.active_connections = 0;
        return 0;
    }

    fn registerService(name, instance) {
        self.services[name] = instance;
        return 0;
    }

    fn unregisterService(name) {
        self.services[name] = nullptr;
        return 0;
    }

    fn getService(name) {
        return self.services[name];
    }

    fn hasService(name) {
        return self.services[name] != nullptr;
    }

    fn addEndpoint(endpoint) {
        push(self.endpoints, endpoint);
        return 0;
    }

    fn start() {
        self.is_running = true;
        return 0;
    }

    fn stop() {
        self.is_running = false;
        return 0;
    }

    fn isRunning() { return self.is_running; }
    fn getPort() { return self.port; }
    fn getHostName() { return self.host_name; }
    fn getServiceCount() {
        let count = 0;
        for k in self.services {
            if (self.services[k] != nullptr) {
                count = count + 1;
            }
        }
        return count;
    }

    fn getEndpoints() { return self.endpoints; }
    fn setMaxConnections(max) { self.max_connections = max; return 0; }
    fn getMaxConnections() { return self.max_connections; }
    fn getActiveConnections() { return self.active_connections; }
}


class JavaRPCClient {
    let endpoint = "";
    let timeout_ms = 30000;
    let is_connected = false;
    let auth_token = "";
    let headers = {};
    let call_counter = 0;

    fn init_client(endpoint) {
        self.endpoint = endpoint;
        self.timeout_ms = 30000;
        self.is_connected = false;
        self.auth_token = "";
        self.headers = {};
        self.call_counter = 0;
        return 0;
    }

    fn setTimeout(ms) { self.timeout_ms = ms; return 0; }
    fn setAuthToken(token) { self.auth_token = token; return 0; }
    fn setHeader(key, value) { self.headers[key] = value; return 0; }

    fn connect() {
        self.is_connected = true;
        return 0;
    }

    fn disconnect() {
        self.is_connected = false;
        return 0;
    }

    fn isConnected() { return self.is_connected; }

    fn call(method, args) {
        self.call_counter = self.call_counter + 1;
        let result = new JavaResult();
        result.init_result();
        result.setCallId(self.call_counter);
        result.setSuccess(nullptr);
        return result;
    }

    fn callAsync(method, args) {
        return self.call(method, args);
    }

    fn getEndpoint() { return self.endpoint; }
    fn getTimeout() { return self.timeout_ms; }
    fn getCallCount() { return self.call_counter; }
}


class JavaRPCMessage {
    let message_id = 0;
    let method = "";
    let params = [];
    let is_notification = false;
    let is_request = true;
    let timestamp = 0;
    let correlation_id = "";
    let headers = {};

    fn init_msg(method, params) {
        self.method = method;
        self.params = params;
        self.is_notification = false;
        self.is_request = true;
        self.timestamp = 0;
        self.correlation_id = "";
        self.headers = {};
        self.message_id = 0;
        return 0;
    }

    fn setNotification(v) { self.is_notification = v; return 0; }
    fn setRequest(v) { self.is_request = v; return 0; }
    fn setCorrelationId(id) { self.correlation_id = id; return 0; }
    fn setHeader(key, value) { self.headers[key] = value; return 0; }
    fn setId(id) { self.message_id = id; return 0; }

    fn getMethod() { return self.method; }
    fn getParams() { return self.params; }
    fn getParamCount() { return len(self.params); }
    fn isNotification() { return self.is_notification; }
    fn isRequest() { return self.is_request; }
    fn getCorrelationId() { return self.correlation_id; }
    fn getId() { return self.message_id; }
}


class JavaRPCResponse {
    let message_id = 0;
    let result = nullptr;
    let error = "";
    let error_code = 0;
    let is_success = false;
    let correlation_id = "";

    fn init_response(msg_id) {
        self.message_id = msg_id;
        self.result = nullptr;
        self.error = "";
        self.error_code = 0;
        self.is_success = false;
        self.correlation_id = "";
        return 0;
    }

    fn setSuccess(result) {
        self.result = result;
        self.is_success = true;
        return 0;
    }

    fn setError(code, msg) {
        self.error_code = code;
        self.error = msg;
        self.is_success = false;
        return 0;
    }

    fn setCorrelationId(id) { self.correlation_id = id; return 0; }

    fn isSuccess() { return self.is_success; }
    fn getResult() { return self.result; }
    fn getError() { return self.error; }
    fn getErrorCode() { return self.error_code; }
    fn getMessageId() { return self.message_id; }
    fn getCorrelationId() { return self.correlation_id; }
}


class JavaRPCContext {
    let request = nullptr;
    let response = nullptr;
    let user_data = nullptr;
    let is_authenticated = false;
