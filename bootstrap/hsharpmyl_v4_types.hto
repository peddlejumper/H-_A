# SECTION 49: Data Utilities
# ═══════════════════════════════════════════════════════════════════════════

# ── DataLoader ──
class DataLoader {
    let X = [];
    let y = [];
    let batch_size = 32;
    let shuffle = 1;
    let indices = [];
    let current = 0;

    fn init_data_loader(X, y, batch_size, shuffle) {
        self.X = X;
        self.y = y;
        if (batch_size != nullptr) { self.batch_size = batch_size; }
        if (shuffle != nullptr) { self.shuffle = shuffle; }
        self.current = 0;
        self.build_indices();
        return 0;
    }

    fn build_indices() {
        let n = len(self.X);
        self.indices = [];
        let i = 0;
        while (i < n) { push(self.indices, i); i = i + 1; }
        if (self.shuffle == 1) {
            i = n - 1;
            while (i > 0) {
                let j = hml_randint(0, i);
                let tmp = self.indices[i];
                self.indices[i] = self.indices[j];
                self.indices[j] = tmp;
                i = i - 1;
            }
        }
        return 0;
    }

    fn next_batch() {
        let n = len(self.X);
        if (self.current >= n) {
            self.current = 0;
            self.build_indices();
        }
        let end = self.current + self.batch_size;
        if (end > n) { end = n; }
        let batch_X = [];
        let batch_y = [];
        let i = self.current;
        while (i < end) {
            push(batch_X, self.X[self.indices[i]]);
            push(batch_y, self.y[self.indices[i]]);
            i = i + 1;
        }
        self.current = end;
        return {"X": batch_X, "y": batch_y};
    }

    fn reset() {
        self.current = 0;
        self.build_indices();
        return 0;
    }
}

# ── BatchGenerator ──
class BatchGenerator {
    let X = [];
    let batch_size = 32;

    fn init_batch_generator(X, batch_size) {
        self.X = X;
        if (batch_size != nullptr) { self.batch_size = batch_size; }
        return 0;
    }

    fn generate() {
        let n = len(self.X);
        let i = 0;
        while (i < n) {
            let end = i + self.batch_size;
            if (end > n) { end = n; }
            let batch = [];
            let j = i;
            while (j < end) { push(batch, self.X[j]); j = j + 1; }
            i = end;
        }
        return 0;
    }
}

# ── Dataset ──
class Dataset {
    let features = [];
    let targets = [];
    let feature_names = [];
    let description = "";

    fn init_dataset(features, targets, feature_names, description) {
        self.features = features;
        self.targets = targets;
        if (feature_names != nullptr) { self.feature_names = feature_names; }
        if (description != nullptr) { self.description = description; }
        return 0;
    }

    fn shape() {
        return [len(self.features), len(self.features[0])];
    }

    fn get_batch(indices) {
        let batch_X = [];
        let batch_y = [];
        let i = 0;
        while (i < len(indices)) {
            push(batch_X, self.features[indices[i]]);
            if (len(self.targets) > 0) { push(batch_y, self.targets[indices[i]]); }
            i = i + 1;
        }
        return {"X": batch_X, "y": batch_y};
    }

    fn split(test_size) {
        let n = len(self.features);
        let split_idx = math_floor(n * (1.0 - test_size));
        let train_X = [];
        let train_y = [];
        let test_X = [];
        let test_y = [];
        let i = 0;
        while (i < split_idx) { push(train_X, self.features[i]); push(train_y, self.targets[i]); i = i + 1; }
        while (i < n) { push(test_X, self.features[i]); push(test_y, self.targets[i]); i = i + 1; }
        return {"train_X": train_X, "train_y": train_y, "test_X": test_X, "test_y": test_y};
    }
}

# ── LabeledDataset ──
class LabeledDataset {
    let X = [];
    let y = [];
    let labels = [];

    fn init_labeled_dataset(X, y, labels) {
        self.X = X;
        self.y = y;
        if (labels != nullptr) { self.labels = labels; }
        return 0;
    }

    fn class_distribution() {
        let dist = {};
        let i = 0;
        while (i < len(self.y)) {
            let key = self.y[i];
            let c = 0;
            if (dict_keys(dist) != []) {
                let keys = dict_keys(dist);
                let found = 0;
                let kk = 0;
                while (kk < len(keys)) { if (keys[kk] == key) { found = 1; } kk = kk + 1; }
                if (found == 1) { c = dist[key]; }
            }
            dist[key] = c + 1;
            i = i + 1;
        }
        return dist;
    }

    fn filter_by_label(label) {
        let filtered_X = [];
        let filtered_y = [];
        let i = 0;
        while (i < len(self.y)) {
            if (self.y[i] == label) { push(filtered_X, self.X[i]); push(filtered_y, self.y[i]); }
            i = i + 1;
        }
        return {"X": filtered_X, "y": filtered_y};
    }
}

# ── ImbalancedSampler ──
class ImbalancedSampler {
    let strategy = "oversample";

    fn init_imbalanced_sampler(strategy) {
        if (strategy != nullptr) { self.strategy = strategy; }
        return 0;
    }

    fn fit_resample(X, y) {
        let n = len(X);
        let classes = hml_unique(y);
        let counts = {};
        let i = 0;
        while (i < n) {
            let key = y[i];
            let c = 0;
            if (dict_keys(counts) != []) {
                let keys = dict_keys(counts);
                let found = 0;
                let kk = 0;
                while (kk < len(keys)) { if (keys[kk] == key) { found = 1; } kk = kk + 1; }
                if (found == 1) { c = counts[key]; }
            }
            counts[key] = c + 1;
            i = i + 1;
        }
        let max_count = 0;
        let keys = dict_keys(counts);
        let kk = 0;
        while (kk < len(keys)) { if (counts[keys[kk]] > max_count) { max_count = counts[keys[kk]]; } kk = kk + 1; }
        let res_X = [];
        let res_y = [];
        let c = 0;
        while (c < len(classes)) {
            let cls = classes[c];
            let indices = [];
            i = 0;
            while (i < n) { if (y[i] == cls) { push(indices, i); } i = i + 1; }
            let needed = max_count;
            i = 0;
            while (i < needed) {
                let idx = i % len(indices);
                if (self.strategy == "oversample") { idx = hml_randint(0, len(indices) - 1); }
                push(res_X, X[indices[idx]]);
                push(res_y, y[indices[idx]]);
                i = i + 1;
            }
            c = c + 1;
        }
        return {"X": res_X, "y": res_y};
    }
}

# ── StratifiedSampler ──
class StratifiedSampler {
    let n_splits = 5;

    fn init_stratified_sampler(n_splits) {
        if (n_splits != nullptr) { self.n_splits = n_splits; }
        return 0;
    }

    fn split(X, y) {
        let n = len(X);
        let classes = hml_unique(y);
        let class_indices = {};
        let c = 0;
        while (c < len(classes)) {
            class_indices[classes[c]] = [];
            c = c + 1;
        }
        let i = 0;
        while (i < n) {
            push(class_indices[y[i]], i);
            i = i + 1;
        }
        let folds = [];
        let fold = 0;
        while (fold < self.n_splits) {
            let train = [];
            let test = [];
            let c = 0;
            while (c < len(classes)) {
                let idxs = class_indices[classes[c]];
                let fold_size = math_floor(len(idxs) / self.n_splits);
                let start = fold * fold_size;
                let end = start + fold_size;
                if (fold == self.n_splits - 1) { end = len(idxs); }
                let j = 0;
                while (j < len(idxs)) {
                    if (j >= start and j < end) { push(test, idxs[j]); }
                    else { push(train, idxs[j]); }
                    j = j + 1;
                }
                c = c + 1;
            }
            push(folds, {"train": train, "test": test});
            fold = fold + 1;
        }
        return folds;
    }
}

# ── TrainValSplit ──
class TrainValSplit {
    let test_size = 0.2;
    let val_size = 0.1;
    let shuffle = 1;

    fn init_train_val_split(test_size, val_size, shuffle) {
        if (test_size != nullptr) { self.test_size = test_size; }
        if (val_size != nullptr) { self.val_size = val_size; }
        if (shuffle != nullptr) { self.shuffle = shuffle; }
        return 0;
    }

    fn split(X, y) {
        let n = len(X);
        let indices = [];
        let i = 0;
        while (i < n) { push(indices, i); i = i + 1; }
        if (self.shuffle == 1) {
            i = n - 1;
            while (i > 0) {
                let j = hml_randint(0, i);
                let tmp = indices[i];
                indices[i] = indices[j];
                indices[j] = tmp;
                i = i - 1;
            }
        }
        let test_n = math_floor(n * self.test_size);
        let val_n = math_floor(n * self.val_size);
        let train_n = n - test_n - val_n;
        let train_X = [];
        let train_y = [];
        let val_X = [];
        let val_y = [];
        let test_X = [];
        let test_y = [];
        i = 0;
        while (i < train_n) {
            push(train_X, X[indices[i]]);
            push(train_y, y[indices[i]]);
            i = i + 1;
        }
        while (i < train_n + val_n) {
            push(val_X, X[indices[i]]);
            push(val_y, y[indices[i]]);
            i = i + 1;
        }
        while (i < n) {
            push(test_X, X[indices[i]]);
            push(test_y, y[indices[i]]);
            i = i + 1;
        }
        return {
            "train": {"X": train_X, "y": train_y},
            "val": {"X": val_X, "y": val_y},
            "test": {"X": test_X, "y": test_y}
        };
    }
}

# ── ShuffleData ──
class ShuffleData {
    let random_state = 42;

    fn init_shuffle_data(random_state) {
        if (random_state != nullptr) { self.random_state = random_state; }
        return 0;
    }

    fn shuffle(X, y) {
        let n = len(X);
        let indices = [];
        let i = 0;
        while (i < n) { push(indices, i); i = i + 1; }
        i = n - 1;
        while (i > 0) {
            let j = hml_randint(0, i);
            let tmp = indices[i];
            indices[i] = indices[j];
            indices[j] = tmp;
            i = i - 1;
        }
        let sX = [];
        let sy = [];
        i = 0;
        while (i < n) { push(sX, X[indices[i]]); push(sy, y[indices[i]]); i = i + 1; }
        return {"X": sX, "y": sy};
    }
}

# ── DataNormalizer ──
class DataNormalizer {
    let method = "minmax";
    let min_vals = [];
    let max_vals = [];
    let mean = [];
    let std = [];

    fn init_data_normalizer(method) {
        if (method != nullptr) { self.method = method; }
        self.min_vals = [];
        self.max_vals = [];
        self.mean = [];
        self.std = [];
        return 0;
    }

    fn fit(X) {
        let n = len(X);
        let d = len(X[0]);
        self.min_vals = [];
        self.max_vals = [];
        self.mean = hml_vector_zeros(d);
        self.std = hml_vector_zeros(d);
        let j = 0;
        while (j < d) {
            let min_v = X[0][j];
            let max_v = X[0][j];
            let i = 1;
            while (i < n) {
                if (X[i][j] < min_v) { min_v = X[i][j]; }
                if (X[i][j] > max_v) { max_v = X[i][j]; }
                self.mean[j] = self.mean[j] + X[i][j];
                i = i + 1;
            }
            self.mean[j] = self.mean[j] / n;
            push(self.min_vals, min_v);
            push(self.max_vals, max_v);
            j = j + 1;
        }
        let i = 0;
        while (i < n) {
            let j = 0;
            while (j < d) { let diff = X[i][j] - self.mean[j]; self.std[j] = self.std[j] + diff * diff; j = j + 1; }
            i = i + 1;
        }
        j = 0;
        while (j < d) { self.std[j] = math_sqrt(self.std[j] / n); j = j + 1; }
        return 0;
    }

    fn transform(X) {
        let n = len(X);
        let d = len(X[0]);
        let result = [];
        let i = 0;
        while (i < n) {
            let row = [];
            let j = 0;
            while (j < d) {
                if (self.method == "minmax") {
                    let denom = self.max_vals[j] - self.min_vals[j];
                    if (denom < 0.000000001) { denom = 1.0; }
                    push(row, (X[i][j] - self.min_vals[j]) / denom);
                }
                else {
                    let denom = self.std[j];
                    if (denom < 0.000000001) { denom = 1.0; }
                    push(row, (X[i][j] - self.mean[j]) / denom);
                }
                j = j + 1;
            }
            push(result, row);
            i = i + 1;
        }
        return result;
    }

    fn fit_transform(X) {
        self.fit(X);
        return self.transform(X);
    }
}

# ── FeatureSelector ──
class FeatureSelector {
    let method = "variance";
    let threshold = 0.0;
    let selected_features = [];

    fn init_feature_selector(method, threshold) {
        if (method != nullptr) { self.method = method; }
        if (threshold != nullptr) { self.threshold = threshold; }
        self.selected_features = [];
        return 0;
    }

    fn fit(X, y) {
        let n = len(X);
        let d = len(X[0]);
        self.selected_features = [];
        let j = 0;
        while (j < d) {
            if (self.method == "variance") {
                let mean = 0.0;
                let i = 0;
                while (i < n) { mean = mean + X[i][j]; i = i + 1; }
                mean = mean / n;
                let var = 0.0;
                i = 0;
                while (i < n) { let diff = X[i][j] - mean; var = var + diff * diff; i = i + 1; }
                var = var / n;
                if (var > self.threshold) { push(self.selected_features, j); }
            }
            else {
                let corr = 0.0;
                if (y != nullptr) {
                    let mean_x = 0.0;
                    let mean_y = 0.0;
                    let i = 0;
                    while (i < n) { mean_x = mean_x + X[i][j]; mean_y = mean_y + y[i]; i = i + 1; }
                    mean_x = mean_x / n;
                    mean_y = mean_y / n;
                    let num = 0.0;
                    let denom_x = 0.0;
                    let denom_y = 0.0;
                    i = 0;
                    while (i < n) {
                        let dx = X[i][j] - mean_x;
                        let dy = y[i] - mean_y;
                        num = num + dx * dy;
                        denom_x = denom_x + dx * dx;
                        denom_y = denom_y + dy * dy;
                        i = i + 1;
                    }
                    if (denom_x > 0 and denom_y > 0) { corr = math_fabs(num / math_sqrt(denom_x * denom_y)); }
                }
                if (corr > self.threshold) { push(self.selected_features, j); }
            }
            j = j + 1;
        }
        return 0;
    }

    fn transform(X) {
        let n = len(X);
        let result = [];
        let i = 0;
        while (i < n) {
            let row = [];
            let k = 0;
            while (k < len(self.selected_features)) { push(row, X[i][self.selected_features[k]]); k = k + 1; }
            push(result, row);
            i = i + 1;
        }
        return result;
    }

    fn fit_transform(X, y) {
        self.fit(X, y);
        return self.transform(X);
    }
}

# ═══════════════════════════════════════════════════════════════════════════
# SECTION 50: Model Persistence & Deployment
# ═══════════════════════════════════════════════════════════════════════════

# ── ModelSaver ──
class ModelSaver {
    fn init_model_saver() { return 0; }

    fn save(model, path) {
        let data = {
            "type": "hml_model",
            "version": "4.0",
            "model_data": {}
        };
        let keys = dict_keys(model);
        let i = 0;
        while (i < len(keys)) {
            let key = keys[i];
            data["model_data"][key] = model[key];
            i = i + 1;
        }
        return data;
    }

    fn serialize(model) {
        let data = self.save(model, "");
        return data;
    }
}

# ── ModelLoader ──
class ModelLoader {
    fn init_model_loader() { return 0; }

    fn load(data, model_class) {
        let model = {};
        let keys = dict_keys(model_class);
        let i = 0;
        while (i < len(keys)) {
            let key = keys[i];
            if (model_class[key] != nullptr) { model[key] = model_class[key]; }
            i = i + 1;
        }
        if (data["model_data"] != nullptr) {
            let data_keys = dict_keys(data["model_data"]);
            i = 0;
            while (i < len(data_keys)) {
                let key = data_keys[i];
                model[key] = data["model_data"][key];
                i = i + 1;
            }
        }
        return model;
    }

    fn deserialize(data, model_class) {
        return self.load(data, model_class);
    }
}

# ── Checkpoint ──
class Checkpoint {
    let save_dir = "./checkpoints";
    let max_to_keep = 5;
    let checkpoints = [];

    fn init_checkpoint(save_dir, max_to_keep) {
        if (save_dir != nullptr) { self.save_dir = save_dir; }
        if (max_to_keep != nullptr) { self.max_to_keep = max_to_keep; }
        self.checkpoints = [];
        return 0;
    }

    fn save(model, step) {
        let saver = new ModelSaver();
        let data = saver.save(model, "");
        let ckpt = {
            "step": step,
            "model": data,
            "timestamp": step
        };
        push(self.checkpoints, ckpt);
        if (len(self.checkpoints) > self.max_to_keep) {
            let new_ckpts = [];
            let i = 1;
            while (i < len(self.checkpoints)) { push(new_ckpts, self.checkpoints[i]); i = i + 1; }
            self.checkpoints = new_ckpts;
        }
        return 0;
    }

    fn restore() {
        if (len(self.checkpoints) > 0) {
            return self.checkpoints[len(self.checkpoints) - 1]["model"];
        }
        return nullptr;
    }

    fn restore_best(score_fn) {
        let best = nullptr;
        let best_score = -1000000000.0;
        let i = 0;
        while (i < len(self.checkpoints)) {
            let score = score_fn(self.checkpoints[i]["model"]);
            if (score > best_score) { best_score = score; best = self.checkpoints[i]["model"]; }
            i = i + 1;
        }
        return best;
    }
}

# ── EarlyStopping ──
class EarlyStopping {
    let patience = 10;
    let min_delta = 0.0;
    let best_score = -1000000000.0;
    let counter = 0;
    let best_model = nullptr;
    let should_stop = 0;

    fn init_early_stopping(patience, min_delta) {
        if (patience != nullptr) { self.patience = patience; }
        if (min_delta != nullptr) { self.min_delta = min_delta; }
        self.best_score = -1000000000.0;
        self.counter = 0;
        self.best_model = nullptr;
        self.should_stop = 0;
        return 0;
    }

    fn evaluate(score, model) {
        if (score > self.best_score + self.min_delta) {
            self.best_score = score;
            self.counter = 0;
            self.best_model = model;
        }
        else {
            self.counter = self.counter + 1;
        }
        if (self.counter >= self.patience) { self.should_stop = 1; }
        return self.should_stop;
    }

    fn get_best() { return self.best_model; }
}

# ── ReduceLROnPlateau ──
class ReduceLROnPlateau {
    let factor = 0.1;
    let patience = 10;
    let min_lr = 0.0;
    let best_score = -1000000000.0;
    let counter = 0;
    let current_lr = 0.0;

    fn init_reduce_lr_plateau(factor, patience, min_lr) {
        if (factor != nullptr) { self.factor = factor; }
        if (patience != nullptr) { self.patience = patience; }
        if (min_lr != nullptr) { self.min_lr = min_lr; }
        self.best_score = -1000000000.0;
        self.counter = 0;
        return 0;
    }

    fn evaluate(score, current_lr) {
        self.current_lr = current_lr;
        if (score > self.best_score + 0.0001) {
            self.best_score = score;
            self.counter = 0;
        }
        else {
            self.counter = self.counter + 1;
        }
        if (self.counter >= self.patience) {
            self.counter = 0;
            let new_lr = self.current_lr * self.factor;
            if (new_lr < self.min_lr) { new_lr = self.min_lr; }
            return new_lr;
        }
        return self.current_lr;
    }
}

# ── ModelCheckpoint ──
class ModelCheckpoint {
    let save_best_only = 1;
    let best_score = -1000000000.0;
    let checkpoints = [];

    fn init_model_checkpoint(save_best_only) {
        if (save_best_only != nullptr) { self.save_best_only = save_best_only; }
        self.best_score = -1000000000.0;
        self.checkpoints = [];
        return 0;
    }

    fn save(model, score, step) {
        if (self.save_best_only == 1) {
            if (score > self.best_score) {
                self.best_score = score;
                let ckpt = {"step": step, "model": model, "score": score};
                push(self.checkpoints, ckpt);
            }
        }
        else {
            let ckpt = {"step": step, "model": model, "score": score};
            push(self.checkpoints, ckpt);
        }
        return 0;
    }

    fn get_best() {
        if (len(self.checkpoints) > 0) {
            return self.checkpoints[len(self.checkpoints) - 1]["model"];
        }
        return nullptr;
    }
}

# ── TensorBoardLogger ──
class TensorBoardLogger {
    let log_dir = "./logs";
    let logs = {};

    fn init_tensorboard_logger(log_dir) {
        if (log_dir != nullptr) { self.log_dir = log_dir; }
        self.logs = {};
        return 0;
    }

    fn log_scalar(tag, value, step) {
        if (self.logs[tag] == nullptr) { self.logs[tag] = []; }
        push(self.logs[tag], {"step": step, "value": value});
        return 0;
    }

    fn log_histogram(tag, values, step) {
        if (self.logs[tag] == nullptr) { self.logs[tag] = []; }
        push(self.logs[tag], {"step": step, "values": values});
        return 0;
    }

    fn get_log(tag) {
        return self.logs[tag];
    }

    fn flush() {
        self.logs = {};
        return 0;
    }
}

# ── CSVLogger ──
class CSVLogger {
    let log_path = "./training_log.csv";
    let headers = [];
    let entries = [];

    fn init_csv_logger(log_path) {
        if (log_path != nullptr) { self.log_path = log_path; }
        self.headers = [];
        self.entries = [];
        return 0;
    }

    fn log(metrics) {
        let keys = dict_keys(metrics);
        if (len(self.headers) == 0) {
            let i = 0;
            while (i < len(keys)) { push(self.headers, keys[i]); i = i + 1; }
        }
        let entry = {};
        let i = 0;
        while (i < len(keys)) { entry[keys[i]] = metrics[keys[i]]; i = i + 1; }
        push(self.entries, entry);
        return 0;
    }

    fn get_entries() { return self.entries; }

    fn get_column(name) {
        let col = [];
        let i = 0;
        while (i < len(self.entries)) { push(col, self.entries[i][name]); i = i + 1; }
        return col;
    }

    fn clear() {
        self.headers = [];
        self.entries = [];
        return 0;
    }
}

# ── LambdaCallback ──
class LambdaCallback {
    let on_train_begin = nullptr;
    let on_train_end = nullptr;
    let on_epoch_begin = nullptr;
    let on_epoch_end = nullptr;
    let on_batch_begin = nullptr;
    let on_batch_end = nullptr;

    fn init_lambda_callback(on_train_begin, on_train_end, on_epoch_begin, on_epoch_end, on_batch_begin, on_batch_end) {
        self.on_train_begin = on_train_begin;
        self.on_train_end = on_train_end;
        self.on_epoch_begin = on_epoch_begin;
        self.on_epoch_end = on_epoch_end;
        self.on_batch_begin = on_batch_begin;
        self.on_batch_end = on_batch_end;
        return 0;
    }

    fn train_begin(logs) {
        if (self.on_train_begin != nullptr) { self.on_train_begin(logs); }
        return 0;
    }

    fn train_end(logs) {
        if (self.on_train_end != nullptr) { self.on_train_end(logs); }
        return 0;
    }

    fn epoch_begin(epoch, logs) {
        if (self.on_epoch_begin != nullptr) { self.on_epoch_begin(epoch, logs); }
        return 0;
    }

    fn epoch_end(epoch, logs) {
        if (self.on_epoch_end != nullptr) { self.on_epoch_end(epoch, logs); }
        return 0;
    }

    fn batch_begin(batch, logs) {
        if (self.on_batch_begin != nullptr) { self.on_batch_begin(batch, logs); }
        return 0;
    }

    fn batch_end(batch, logs) {
        if (self.on_batch_end != nullptr) { self.on_batch_end(batch, logs); }
        return 0;
    }
}

# ── CallbackList ──
class CallbackList {
    let callbacks = [];

    fn init_callback_list(callbacks) {
        if (callbacks != nullptr) { self.callbacks = callbacks; }
        return 0;
    }

    fn train_begin(logs) {
        let i = 0;
        while (i < len(self.callbacks)) {
            if (self.callbacks[i]["train_begin"] != nullptr) { self.callbacks[i]["train_begin"](logs); }
            i = i + 1;
        }
        return 0;
    }

    fn train_end(logs) {
        let i = 0;
        while (i < len(self.callbacks)) {
            if (self.callbacks[i]["train_end"] != nullptr) { self.callbacks[i]["train_end"](logs); }
            i = i + 1;
        }
        return 0;
    }

    fn epoch_begin(epoch, logs) {
        let i = 0;
        while (i < len(self.callbacks)) {
            if (self.callbacks[i]["epoch_begin"] != nullptr) { self.callbacks[i]["epoch_begin"](epoch, logs); }
            i = i + 1;
        }
        return 0;
    }

    fn epoch_end(epoch, logs) {
        let i = 0;
        while (i < len(self.callbacks)) {
            if (self.callbacks[i]["epoch_end"] != nullptr) { self.callbacks[i]["epoch_end"](epoch, logs); }
            i = i + 1;
        }
        return 0;
    }

    fn batch_begin(batch, logs) {
        let i = 0;
        while (i < len(self.callbacks)) {
            if (self.callbacks[i]["batch_begin"] != nullptr) { self.callbacks[i]["batch_begin"](batch, logs); }
            i = i + 1;
        }
        return 0;
    }

    fn batch_end(batch, logs) {
        let i = 0;
        while (i < len(self.callbacks)) {
            if (self.callbacks[i]["batch_end"] != nullptr) { self.callbacks[i]["batch_end"](batch, logs); }
            i = i + 1;
        }
        return 0;
    }

    fn add(callback) {
        push(self.callbacks, callback);
        return 0;
    }
}