# ── IsolationForest ──
class IsolationForest {
    let n_estimators = 100;
    let max_samples = 256;
    let contamination = 0.1;
    let trees = [];

    fn init_isolation_forest(n_estimators, max_samples, contamination) {
        if (n_estimators != nullptr) { self.n_estimators = n_estimators; }
        if (max_samples != nullptr) { self.max_samples = max_samples; }
        if (contamination != nullptr) { self.contamination = contamination; }
        self.trees = [];
        return 0;
    }

    fn fit(X) {
        let n = len(X);
        let d = len(X[0]);
        self.trees = [];
        let sub_n = self.max_samples;
        if (sub_n > n) { sub_n = n; }
        let t = 0;
        while (t < self.n_estimators) {
            let sample_idx = [];
            let i = 0;
            while (i < sub_n) {
                let r = hml_randint(0, n - 1);
                push(sample_idx, r);
                i = i + 1;
            }
            let tree = self.build_tree(X, sample_idx, 0, math_floor(math_log(sub_n * 1.0) / math_log(2.0)));
            push(self.trees, tree);
            t = t + 1;
        }
        return 0;
    }

    fn build_tree(X, indices, depth, max_depth) {
        let n = len(indices);
        if (n <= 1) { return {"type": "leaf", "size": n}; }
        if (depth >= max_depth) { return {"type": "leaf", "size": n}; }
        let d = len(X[0]);
        let feat = hml_randint(0, d - 1);
        let min_val = X[indices[0]][feat];
        let max_val = X[indices[0]][feat];
        let i = 1;
        while (i < n) {
            let v = X[indices[i]][feat];
            if (v < min_val) { min_val = v; }
            if (v > max_val) { max_val = v; }
            i = i + 1;
        }
        if (min_val >= max_val) { return {"type": "leaf", "size": n}; }
        let split = min_val + hml_random() * (max_val - min_val);
        let left = [];
        let right = [];
        i = 0;
        while (i < n) {
            if (X[indices[i]][feat] < split) { push(left, indices[i]); }
            else { push(right, indices[i]); }
            i = i + 1;
        }
        let left_tree = self.build_tree(X, left, depth + 1, max_depth);
        let right_tree = self.build_tree(X, right, depth + 1, max_depth);
        return {"type": "node", "feature": feat, "split": split, "left": left_tree, "right": right_tree};
    }

    fn path_length(tree, x, depth) {
        if (tree["type"] == "leaf") {
            let n = tree["size"];
            if (n <= 1) { return depth; }
            return depth + 2.0 * (math_log(n - 1.0) + 0.5772156649) - 2.0 * (n - 1.0) / n;
        }
        if (x[tree["feature"]] < tree["split"]) {
            return self.path_length(tree["left"], x, depth + 1);
        }
        return self.path_length(tree["right"], x, depth + 1);
    }

    fn anomaly_score(x) {
        let total = 0.0;
        let t = 0;
        while (t < len(self.trees)) {
            total = total + self.path_length(self.trees[t], x, 0);
            t = t + 1;
        }
        let avg = total / len(self.trees);
        let n = self.max_samples;
        let c = 2.0 * (math_log(n - 1.0) + 0.5772156649) - 2.0 * (n - 1.0) / n;
        return math_exp(-avg / c);
    }

    fn predict(X) {
        let n = len(X);
        let preds = [];
        let scores = [];
        let i = 0;
        while (i < n) {
            push(scores, self.anomaly_score(X[i]));
            i = i + 1;
        }
        let sorted = [];
        i = 0;
        while (i < n) { push(sorted, scores[i]); i = i + 1; }
        let a = 0;
        while (a < n - 1) {
            let b = 0;
            while (b < n - a - 1) {
                if (sorted[b] < sorted[b + 1]) { let tmp = sorted[b]; sorted[b] = sorted[b + 1]; sorted[b + 1] = tmp; }
                b = b + 1;
            }
            a = a + 1;
        }
        let thresh_idx = math_floor(n * self.contamination);
        let thresh = 0.5;
        if (thresh_idx < n and thresh_idx > 0) { thresh = sorted[thresh_idx]; }
        i = 0;
        while (i < n) {
            if (scores[i] >= thresh) { push(preds, -1); }
            else { push(preds, 1); }
            i = i + 1;
        }
        return preds;
    }

    fn score_samples(X) {
        let n = len(X);
        let scores = [];
        let i = 0;
        while (i < n) { push(scores, self.anomaly_score(X[i])); i = i + 1; }
        return scores;
    }
}

# ── LocalOutlierFactor ──
class LocalOutlierFactor {
    let n_neighbors = 20;
    let contamination = 0.1;
    let X_train = [];

    fn init_lof(n_neighbors, contamination) {
        if (n_neighbors != nullptr) { self.n_neighbors = n_neighbors; }
        if (contamination != nullptr) { self.contamination = contamination; }
        self.X_train = [];
        return 0;
    }

    fn fit(X) {
        self.X_train = X;
        return 0;
    }

    fn predict(X) {
        let n = len(X);
        let d = len(X[0]);
        let scores = [];
        let i = 0;
        while (i < n) {
            let k = self.n_neighbors;
            let distances = [];
            let j = 0;
            while (j < n) {
                if (j != i) {
                    let dist = 0.0;
                    let l = 0;
                    while (l < d) { let diff = X[i][l] - X[j][l]; dist = dist + diff * diff; l = l + 1; }
                    push(distances, {"dist": math_sqrt(dist), "idx": j});
                }
                j = j + 1;
            }
            let a = 0;
            while (a < len(distances) - 1) {
                let b = 0;
                while (b < len(distances) - a - 1) {
                    if (distances[b]["dist"] > distances[b + 1]["dist"]) {
                        let tmp = distances[b];
                        distances[b] = distances[b + 1];
                        distances[b + 1] = tmp;
                    }
                    b = b + 1;
                }
                a = a + 1;
            }
            let lrd = 0.0;
            let m = 0;
            if (k < len(distances)) {
                let max_dist = distances[k - 1]["dist"];
                j = 0;
                while (j < k and j < len(distances)) {
                    let reach_dist = distances[j]["dist"];
                    if (reach_dist < max_dist) { reach_dist = max_dist; }
                    lrd = lrd + reach_dist;
                    j = j + 1;
                }
                lrd = k / lrd;
            }
            push(scores, lrd);
            i = i + 1;
        }
        let sorted = [];
        i = 0;
        while (i < n) { push(sorted, scores[i]); i = i + 1; }
        let a = 0;
        while (a < n - 1) {
            let b = 0;
            while (b < n - a - 1) {
                if (sorted[b] < sorted[b + 1]) { let tmp = sorted[b]; sorted[b] = sorted[b + 1]; sorted[b + 1] = tmp; }
                b = b + 1;
            }
            a = a + 1;
        }
        let thresh_idx = math_floor(n * self.contamination);
        let thresh = sorted[0];
        if (thresh_idx < n and thresh_idx > 0) { thresh = sorted[thresh_idx]; }
        let preds = [];
        i = 0;
        while (i < n) {
            if (scores[i] < thresh) { push(preds, -1); }
            else { push(preds, 1); }
            i = i + 1;
        }
        return preds;
    }

    fn score_samples(X) {
        let n = len(X);
        let d = len(X[0]);
        let scores = [];
        let i = 0;
        while (i < n) {
            let k = self.n_neighbors;
            let distances = [];
            let j = 0;
            while (j < n) {
                if (j != i) {
                    let dist = 0.0;
                    let l = 0;
                    while (l < d) { let diff = X[i][l] - X[j][l]; dist = dist + diff * diff; l = l + 1; }
                    push(distances, {"dist": math_sqrt(dist), "idx": j});
                }
                j = j + 1;
            }
            let a = 0;
            while (a < len(distances) - 1) {
                let b = 0;
                while (b < len(distances) - a - 1) {
                    if (distances[b]["dist"] > distances[b + 1]["dist"]) {
                        let tmp = distances[b];
                        distances[b] = distances[b + 1];
                        distances[b + 1] = tmp;
                    }
                    b = b + 1;
                }
                a = a + 1;
            }
            let lrd = 0.0;
            if (k < len(distances)) {
                let max_dist = distances[k - 1]["dist"];
                j = 0;
                while (j < k and j < len(distances)) {
                    let reach_dist = distances[j]["dist"];
                    if (reach_dist < max_dist) { reach_dist = max_dist; }
                    lrd = lrd + reach_dist;
                    j = j + 1;
                }
                lrd = k / lrd;
            }
            push(scores, lrd);
            i = i + 1;
        }
        return scores;
    }
}

# ── EllipticEnvelope ──
class EllipticEnvelope {
    let contamination = 0.1;
    let mean = [];
    let cov = [];
    let threshold = 0.0;

    fn init_elliptic_envelope(contamination) {
        if (contamination != nullptr) { self.contamination = contamination; }
        self.mean = [];
        self.cov = [];
        return 0;
    }

    fn fit(X) {
        let n = len(X);
        let d = len(X[0]);
        self.mean = hml_vector_zeros(d);
        let i = 0;
        while (i < n) {
            let j = 0;
            while (j < d) { self.mean[j] = self.mean[j] + X[i][j]; j = j + 1; }
            i = i + 1;
        }
        let j = 0;
        while (j < d) { self.mean[j] = self.mean[j] / n; j = j + 1; }
        self.cov = [];
        i = 0;
        while (i < d) {
            let row = [];
            j = 0;
            while (j < d) { push(row, 0.0); j = j + 1; }
            push(self.cov, row);
            i = i + 1;
        }
        i = 0;
        while (i < n) {
            j = 0;
            while (j < d) {
                let k = 0;
                while (k < d) {
                    self.cov[j][k] = self.cov[j][k] + (X[i][j] - self.mean[j]) * (X[i][k] - self.mean[k]);
                    k = k + 1;
                }
                j = j + 1;
            }
            i = i + 1;
        }
        j = 0;
        while (j < d) {
            let k = 0;
            while (k < d) { self.cov[j][k] = self.cov[j][k] / n; k = k + 1; }
            j = j + 1;
        }
        let distances = [];
        i = 0;
        while (i < n) {
            let dist = self.mahalanobis(X[i]);
            push(distances, dist);
            i = i + 1;
        }
        let sorted = [];
        i = 0;
        while (i < n) { push(sorted, distances[i]); i = i + 1; }
        let a = 0;
        while (a < n - 1) {
            let b = 0;
            while (b < n - a - 1) {
                if (sorted[b] < sorted[b + 1]) { let tmp = sorted[b]; sorted[b] = sorted[b + 1]; sorted[b + 1] = tmp; }
                b = b + 1;
            }
            a = a + 1;
        }
        let thresh_idx = math_floor(n * (1.0 - self.contamination));
        if (thresh_idx >= n) { thresh_idx = n - 1; }
        if (thresh_idx < 0) { thresh_idx = 0; }
        self.threshold = sorted[thresh_idx];
        return 0;
    }

    fn mahalanobis(x) {
        let d = len(x);
        let diff = [];
        let i = 0;
        while (i < d) { push(diff, x[i] - self.mean[i]); i = i + 1; }
        let result = 0.0;
        i = 0;
        while (i < d) {
            let j = 0;
            while (j < d) {
                result = result + diff[i] * self.cov[i][j] * diff[j];
                j = j + 1;
            }
            i = i + 1;
        }
        return math_sqrt(result);
    }

    fn predict(X) {
        let n = len(X);
        let preds = [];
        let i = 0;
        while (i < n) {
            let dist = self.mahalanobis(X[i]);
            if (dist <= self.threshold) { push(preds, 1); }
            else { push(preds, -1); }
            i = i + 1;
        }
        return preds;
    }

    fn score_samples(X) {
        let n = len(X);
        let scores = [];
        let i = 0;
        while (i < n) { push(scores, self.mahalanobis(X[i])); i = i + 1; }
        return scores;
    }
}

# ── OneClassSVM ──
class OneClassSVM {
    let nu = 0.5;
    let kernel = "rbf";
    let gamma = 1.0;
    let support_vectors = [];
    let decision_boundary = 0.0;

    fn init_one_class_svm(nu, kernel, gamma) {
        if (nu != nullptr) { self.nu = nu; }
        if (kernel != nullptr) { self.kernel = kernel; }
        if (gamma != nullptr) { self.gamma = gamma; }
        self.support_vectors = [];
        return 0;
    }

    fn fit(X) {
        let n = len(X);
        self.support_vectors = X;
        let d = len(X[0]);
        let max_dist = 0.0;
        let i = 0;
        while (i < n) {
            let j = i + 1;
            while (j < n) {
                let dist = 0.0;
                let l = 0;
                while (l < d) { let diff = X[i][l] - X[j][l]; dist = dist + diff * diff; l = l + 1; }
                if (dist > max_dist) { max_dist = dist; }
                j = j + 1;
            }
            i = i + 1;
        }
        self.decision_boundary = math_sqrt(max_dist) * (1.0 - self.nu);
        return 0;
    }

    fn predict(X) {
        let n = len(X);
        let d = len(X[0]);
        let preds = [];
        let i = 0;
        while (i < n) {
            let min_dist = 1000000000.0;
            let j = 0;
            while (j < len(self.support_vectors)) {
                let dist = 0.0;
                let l = 0;
                while (l < d) { let diff = X[i][l] - self.support_vectors[j][l]; dist = dist + diff * diff; l = l + 1; }
                dist = math_sqrt(dist);
                if (dist < min_dist) { min_dist = dist; }
                j = j + 1;
            }
            if (min_dist <= self.decision_boundary) { push(preds, 1); }
            else { push(preds, -1); }
            i = i + 1;
        }
        return preds;
    }

    fn score_samples(X) {
        let n = len(X);
        let d = len(X[0]);
        let scores = [];
        let i = 0;
        while (i < n) {
            let min_dist = 1000000000.0;
            let j = 0;
            while (j < len(self.support_vectors)) {
                let dist = 0.0;
                let l = 0;
                while (l < d) { let diff = X[i][l] - self.support_vectors[j][l]; dist = dist + diff * diff; l = l + 1; }
                dist = math_sqrt(dist);
                if (dist < min_dist) { min_dist = dist; }
                j = j + 1;
            }
            push(scores, -min_dist);
            i = i + 1;
        }
        return scores;
    }
}

# ── RobustCovariance ──
class RobustCovariance {
    let contamination = 0.1;
    let mean = [];
    let cov = [];
    let threshold = 0.0;

    fn init_robust_covariance(contamination) {
        if (contamination != nullptr) { self.contamination = contamination; }
        self.mean = [];
        self.cov = [];
        return 0;
    }

    fn fit(X) {
        let n = len(X);
        let d = len(X[0]);
        self.mean = hml_vector_zeros(d);
        let i = 0;
        while (i < n) {
            let j = 0;
            while (j < d) { self.mean[j] = self.mean[j] + X[i][j]; j = j + 1; }
            i = i + 1;
        }
        let j = 0;
        while (j < d) { self.mean[j] = self.mean[j] / n; j = j + 1; }
        let distances = [];
        i = 0;
        while (i < n) {
            let dist = 0.0;
            j = 0;
            while (j < d) { let diff = X[i][j] - self.mean[j]; dist = dist + diff * diff; j = j + 1; }
            push(distances, {"dist": math_sqrt(dist), "idx": i});
            i = i + 1;
        }
        let a = 0;
        while (a < n - 1) {
            let b = 0;
            while (b < n - a - 1) {
                if (distances[b]["dist"] > distances[b + 1]["dist"]) {
                    let tmp = distances[b];
                    distances[b] = distances[b + 1];
                    distances[b + 1] = tmp;
                }
                b = b + 1;
            }
            a = a + 1;
        }
        let keep = math_floor(n * (1.0 - self.contamination));
        if (keep < 1) { keep = 1; }
        self.cov = [];
        i = 0;
        while (i < d) {
            let row = [];
            j = 0;
            while (j < d) { push(row, 0.0); j = j + 1; }
            push(self.cov, row);
            i = i + 1;
        }
        let k = 0;
        while (k < keep) {
            let idx = distances[k]["idx"];
            j = 0;
            while (j < d) {
                let l = 0;
                while (l < d) {
                    self.cov[j][l] = self.cov[j][l] + (X[idx][j] - self.mean[j]) * (X[idx][l] - self.mean[l]);
                    l = l + 1;
                }
                j = j + 1;
            }
            k = k + 1;
        }
        j = 0;
        while (j < d) {
            let l = 0;
            while (l < d) { self.cov[j][l] = self.cov[j][l] / keep; l = l + 1; }
            j = j + 1;
        }
        self.threshold = distances[keep - 1]["dist"];
        return 0;
    }

    fn mahalanobis(x) {
        let d = len(x);
        let diff = [];
        let i = 0;
        while (i < d) { push(diff, x[i] - self.mean[i]); i = i + 1; }
        let result = 0.0;
        i = 0;
        while (i < d) {
            let j = 0;
            while (j < d) {
                result = result + diff[i] * self.cov[i][j] * diff[j];
                j = j + 1;
            }
            i = i + 1;
        }
        return math_sqrt(result);
    }

    fn predict(X) {
        let n = len(X);
        let preds = [];
        let i = 0;
        while (i < n) {
            let dist = self.mahalanobis(X[i]);
            if (dist <= self.threshold) { push(preds, 1); }
            else { push(preds, -1); }
            i = i + 1;
        }
        return preds;
    }
}

# ── DBSCANOutlierDetector ──
class DBSCANOutlierDetector {
    let eps = 0.5;
    let min_samples = 5;
    let labels = [];

    fn init_dbscan_outlier(eps, min_samples) {
        if (eps != nullptr) { self.eps = eps; }
        if (min_samples != nullptr) { self.min_samples = min_samples; }
        self.labels = [];
        return 0;
    }

    fn fit_predict(X) {
        let n = len(X);
        let d = len(X[0]);
        self.labels = [];
        let i = 0;
        while (i < n) { push(self.labels, -1); i = i + 1; }
        let cluster_id = 0;
        i = 0;
        while (i < n) {
            if (self.labels[i] != -1) { i = i + 1; }
            else {
                let neighbors = self.region_query(X, i);
                if (len(neighbors) < self.min_samples) {
                    self.labels[i] = -2;
                    i = i + 1;
                }
                else {
                    self.labels[i] = cluster_id;
                    let j = 0;
                    while (j < len(neighbors)) {
                        let idx = neighbors[j];
                        if (self.labels[idx] == -2) { self.labels[idx] = cluster_id; }
                        if (self.labels[idx] == -1) {
                            self.labels[idx] = cluster_id;
                            let new_neighbors = self.region_query(X, idx);
                            if (len(new_neighbors) >= self.min_samples) {
                                let k = 0;
                                while (k < len(new_neighbors)) {
                                    let found = 0;
                                    let m = 0;
                                    while (m < len(neighbors)) { if (neighbors[m] == new_neighbors[k]) { found = 1; } m = m + 1; }
                                    if (found == 0) { push(neighbors, new_neighbors[k]); }
                                    k = k + 1;
                                }
                            }
                        }
                        j = j + 1;
                    }
                    cluster_id = cluster_id + 1;
                    i = i + 1;
                }
            }
        }
        let preds = [];
        i = 0;
        while (i < n) {
            if (self.labels[i] == -2) { push(preds, -1); }
            else { push(preds, 1); }
            i = i + 1;
        }
        return preds;
    }

    fn region_query(X, idx) {
        let n = len(X);
        let d = len(X[0]);
        let neighbors = [];
        let i = 0;
        while (i < n) {
            if (i != idx) {
                let dist = 0.0;
                let j = 0;
                while (j < d) { let diff = X[i][j] - X[idx][j]; dist = dist + diff * diff; j = j + 1; }
                dist = math_sqrt(dist);
                if (dist <= self.eps) { push(neighbors, i); }
            }
            i = i + 1;
        }
        return neighbors;
    }
}

# ── HBOS ──
class HBOS {
    let n_bins = 10;
    let histograms = [];

    fn init_hbos(n_bins) {
        if (n_bins != nullptr) { self.n_bins = n_bins; }
        self.histograms = [];
        return 0;
    }

    fn fit(X) {
        let n = len(X);
        let d = len(X[0]);
        self.histograms = [];
        let j = 0;
        while (j < d) {
            let min_val = X[0][j];
            let max_val = X[0][j];
            let i = 1;
            while (i < n) {
                if (X[i][j] < min_val) { min_val = X[i][j]; }
                if (X[i][j] > max_val) { max_val = X[i][j]; }
                i = i + 1;
            }
            let range = max_val - min_val;
            if (range < 0.000000001) { range = 0.000000001; }
            let bins = [];
            let b = 0;
            while (b < self.n_bins) { push(bins, 0); b = b + 1; }
            i = 0;
            while (i < n) {
                let bin_idx = math_floor((X[i][j] - min_val) / range * self.n_bins);
                if (bin_idx >= self.n_bins) { bin_idx = self.n_bins - 1; }
                if (bin_idx < 0) { bin_idx = 0; }
                bins[bin_idx] = bins[bin_idx] + 1;
                i = i + 1;
            }
            push(self.histograms, {"min": min_val, "max": max_val, "bins": bins, "range": range});
            j = j + 1;
        }
        return 0;
    }

    fn score_samples(X) {
        let n = len(X);
        let d = len(X[0]);
        let scores = [];
        let i = 0;
        while (i < n) {
            let score = 0.0;
            let j = 0;
            while (j < d) {
                let hist = self.histograms[j];
                let bin_idx = math_floor((X[i][j] - hist["min"]) / hist["range"] * self.n_bins);
                if (bin_idx >= self.n_bins) { bin_idx = self.n_bins - 1; }
                if (bin_idx < 0) { bin_idx = 0; }
                let count = hist["bins"][bin_idx];
                if (count < 1) { count = 1; }
                score = score + math_log(1.0 / (count * 1.0 / n));
                j = j + 1;
            }
            push(scores, score);
            i = i + 1;
        }
        return scores;
    }

    fn predict(X) {
        let n = len(X);
        let scores = self.score_samples(X);
        let sorted = [];
        let i = 0;
        while (i < n) { push(sorted, scores[i]); i = i + 1; }
        let a = 0;
        while (a < n - 1) {
            let b = 0;
            while (b < n - a - 1) {
                if (sorted[b] < sorted[b + 1]) { let tmp = sorted[b]; sorted[b] = sorted[b + 1]; sorted[b + 1] = tmp; }
                b = b + 1;
            }
            a = a + 1;
        }
        let thresh = sorted[math_floor(n * 0.9)];
        let preds = [];
        i = 0;
        while (i < n) {
            if (scores[i] > thresh) { push(preds, -1); }
            else { push(preds, 1); }
            i = i + 1;
        }
        return preds;
    }
}

# ── ABOD ──
class ABOD {
    let n_neighbors = 10;
    let X_train = [];

    fn init_abod(n_neighbors) {
        if (n_neighbors != nullptr) { self.n_neighbors = n_neighbors; }
        self.X_train = [];
        return 0;
    }

    fn fit(X) {
        self.X_train = X;
        return 0;
    }

    fn predict(X) {
        let n = len(X);
        let scores = self.score_samples(X);
        let sorted = [];
        let i = 0;
        while (i < n) { push(sorted, scores[i]); i = i + 1; }
        let a = 0;
        while (a < n - 1) {
            let b = 0;
            while (b < n - a - 1) {
                if (sorted[b] < sorted[b + 1]) { let tmp = sorted[b]; sorted[b] = sorted[b + 1]; sorted[b + 1] = tmp; }
                b = b + 1;
            }
            a = a + 1;
        }
        let thresh = sorted[math_floor(n * 0.9)];
        let preds = [];
        i = 0;
        while (i < n) {
            if (scores[i] > thresh) { push(preds, -1); }
            else { push(preds, 1); }
            i = i + 1;
        }
        return preds;
    }

    fn score_samples(X) {
        let n = len(X);
        let d = len(X[0]);
        let scores = [];
        let i = 0;
        while (i < n) {
            let avg_angle = 0.0;
            let count = 0;
            let j = 0;
            while (j < n) {
                if (j != i) {
                    let dot = 0.0;
                    let norm_i = 0.0;
                    let norm_j = 0.0;
                    let l = 0;
                    while (l < d) {
                        dot = dot + X[i][l] * X[j][l];
                        norm_i = norm_i + X[i][l] * X[i][l];
                        norm_j = norm_j + X[j][l] * X[j][l];
                        l = l + 1;
                    }
                    norm_i = math_sqrt(norm_i);
                    norm_j = math_sqrt(norm_j);
                    let cos_angle = 0.0;
                    if (norm_i > 0 and norm_j > 0) {
                        cos_angle = dot / (norm_i * norm_j);
                        if (cos_angle > 1.0) { cos_angle = 1.0; }
                        if (cos_angle < -1.0) { cos_angle = -1.0; }
                    }
                    avg_angle = avg_angle + cos_angle;
                    count = count + 1;
                }
                j = j + 1;
            }
            if (count > 0) { avg_angle = avg_angle / count; }
            push(scores, 1.0 - avg_angle);
            i = i + 1;
        }
        return scores;
    }
}

