    }
}

# ── SoftplusActivation ──
class SoftplusActivation {
    fn init_softplus() { return 0; }

    fn call(x) {
        if (x > 20) { return x; }
        return math_log(1.0 + math_exp(x));
    }

    fn forward(X) {
        let result = [];
        let i = 0;
        while (i < len(X)) {
            let row = [];
            let j = 0;
            while (j < len(X[i])) {
                let x = X[i][j];
                if (x > 20) { push(row, x); }
                else { push(row, math_log(1.0 + math_exp(x))); }
                j = j + 1;
            }
            push(result, row);
            i = i + 1;
        }
        return result;
    }
}

# ── SwishActivation ──
class SwishActivation {
    fn init_swish() { return 0; }

    fn call(x) {
        return x * sigmoid(x);
    }

    fn forward(X) {
        let result = [];
        let i = 0;
        while (i < len(X)) {
            let row = [];
            let j = 0;
            while (j < len(X[i])) {
                push(row, X[i][j] * sigmoid(X[i][j]));
                j = j + 1;
            }
            push(result, row);
            i = i + 1;
        }
        return result;
    }
}

# ── MishActivation ──
class MishActivation {
    fn init_mish() { return 0; }

    fn call(x) {
        let sp = math_log(1.0 + math_exp(x));
        return x * tanh_act(sp);
    }

    fn forward(X) {
        let result = [];
        let i = 0;
        while (i < len(X)) {
            let row = [];
            let j = 0;
            while (j < len(X[i])) {
                let sp = math_log(1.0 + math_exp(X[i][j]));
                push(row, X[i][j] * tanh_act(sp));
                j = j + 1;
            }
            push(result, row);
            i = i + 1;
        }
        return result;
    }
}

# ── HardSigmoidActivation ──
class HardSigmoidActivation {
    fn init_hard_sigmoid() { return 0; }

    fn call(x) {
        if (x <= -2.5) { return 0.0; }
        if (x >= 2.5) { return 1.0; }
        return 0.2 * x + 0.5;
    }

    fn forward(X) {
        let result = [];
        let i = 0;
        while (i < len(X)) {
            let row = [];
            let j = 0;
            while (j < len(X[i])) {
                let x = X[i][j];
                if (x <= -2.5) { push(row, 0.0); }
                else if (x >= 2.5) { push(row, 1.0); }
                else { push(row, 0.2 * x + 0.5); }
                j = j + 1;
            }
            push(result, row);
            i = i + 1;
        }
        return result;
    }
}

