# ── L1Regularizer ──
class L1Regularizer {
    let lambda_val = 0.01;

    fn init_l1(lambda_val) {
        if (lambda_val == nullptr) { self.lambda_val = 0.01; }
        else { self.lambda_val = lambda_val; }
        return 0;
    }

    fn call(weights) {
        let s = 0.0;
        let i = 0;
        while (i < len(weights)) {
            let j = 0;
            while (j < len(weights[i])) {
                let w = weights[i][j];
                if (w < 0) { w = -w; }
                s = s + w;
                j = j + 1;
            }
            i = i + 1;
        }
        return self.lambda_val * s;
    }

    fn gradient(weights) {
        let result = [];
        let i = 0;
        while (i < len(weights)) {
            let row = [];
            let j = 0;
            while (j < len(weights[i])) {
                if (weights[i][j] > 0) { push(row, self.lambda_val); }
                else if (weights[i][j] < 0) { push(row, -self.lambda_val); }
                else { push(row, 0.0); }
                j = j + 1;
            }
            push(result, row);
            i = i + 1;
        }
        return result;
    }
}

# ── L2Regularizer ──
class L2Regularizer {
    let lambda_val = 0.01;

    fn init_l2(lambda_val) {
        if (lambda_val == nullptr) { self.lambda_val = 0.01; }
        else { self.lambda_val = lambda_val; }
        return 0;
    }

    fn call(weights) {
        let s = 0.0;
        let i = 0;
        while (i < len(weights)) {
            let j = 0;
            while (j < len(weights[i])) {
                s = s + weights[i][j] * weights[i][j];
                j = j + 1;
            }
            i = i + 1;
        }
        return self.lambda_val * s;
    }

    fn gradient(weights) {
        return hml_matrix_scale(weights, self.lambda_val);
    }
}

# ── L1L2Regularizer ──
class L1L2Regularizer {
    let l1 = 0.01;
    let l2 = 0.01;

    fn init_l1l2(l1, l2) {
        if (l1 == nullptr) { self.l1 = 0.01; }
        else { self.l1 = l1; }
        if (l2 == nullptr) { self.l2 = 0.01; }
        else { self.l2 = l2; }
        return 0;
    }

    fn call(weights) {
        let s = 0.0;
        let i = 0;
        while (i < len(weights)) {
            let j = 0;
            while (j < len(weights[i])) {
                let w = weights[i][j];
                let aw = w;
                if (aw < 0) { aw = -aw; }
                s = s + self.l1 * aw + self.l2 * w * w;
                j = j + 1;
            }
            i = i + 1;
        }
        return s;
    }
}

# ── SpatialDropout1D ──
class SpatialDropout1D {
    let rate = 0.5;
    let training = true;

    fn init_spatial_dropout1d(rate) {
        self.rate = rate;
        self.training = true;
        return 0;
    }

    fn forward(X) {
        if (not self.training) { return X; }
        let n = len(X);
        let d = len(X[0]);
        let result = [];
        let i = 0;
        while (i < n) {
            if (hml_random() > self.rate) {
                let row = [];
                let j = 0;
                while (j < d) { push(row, X[i][j] / (1.0 - self.rate)); j = j + 1; }
                push(result, row);
            } else {
                push(result, hml_vector_zeros(d));
            }
            i = i + 1;
        }
        return result;
    }

    fn train_mode() { self.training = true; return 0; }
    fn eval_mode() { self.training = false; return 0; }
}

# ── SpatialDropout2D ──
class SpatialDropout2D {
    let rate = 0.5;
    let training = true;

    fn init_spatial_dropout2d(rate) {
        self.rate = rate;
        self.training = true;
        return 0;
    }

    fn forward(X) {
        if (not self.training) { return X; }
        let result = [];
        let i = 0;
        while (i < len(X)) {
            if (hml_random() > self.rate) {
                result = hml_matrix_scale(X, 1.0 / (1.0 - self.rate));
            } else {
                result = hml_matrix_zeros(len(X), len(X[0]));
            }
            i = i + 1;
        }
        return result;
    }

    fn train_mode() { self.training = true; return 0; }
    fn eval_mode() { self.training = false; return 0; }
}

# ── AlphaDropout ──
class AlphaDropout {
    let rate = 0.5;
    let training = true;
    let alpha = 1.6732632423543772;
    let scale = 1.0507009873554805;

    fn init_alpha_dropout(rate) {
        self.rate = rate;
        self.training = true;
        return 0;
    }

    fn forward(X) {
        if (not self.training) { return X; }
        let result = [];
        let i = 0;
        while (i < len(X)) {
            let row = [];
            let j = 0;
            while (j < len(X[i])) {
                if (hml_random() > self.rate) {
                    push(row, X[i][j] * self.scale / (1.0 - self.rate));
                } else {
                    push(row, -self.alpha * self.scale);
                }
                j = j + 1;
            }
            push(result, row);
            i = i + 1;
        }
        return result;
    }

    fn train_mode() { self.training = true; return 0; }
    fn eval_mode() { self.training = false; return 0; }
}

# ── GaussianNoise ──
class GaussianNoise {
    let stddev = 0.1;
    let training = true;

    fn init_gaussian_noise(stddev) {
        if (stddev == nullptr) { self.stddev = 0.1; }
        else { self.stddev = stddev; }
        self.training = true;
        return 0;
    }

    fn forward(X) {
        if (not self.training) { return X; }
        let result = [];
        let i = 0;
        while (i < len(X)) {
            let row = [];
            let j = 0;
            while (j < len(X[i])) {
                let noise = (hml_random() - 0.5) * 2.0 * self.stddev;
                push(row, X[i][j] + noise);
                j = j + 1;
            }
            push(result, row);
            i = i + 1;
        }
        return result;
    }
}

# ── GaussianDropout ──
class GaussianDropout {
    let rate = 0.5;
    let training = true;

    fn init_gaussian_dropout(rate) {
        self.rate = rate;
        self.training = true;
        return 0;
    }

    fn forward(X) {
        if (not self.training) { return X; }
        let result = [];
        let i = 0;
        while (i < len(X)) {
            let row = [];
            let j = 0;
            while (j < len(X[i])) {
                let multiplier = 1.0 + (hml_random() - 0.5) * 2.0 * math_sqrt(self.rate / (1.0 - self.rate));
                push(row, X[i][j] * multiplier);
                j = j + 1;
            }
            push(result, row);
            i = i + 1;
        }
        return result;
    }

    fn train_mode() { self.training = true; return 0; }
    fn eval_mode() { self.training = false; return 0; }
}

# ── ActivityRegularization ──
class ActivityRegularization {
    let l1 = 0.0;
    let l2 = 0.0;

    fn init_activity_reg(l1, l2) {
        if (l1 == nullptr) { self.l1 = 0.0; }
        else { self.l1 = l1; }
        if (l2 == nullptr) { self.l2 = 0.0; }
        else { self.l2 = l2; }
        return 0;
    }

    fn call(X) {
        let s = 0.0;
        let i = 0;
        while (i < len(X)) {
            let j = 0;
            while (j < len(X[i])) {
                let v = X[i][j];
                let av = v;
                if (av < 0) { av = -av; }
                s = s + self.l1 * av + self.l2 * v * v;
                j = j + 1;
            }
            i = i + 1;
        }
        return s;
    }
}

# ── SpectralNormalization ──
class SpectralNormalization {
    let weight_matrix = [];
    let u = [];
    let v = [];
    let n_power_iterations = 1;

    fn init_spectral_norm(weight, n_power_iterations) {
        self.weight_matrix = weight;
        if (n_power_iterations == nullptr) { self.n_power_iterations = 1; }
        else { self.n_power_iterations = n_power_iterations; }
        self.u = hml_vector_random(len(weight));
        self.v = hml_vector_random(len(weight[0]));
        return 0;
    }

    fn compute_sigma() {
        let iter = 0;
        while (iter < self.n_power_iterations) {
            let v_new = [];
            let i = 0;
            while (i < len(self.weight_matrix[0])) {
                let s = 0.0;
                let j = 0;
                while (j < len(self.weight_matrix)) {
                    s = s + self.weight_matrix[j][i] * self.u[j];
                    j = j + 1;
                }
                push(v_new, s);
                i = i + 1;
            }
            let v_norm = 0.0;
            i = 0;
            while (i < len(v_new)) { v_norm = v_norm + v_new[i] * v_new[i]; i = i + 1; }
            v_norm = math_sqrt(v_norm);
            if (v_norm > 0) {
                i = 0;
                while (i < len(v_new)) { self.v[i] = v_new[i] / v_norm; i = i + 1; }
            }
            let u_new = [];
            i = 0;
            while (i < len(self.weight_matrix)) {
                let s = 0.0;
                let j = 0;
                while (j < len(self.weight_matrix[0])) {
                    s = s + self.weight_matrix[i][j] * self.v[j];
                    j = j + 1;
                }
                push(u_new, s);
                i = i + 1;
            }
            let u_norm = 0.0;
            i = 0;
            while (i < len(u_new)) { u_norm = u_norm + u_new[i] * u_new[i]; i = i + 1; }
            u_norm = math_sqrt(u_norm);
            if (u_norm > 0) {
                i = 0;
                while (i < len(u_new)) { self.u[i] = u_new[i] / u_norm; i = i + 1; }
            }
            iter = iter + 1;
        }
        let sigma = 0.0;
        let i = 0;
        while (i < len(self.weight_matrix)) {
            let j = 0;
            while (j < len(self.weight_matrix[0])) {
                sigma = sigma + self.u[i] * self.weight_matrix[i][j] * self.v[j];
                j = j + 1;
            }
            i = i + 1;
        }
        return sigma;
    }

    fn normalize() {
        let sigma = self.compute_sigma();
        if (sigma > 0) {
            return hml_matrix_scale(self.weight_matrix, 1.0 / sigma);
        }
        return self.weight_matrix;
    }
}

# ── WeightDecay ──
class WeightDecay {
    let rate = 0.0001;
    let step = 0;

    fn init_weight_decay(rate) {
        if (rate == nullptr) { self.rate = 0.0001; }
        else { self.rate = rate; }
        self.step = 0;
        return 0;
    }

    fn apply(weights) {
        self.step = self.step + 1;
        let decay = 1.0 - self.rate;
        let result = [];
        let i = 0;
        while (i < len(weights)) {
            let row = [];
            let j = 0;
            while (j < len(weights[i])) {
                push(row, weights[i][j] * decay);
                j = j + 1;
            }
            push(result, row);
            i = i + 1;
        }
        return result;
    }
}

# ── GradientClipping ──
class GradientClipping {
    let clip_value = 1.0;

    fn init_gradient_clip(clip_value) {
        if (clip_value == nullptr) { self.clip_value = 1.0; }
        else { self.clip_value = clip_value; }
        return 0;
    }

    fn clip(grads) {
        let total_norm = 0.0;
        let i = 0;
        while (i < len(grads)) {
            let j = 0;
            while (j < len(grads[i])) {
                total_norm = total_norm + grads[i][j] * grads[i][j];
                j = j + 1;
            }
            i = i + 1;
        }
        total_norm = math_sqrt(total_norm);
        if (total_norm > self.clip_value) {
            let scale = self.clip_value / (total_norm + 0.000000001);
            let result = [];
            i = 0;
            while (i < len(grads)) {
                let row = [];
                let j = 0;
                while (j < len(grads[i])) {
                    push(row, grads[i][j] * scale);
                    j = j + 1;
                }
                push(result, row);
                i = i + 1;
            }
            return result;
        }
        return grads;
    }
}

