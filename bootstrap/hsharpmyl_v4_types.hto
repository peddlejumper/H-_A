class MaxPool2DLayer {
    let pool_size = 2;
    let stride = 2;

    fn init_maxpool2d(pool_size, stride) {
        self.pool_size = pool_size;
        self.stride = stride;
        return 0;
    }

    fn forward(X) {
        let result = [];
        let i = 0;
        while (i < len(X)) {
            push(result, hml_max_pool2d(X[i], self.pool_size, self.stride));
            i = i + 1;
        }
        return result;
    }
}

# ── AvgPool1DLayer ──
class AvgPool1DLayer {
    let pool_size = 2;
    let stride = 2;

    fn init_avgpool1d(pool_size, stride) {
        self.pool_size = pool_size;
        self.stride = stride;
        return 0;
    }

    fn forward(X) {
        let result = [];
        let i = 0;
        while (i < len(X)) {
            let in_len = len(X[i]);
            let out_len = math_floor((in_len - self.pool_size) * 1.0 / self.stride) + 1;
            let row = [];
            let j = 0;
            while (j < out_len) {
                let s = 0.0;
                let cnt = 0;
                let k = 0;
                while (k < self.pool_size) {
                    let idx = j * self.stride + k;
                    if (idx < in_len) { s = s + X[i][idx]; cnt = cnt + 1; }
                    k = k + 1;
                }
                if (cnt > 0) { push(row, s * 1.0 / cnt); }
                else { push(row, 0.0); }
                j = j + 1;
            }
            push(result, row);
            i = i + 1;
        }
        return result;
    }
}

# ── AvgPool2DLayer ──
class AvgPool2DLayer {
    let pool_size = 2;
