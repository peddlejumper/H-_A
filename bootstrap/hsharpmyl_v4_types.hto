# ── MSELoss ──
class MSELoss {
    fn init_mse_loss() { return 0; }

    fn call(y_true, y_pred) {
        return mse(y_true, y_pred);
    }

    fn forward(y_pred, y_true) {
        let s = 0.0;
        let i = 0;
        while (i < len(y_true)) {
            let d = y_true[i] - y_pred[i];
            s = s + d * d;
            i = i + 1;
        }
        return s * 1.0 / len(y_true);
    }
}

# ── MAELoss ──
class MAELoss {
    fn init_mae_loss() { return 0; }

    fn call(y_true, y_pred) {
        return mae(y_true, y_pred);
    }

    fn forward(y_pred, y_true) {
        let s = 0.0;
        let i = 0;
        while (i < len(y_true)) {
            let d = y_true[i] - y_pred[i];
            if (d < 0) { d = -d; }
            s = s + d;
            i = i + 1;
        }
        return s * 1.0 / len(y_true);
    }
}

# ── HuberLoss ──
class HuberLoss {
    let delta = 1.0;

    fn init_huber(delta) {
        if (delta == nullptr) { self.delta = 1.0; }
        else { self.delta = delta; }
        return 0;
    }

    fn forward(y_pred, y_true) {
        let s = 0.0;
        let n = len(y_true);
        let i = 0;
        while (i < n) {
            let d = y_true[i] - y_pred[i];
            let ad = d;
            if (ad < 0) { ad = -ad; }
            if (ad <= self.delta) {
                s = s + 0.5 * d * d;
            } else {
                s = s + self.delta * (ad - 0.5 * self.delta);
            }
            i = i + 1;
        }
        return s * 1.0 / n;
    }
}

# ── BinaryCrossEntropyLoss ──
class BinaryCrossEntropyLoss {
    fn init_bce() { return 0; }

    fn forward(y_pred, y_true) {
        let s = 0.0;
        let n = len(y_true);
        let i = 0;
        while (i < n) {
            let p = y_pred[i];
            if (p < 0.000000001) { p = 0.000000001; }
            if (p > 0.999999999) { p = 0.999999999; }
            s = s - (y_true[i] * math_log(p) + (1.0 - y_true[i]) * math_log(1.0 - p));
            i = i + 1;
        }
        return s * 1.0 / n;
    }
}

# ── CategoricalCrossEntropyLoss ──
class CategoricalCrossEntropyLoss {
    fn init_cce() { return 0; }

    fn forward(y_pred, y_true) {
        let n = len(y_pred);
        let s = 0.0;
        let i = 0;
        while (i < n) {
            let j = 0;
            while (j < len(y_pred[i])) {
                let p = y_pred[i][j];
                if (p < 0.000000001) { p = 0.000000001; }
                s = s - y_true[i][j] * math_log(p);
                j = j + 1;
            }
            i = i + 1;
        }
        return s * 1.0 / n;
    }
}

# ── SparseCategoricalCrossEntropyLoss ──
class SparseCategoricalCrossEntropyLoss {
    fn init_sparse_cce() { return 0; }

    fn forward(y_pred, y_true) {
        let n = len(y_pred);
        let s = 0.0;
        let i = 0;
        while (i < n) {
            let p = y_pred[i][y_true[i]];
            if (p < 0.000000001) { p = 0.000000001; }
            s = s - math_log(p);
            i = i + 1;
        }
        return s * 1.0 / n;
    }
}

# ── HingeLoss ──
class HingeLoss {
    fn init_hinge() { return 0; }

    fn forward(y_pred, y_true) {
        let s = 0.0;
        let n = len(y_true);
        let i = 0;
        while (i < n) {
            let margin = 1.0 - y_true[i] * y_pred[i];
            if (margin > 0) { s = s + margin; }
            i = i + 1;
        }
        return s * 1.0 / n;
    }
}

# ── SquaredHingeLoss ──
class SquaredHingeLoss {
    fn init_squared_hinge() { return 0; }

    fn forward(y_pred, y_true) {
        let s = 0.0;
        let n = len(y_true);
        let i = 0;
        while (i < n) {
            let margin = 1.0 - y_true[i] * y_pred[i];
            if (margin > 0) { s = s + margin * margin; }
            i = i + 1;
        }
        return s * 1.0 / n;
    }
}

# ── KLDivergenceLoss ──
class KLDivergenceLoss {
    fn init_kl_div() { return 0; }

    fn forward(y_pred, y_true) {
        let s = 0.0;
        let n = len(y_pred);
        let i = 0;
        while (i < n) {
            let j = 0;
            while (j < len(y_pred[i])) {
                let p = y_true[i][j];
                let q = y_pred[i][j];
                if (q < 0.000000001) { q = 0.000000001; }
                if (p > 0) { s = s + p * math_log(p / q); }
                j = j + 1;
            }
            i = i + 1;
        }
        return s * 1.0 / n;
    }
}

# ── PoissonLoss ──
class PoissonLoss {
    fn init_poisson() { return 0; }

    fn forward(y_pred, y_true) {
        let s = 0.0;
        let n = len(y_true);
        let i = 0;
        while (i < n) {
            let pred = y_pred[i];
            if (pred < 0.000000001) { pred = 0.000000001; }
            s = s + pred - y_true[i] * math_log(pred);
            i = i + 1;
        }
        return s * 1.0 / n;
    }
}

# ── CosineSimilarityLoss ──
class CosineSimilarityLoss {
    fn init_cosine_loss() { return 0; }

    fn forward(y_pred, y_true) {
        let n = len(y_pred);
        let d = len(y_pred[0]);
        let s = 0.0;
        let i = 0;
        while (i < n) {
            let dot = 0.0;
            let n1 = 0.0;
            let n2 = 0.0;
            let j = 0;
            while (j < d) {
                dot = dot + y_pred[i][j] * y_true[i][j];
                n1 = n1 + y_pred[i][j] * y_pred[i][j];
                n2 = n2 + y_true[i][j] * y_true[i][j];
                j = j + 1;
            }
            let denom = math_sqrt(n1) * math_sqrt(n2) + 0.000000001;
            s = s + (1.0 - dot / denom);
            i = i + 1;
        }
        return s * 1.0 / n;
    }
}

# ── LogCoshLoss ──
class LogCoshLoss {
    fn init_log_cosh() { return 0; }

    fn forward(y_pred, y_true) {
        let s = 0.0;
        let n = len(y_true);
        let i = 0;
        while (i < n) {
            let d = y_pred[i] - y_true[i];
            s = s + math_log((math_exp(d) + math_exp(-d)) * 0.5);
            i = i + 1;
        }
        return s * 1.0 / n;
    }
}

# ── QuantileLoss ──
class QuantileLoss {
    let quantile = 0.5;

    fn init_quantile(quantile) {
        if (quantile == nullptr) { self.quantile = 0.5; }
        else { self.quantile = quantile; }
        return 0;
    }

    fn forward(y_pred, y_true) {
        let s = 0.0;
        let n = len(y_true);
        let i = 0;
        while (i < n) {
            let e = y_true[i] - y_pred[i];
            if (e > 0) { s = s + self.quantile * e; }
            else { s = s + (self.quantile - 1.0) * e; }
            i = i + 1;
        }
        return s * 1.0 / n;
    }
}

# ── FocalLoss ──
class FocalLoss {
    let gamma = 2.0;
    let alpha = 0.25;

    fn init_focal(gamma, alpha) {
        if (gamma == nullptr) { self.gamma = 2.0; }
        else { self.gamma = gamma; }
        if (alpha == nullptr) { self.alpha = 0.25; }
        else { self.alpha = alpha; }
        return 0;
    }

    fn forward(y_pred, y_true) {
        let s = 0.0;
        let n = len(y_true);
        let i = 0;
        while (i < n) {
            let p = y_pred[i];
            if (p < 0.000000001) { p = 0.000000001; }
            if (p > 0.999999999) { p = 0.999999999; }
            let pt = y_true[i] * p + (1.0 - y_true[i]) * (1.0 - p);
            let alpha_t = y_true[i] * self.alpha + (1.0 - y_true[i]) * (1.0 - self.alpha);
            s = s - alpha_t * math_pow(1.0 - pt, self.gamma) * math_log(pt);
            i = i + 1;
        }
        return s * 1.0 / n;
    }
}

# ── TripletLoss ──
class TripletLoss {
    let margin = 1.0;

    fn init_triplet(margin) {
        if (margin == nullptr) { self.margin = 1.0; }
        else { self.margin = margin; }
        return 0;
    }

    fn forward(anchor, positive, negative) {
        let n = len(anchor);
        let s = 0.0;
        let i = 0;
        while (i < n) {
            let d_ap = 0.0;
            let d_an = 0.0;
            let j = 0;
            while (j < len(anchor[i])) {
                let da = anchor[i][j] - positive[i][j];
                d_ap = d_ap + da * da;
                let dn = anchor[i][j] - negative[i][j];
                d_an = d_an + dn * dn;
                j = j + 1;
            }
            let loss = d_ap - d_an + self.margin;
            if (loss > 0) { s = s + loss; }
            i = i + 1;
        }
        return s * 1.0 / n;
    }
}

