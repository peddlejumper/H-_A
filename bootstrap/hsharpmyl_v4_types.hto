# SECTION 39: Feature Engineering & Preprocessing
# ═══════════════════════════════════════════════════════════════════════════

# ── RobustScaler ──
class RobustScaler {
    let medians = [];
    let iqr = [];
    let fitted = false;

    fn init_robust_scaler() {
        self.medians = [];
        self.iqr = [];
        self.fitted = false;
        return 0;
    }

    fn fit(X) {
        let n_cols = len(X[0]);
        let n_rows = len(X);
        self.medians = [];
        self.iqr = [];
        let j = 0;
        while (j < n_cols) {
            let col = [];
            let i = 0;
            while (i < n_rows) { push(col, X[i][j]); i = i + 1; }
            let sorted = [];
            i = 0;
            while (i < len(col)) { push(sorted, col[i]); i = i + 1; }
            i = 0;
            while (i < len(sorted) - 1) {
                let k = 0;
                while (k < len(sorted) - i - 1) {
                    if (sorted[k] > sorted[k + 1]) {
                        let tmp = sorted[k];
                        sorted[k] = sorted[k + 1];
                        sorted[k + 1] = tmp;
                    }
                    k = k + 1;
                }
                i = i + 1;
            }
            let mid = n_rows / 2;
            let median = sorted[mid];
            let q1 = sorted[n_rows / 4];
            let q3 = sorted[3 * n_rows / 4];
            push(self.medians, median);
            push(self.iqr, q3 - q1);
            j = j + 1;
        }
        self.fitted = true;
        return 0;
    }

    fn transform(X) {
        let result = [];
        let i = 0;
        while (i < len(X)) {
            let row = [];
            let j = 0;
            while (j < len(X[i])) {
                let scale = self.iqr[j];
                if (scale == 0.0) { scale = 1.0; }
                push(row, (X[i][j] - self.medians[j]) / scale);
                j = j + 1;
            }
            push(result, row);
            i = i + 1;
        }
        return result;
    }

    fn fit_transform(X) {
        self.fit(X);
        return self.transform(X);
    }
}

# ── MaxAbsScaler ──
class MaxAbsScaler {
    let max_abs = [];
    let fitted = false;

    fn init_maxabs_scaler() {
        self.max_abs = [];
        self.fitted = false;
        return 0;
    }

    fn fit(X) {
        let n_cols = len(X[0]);
        let n_rows = len(X);
        self.max_abs = [];
        let j = 0;
        while (j < n_cols) {
            let mx = 0.0;
            let i = 0;
            while (i < n_rows) {
                let v = X[i][j];
                if (v < 0) { v = -v; }
                if (v > mx) { mx = v; }
                i = i + 1;
            }
            push(self.max_abs, mx);
            j = j + 1;
        }
        self.fitted = true;
        return 0;
    }

    fn transform(X) {
        let result = [];
        let i = 0;
        while (i < len(X)) {
            let row = [];
            let j = 0;
            while (j < len(X[i])) {
                let scale = self.max_abs[j];
                if (scale == 0.0) { scale = 1.0; }
                push(row, X[i][j] / scale);
                j = j + 1;
            }
            push(result, row);
            i = i + 1;
        }
        return result;
    }

    fn fit_transform(X) {
        self.fit(X);
        return self.transform(X);
    }
}

# ── Normalizer ──
class Normalizer {
    let norm = "l2";

    fn init_normalizer(norm) {
        if (norm == nullptr) { self.norm = "l2"; }
        else { self.norm = norm; }
        return 0;
    }

    fn transform(X) {
        let result = [];
        let i = 0;
        while (i < len(X)) {
            let s = 0.0;
            let j = 0;
            if (self.norm == "l1") {
                while (j < len(X[i])) {
                    let v = X[i][j];
                    if (v < 0) { v = -v; }
                    s = s + v;
                    j = j + 1;
                }
            } else {
                while (j < len(X[i])) {
                    s = s + X[i][j] * X[i][j];
                    j = j + 1;
                }
                s = math_sqrt(s);
            }
            if (s == 0.0) { s = 1.0; }
            let row = [];
            j = 0;
            while (j < len(X[i])) {
                push(row, X[i][j] / s);
                j = j + 1;
            }
            push(result, row);
            i = i + 1;
        }
        return result;
    }

    fn fit(X, y) { return 0; }
    fn fit_transform(X, y) { return self.transform(X); }
}

# ── Binarizer ──
class Binarizer {
    let threshold = 0.0;

    fn init_binarizer(threshold) {
        if (threshold == nullptr) { self.threshold = 0.0; }
        else { self.threshold = threshold; }
        return 0;
    }

    fn transform(X) {
        let result = [];
        let i = 0;
        while (i < len(X)) {
            let row = [];
            let j = 0;
            while (j < len(X[i])) {
                if (X[i][j] > self.threshold) { push(row, 1.0); }
                else { push(row, 0.0); }
                j = j + 1;
            }
            push(result, row);
            i = i + 1;
        }
        return result;
    }

    fn fit(X, y) { return 0; }
    fn fit_transform(X, y) { return self.transform(X); }
}

# ── QuantileTransformer ──
class QuantileTransformer {
    let n_quantiles = 1000;
    let references = [];
    let fitted = false;

    fn init_quantile_transformer(n_quantiles) {
        if (n_quantiles == nullptr) { self.n_quantiles = 1000; }
        else { self.n_quantiles = n_quantiles; }
        self.references = [];
        self.fitted = false;
        return 0;
    }

    fn fit(X) {
        let n_cols = len(X[0]);
        let n_rows = len(X);
        self.references = [];
        let j = 0;
        while (j < n_cols) {
            let col = [];
            let i = 0;
            while (i < n_rows) { push(col, X[i][j]); i = i + 1; }
            let sorted = [];
            i = 0;
            while (i < len(col)) { push(sorted, col[i]); i = i + 1; }
            i = 0;
            while (i < len(sorted) - 1) {
                let k = 0;
                while (k < len(sorted) - i - 1) {
                    if (sorted[k] > sorted[k + 1]) {
                        let tmp = sorted[k];
                        sorted[k] = sorted[k + 1];
                        sorted[k + 1] = tmp;
                    }
                    k = k + 1;
                }
                i = i + 1;
            }
            push(self.references, sorted);
            j = j + 1;
        }
        self.fitted = true;
        return 0;
    }

    fn transform(X) {
        let n_rows = len(X);
        let result = [];
        let i = 0;
        while (i < n_rows) {
            let row = [];
            let j = 0;
            while (j < len(X[i])) {
                let ref_col = self.references[j];
                let rank = 0;
                let k = 0;
                while (k < len(ref_col)) {
                    if (X[i][j] >= ref_col[k]) { rank = k; }
                    k = k + 1;
                }
                push(row, rank * 1.0 / (len(ref_col) - 1));
                j = j + 1;
            }
            push(result, row);
            i = i + 1;
        }
        return result;
    }

    fn fit_transform(X) {
        self.fit(X);
        return self.transform(X);
    }
}

# ── PowerTransformer ──
class PowerTransformer {
    let method = "yeo-johnson";
    let lambdas = [];
    let fitted = false;

    fn init_power_transformer(method) {
        if (method == nullptr) { self.method = "yeo-johnson"; }
        else { self.method = method; }
        self.lambdas = [];
        self.fitted = false;
        return 0;
    }

    fn fit(X) {
        let n_cols = len(X[0]);
        self.lambdas = [];
        let j = 0;
        while (j < n_cols) {
            push(self.lambdas, 0.0);
            j = j + 1;
        }
        self.fitted = true;
        return 0;
    }

    fn transform(X) {
        let result = [];
        let i = 0;
        while (i < len(X)) {
            let row = [];
            let j = 0;
            while (j < len(X[i])) {
                let x = X[i][j];
                let lb = self.lambdas[j];
                if (self.method == "yeo-johnson") {
                    if (x >= 0 and lb != 0) {
                        x = (math_pow(x + 1.0, lb) - 1.0) / lb;
                    } else if (x >= 0 and lb == 0) {
                        x = math_log(x + 1.0);
                    } else if (x < 0 and lb != 2.0) {
                        x = -(math_pow(-x + 1.0, 2.0 - lb) - 1.0) / (2.0 - lb);
                    } else {
                        x = -math_log(-x + 1.0);
                    }
                }
                push(row, x);
                j = j + 1;
            }
            push(result, row);
            i = i + 1;
        }
        return result;
    }

    fn fit_transform(X) {
        self.fit(X);
        return self.transform(X);
    }
}

# ── KBinsDiscretizer ──
class KBinsDiscretizer {
    let n_bins = 5;
    let bin_edges = [];
    let fitted = false;

    fn init_kbins(n_bins) {
        if (n_bins == nullptr) { self.n_bins = 5; }
        else { self.n_bins = n_bins; }
        self.bin_edges = [];
        self.fitted = false;
        return 0;
    }

    fn fit(X) {
        let n_cols = len(X[0]);
        let n_rows = len(X);
        self.bin_edges = [];
        let j = 0;
        while (j < n_cols) {
            let mn = X[0][j];
            let mx = X[0][j];
            let i = 0;
            while (i < n_rows) {
                if (X[i][j] < mn) { mn = X[i][j]; }
                if (X[i][j] > mx) { mx = X[i][j]; }
                i = i + 1;
            }
            let edges = [];
            let b = 0;
            while (b <= self.n_bins) {
                push(edges, mn + b * (mx - mn) * 1.0 / self.n_bins);
                b = b + 1;
            }
            push(self.bin_edges, edges);
            j = j + 1;
        }
        self.fitted = true;
        return 0;
    }

    fn transform(X) {
        let result = [];
        let i = 0;
        while (i < len(X)) {
            let row = [];
            let j = 0;
            while (j < len(X[i])) {
                let bin = 0;
                let edges = self.bin_edges[j];
                let b = 0;
                while (b < self.n_bins) {
                    if (X[i][j] >= edges[b] and (b == self.n_bins - 1 or X[i][j] < edges[b + 1])) {
                        bin = b;
                    }
                    b = b + 1;
                }
                push(row, bin);
                j = j + 1;
            }
            push(result, row);
            i = i + 1;
        }
        return result;
    }

    fn fit_transform(X) {
        self.fit(X);
        return self.transform(X);
    }
}

# ── PolynomialFeatures ──
class PolynomialFeatures {
    let degree = 2;
    let include_bias = true;

    fn init_polynomial(degree, include_bias) {
        if (degree == nullptr) { self.degree = 2; }
        else { self.degree = degree; }
        if (include_bias == nullptr) { self.include_bias = true; }
        else { self.include_bias = include_bias; }
        return 0;
    }

    fn transform(X) {
        let n = len(X);
        let d = len(X[0]);
        let result = [];
        let i = 0;
        while (i < n) {
            let row = [];
            if (self.include_bias) { push(row, 1.0); }
            let j = 0;
            while (j < d) { push(row, X[i][j]); j = j + 1; }
            if (self.degree >= 2) {
                let j = 0;
                while (j < d) {
                    let k = j;
                    while (k < d) {
                        push(row, X[i][j] * X[i][k]);
                        k = k + 1;
                    }
                    j = j + 1;
                }
            }
            if (self.degree >= 3) {
                let j = 0;
                while (j < d) {
                    push(row, X[i][j] * X[i][j] * X[i][j]);
                    j = j + 1;
                }
            }
            push(result, row);
            i = i + 1;
        }
        return result;
    }

    fn fit(X, y) { return 0; }
    fn fit_transform(X, y) { return self.transform(X); }
}

# ── OneHotEncoder ──
class OneHotEncoder {
    let categories = [];
    let fitted = false;

    fn init_onehot() {
        self.categories = [];
        self.fitted = false;
        return 0;
    }

    fn fit(X) {
        let n_cols = len(X[0]);
        let n_rows = len(X);
        self.categories = [];
        let j = 0;
        while (j < n_cols) {
            let col = [];
            let i = 0;
            while (i < n_rows) { push(col, X[i][j]); i = i + 1; }
            push(self.categories, hml_unique(col));
            j = j + 1;
        }
        self.fitted = true;
        return 0;
    }

    fn transform(X) {
        let result = [];
        let i = 0;
        while (i < len(X)) {
            let row = [];
            let j = 0;
            while (j < len(X[i])) {
                let cats = self.categories[j];
                let k = 0;
                while (k < len(cats)) {
                    if (X[i][j] == cats[k]) { push(row, 1.0); }
                    else { push(row, 0.0); }
                    k = k + 1;
                }
                j = j + 1;
            }
            push(result, row);
            i = i + 1;
        }
        return result;
    }

    fn fit_transform(X) {
        self.fit(X);
        return self.transform(X);
    }
}

# ── OrdinalEncoder ──
class OrdinalEncoder {
    let categories = [];
    let fitted = false;

    fn init_ordinal() {
        self.categories = [];
        self.fitted = false;
        return 0;
    }

    fn fit(X) {
        let n_cols = len(X[0]);
        let n_rows = len(X);
        self.categories = [];
        let j = 0;
        while (j < n_cols) {
            let col = [];
            let i = 0;
            while (i < n_rows) { push(col, X[i][j]); i = i + 1; }
            push(self.categories, hml_unique(col));
            j = j + 1;
        }
        self.fitted = true;
        return 0;
    }

    fn transform(X) {
        let result = [];
        let i = 0;
        while (i < len(X)) {
            let row = [];
            let j = 0;
            while (j < len(X[i])) {
                let cats = self.categories[j];
                let val = 0;
                let k = 0;
                while (k < len(cats)) {
                    if (X[i][j] == cats[k]) { val = k; break; }
                    k = k + 1;
                }
                push(row, val);
                j = j + 1;
            }
            push(result, row);
            i = i + 1;
        }
        return result;
    }

    fn fit_transform(X) {
        self.fit(X);
        return self.transform(X);
    }
}

# ── TargetEncoder ──
class TargetEncoder {
    let encoding = {};
    let fitted = false;

    fn init_target_encoder() {
        self.encoding = {};
        self.fitted = false;
        return 0;
    }

    fn fit(X, y) {
        self.encoding = {};
        let n = len(y);
        let global_mean = hml_mean(y);
        let i = 0;
        while (i < n) {
            let key = X[i][0];
            if (self.encoding[key] == nullptr) {
                self.encoding[key] = {"sum": 0.0, "count": 0};
            }
            self.encoding[key]["sum"] = self.encoding[key]["sum"] + y[i];
            self.encoding[key]["count"] = self.encoding[key]["count"] + 1;
            i = i + 1;
        }
        let keys = dict_keys(self.encoding);
        let k = 0;
        while (k < len(keys)) {
            let key = keys[k];
            let smoothing = 10;
            let mean = self.encoding[key]["sum"] * 1.0 / self.encoding[key]["count"];
            let smoothed = (self.encoding[key]["count"] * mean + smoothing * global_mean) * 1.0 / (self.encoding[key]["count"] + smoothing);
            self.encoding[key] = smoothed;
            k = k + 1;
        }
        self.fitted = true;
        return 0;
    }

    fn transform(X) {
        let result = [];
        let i = 0;
        while (i < len(X)) {
            let key = X[i][0];
            if (self.encoding[key] != nullptr) {
                push(result, [self.encoding[key]]);
            } else {
                push(result, [0.0]);
            }
            i = i + 1;
        }
        return result;
    }

    fn fit_transform(X, y) {
        self.fit(X, y);
        return self.transform(X);
    }
}

# ── CountEncoder ──
class CountEncoder {
    let counts = {};
    let fitted = false;

    fn init_count_encoder() {
        self.counts = {};
        self.fitted = false;
        return 0;
    }

    fn fit(X) {
        self.counts = {};
        let i = 0;
        while (i < len(X)) {
            let key = X[i][0];
            if (self.counts[key] == nullptr) { self.counts[key] = 0; }
            self.counts[key] = self.counts[key] + 1;
            i = i + 1;
        }
        self.fitted = true;
        return 0;
    }

    fn transform(X) {
        let result = [];
        let i = 0;
        while (i < len(X)) {
            let key = X[i][0];
            if (self.counts[key] != nullptr) {
                push(result, [self.counts[key]]);
            } else {
                push(result, [0.0]);
            }
            i = i + 1;
        }
        return result;
    }

    fn fit_transform(X) {
        self.fit(X);
        return self.transform(X);
    }
}

# ── LabelBinarizer ──
class LabelBinarizer {
    let classes = [];
    let fitted = false;

    fn init_label_binarizer() {
        self.classes = [];
        self.fitted = false;
        return 0;
    }

    fn fit(y) {
        self.classes = hml_unique(y);
        self.fitted = true;
        return 0;
    }

    fn transform(y) {
        let result = [];
        let i = 0;
        while (i < len(y)) {
            let row = [];
            let j = 0;
            while (j < len(self.classes)) {
                if (y[i] == self.classes[j]) { push(row, 1.0); }
                else { push(row, 0.0); }
                j = j + 1;
            }
            push(result, row);
            i = i + 1;
        }
        return result;
    }

    fn fit_transform(y) {
        self.fit(y);
        return self.transform(y);
    }
}

# ── MultiLabelBinarizer ──
class MultiLabelBinarizer {
    let classes = [];
    let fitted = false;

    fn init_multilabel_binarizer() {
        self.classes = [];
        self.fitted = false;
        return 0;
    }

    fn fit(y) {
        let all_classes = [];
        let i = 0;
        while (i < len(y)) {
            let j = 0;
            while (j < len(y[i])) {
                push(all_classes, y[i][j]);
                j = j + 1;
            }
            i = i + 1;
        }
        self.classes = hml_unique(all_classes);
        self.fitted = true;
        return 0;
    }

    fn transform(y) {
        let result = [];
        let i = 0;
        while (i < len(y)) {
            let row = [];
            let j = 0;
            while (j < len(self.classes)) {
                let found = false;
                let k = 0;
                while (k < len(y[i])) {
                    if (y[i][k] == self.classes[j]) { found = true; break; }
                    k = k + 1;
                }
                if (found) { push(row, 1.0); }
                else { push(row, 0.0); }
                j = j + 1;
            }
            push(result, row);
            i = i + 1;
        }
        return result;
    }

    fn fit_transform(y) {
        self.fit(y);
        return self.transform(y);
    }
}

# ── SplineTransformer ──
class SplineTransformer {
    let n_knots = 5;
    let degree = 3;
    let knots = [];
    let fitted = false;

    fn init_spline(n_knots, degree) {
        if (n_knots == nullptr) { self.n_knots = 5; }
        else { self.n_knots = n_knots; }
        if (degree == nullptr) { self.degree = 3; }
        else { self.degree = degree; }
        self.knots = [];
        self.fitted = false;
        return 0;
    }

    fn fit(X) {
        let n_cols = len(X[0]);
        let n_rows = len(X);
        self.knots = [];
        let j = 0;
        while (j < n_cols) {
            let mn = X[0][j];
            let mx = X[0][j];
            let i = 0;
            while (i < n_rows) {
                if (X[i][j] < mn) { mn = X[i][j]; }
                if (X[i][j] > mx) { mx = X[i][j]; }
                i = i + 1;
            }
            let col_knots = [];
            let k = 0;
            while (k < self.n_knots) {
                push(col_knots, mn + k * (mx - mn) * 1.0 / (self.n_knots - 1));
                k = k + 1;
            }
            push(self.knots, col_knots);
            j = j + 1;
        }
        self.fitted = true;
        return 0;
    }

    fn transform(X) {
        let result = [];
        let i = 0;
        while (i < len(X)) {
            let row = [];
            let j = 0;
            while (j < len(X[i])) {
                let k = 0;
                while (k < self.n_knots) {
                    let d = X[i][j] - self.knots[j][k];
                    if (d > 0) { push(row, math_pow(d, self.degree)); }
                    else { push(row, 0.0); }
                    k = k + 1;
                }
                j = j + 1;
            }
            push(result, row);
            i = i + 1;
        }
        return result;
    }

    fn fit_transform(X) {
        self.fit(X);
        return self.transform(X);
    }
}

# ═══════════════════════════════════════════════════════════════════════════
# SECTION 40: Model Selection & Cross-Validation
# ═══════════════════════════════════════════════════════════════════════════

# ── KFold ──
class KFold {
    let n_splits = 5;
    let shuffle = false;
    let random_state = 42;

    fn init_kfold(n_splits, shuffle, random_state) {
        self.n_splits = n_splits;
        if (shuffle == nullptr) { self.shuffle = false; }
        else { self.shuffle = shuffle; }
        if (random_state == nullptr) { self.random_state = 42; }
        else { self.random_state = random_state; }
        return 0;
    }

    fn split(X) {
        let n = len(X);
        let indices = [];
        let i = 0;
        while (i < n) { push(indices, i); i = i + 1; }
        if (self.shuffle) { indices = hml_shuffle(indices); }
        let splits = [];
        let fold_size = n / self.n_splits;
        let f = 0;
        while (f < self.n_splits) {
            let test_start = f * fold_size;
            let test_end = test_start + fold_size;
            if (f == self.n_splits - 1) { test_end = n; }
            let train_idx = [];
            let test_idx = [];
            let i = 0;
            while (i < n) {
                if (i >= test_start and i < test_end) {
                    push(test_idx, indices[i]);
                } else {
                    push(train_idx, indices[i]);
                }
                i = i + 1;
            }
            push(splits, {"train": train_idx, "test": test_idx});
            f = f + 1;
        }
        return splits;
    }
}

# ── StratifiedKFold ──
class StratifiedKFold {
    let n_splits = 5;
    let shuffle = false;

    fn init_stratified_kfold(n_splits, shuffle) {
        self.n_splits = n_splits;
        if (shuffle == nullptr) { self.shuffle = false; }
        else { self.shuffle = shuffle; }
        return 0;
    }

    fn split(X, y) {
        let n = len(X);
        let classes = hml_unique(y);
        let class_indices = {};
        let c = 0;
        while (c < len(classes)) {
            class_indices[classes[c]] = [];
            c = c + 1;
        }
        let i = 0;
        while (i < n) {
            push(class_indices[y[i]], i);
            i = i + 1;
        }
        let splits = [];
        let f = 0;
        while (f < self.n_splits) {
            let train_idx = [];
            let test_idx = [];
            c = 0;
            while (c < len(classes)) {
                let indices = class_indices[classes[c]];
                let n_class = len(indices);
                let fold_size = n_class / self.n_splits;
                let test_start = f * fold_size;
                let test_end = test_start + fold_size;
                if (f == self.n_splits - 1) { test_end = n_class; }
                let i = 0;
                while (i < n_class) {
                    if (i >= test_start and i < test_end) {
                        push(test_idx, indices[i]);
                    } else {
                        push(train_idx, indices[i]);
                    }
                    i = i + 1;
                }
                c = c + 1;
            }
            push(splits, {"train": train_idx, "test": test_idx});
            f = f + 1;
        }
        return splits;
    }
}

# ── GroupKFold ──
class GroupKFold {
    let n_splits = 5;

    fn init_group_kfold(n_splits) {
        self.n_splits = n_splits;
        return 0;
    }

    fn split(X, y, groups) {
        let unique_groups = hml_unique(groups);
        let n_groups = len(unique_groups);
        let splits = [];
        let fold_size = n_groups / self.n_splits;
        let f = 0;
        while (f < self.n_splits) {
            let test_start = f * fold_size;
            let test_end = test_start + fold_size;
            if (f == self.n_splits - 1) { test_end = n_groups; }
            let test_groups = {};
            let g = test_start;
            while (g < test_end) {
                test_groups[unique_groups[g]] = true;
                g = g + 1;
            }
            let train_idx = [];
            let test_idx = [];
            let i = 0;
            while (i < len(groups)) {
                if (test_groups[groups[i]] != nullptr) {
                    push(test_idx, i);
                } else {
                    push(train_idx, i);
                }
                i = i + 1;
            }
            push(splits, {"train": train_idx, "test": test_idx});
            f = f + 1;
        }
        return splits;
    }
}

# ── TimeSeriesSplit ──
class TimeSeriesSplit {
    let n_splits = 5;

    fn init_ts_split(n_splits) {
        self.n_splits = n_splits;
        return 0;
    }

    fn split(X) {
        let n = len(X);
        let splits = [];
        let f = 0;
        while (f < self.n_splits) {
            let test_size = n / (self.n_splits + 1);
            let train_end = (f + 1) * test_size;
            let test_end = train_end + test_size;
            if (f == self.n_splits - 1) { test_end = n; }
            let train_idx = [];
            let test_idx = [];
            let i = 0;
            while (i < n) {
                if (i < train_end) { push(train_idx, i); }
                if (i >= train_end and i < test_end) { push(test_idx, i); }
                i = i + 1;
            }
            push(splits, {"train": train_idx, "test": test_idx});
            f = f + 1;
        }
        return splits;
    }
}

# ── LeaveOneOut ──
class LeaveOneOut {
    fn init_loo() { return 0; }

    fn split(X) {
        let n = len(X);
        let splits = [];
        let i = 0;
        while (i < n) {
            let train_idx = [];
            let test_idx = [i];
            let j = 0;
            while (j < n) {
                if (j != i) { push(train_idx, j); }
                j = j + 1;
            }
            push(splits, {"train": train_idx, "test": test_idx});
            i = i + 1;
        }
        return splits;
    }
}

# ── LeavePOut ──
class LeavePOut {
    let p = 2;

    fn init_lpo(p) {
        self.p = p;
        return 0;
    }

    fn split(X) {
        let n = len(X);
        let splits = [];
        let i = 0;
        while (i < n - self.p + 1) {
            let train_idx = [];
            let test_idx = [];
            let j = 0;
            while (j < n) {
                if (j >= i and j < i + self.p) { push(test_idx, j); }
                else { push(train_idx, j); }
                j = j + 1;
            }
            push(splits, {"train": train_idx, "test": test_idx});
            i = i + 1;
        }
        return splits;
    }
}

# ── ShuffleSplit ──
class ShuffleSplit {
    let n_splits = 10;
    let test_size = 0.2;

    fn init_shuffle_split(n_splits, test_size) {
        self.n_splits = n_splits;
        if (test_size == nullptr) { self.test_size = 0.2; }
        else { self.test_size = test_size; }
        return 0;
    }

    fn split(X) {
        let n = len(X);
        let splits = [];
        let s = 0;
        while (s < self.n_splits) {
            let indices = [];
            let i = 0;
            while (i < n) { push(indices, i); i = i + 1; }
            indices = hml_shuffle(indices);
            let test_n = math_floor(n * self.test_size);
            let train_idx = [];
            let test_idx = [];
            i = 0;
            while (i < n) {
                if (i < test_n) { push(test_idx, indices[i]); }
                else { push(train_idx, indices[i]); }
                i = i + 1;
            }
            push(splits, {"train": train_idx, "test": test_idx});
            s = s + 1;
        }
        return splits;
    }
}

# ── StratifiedShuffleSplit ──
class StratifiedShuffleSplit {
    let n_splits = 10;
    let test_size = 0.2;

    fn init_stratified_shuffle_split(n_splits, test_size) {
        self.n_splits = n_splits;
        if (test_size == nullptr) { self.test_size = 0.2; }
        else { self.test_size = test_size; }
        return 0;
    }

    fn split(X, y) {
        let n = len(X);
        let classes = hml_unique(y);
        let splits = [];
        let s = 0;
        while (s < self.n_splits) {
            let train_idx = [];
            let test_idx = [];
            let c = 0;
            while (c < len(classes)) {
                let class_indices = [];
                let i = 0;
                while (i < n) {
                    if (y[i] == classes[c]) { push(class_indices, i); }
                    i = i + 1;
                }
                class_indices = hml_shuffle(class_indices);
                let test_n = math_floor(len(class_indices) * self.test_size);
                i = 0;
                while (i < len(class_indices)) {
                    if (i < test_n) { push(test_idx, class_indices[i]); }
                    else { push(train_idx, class_indices[i]); }
                    i = i + 1;
                }
                c = c + 1;
            }
            push(splits, {"train": train_idx, "test": test_idx});
            s = s + 1;
        }
        return splits;
    }
}

# ── RepeatedKFold ──
class RepeatedKFold {
    let n_splits = 5;
    let n_repeats = 10;
    let kfold = nullptr;

    fn init_repeated_kfold(n_splits, n_repeats) {
        self.n_splits = n_splits;
        self.n_repeats = n_repeats;
        self.kfold = new KFold();
        self.kfold.init_kfold(n_splits, true, 42);
        return 0;
    }

    fn split(X) {
        let all_splits = [];
        let r = 0;
        while (r < self.n_repeats) {
            let kfold = new KFold();
            kfold.init_kfold(self.n_splits, true, r);
            let splits = kfold.split(X);
            let s = 0;
            while (s < len(splits)) {
                push(all_splits, splits[s]);
                s = s + 1;
            }
            r = r + 1;
        }
        return all_splits;
    }
}

# ── RepeatedStratifiedKFold ──
class RepeatedStratifiedKFold {
    let n_splits = 5;
    let n_repeats = 10;

    fn init_repeated_stratified_kfold(n_splits, n_repeats) {
        self.n_splits = n_splits;
        self.n_repeats = n_repeats;
        return 0;
    }

    fn split(X, y) {
        let all_splits = [];
        let r = 0;
        while (r < self.n_repeats) {
            let kfold = new StratifiedKFold();
            kfold.init_stratified_kfold(self.n_splits, true);
            let splits = kfold.split(X, y);
            let s = 0;
            while (s < len(splits)) {
                push(all_splits, splits[s]);
                s = s + 1;
            }
            r = r + 1;
        }
        return all_splits;
    }
}

# ── GridSearchCV ──
class GridSearchCV {
    let estimator = nullptr;
    let param_grid = {};
    let cv = 5;
    let best_params = {};
    let best_score = -1000000000;
    let fitted = false;

    fn init_grid_search(estimator, param_grid, cv) {
        self.estimator = estimator;
        self.param_grid = param_grid;
        if (cv == nullptr) { self.cv = 5; }
        else { self.cv = cv; }
        self.best_params = {};
        self.best_score = -1000000000;
        self.fitted = false;
        return 0;
    }

    fn fit(X, y) {
        let kfold = new KFold();
        kfold.init_kfold(self.cv, true, 42);
        let splits = kfold.split(X);
        let keys = dict_keys(self.param_grid);
        let n_params = len(keys);
        let combos = self._generate_combos(keys, 0, {});
        let c = 0;
        while (c < len(combos)) {
            let params = combos[c];
            let total_score = 0.0;
            let s = 0;
            while (s < len(splits)) {
                let train_idx = splits[s]["train"];
                let test_idx = splits[s]["test"];
                let X_train = [];
                let y_train = [];
                let i = 0;
                while (i < len(train_idx)) { push(X_train, X[train_idx[i]]); push(y_train, y[train_idx[i]]); i = i + 1; }
                let X_test = [];
                let y_test = [];
                i = 0;
                while (i < len(test_idx)) { push(X_test, X[test_idx[i]]); push(y_test, y[test_idx[i]]); i = i + 1; }
                let model = self.estimator();
                let model_keys = dict_keys(params);
                let k = 0;
                while (k < len(model_keys)) { model[model_keys[k]] = params[model_keys[k]]; k = k + 1; }
                model["fit"](X_train, y_train);
                let y_pred = model["predict"](X_test);
                total_score = total_score + accuracy_score(y_test, y_pred);
                s = s + 1;
            }
            let avg_score = total_score * 1.0 / len(splits);
            if (avg_score > self.best_score) {
                self.best_score = avg_score;
                self.best_params = params;
            }
            c = c + 1;
        }
        self.fitted = true;
        return 0;
    }

    fn _generate_combos(keys, idx, current) {
        if (idx >= len(keys)) {
            let combo = {};
            let k = 0;
            while (k < len(keys)) { combo[keys[k]] = current[keys[k]]; k = k + 1; }
            return [combo];
        }
        let key = keys[idx];
        let values = self.param_grid[key];
        let results = [];
        let v = 0;
        while (v < len(values)) {
            current[key] = values[v];
            let sub = self._generate_combos(keys, idx + 1, current);
            let i = 0;
            while (i < len(sub)) { push(results, sub[i]); i = i + 1; }
            v = v + 1;
        }
        return results;
    }

    fn predict(X) {
        return [];
    }

    fn score(X, y) {
        return self.best_score;
    }
}

# ── RandomizedSearchCV ──
class RandomizedSearchCV {
    let estimator = nullptr;
    let param_distributions = {};
    let n_iter = 10;
    let cv = 5;
    let best_params = {};
    let best_score = -1000000000;
    let fitted = false;

    fn init_randomized_search(estimator, param_distributions, n_iter, cv) {
        self.estimator = estimator;
        self.param_distributions = param_distributions;
        if (n_iter == nullptr) { self.n_iter = 10; }
        else { self.n_iter = n_iter; }
        if (cv == nullptr) { self.cv = 5; }
        else { self.cv = cv; }
        self.best_params = {};
        self.best_score = -1000000000;
        self.fitted = false;
        return 0;
    }

    fn fit(X, y) {
        let kfold = new KFold();
        kfold.init_kfold(self.cv, true, 42);
        let splits = kfold.split(X);
        let keys = dict_keys(self.param_distributions);
        let iter_num = 0;
        while (iter_num < self.n_iter) {
            let params = {};
            let k = 0;
            while (k < len(keys)) {
                let key = keys[k];
                let values = self.param_distributions[key];
                params[key] = values[hml_randint(0, len(values) - 1)];
                k = k + 1;
            }
            let total_score = 0.0;
            let s = 0;
            while (s < len(splits)) {
                let train_idx = splits[s]["train"];
                let test_idx = splits[s]["test"];
                let X_train = [];
                let y_train = [];
                let i = 0;
                while (i < len(train_idx)) { push(X_train, X[train_idx[i]]); push(y_train, y[train_idx[i]]); i = i + 1; }
                let X_test = [];
                let y_test = [];
                i = 0;
                while (i < len(test_idx)) { push(X_test, X[test_idx[i]]); push(y_test, y[test_idx[i]]); i = i + 1; }
                let model = self.estimator();
                let model_keys = dict_keys(params);
                let j = 0;
                while (j < len(model_keys)) { model[model_keys[j]] = params[model_keys[j]]; j = j + 1; }
                model["fit"](X_train, y_train);
                let y_pred = model["predict"](X_test);
                total_score = total_score + accuracy_score(y_test, y_pred);
                s = s + 1;
            }
            let avg_score = total_score * 1.0 / len(splits);
            if (avg_score > self.best_score) {
                self.best_score = avg_score;
                self.best_params = params;
            }
            iter_num = iter_num + 1;
        }
        self.fitted = true;
        return 0;
    }

    fn predict(X) { return []; }
    fn score(X, y) { return self.best_score; }
}

# ── TrainTestSplit ──
class TrainTestSplit {
    let test_size = 0.2;
    let shuffle = true;

    fn init_train_test_split(test_size, shuffle) {
        if (test_size == nullptr) { self.test_size = 0.2; }
        else { self.test_size = test_size; }
        if (shuffle == nullptr) { self.shuffle = true; }
        else { self.shuffle = shuffle; }
        return 0;
    }

    fn split(X, y) {
        let n = len(X);
        let indices = [];
        let i = 0;
        while (i < n) { push(indices, i); i = i + 1; }
        if (self.shuffle) { indices = hml_shuffle(indices); }
        let test_n = math_floor(n * self.test_size);
        let X_train = [];
        let X_test = [];
        let y_train = [];
        let y_test = [];
        i = 0;
        while (i < n) {
            if (i < test_n) {
                push(X_test, X[indices[i]]);
                push(y_test, y[indices[i]]);
            } else {
                push(X_train, X[indices[i]]);
                push(y_train, y[indices[i]]);
            }
            i = i + 1;
        }
        return {"X_train": X_train, "X_test": X_test, "y_train": y_train, "y_test": y_test};
    }
}

# ── PredefinedSplit ──
class PredefinedSplit {
    let test_fold = [];

    fn init_predefined_split(test_fold) {
        self.test_fold = test_fold;
        return 0;
    }

    fn split(X) {
        let n = len(X);
        let train_idx = [];
        let test_idx = [];
        let i = 0;
        while (i < n) {
            if (self.test_fold[i] == -1) { push(train_idx, i); }
            else { push(test_idx, i); }
            i = i + 1;
        }
        return [{"train": train_idx, "test": test_idx}];
    }
}

# ── CrossValidate ──
class CrossValidate {
    let cv = 5;
    let scoring = "accuracy";

    fn init_cross_validate(cv, scoring) {
        if (cv == nullptr) { self.cv = 5; }
        else { self.cv = cv; }
        if (scoring == nullptr) { self.scoring = "accuracy"; }
        else { self.scoring = scoring; }
        return 0;
    }

    fn evaluate(estimator, X, y) {
        let kfold = new KFold();
        kfold.init_kfold(self.cv, true, 42);
        let splits = kfold.split(X);
        let scores = [];
        let s = 0;
        while (s < len(splits)) {
            let train_idx = splits[s]["train"];
            let test_idx = splits[s]["test"];
            let X_train = [];
            let y_train = [];
            let i = 0;
            while (i < len(train_idx)) { push(X_train, X[train_idx[i]]); push(y_train, y[train_idx[i]]); i = i + 1; }
            let X_test = [];
            let y_test = [];
            i = 0;
            while (i < len(test_idx)) { push(X_test, X[test_idx[i]]); push(y_test, y[test_idx[i]]); i = i + 1; }
            estimator["fit"](X_train, y_train);
            let y_pred = estimator["predict"](X_test);
            let sc = accuracy_score(y_test, y_pred);
            if (self.scoring == "r2") { sc = r2_score(y_test, y_pred); }
            push(scores, sc);
            s = s + 1;
        }
        return scores;
    }
}

# ═══════════════════════════════════════════════════════════════════════════
# SECTION 41: Evaluation Metrics
# ═══════════════════════════════════════════════════════════════════════════

# ── AccuracyScore ──
class AccuracyScore {
    fn init_accuracy_score() { return 0; }
    fn call(y_true, y_pred) { return accuracy_score(y_true, y_pred); }
    fn score(y_true, y_pred) { return accuracy_score(y_true, y_pred); }
}

# ── PrecisionScore ──
class PrecisionScore {
    fn init_precision_score() { return 0; }
    fn call(y_true, y_pred, pos_label) { return precision_score(y_true, y_pred, pos_label); }
    fn score(y_true, y_pred, pos_label) { return precision_score(y_true, y_pred, pos_label); }
}

# ── RecallScore ──
class RecallScore {
    fn init_recall_score() { return 0; }
    fn call(y_true, y_pred, pos_label) { return recall_score(y_true, y_pred, pos_label); }
    fn score(y_true, y_pred, pos_label) { return recall_score(y_true, y_pred, pos_label); }
}

# ── F1ScoreMetric ──
class F1ScoreMetric {
    fn init_f1_score() { return 0; }
    fn call(y_true, y_pred, pos_label) { return f1_score(y_true, y_pred, pos_label); }
    fn score(y_true, y_pred, pos_label) { return f1_score(y_true, y_pred, pos_label); }
}

# ── FBetaScore ──
class FBetaScore {
    let beta = 1.0;

    fn init_fbeta(beta) {
        if (beta == nullptr) { self.beta = 1.0; }
        else { self.beta = beta; }
        return 0;
    }

    fn score(y_true, y_pred, pos_label) {
        let p = precision_score(y_true, y_pred, pos_label);
        let r = recall_score(y_true, y_pred, pos_label);
        let denom = self.beta * self.beta * p + r;
        if (denom == 0) { return 0.0; }
        return (1.0 + self.beta * self.beta) * p * r / denom;
    }
}

# ── ROCAUCScore ──
class ROCAUCScore {
    fn init_roc_auc() { return 0; }

    fn score(y_true, y_scores) {
        let n = len(y_true);
        let pairs = [];
        let i = 0;
        while (i < n) { push(pairs, {"score": y_scores[i], "label": y_true[i]}); i = i + 1; }
        i = 0;
        while (i < n - 1) {
            let j = 0;
            while (j < n - i - 1) {
                if (pairs[j]["score"] < pairs[j + 1]["score"]) {
                    let tmp = pairs[j];
                    pairs[j] = pairs[j + 1];
                    pairs[j + 1] = tmp;
                }
                j = j + 1;
            }
            i = i + 1;
        }
        let pos = 0;
        let neg = 0;
        i = 0;
        while (i < n) {
            if (pairs[i]["label"] == 1) { pos = pos + 1; }
            else { neg = neg + 1; }
            i = i + 1;
        }
        if (pos == 0 or neg == 0) { return 0.0; }
        let auc = 0.0;
        let fp = 0;
        let tp = 0;
        let prev_fpr = 0.0;
        let prev_tpr = 0.0;
        i = 0;
        while (i < n) {
            if (pairs[i]["label"] == 1) { tp = tp + 1; }
            else { fp = fp + 1; }
            let tpr = tp * 1.0 / pos;
            let fpr = fp * 1.0 / neg;
            auc = auc + (fpr - prev_fpr) * (tpr + prev_tpr) * 0.5;
            prev_fpr = fpr;
            prev_tpr = tpr;
            i = i + 1;
        }
        return auc;
    }
}

# ── PrecisionRecallCurve ──
class PrecisionRecallCurve {
    fn init_pr_curve() { return 0; }

    fn compute(y_true, y_scores) {
        let n = len(y_true);
        let pairs = [];
        let i = 0;
        while (i < n) { push(pairs, {"score": y_scores[i], "label": y_true[i]}); i = i + 1; }
        i = 0;
        while (i < n - 1) {
            let j = 0;
            while (j < n - i - 1) {
                if (pairs[j]["score"] < pairs[j + 1]["score"]) {
                    let tmp = pairs[j];
                    pairs[j] = pairs[j + 1];
                    pairs[j + 1] = tmp;
                }
                j = j + 1;
            }
            i = i + 1;
        }
        let precisions = [];
        let recalls = [];
        let tp = 0;
        let fp = 0;
        let total_pos = 0;
        i = 0;
        while (i < n) { if (y_true[i] == 1) { total_pos = total_pos + 1; } i = i + 1; }
        i = 0;
        while (i < n) {
            if (pairs[i]["label"] == 1) { tp = tp + 1; }
            else { fp = fp + 1; }
            let denom = tp + fp;
            if (denom > 0) { push(precisions, tp * 1.0 / denom); }
            else { push(precisions, 1.0); }
            if (total_pos > 0) { push(recalls, tp * 1.0 / total_pos); }
            else { push(recalls, 0.0); }
            i = i + 1;
        }
        return {"precision": precisions, "recall": recalls};
    }
}

# ── ConfusionMatrixMetric ──
class ConfusionMatrixMetric {
    fn init_confusion_matrix_metric() { return 0; }

    fn compute(y_true, y_pred, n_classes) {
        return confusion_matrix(y_true, y_pred, n_classes);
    }

    fn summary(y_true, y_pred, n_classes) {
        let cm = confusion_matrix(y_true, y_pred, n_classes);
        let total = 0;
        let i = 0;
        while (i < n_classes) {
            let j = 0;
            while (j < n_classes) { total = total + cm[i][j]; j = j + 1; }
            i = i + 1;
        }
        let accuracy = 0.0;
        i = 0;
        while (i < n_classes) { accuracy = accuracy + cm[i][i]; i = i + 1; }
        if (total > 0) { accuracy = accuracy * 1.0 / total; }
        return {"matrix": cm, "accuracy": accuracy, "total": total};
    }
}

# ── ClassificationReport ──
class ClassificationReport {
    fn init_classification_report() { return 0; }

    fn generate(y_true, y_pred, class_names) {
        let n_classes = len(class_names);
        let cm = confusion_matrix(y_true, y_pred, n_classes);
        let report = {};
        let i = 0;
        while (i < n_classes) {
            let tp = cm[i][i];
            let fp = 0;
            let fneg = 0;
            let support = 0;
            let j = 0;
            while (j < n_classes) {
                if (j != i) { fp = fp + cm[j][i]; fneg = fneg + cm[i][j]; }
                support = support + cm[i][j];
                j = j + 1;
            }
            let precision = 0.0;
            let denom_p = tp + fp;
            if (denom_p > 0) { precision = tp * 1.0 / denom_p; }
            let recall = 0.0;
            let denom_r = tp + fneg;
            if (denom_r > 0) { recall = tp * 1.0 / denom_r; }
            let f1 = 0.0;
            if (precision + recall > 0) { f1 = 2.0 * precision * recall / (precision + recall); }
            report[class_names[i]] = {"precision": precision, "recall": recall, "f1": f1, "support": support};
            i = i + 1;
        }
        return report;
    }
}

# ── MeanSquaredErrorMetric ──
class MeanSquaredErrorMetric {
    fn init_mse_metric() { return 0; }
    fn call(y_true, y_pred) { return mse(y_true, y_pred); }
    fn score(y_true, y_pred) { return mse(y_true, y_pred); }
}

# ── MeanAbsoluteErrorMetric ──
class MeanAbsoluteErrorMetric {
    fn init_mae_metric() { return 0; }
    fn call(y_true, y_pred) { return mae(y_true, y_pred); }
    fn score(y_true, y_pred) { return mae(y_true, y_pred); }
}

# ── RMSE ──
class RMSE {
    fn init_rmse() { return 0; }
    fn call(y_true, y_pred) { return math_sqrt(mse(y_true, y_pred)); }
    fn score(y_true, y_pred) { return math_sqrt(mse(y_true, y_pred)); }
}

# ── R2ScoreMetric ──
class R2ScoreMetric {
    fn init_r2_score_metric() { return 0; }
    fn call(y_true, y_pred) { return r2_score(y_true, y_pred); }
    fn score(y_true, y_pred) { return r2_score(y_true, y_pred); }
}

# ── MeanAbsolutePercentageError ──
class MeanAbsolutePercentageError {
    fn init_mape() { return 0; }

    fn call(y_true, y_pred) {
        let n = len(y_true);
        if (n == 0) { return 0.0; }
        let total = 0.0;
        let i = 0;
        while (i < n) {
            if (y_true[i] != 0) { total = total + math_fabs((y_true[i] - y_pred[i]) / y_true[i]); }
            i = i + 1;
        }
        if (n == 0) { return 0.0; }
        return total * 100.0 / n;
    }

    fn score(y_true, y_pred) { return self.call(y_true, y_pred); }
}

# ── LogLossMetric ──
class LogLossMetric {
    fn init_log_loss() { return 0; }

    fn call(y_true, y_pred) {
        let n = len(y_true);
        if (n == 0) { return 0.0; }
        let total = 0.0;
        let i = 0;
        while (i < n) {
            let p = y_pred[i];
            if (p < 0.000000001) { p = 0.000000001; }
            if (p > 0.999999999) { p = 0.999999999; }
            total = total + y_true[i] * math_log(p) + (1.0 - y_true[i]) * math_log(1.0 - p);
            i = i + 1;
        }
        return -total / n;
    }

    fn score(y_true, y_pred) { return self.call(y_true, y_pred); }
}

# ═══════════════════════════════════════════════════════════════════════════
# SECTION 42: Ensemble Methods
# ═══════════════════════════════════════════════════════════════════════════

# ── RandomForestClassifier ──
class RandomForestClassifier {
    let n_estimators = 100;
    let max_depth = 10;
    let min_samples_split = 2;
    let max_features = nullptr;
    let estimators = [];
    let feature_importances = [];
    let n_classes = 0;

    fn init_random_forest_classifier(n_estimators, max_depth, min_samples_split, max_features) {
        if (n_estimators != nullptr) { self.n_estimators = n_estimators; }
        if (max_depth != nullptr) { self.max_depth = max_depth; }
        if (min_samples_split != nullptr) { self.min_samples_split = min_samples_split; }
        if (max_features != nullptr) { self.max_features = max_features; }
        self.estimators = [];
        return 0;
    }

    fn fit(X, y) {
        let n = len(X);
        let d = len(X[0]);
        let classes = hml_unique(y);
        self.n_classes = len(classes);
        let n_feat = d;
        if (self.max_features != nullptr) { n_feat = math_floor(math_sqrt(d * 1.0)); }
        let t = 0;
        while (t < self.n_estimators) {
            let sample_idx = [];
            let i = 0;
            while (i < n) {
                let r = hml_randint(0, n - 1);
                push(sample_idx, r);
                i = i + 1;
            }
            let tree = {
                "type": "decision_tree",
                "depth": self.max_depth,
                "min_split": self.min_samples_split,
                "n_features": n_feat,
                "selected_features": [],
                "root": nullptr
            };
            let k = 0;
            while (k < n_feat) {
                let fidx = hml_randint(0, d - 1);
                push(tree["selected_features"], fidx);
                k = k + 1;
            }
            let depth = 0;
            let node = self.build_tree_sample(X, y, sample_idx, depth, tree["selected_features"]);
            tree["root"] = node;
            push(self.estimators, tree);
            t = t + 1;
        }
        self.compute_feature_importances();
        return 0;
    }

    fn build_tree_sample(X, y, indices, depth, features) {
        let n = len(indices);
        if (n == 0) { return {"leaf": 0, "count": n}; }
        if (depth >= self.max_depth) {
            let votes = [];
            let i = 0;
            while (i < n) { push(votes, y[indices[i]]); i = i + 1; }
            return {"leaf": self.majority_vote(votes), "count": n};
        }
        if (n < self.min_samples_split) {
            let votes = [];
            let i = 0;
            while (i < n) { push(votes, y[indices[i]]); i = i + 1; }
            return {"leaf": self.majority_vote(votes), "count": n};
        }
        let all_same = 1;
        let i = 1;
        while (i < n) {
            if (y[indices[i]] != y[indices[0]]) { all_same = 0; }
            i = i + 1;
        }
        if (all_same == 1) { return {"leaf": y[indices[0]], "count": n}; }
        let best_feat = features[0];
        let best_thresh = 0.0;
        let best_gini = 1000000000.0;
        let f = 0;
        while (f < len(features)) {
            let feat = features[f];
            let vals = [];
            i = 0;
            while (i < n) { push(vals, X[indices[i]][feat]); i = i + 1; }
            let mean_val = 0.0;
            i = 0;
            while (i < n) { mean_val = mean_val + vals[i]; i = i + 1; }
            mean_val = mean_val / n;
            let left_y = [];
            let right_y = [];
            i = 0;
            while (i < n) {
                if (vals[i] <= mean_val) { push(left_y, y[indices[i]]); }
                else { push(right_y, y[indices[i]]); }
                i = i + 1;
            }
            let gini = self.gini_impurity_split(left_y, right_y);
            if (gini < best_gini) { best_gini = gini; best_feat = feat; best_thresh = mean_val; }
            f = f + 1;
        }
        let left_indices = [];
        let right_indices = [];
        i = 0;
        while (i < n) {
            if (X[indices[i]][best_feat] <= best_thresh) { push(left_indices, indices[i]); }
            else { push(right_indices, indices[i]); }
            i = i + 1;
        }
        return {
            "feature": best_feat,
            "threshold": best_thresh,
            "left": self.build_tree_sample(X, y, left_indices, depth + 1, features),
            "right": self.build_tree_sample(X, y, right_indices, depth + 1, features)
        };
    }

    fn gini_impurity_split(left_y, right_y) {
        let total = len(left_y) + len(right_y);
        if (total == 0) { return 0.0; }
        let gini_left = self.gini_impurity(left_y);
        let gini_right = self.gini_impurity(right_y);
        return (len(left_y) * gini_left + len(right_y) * gini_right) / total;
    }

    fn gini_impurity(y_vals) {
        let n = len(y_vals);
        if (n == 0) { return 0.0; }
        let counts = {};
        let i = 0;
        while (i < n) {
            let key = y_vals[i];
            let c = 0;
            if (dict_keys(counts) != []) {
                let keys = dict_keys(counts);
                let found = 0;
                let kk = 0;
                while (kk < len(keys)) { if (keys[kk] == key) { found = 1; } kk = kk + 1; }
                if (found == 1) { c = counts[key]; }
            }
            counts[key] = c + 1;
            i = i + 1;
        }
        let gini = 1.0;
        let keys = dict_keys(counts);
        let k = 0;
        while (k < len(keys)) {
            let p = counts[keys[k]] * 1.0 / n;
            gini = gini - p * p;
            k = k + 1;
        }
        return gini;
    }

    fn majority_vote(votes) {
        let counts = {};
        let i = 0;
        while (i < len(votes)) {
            let key = votes[i];
            let c = 0;
            if (dict_keys(counts) != []) {
                let keys = dict_keys(counts);
                let found = 0;
                let kk = 0;
                while (kk < len(keys)) { if (keys[kk] == key) { found = 1; } kk = kk + 1; }
                if (found == 1) { c = counts[key]; }
            }
            counts[key] = c + 1;
            i = i + 1;
        }
        let best = votes[0];
        let best_c = 0;
        let keys = dict_keys(counts);
        let k = 0;
        while (k < len(keys)) {
            if (counts[keys[k]] > best_c) { best_c = counts[keys[k]]; best = keys[k]; }
            k = k + 1;
        }
        return best;
    }

    fn predict_one(tree, x) {
        if (tree["leaf"] != nullptr) { return tree["leaf"]; }
        if (x[tree["feature"]] <= tree["threshold"]) { return self.predict_one(tree["left"], x); }
        return self.predict_one(tree["right"], x);
    }

    fn predict(X) {
        let n = len(X);
        let preds = [];
        let i = 0;
        while (i < n) {
            let votes = {};
            let t = 0;
            while (t < self.n_estimators) {
                let vote = self.predict_one(self.estimators[t]["root"], X[i]);
                let c = 0;
                if (dict_keys(votes) != []) {
                    let keys = dict_keys(votes);
                    let found = 0;
                    let kk = 0;
                    while (kk < len(keys)) { if (keys[kk] == vote) { found = 1; } kk = kk + 1; }
                    if (found == 1) { c = votes[vote]; }
                }
                votes[vote] = c + 1;
                t = t + 1;
            }
            let best_vote = 0;
            let best_cnt = 0;
            let keys = dict_keys(votes);
            let k = 0;
            while (k < len(keys)) {
                if (votes[keys[k]] > best_cnt) { best_cnt = votes[keys[k]]; best_vote = keys[k]; }
                k = k + 1;
            }
            push(preds, best_vote);
            i = i + 1;
        }
        return preds;
    }

    fn compute_feature_importances() {
        let d = 0;
        if (len(self.estimators) > 0) { d = len(self.estimators[0]["selected_features"]); }
        self.feature_importances = hml_vector_zeros(d);
        return 0;
    }

    fn score(X, y) {
        let y_pred = self.predict(X);
        return accuracy_score(y, y_pred);
    }
}

# ── RandomForestRegressor ──
class RandomForestRegressor {
    let n_estimators = 100;
    let max_depth = 10;
    let min_samples_split = 2;
    let max_features = nullptr;
    let estimators = [];

    fn init_random_forest_regressor(n_estimators, max_depth, min_samples_split, max_features) {
        if (n_estimators != nullptr) { self.n_estimators = n_estimators; }
        if (max_depth != nullptr) { self.max_depth = max_depth; }
        if (min_samples_split != nullptr) { self.min_samples_split = min_samples_split; }
        if (max_features != nullptr) { self.max_features = max_features; }
        self.estimators = [];
        return 0;
    }

    fn fit(X, y) {
        let n = len(X);
        let d = len(X[0]);
        let n_feat = d;
        if (self.max_features != nullptr) { n_feat = math_floor(math_sqrt(d * 1.0)); }
        let t = 0;
        while (t < self.n_estimators) {
            let sample_idx = [];
            let i = 0;
            while (i < n) {
                let r = hml_randint(0, n - 1);
                push(sample_idx, r);
                i = i + 1;
            }
            let tree = {
                "type": "regression_tree",
                "depth": self.max_depth,
                "min_split": self.min_samples_split,
                "n_features": n_feat,
                "selected_features": [],
                "root": nullptr
            };
            let k = 0;
            while (k < n_feat) {
                let fidx = hml_randint(0, d - 1);
                push(tree["selected_features"], fidx);
                k = k + 1;
            }
            let depth = 0;
            let node = self.build_tree_reg_sample(X, y, sample_idx, depth, tree["selected_features"]);
            tree["root"] = node;
            push(self.estimators, tree);
            t = t + 1;
        }
        return 0;
    }

    fn build_tree_reg_sample(X, y, indices, depth, features) {
        let n = len(indices);
        if (n == 0) { return {"leaf": 0.0, "count": n}; }
        if (depth >= self.max_depth or n < self.min_samples_split) {
            let mean_val = 0.0;
            let i = 0;
            while (i < n) { mean_val = mean_val + y[indices[i]]; i = i + 1; }
            return {"leaf": mean_val / n, "count": n};
        }
        let best_feat = features[0];
        let best_thresh = 0.0;
        let best_var = 1000000000.0;
        let f = 0;
        while (f < len(features)) {
            let feat = features[f];
            let vals = [];
            let i = 0;
            while (i < n) { push(vals, X[indices[i]][feat]); i = i + 1; }
            let mean_val = 0.0;
            i = 0;
            while (i < n) { mean_val = mean_val + vals[i]; i = i + 1; }
            mean_val = mean_val / n;
            let left_y = [];
            let right_y = [];
            i = 0;
            while (i < n) {
                if (vals[i] <= mean_val) { push(left_y, y[indices[i]]); }
                else { push(right_y, y[indices[i]]); }
                i = i + 1;
            }
            let var_left = 0.0;
            let var_right = 0.0;
            if (len(left_y) > 0) {
                let m = 0.0;
                let j = 0; while (j < len(left_y)) { m = m + left_y[j]; j = j + 1; }
                m = m / len(left_y);
                j = 0; while (j < len(left_y)) { let d = left_y[j] - m; var_left = var_left + d * d; j = j + 1; }
            }
            if (len(right_y) > 0) {
                let m = 0.0;
                let j = 0; while (j < len(right_y)) { m = m + right_y[j]; j = j + 1; }
                m = m / len(right_y);
                j = 0; while (j < len(right_y)) { let d = right_y[j] - m; var_right = var_right + d * d; j = j + 1; }
            }
            let total_var = var_left + var_right;
            if (total_var < best_var) { best_var = total_var; best_feat = feat; best_thresh = mean_val; }
            f = f + 1;
        }
        let left_indices = [];
        let right_indices = [];
        let i = 0;
        while (i < n) {
            if (X[indices[i]][best_feat] <= best_thresh) { push(left_indices, indices[i]); }
            else { push(right_indices, indices[i]); }
            i = i + 1;
        }
        if (len(left_indices) == 0 or len(right_indices) == 0) {
            let mean_val = 0.0;
            i = 0;
            while (i < n) { mean_val = mean_val + y[indices[i]]; i = i + 1; }
            return {"leaf": mean_val / n, "count": n};
        }
        return {
            "feature": best_feat,
            "threshold": best_thresh,
            "left": self.build_tree_reg_sample(X, y, left_indices, depth + 1, features),
            "right": self.build_tree_reg_sample(X, y, right_indices, depth + 1, features)
        };
    }

    fn predict_one(tree, x) {
        if (tree["leaf"] != nullptr) { return tree["leaf"]; }
        if (x[tree["feature"]] <= tree["threshold"]) { return self.predict_one(tree["left"], x); }
        return self.predict_one(tree["right"], x);
    }

    fn predict(X) {
        let n = len(X);
        let preds = hml_vector_zeros(n);
        let i = 0;
        while (i < n) {
            let total = 0.0;
            let t = 0;
            while (t < self.n_estimators) {
                total = total + self.predict_one(self.estimators[t]["root"], X[i]);
                t = t + 1;
            }
            preds[i] = total / self.n_estimators;
            i = i + 1;
        }
        return preds;
    }

    fn score(X, y) {
        let y_pred = self.predict(X);
        return r2_score(y, y_pred);
    }
}

# ── ExtraTreesClassifier ──
class ExtraTreesClassifier {
    let n_estimators = 100;
    let max_depth = 10;
    let estimators = [];

    fn init_extra_trees(n_estimators, max_depth) {
        if (n_estimators != nullptr) { self.n_estimators = n_estimators; }
        if (max_depth != nullptr) { self.max_depth = max_depth; }
        self.estimators = [];
        return 0;
    }

    fn fit(X, y) {
        let n = len(X);
        let d = len(X[0]);
        let t = 0;
        while (t < self.n_estimators) {
            let sample_idx = [];
            let i = 0;
            while (i < n) {
                let r = hml_randint(0, n - 1);
                push(sample_idx, r);
                i = i + 1;
            }
            let feat = hml_randint(0, d - 1);
            let thresh_vals = [];
            i = 0;
            while (i < n) { push(thresh_vals, X[sample_idx[i]][feat]); i = i + 1; }
            let min_v = thresh_vals[0];
            let max_v = thresh_vals[0];
            i = 1;
            while (i < len(thresh_vals)) {
                if (thresh_vals[i] < min_v) { min_v = thresh_vals[i]; }
                if (thresh_vals[i] > max_v) { max_v = thresh_vals[i]; }
                i = i + 1;
            }
            let random_thresh = min_v + hml_random() * (max_v - min_v);
            let tree = {
                "feature": feat,
                "threshold": random_thresh,
                "max_depth": self.max_depth,
                "n_classes": len(hml_unique(y)),
                "left_count": 0,
                "right_count": 0,
                "left_class": 0,
                "right_class": 0
            };
            let left_y = [];
            let right_y = [];
            i = 0;
            while (i < n) {
                if (X[sample_idx[i]][feat] <= random_thresh) {
                    push(left_y, y[sample_idx[i]]);
                    tree["left_count"] = tree["left_count"] + 1;
                }
                else {
                    push(right_y, y[sample_idx[i]]);
                    tree["right_count"] = tree["right_count"] + 1;
                }
                i = i + 1;
            }
            if (len(left_y) > 0) { tree["left_class"] = left_y[0]; }
            if (len(right_y) > 0) { tree["right_class"] = right_y[0]; }
            push(self.estimators, tree);
            t = t + 1;
        }
        return 0;
    }

    fn predict_one(tree, x) {
        if (x[tree["feature"]] <= tree["threshold"]) { return tree["left_class"]; }
        return tree["right_class"];
    }

    fn predict(X) {
        let n = len(X);
        let preds = [];
        let i = 0;
        while (i < n) {
            let votes = {};
            let t = 0;
            while (t < self.n_estimators) {
                let v = self.predict_one(self.estimators[t], X[i]);
                let c = 0;
                if (dict_keys(votes) != []) {
                    let keys = dict_keys(votes);
                    let found = 0;
                    let kk = 0;
                    while (kk < len(keys)) { if (keys[kk] == v) { found = 1; } kk = kk + 1; }
                    if (found == 1) { c = votes[v]; }
                }
                votes[v] = c + 1;
                t = t + 1;
            }
            let best = 0;
            let best_c = 0;
            let keys = dict_keys(votes);
            let k = 0;
            while (k < len(keys)) {
                if (votes[keys[k]] > best_c) { best_c = votes[keys[k]]; best = keys[k]; }
                k = k + 1;
            }
            push(preds, best);
            i = i + 1;
        }
        return preds;
    }

    fn score(X, y) { return accuracy_score(self.predict(X), y); }
}

# ── ExtraTreesRegressor ──
class ExtraTreesRegressor {
    let n_estimators = 100;
    let max_depth = 10;
    let estimators = [];

    fn init_extra_trees_reg(n_estimators, max_depth) {
        if (n_estimators != nullptr) { self.n_estimators = n_estimators; }
        if (max_depth != nullptr) { self.max_depth = max_depth; }
        self.estimators = [];
        return 0;
    }

    fn fit(X, y) {
        let n = len(X);
        let d = len(X[0]);
        let t = 0;
        while (t < self.n_estimators) {
            let sample_idx = [];
            let i = 0;
            while (i < n) {
                let r = hml_randint(0, n - 1);
                push(sample_idx, r);
                i = i + 1;
            }
            let feat = hml_randint(0, d - 1);
            let thresh_vals = [];
            i = 0;
            while (i < n) { push(thresh_vals, X[sample_idx[i]][feat]); i = i + 1; }
            let min_v = thresh_vals[0];
            let max_v = thresh_vals[0];
            i = 1;
            while (i < len(thresh_vals)) {
                if (thresh_vals[i] < min_v) { min_v = thresh_vals[i]; }
                if (thresh_vals[i] > max_v) { max_v = thresh_vals[i]; }
                i = i + 1;
            }
            let random_thresh = min_v + hml_random() * (max_v - min_v);
            let left_y = [];
            let right_y = [];
            i = 0;
            while (i < n) {
                if (X[sample_idx[i]][feat] <= random_thresh) { push(left_y, y[sample_idx[i]]); }
                else { push(right_y, y[sample_idx[i]]); }
                i = i + 1;
            }
            let left_mean = 0.0;
            if (len(left_y) > 0) {
                let j = 0; while (j < len(left_y)) { left_mean = left_mean + left_y[j]; j = j + 1; }
                left_mean = left_mean / len(left_y);
            }
            let right_mean = 0.0;
            if (len(right_y) > 0) {
                let j = 0; while (j < len(right_y)) { right_mean = right_mean + right_y[j]; j = j + 1; }
                right_mean = right_mean / len(right_y);
            }
            let tree = {"feature": feat, "threshold": random_thresh, "left_val": left_mean, "right_val": right_mean};
            push(self.estimators, tree);
            t = t + 1;
        }
        return 0;
    }

    fn predict(X) {
        let n = len(X);
        let preds = hml_vector_zeros(n);
        let i = 0;
        while (i < n) {
            let total = 0.0;
            let t = 0;
            while (t < self.n_estimators) {
                if (X[i][self.estimators[t]["feature"]] <= self.estimators[t]["threshold"]) {
                    total = total + self.estimators[t]["left_val"];
                }
                else { total = total + self.estimators[t]["right_val"]; }
                t = t + 1;
            }
            preds[i] = total / self.n_estimators;
            i = i + 1;
        }
        return preds;
    }

    fn score(X, y) { return r2_score(y, self.predict(X)); }
}

# ── StackingClassifier ──
class StackingClassifier {
    let base_estimators = [];
    let meta_estimator = nullptr;

    fn init_stacking_classifier(base_estimators, meta_estimator) {
        self.base_estimators = base_estimators;
        self.meta_estimator = meta_estimator;
        return 0;
    }

    fn fit(X, y) {
        let n = len(X);
        let k = len(self.base_estimators);
        let meta_features = [];
        let i = 0;
        while (i < k) {
            self.base_estimators[i]["fit"](X, y);
            i = i + 1;
        }
        i = 0;
        while (i < n) {
            let row = [];
            let j = 0;
            while (j < k) {
                let pred = self.base_estimators[j]["predict"]([X[i]]);
                push(row, pred[0]);
                j = j + 1;
            }
            push(meta_features, row);
            i = i + 1;
        }
        if (self.meta_estimator != nullptr) {
            self.meta_estimator["fit"](meta_features, y);
        }
        return 0;
    }

    fn predict(X) {
        let n = len(X);
        let k = len(self.base_estimators);
        let meta_features = [];
        let i = 0;
        while (i < n) {
            let row = [];
            let j = 0;
            while (j < k) {
                let pred = self.base_estimators[j]["predict"]([X[i]]);
                push(row, pred[0]);
                j = j + 1;
            }
            push(meta_features, row);
            i = i + 1;
        }
        if (self.meta_estimator != nullptr) { return self.meta_estimator["predict"](meta_features); }
        let preds = [];
        i = 0;
        while (i < n) { push(preds, meta_features[i][0]); i = i + 1; }
        return preds;
    }

    fn score(X, y) { return accuracy_score(self.predict(X), y); }
}

# ── StackingRegressor ──
class StackingRegressor {
    let base_estimators = [];
    let meta_estimator = nullptr;

    fn init_stacking_regressor(base_estimators, meta_estimator) {
        self.base_estimators = base_estimators;
        self.meta_estimator = meta_estimator;
        return 0;
    }

    fn fit(X, y) {
        let n = len(X);
        let k = len(self.base_estimators);
        let i = 0;
        while (i < k) {
            self.base_estimators[i]["fit"](X, y);
            i = i + 1;
        }
        let meta_features = [];
        i = 0;
        while (i < n) {
            let row = [];
            let j = 0;
            while (j < k) {
                let pred = self.base_estimators[j]["predict"]([X[i]]);
                push(row, pred[0]);
                j = j + 1;
            }
            push(meta_features, row);
            i = i + 1;
        }
        if (self.meta_estimator != nullptr) {
            self.meta_estimator["fit"](meta_features, y);
        }
        return 0;
    }

    fn predict(X) {
        let n = len(X);
        let k = len(self.base_estimators);
        let meta_features = [];
        let i = 0;
        while (i < n) {
            let row = [];
            let j = 0;
            while (j < k) {
                let pred = self.base_estimators[j]["predict"]([X[i]]);
                push(row, pred[0]);
                j = j + 1;
            }
            push(meta_features, row);
            i = i + 1;
        }
        if (self.meta_estimator != nullptr) { return self.meta_estimator["predict"](meta_features); }
        return meta_features[0];
    }

    fn score(X, y) { return r2_score(y, self.predict(X)); }
}

# ── BlendingClassifier ──
class BlendingClassifier {
    let base_estimators = [];
    let meta_estimator = nullptr;
    let holdout_ratio = 0.2;

    fn init_blending(base_estimators, meta_estimator, holdout_ratio) {
        self.base_estimators = base_estimators;
        self.meta_estimator = meta_estimator;
        if (holdout_ratio != nullptr) { self.holdout_ratio = holdout_ratio; }
        return 0;
    }

    fn fit(X, y) {
        let n = len(X);
        let split = math_floor(n * (1.0 - self.holdout_ratio));
        if (split < 1) { split = 1; }
        if (split >= n) { split = n - 1; }
        let X_train = [];
        let y_train = [];
        let X_hold = [];
        let y_hold = [];
        let i = 0;
        while (i < split) { push(X_train, X[i]); push(y_train, y[i]); i = i + 1; }
        while (i < n) { push(X_hold, X[i]); push(y_hold, y[i]); i = i + 1; }
        let k = len(self.base_estimators);
        i = 0;
        while (i < k) {
            self.base_estimators[i]["fit"](X_train, y_train);
            i = i + 1;
        }
        let n_hold = len(X_hold);
        let meta_features = [];
        i = 0;
        while (i < n_hold) {
            let row = [];
            let j = 0;
            while (j < k) {
                let pred = self.base_estimators[j]["predict"]([X_hold[i]]);
                push(row, pred[0]);
                j = j + 1;
            }
            push(meta_features, row);
            i = i + 1;
        }
        if (self.meta_estimator != nullptr) {
            self.meta_estimator["fit"](meta_features, y_hold);
        }
        return 0;
    }

    fn predict(X) { return self.predict_proba_vote(X); }

    fn predict_proba_vote(X) {
        let n = len(X);
        let k = len(self.base_estimators);
        let meta_features = [];
        let i = 0;
        while (i < n) {
            let row = [];
            let j = 0;
            while (j < k) {
                let pred = self.base_estimators[j]["predict"]([X[i]]);
                push(row, pred[0]);
                j = j + 1;
            }
            push(meta_features, row);
            i = i + 1;
        }
        if (self.meta_estimator != nullptr) { return self.meta_estimator["predict"](meta_features); }
        let preds = [];
        i = 0;
        while (i < n) { push(preds, meta_features[i][0]); i = i + 1; }
        return preds;
    }

    fn score(X, y) { return accuracy_score(self.predict(X), y); }
}

# ── WeightedEnsemble ──
class WeightedEnsemble {
    let estimators = [];
    let weights = [];

    fn init_weighted_ensemble(estimators, weights) {
        self.estimators = estimators;
        self.weights = weights;
        return 0;
    }

    fn fit(X, y) {
        let k = len(self.estimators);
        let i = 0;
        while (i < k) {
            self.estimators[i]["fit"](X, y);
            i = i + 1;
        }
        return 0;
    }

    fn predict(X) {
        let n = len(X);
        let k = len(self.estimators);
        let preds = hml_vector_zeros(n);
        let i = 0;
        while (i < n) {
            let w_sum = 0.0;
            let j = 0;
            while (j < k) {
                let p = self.estimators[j]["predict"]([X[i]]);
                preds[i] = preds[i] + self.weights[j] * p[0];
                w_sum = w_sum + self.weights[j];
                j = j + 1;
            }
            if (w_sum > 0) { preds[i] = preds[i] / w_sum; }
            i = i + 1;
        }
        return preds;
    }

    fn predict_class(X) {
        let n = len(X);
        let k = len(self.estimators);
        let classes = [];
        let i = 0;
        while (i < n) {
            let votes = {};
            let j = 0;
            while (j < k) {
                let p = self.estimators[j]["predict"]([X[i]]);
                let v = p[0];
                let c = 0;
                if (dict_keys(votes) != []) {
                    let keys = dict_keys(votes);
                    let found = 0;
                    let kk = 0;
                    while (kk < len(keys)) { if (keys[kk] == v) { found = 1; } kk = kk + 1; }
                    if (found == 1) { c = votes[v]; }
                }
                votes[v] = c + self.weights[j];
                j = j + 1;
            }
            let best = 0;
            let best_w = 0.0;
            let keys = dict_keys(votes);
            let kk = 0;
            while (kk < len(keys)) {
                if (votes[keys[kk]] > best_w) { best_w = votes[keys[kk]]; best = keys[kk]; }
                kk = kk + 1;
            }
            push(classes, best);
            i = i + 1;
        }
        return classes;
    }

    fn score(X, y) { return accuracy_score(self.predict_class(X), y); }
}

# ── HistGradientBoostingClassifier ──
class HistGradientBoostingClassifier {
    let n_estimators = 100;
    let learning_rate = 0.1;
    let max_depth = 5;
    let estimators = [];
    let init_pred = 0.0;

    fn init_hist_gradient_boosting(n_estimators, learning_rate, max_depth) {
        if (n_estimators != nullptr) { self.n_estimators = n_estimators; }
        if (learning_rate != nullptr) { self.learning_rate = learning_rate; }
        if (max_depth != nullptr) { self.max_depth = max_depth; }
        self.estimators = [];
        return 0;
    }

    fn fit(X, y) {
        let n = len(X);
        let d = len(X[0]);
        let pos = 0;
        let i = 0;
        while (i < n) { if (y[i] == 1) { pos = pos + 1; } i = i + 1; }
        let p = (pos * 1.0 + 1.0) / (n + 2.0);
        self.init_pred = math_log(p / (1.0 - p));
        let residuals = [];
        i = 0;
        while (i < n) { push(residuals, y[i] - p); i = i + 1; }
        let t = 0;
        while (t < self.n_estimators) {
            let tree = self.build_simple_tree(X, residuals, 0, self.max_depth);
            push(self.estimators, tree);
            i = 0;
            while (i < n) {
                let pred = self.predict_one(tree, X[i]);
                residuals[i] = residuals[i] - self.learning_rate * pred;
                i = i + 1;
            }
            t = t + 1;
        }
        return 0;
    }

    fn build_simple_tree(X, y, depth, max_depth) {
        let n = len(X);
        if (n == 0) { return {"leaf": 0.0}; }
        if (depth >= max_depth) {
            let avg = 0.0;
            let i = 0; while (i < n) { avg = avg + y[i]; i = i + 1; }
            return {"leaf": avg / n};
        }
        let d = len(X[0]);
        let best_feat = 0;
        let best_thresh = 0.0;
        let best_var = 1000000000.0;
        let feat = 0;
        while (feat < d) {
            let vals = hml_column_means([X])[feat];
            let left_y = [];
            let right_y = [];
            let i = 0;
            let thresh = 0.0;
            i = 0; while (i < n) { thresh = thresh + X[i][feat]; i = i + 1; }
            thresh = thresh / n;
            i = 0;
            while (i < n) {
                if (X[i][feat] <= thresh) { push(left_y, y[i]); }
                else { push(right_y, y[i]); }
                i = i + 1;
            }
            let v_left = self.compute_variance(left_y);
            let v_right = self.compute_variance(right_y);
            if (v_left + v_right < best_var) { best_var = v_left + v_right; best_feat = feat; best_thresh = thresh; }
            feat = feat + 1;
        }
        let left_X = [];
        let left_y = [];
        let right_X = [];
        let right_y = [];
        let i = 0;
        while (i < n) {
            if (X[i][best_feat] <= best_thresh) { push(left_X, X[i]); push(left_y, y[i]); }
            else { push(right_X, X[i]); push(right_y, y[i]); }
            i = i + 1;
        }
        return {
            "feature": best_feat,
            "threshold": best_thresh,
            "left": self.build_simple_tree(left_X, left_y, depth + 1, max_depth),
            "right": self.build_simple_tree(right_X, right_y, depth + 1, max_depth)
        };
    }

    fn compute_variance(vals) {
        let n = len(vals);
        if (n == 0) { return 0.0; }
        let m = 0.0;
        let i = 0; while (i < n) { m = m + vals[i]; i = i + 1; }
        m = m / n;
        let v = 0.0;
        i = 0; while (i < n) { let d = vals[i] - m; v = v + d * d; i = i + 1; }
        return v;
    }

    fn predict_one(tree, x) {
        if (tree["leaf"] != nullptr) { return tree["leaf"]; }
        if (x[tree["feature"]] <= tree["threshold"]) { return self.predict_one(tree["left"], x); }
        return self.predict_one(tree["right"], x);
    }

    fn predict_proba(X) {
        let n = len(X);
        let probs = [];
        let i = 0;
        while (i < n) {
            let logit = self.init_pred;
            let t = 0;
            while (t < len(self.estimators)) {
                logit = logit + self.learning_rate * self.predict_one(self.estimators[t], X[i]);
                t = t + 1;
            }
            push(probs, 1.0 / (1.0 + math_exp(-logit)));
            i = i + 1;
        }
        return probs;
    }

    fn predict(X) {
        let probs = self.predict_proba(X);
        let preds = [];
        let i = 0;
        while (i < len(probs)) {
            if (probs[i] >= 0.5) { push(preds, 1); }
            else { push(preds, 0); }
            i = i + 1;
        }
        return preds;
    }

    fn score(X, y) { return accuracy_score(self.predict(X), y); }
}

# ── HistGradientBoostingRegressor ──
class HistGradientBoostingRegressor {
    let n_estimators = 100;
    let learning_rate = 0.1;
    let max_depth = 5;
    let estimators = [];
    let init_pred = 0.0;

    fn init_hist_gradient_boosting_reg(n_estimators, learning_rate, max_depth) {
        if (n_estimators != nullptr) { self.n_estimators = n_estimators; }
        if (learning_rate != nullptr) { self.learning_rate = learning_rate; }
        if (max_depth != nullptr) { self.max_depth = max_depth; }
        self.estimators = [];
        return 0;
    }

    fn fit(X, y) {
        let n = len(X);
        let mean_y = 0.0;
        let i = 0;
        while (i < n) { mean_y = mean_y + y[i]; i = i + 1; }
        mean_y = mean_y / n;
        self.init_pred = mean_y;
        let residuals = [];
        i = 0;
        while (i < n) { push(residuals, y[i] - mean_y); i = i + 1; }
        let t = 0;
        while (t < self.n_estimators) {
            let best_feat = 0;
            let best_thresh = 0.0;
            let best_mse = 1000000000.0;
            let d = len(X[0]);
            let feat = 0;
            while (feat < d) {
                let thresh = 0.0;
                i = 0; while (i < n) { thresh = thresh + X[i][feat]; i = i + 1; }
                thresh = thresh / n;
                let left_res = [];
                let right_res = [];
                i = 0;
                while (i < n) {
                    if (X[i][feat] <= thresh) { push(left_res, residuals[i]); }
                    else { push(right_res, residuals[i]); }
                    i = i + 1;
                }
                let mse_left = 0.0;
                if (len(left_res) > 0) {
                    let m = 0.0;
                    let j = 0; while (j < len(left_res)) { m = m + left_res[j]; j = j + 1; }
                    m = m / len(left_res);
                    j = 0; while (j < len(left_res)) { let d = left_res[j] - m; mse_left = mse_left + d * d; j = j + 1; }
                }
                let mse_right = 0.0;
                if (len(right_res) > 0) {
                    let m = 0.0;
                    let j = 0; while (j < len(right_res)) { m = m + right_res[j]; j = j + 1; }
                    m = m / len(right_res);
                    j = 0; while (j < len(right_res)) { let d = right_res[j] - m; mse_right = mse_right + d * d; j = j + 1; }
                }
                if (mse_left + mse_right < best_mse) {
                    best_mse = mse_left + mse_right;
                    best_feat = feat;
                    best_thresh = thresh;
                }
                feat = feat + 1;
            }
            let tree = {"feature": best_feat, "threshold": best_thresh, "left_val": 0.0, "right_val": 0.0};
            let left_r = [];
            let right_r = [];
            i = 0;
            while (i < n) {
                if (X[i][best_feat] <= best_thresh) { push(left_r, residuals[i]); }
                else { push(right_r, residuals[i]); }
                i = i + 1;
            }
            if (len(left_r) > 0) {
                let s = 0.0;
                let j = 0; while (j < len(left_r)) { s = s + left_r[j]; j = j + 1; }
                tree["left_val"] = s / len(left_r);
            }
            if (len(right_r) > 0) {
                let s = 0.0;
                let j = 0; while (j < len(right_r)) { s = s + right_r[j]; j = j + 1; }
                tree["right_val"] = s / len(right_r);
            }
            push(self.estimators, tree);
            i = 0;
            while (i < n) {
                if (X[i][best_feat] <= best_thresh) { residuals[i] = residuals[i] - self.learning_rate * tree["left_val"]; }
                else { residuals[i] = residuals[i] - self.learning_rate * tree["right_val"]; }
                i = i + 1;
            }
            t = t + 1;
        }
        return 0;
    }

    fn predict(X) {
        let n = len(X);
        let preds = hml_vector_zeros(n);
        let i = 0;
        while (i < n) {
            let val = self.init_pred;
            let t = 0;
            while (t < len(self.estimators)) {
                if (X[i][self.estimators[t]["feature"]] <= self.estimators[t]["threshold"]) {
                    val = val + self.learning_rate * self.estimators[t]["left_val"];
                }
                else { val = val + self.learning_rate * self.estimators[t]["right_val"]; }
                t = t + 1;
            }
            preds[i] = val;
            i = i + 1;
        }
        return preds;
    }

    fn score(X, y) { return r2_score(y, self.predict(X)); }
}

# ═══════════════════════════════════════════════════════════════════════════
# SECTION 43: Dimensionality Reduction
# ═══════════════════════════════════════════════════════════════════════════

# ── TruncatedSVD ──
class TruncatedSVD {
    let n_components = 2;
    let n_iter = 5;
    let components = [];
    let explained_variance = [];
    let mean = [];

    fn init_truncated_svd(n_components, n_iter) {
        if (n_components != nullptr) { self.n_components = n_components; }
        if (n_iter != nullptr) { self.n_iter = n_iter; }
        self.components = [];
        return 0;
    }

    fn fit(X) {
        let n = len(X);
        let d = len(X[0]);
        let k = self.n_components;
        if (k > d) { k = d; }
        self.mean = hml_vector_zeros(d);
        let i = 0;
        while (i < n) {
            let j = 0;
            while (j < d) { self.mean[j] = self.mean[j] + X[i][j]; j = j + 1; }
            i = i + 1;
        }
        let j = 0;
        while (j < d) { self.mean[j] = self.mean[j] / n; j = j + 1; }
        let X_centered = [];
        i = 0;
        while (i < n) {
            let row = [];
            j = 0;
            while (j < d) { push(row, X[i][j] - self.mean[j]); j = j + 1; }
            push(X_centered, row);
            i = i + 1;
        }
        let comp = 0;
        while (comp < k) {
            let v = [];
            j = 0;
            while (j < d) {
                let r = hml_random();
                push(v, r - 0.5);
                j = j + 1;
            }
            let it = 0;
            while (it < self.n_iter) {
                let v_new = hml_vector_zeros(d);
                i = 0;
                while (i < n) {
                    let dot = 0.0;
                    j = 0; while (j < d) { dot = dot + X_centered[i][j] * v[j]; j = j + 1; }
                    j = 0; while (j < d) { v_new[j] = v_new[j] + dot * X_centered[i][j]; j = j + 1; }
                    i = i + 1;
                }
                let norm = 0.0;
                j = 0; while (j < d) { norm = norm + v_new[j] * v_new[j]; j = j + 1; }
                norm = math_sqrt(norm);
                if (norm > 0) {
                    j = 0; while (j < d) { v_new[j] = v_new[j] / norm; j = j + 1; }
                }
                v = v_new;
                it = it + 1;
            }
            push(self.components, v);
            let variance = 0.0;
            i = 0;
            while (i < n) {
                let dot = 0.0;
                j = 0; while (j < d) { dot = dot + X_centered[i][j] * v[j]; j = j + 1; }
                variance = variance + dot * dot;
                i = i + 1;
            }
            push(self.explained_variance, variance / n);
            i = 0;
            while (i < n) {
                let dot = 0.0;
                j = 0; while (j < d) { dot = dot + X_centered[i][j] * v[j]; j = j + 1; }
                j = 0; while (j < d) { X_centered[i][j] = X_centered[i][j] - dot * v[j]; j = j + 1; }
                i = i + 1;
            }
            comp = comp + 1;
        }
        return 0;
    }

    fn transform(X) {
        let n = len(X);
        let d = len(X[0]);
        let k = len(self.components);
        let result = [];
        let i = 0;
        while (i < n) {
            let proj = [];
            let comp = 0;
            while (comp < k) {
                let dot = 0.0;
                let j = 0;
                while (j < d) { dot = dot + X[i][j] * self.components[comp][j]; j = j + 1; }
                push(proj, dot);
                comp = comp + 1;
            }
            push(result, proj);
            i = i + 1;
        }
        return result;
    }

    fn fit_transform(X) {
        self.fit(X);
        return self.transform(X);
    }
}

# ── NMFDecomposition ──
class NMFDecomposition {
    let n_components = 2;
    let max_iter = 200;
    let W = [];
    let H = [];

    fn init_nmf(n_components, max_iter) {
        if (n_components != nullptr) { self.n_components = n_components; }
        if (max_iter != nullptr) { self.max_iter = max_iter; }
        self.W = [];
        self.H = [];
        return 0;
    }

    fn fit(X) {
        let n = len(X);
        let d = len(X[0]);
        let k = self.n_components;
        self.W = [];
        let i = 0;
        while (i < n) {
            let row = [];
            let j = 0;
            while (j < k) { push(row, hml_random()); j = j + 1; }
            push(self.W, row);
            i = i + 1;
        }
        self.H = [];
        i = 0;
        while (i < k) {
            let row = [];
            let j = 0;
            while (j < d) { push(row, hml_random()); j = j + 1; }
            push(self.H, row);
            i = i + 1;
        }
        let iter = 0;
        while (iter < self.max_iter) {
            let WH = [];
            i = 0;
            while (i < n) {
                let row = [];
                let j = 0;
                while (j < d) {
                    let val = 0.0;
                    let l = 0;
                    while (l < k) { val = val + self.W[i][l] * self.H[l][j]; l = l + 1; }
                    push(row, val);
                    j = j + 1;
                }
                push(WH, row);
                i = i + 1;
            }
            i = 0;
            while (i < n) {
                let j = 0;
                while (j < k) {
                    let num = 0.0;
                    let denom = 0.0;
                    let l = 0;
                    while (l < d) {
                        num = num + X[i][l] * self.H[j][l];
                        denom = denom + WH[i][l] * self.H[j][l];
                        l = l + 1;
                    }
                    if (denom > 0.000000001) { self.W[i][j] = self.W[i][j] * num / denom; }
                    j = j + 1;
                }
                i = i + 1;
            }
            WH = [];
            i = 0;
            while (i < n) {
                let row = [];
                let j = 0;
                while (j < d) {
                    let val = 0.0;
                    let l = 0;
                    while (l < k) { val = val + self.W[i][l] * self.H[l][j]; l = l + 1; }
                    push(row, val);
                    j = j + 1;
                }
                push(WH, row);
                i = i + 1;
            }
            let j = 0;
            while (j < k) {
                let l = 0;
                while (l < d) {
                    let num = 0.0;
                    let denom = 0.0;
                    i = 0;
                    while (i < n) {
                        num = num + self.W[i][j] * X[i][l];
                        denom = denom + self.W[i][j] * WH[i][l];
                        i = i + 1;
                    }
                    if (denom > 0.000000001) { self.H[j][l] = self.H[j][l] * num / denom; }
                    l = l + 1;
                }
                j = j + 1;
            }
            iter = iter + 1;
        }
        return 0;
    }

    fn transform(X) {
        let n = len(X);
        let k = len(self.H);
        let result = [];
        let i = 0;
        while (i < n) {
            let row = [];
            let j = 0;
            while (j < k) {
                let val = 0.0;
                let l = 0;
                while (l < len(X[0])) { val = val + X[i][l] * self.H[j][l]; l = l + 1; }
                push(row, val);
                j = j + 1;
            }
            push(result, row);
            i = i + 1;
        }
        return result;
    }

    fn fit_transform(X) {
        self.fit(X);
        return self.transform(X);
    }
}

# ── LatentDirichletAllocation ──
class LatentDirichletAllocation {
    let n_topics = 5;
    let max_iter = 10;
    let doc_topic = [];
    let topic_word = [];

    fn init_lda(n_topics, max_iter) {
        if (n_topics != nullptr) { self.n_topics = n_topics; }
        if (max_iter != nullptr) { self.max_iter = max_iter; }
        self.doc_topic = [];
        self.topic_word = [];
        return 0;
    }

    fn fit(X) {
        let n_docs = len(X);
        let n_words = 0;
        let i = 0;
        while (i < n_docs) {
            let j = 0;
            while (j < len(X[i])) { if (X[i][j] > n_words) { n_words = X[i][j]; } j = j + 1; }
            i = i + 1;
        }
        n_words = n_words + 1;
        let k = self.n_topics;
        self.doc_topic = [];
        i = 0;
        while (i < n_docs) {
            let row = [];
            let j = 0;
            while (j < k) { push(row, hml_random() + 0.1); j = j + 1; }
            push(self.doc_topic, row);
            i = i + 1;
        }
        self.topic_word = [];
        i = 0;
        while (i < k) {
            let row = [];
            let j = 0;
            while (j < n_words) { push(row, hml_random() + 0.1); j = j + 1; }
            push(self.topic_word, row);
            i = i + 1;
        }
        return 0;
    }

    fn transform(X) {
        let n_docs = len(X);
        let k = self.n_topics;
        let result = [];
        let i = 0;
        while (i < n_docs) {
            let topic_dist = [];
            let j = 0;
            while (j < k) {
                let score = self.doc_topic[i][j];
                let w = 0;
                while (w < len(X[i])) {
                    let word_id = X[i][w];
                    if (word_id < len(self.topic_word[j])) { score = score + self.topic_word[j][word_id]; }
                    w = w + 1;
                }
                push(topic_dist, score);
                j = j + 1;
            }
            let total = 0.0;
            j = 0; while (j < k) { total = total + topic_dist[j]; j = j + 1; }
            if (total > 0) { j = 0; while (j < k) { topic_dist[j] = topic_dist[j] / total; j = j + 1; } }
            push(result, topic_dist);
            i = i + 1;
        }
        return result;
    }

    fn fit_transform(X) {
        self.fit(X);
        return self.transform(X);
    }
}

# ── FastICA ──
class FastICA {
    let n_components = 2;
    let max_iter = 200;
    let components = [];
    let mean = [];

    fn init_fast_ica(n_components, max_iter) {
        if (n_components != nullptr) { self.n_components = n_components; }
        if (max_iter != nullptr) { self.max_iter = max_iter; }
        self.components = [];
        return 0;
    }

    fn fit(X) {
        let n = len(X);
        let d = len(X[0]);
        let k = self.n_components;
        if (k > d) { k = d; }
        self.mean = hml_vector_zeros(d);
        let i = 0;
        while (i < n) {
            let j = 0;
            while (j < d) { self.mean[j] = self.mean[j] + X[i][j]; j = j + 1; }
            i = i + 1;
        }
        let j = 0;
        while (j < d) { self.mean[j] = self.mean[j] / n; j = j + 1; }
        self.components = [];
        let comp = 0;
        while (comp < k) {
            let w = [];
            j = 0;
            while (j < d) {
                let r = hml_random();
                push(w, r - 0.5);
                j = j + 1;
            }
            let norm = 0.0;
            j = 0; while (j < d) { norm = norm + w[j] * w[j]; j = j + 1; }
            norm = math_sqrt(norm);
            if (norm > 0) { j = 0; while (j < d) { w[j] = w[j] / norm; j = j + 1; } }
            let iter = 0;
            while (iter < self.max_iter) {
                let w_new = hml_vector_zeros(d);
                i = 0;
                while (i < n) {
                    let dot = 0.0;
                    j = 0;
                    while (j < d) { dot = dot + (X[i][j] - self.mean[j]) * w[j]; j = j + 1; }
                    let g = math_tan(dot);
                    j = 0;
                    while (j < d) { w_new[j] = w_new[j] + (X[i][j] - self.mean[j]) * g; j = j + 1; }
                    i = i + 1;
                }
                let g_prime = 0.0;
                i = 0;
                while (i < n) {
                    let dot = 0.0;
                    j = 0;
                    while (j < d) { dot = dot + (X[i][j] - self.mean[j]) * w[j]; j = j + 1; }
                    let sec_sq = 1.0 / (math_cos(dot) * math_cos(dot) + 0.000000001);
                    g_prime = g_prime + sec_sq;
                    i = i + 1;
                }
                j = 0;
                while (j < d) { w_new[j] = (w_new[j] - g_prime * w[j]) / n; j = j + 1; }
                let c = 0;
                while (c < len(self.components)) {
                    let dot = 0.0;
                    j = 0; while (j < d) { dot = dot + w_new[j] * self.components[c][j]; j = j + 1; }
                    j = 0; while (j < d) { w_new[j] = w_new[j] - dot * self.components[c][j]; j = j + 1; }
                    c = c + 1;
                }
                norm = 0.0;
                j = 0; while (j < d) { norm = norm + w_new[j] * w_new[j]; j = j + 1; }
                norm = math_sqrt(norm);
                if (norm > 0) { j = 0; while (j < d) { w_new[j] = w_new[j] / norm; j = j + 1; } }
                w = w_new;
                iter = iter + 1;
            }
            push(self.components, w);
            comp = comp + 1;
        }
        return 0;
    }

    fn transform(X) {
        let n = len(X);
        let d = len(X[0]);
        let k = len(self.components);
        let result = [];
        let i = 0;
        while (i < n) {
            let row = [];
            let comp = 0;
            while (comp < k) {
                let dot = 0.0;
                let j = 0;
                while (j < d) { dot = dot + (X[i][j] - self.mean[j]) * self.components[comp][j]; j = j + 1; }
                push(row, dot);
                comp = comp + 1;
            }
            push(result, row);
            i = i + 1;
        }
        return result;
    }

    fn fit_transform(X) {
        self.fit(X);
        return self.transform(X);
    }
}

# ── Isomap ──
class Isomap {
    let n_components = 2;
    let n_neighbors = 5;
    let embedding = [];

    fn init_isomap(n_components, n_neighbors) {
        if (n_components != nullptr) { self.n_components = n_components; }
        if (n_neighbors != nullptr) { self.n_neighbors = n_neighbors; }
        self.embedding = [];
        return 0;
    }

    fn fit_transform(X) {
        let n = len(X);
        let d = len(X[0]);
        let result = [];
        let i = 0;
        while (i < n) {
            let row = [];
            let j = 0;
            while (j < self.n_components) { push(row, 0.0); j = j + 1; }
            let sum_sq = 0.0;
            j = 0;
            while (j < d) {
                let val = X[i][j];
                sum_sq = sum_sq + val * val;
                j = j + 1;
            }
            if (sum_sq > 0) {
                let scale = math_sqrt(sum_sq);
                j = 0;
                while (j < self.n_components and j < d) { row[j] = X[i][j] / scale; j = j + 1; }
            }
            push(result, row);
            i = i + 1;
        }
        self.embedding = result;
        return result;
    }

    fn transform(X) {
        return self.fit_transform(X);
    }
}

# ── MDS ──
class MDS {
    let n_components = 2;
    let max_iter = 300;
    let embedding = [];

    fn init_mds(n_components, max_iter) {
        if (n_components != nullptr) { self.n_components = n_components; }
        if (max_iter != nullptr) { self.max_iter = max_iter; }
        self.embedding = [];
        return 0;
    }

    fn fit_transform(X) {
        let n = len(X);
        let k = self.n_components;
        if (k > n) { k = n; }
        self.embedding = [];
        let i = 0;
        while (i < n) {
            let row = [];
            let j = 0;
            while (j < k) { push(row, hml_random() - 0.5); j = j + 1; }
            push(self.embedding, row);
            i = i + 1;
        }
        let iter = 0;
        while (iter < self.max_iter) {
            i = 0;
            while (i < n) {
                let j = 0;
                while (j < k) {
                    let grad = 0.0;
                    let m = 0;
                    while (m < n) {
                        if (m != i) {
                            let dist = 0.0;
                            let l = 0; while (l < k) { let d = self.embedding[i][l] - self.embedding[m][l]; dist = dist + d * d; l = l + 1; }
                            dist = math_sqrt(dist);
                            if (dist > 0.000000001) {
                                let target = 0.0;
                                l = 0; while (l < len(X[0])) { let d = X[i][l] - X[m][l]; target = target + d * d; l = l + 1; }
                                target = math_sqrt(target);
                                grad = grad + (dist - target) / dist * (self.embedding[i][j] - self.embedding[m][j]);
                            }
                        }
                        m = m + 1;
                    }
                    self.embedding[i][j] = self.embedding[i][j] - 0.01 * grad;
                    j = j + 1;
                }
                i = i + 1;
            }
            iter = iter + 1;
        }
        return self.embedding;
    }
}

# ── TSNE ──
class TSNE {
    let n_components = 2;
    let perplexity = 30.0;
    let max_iter = 1000;
    let learning_rate = 200.0;
    let embedding = [];

    fn init_tsne(n_components, perplexity, max_iter, learning_rate) {
        if (n_components != nullptr) { self.n_components = n_components; }
        if (perplexity != nullptr) { self.perplexity = perplexity; }
        if (max_iter != nullptr) { self.max_iter = max_iter; }
        if (learning_rate != nullptr) { self.learning_rate = learning_rate; }
        self.embedding = [];
        return 0;
    }

    fn fit_transform(X) {
        let n = len(X);
        let d = len(X[0]);
        let k = self.n_components;
        self.embedding = [];
        let i = 0;
        while (i < n) {
            let row = [];
            let j = 0;
            while (j < k) { push(row, hml_random() * 0.0001 - 0.00005); j = j + 1; }
            push(self.embedding, row);
            i = i + 1;
        }
        let iter = 0;
        while (iter < self.max_iter) {
            i = 0;
            while (i < n) {
                let j = 0;
                while (j < k) {
                    let grad = 0.0;
                    let m = 0;
                    while (m < n) {
                        if (m != i) {
                            let dist_sq = 0.0;
                            let l = 0;
                            while (l < k) { let d = self.embedding[i][l] - self.embedding[m][l]; dist_sq = dist_sq + d * d; l = l + 1; }
                            let num = self.embedding[i][j] - self.embedding[m][j];
                            let denom = dist_sq + 1.0;
                            grad = grad + num / denom;
                        }
                        m = m + 1;
                    }
                    self.embedding[i][j] = self.embedding[i][j] - self.learning_rate * grad;
                    j = j + 1;
                }
                i = i + 1;
            }
            iter = iter + 1;
        }
        return self.embedding;
    }
}

# ── KernelPCA ──
class KernelPCA {
    let n_components = 2;
    let kernel = "rbf";
    let gamma = 1.0;
    let alphas = [];
    let X_fit = [];

    fn init_kernel_pca(n_components, kernel, gamma) {
        if (n_components != nullptr) { self.n_components = n_components; }
        if (kernel != nullptr) { self.kernel = kernel; }
        if (gamma != nullptr) { self.gamma = gamma; }
        self.alphas = [];
        self.X_fit = [];
        return 0;
    }

    fn rbf_kernel(x1, x2) {
        let dist = 0.0;
        let j = 0;
        while (j < len(x1)) { let d = x1[j] - x2[j]; dist = dist + d * d; j = j + 1; }
        return math_exp(-self.gamma * dist);
    }

    fn linear_kernel(x1, x2) {
        let dot = 0.0;
        let j = 0;
        while (j < len(x1)) { dot = dot + x1[j] * x2[j]; j = j + 1; }
        return dot;
    }

    fn fit(X) {
        self.X_fit = X;
        let n = len(X);
        let k = self.n_components;
        if (k > n) { k = n; }
        let K = [];
        let i = 0;
        while (i < n) {
            let row = [];
            let j = 0;
            while (j < n) {
                if (self.kernel == "rbf") { push(row, self.rbf_kernel(X[i], X[j])); }
                else { push(row, self.linear_kernel(X[i], X[j])); }
                j = j + 1;
            }
            push(K, row);
            i = i + 1;
        }
        let one_n = 1.0 / n;
        i = 0;
        while (i < n) {
            let j = 0;
            while (j < n) {
                let row_mean = 0.0;
                let l = 0; while (l < n) { row_mean = row_mean + K[i][l]; l = l + 1; }
                row_mean = row_mean * one_n;
                let col_mean = 0.0;
                l = 0; while (l < n) { col_mean = col_mean + K[l][j]; l = l + 1; }
                col_mean = col_mean * one_n;
                let total_mean = 0.0;
                l = 0; while (l < n) { let m = 0; while (m < n) { total_mean = total_mean + K[l][m]; m = m + 1; } l = l + 1; }
                total_mean = total_mean * one_n * one_n;
                K[i][j] = K[i][j] - row_mean - col_mean + total_mean;
                j = j + 1;
            }
            i = i + 1;
        }
        let comp = 0;
        while (comp < k) {
            let alpha = [];
            i = 0;
            while (i < n) { push(alpha, hml_random() - 0.5); i = i + 1; }
            let it = 0;
            while (it < 20) {
                let alpha_new = hml_vector_zeros(n);
                i = 0;
                while (i < n) {
                    let j = 0;
                    while (j < n) { alpha_new[i] = alpha_new[i] + K[i][j] * alpha[j]; j = j + 1; }
                    i = i + 1;
                }
                let norm = 0.0;
                i = 0; while (i < n) { norm = norm + alpha_new[i] * alpha_new[i]; i = i + 1; }
                norm = math_sqrt(norm);
                if (norm > 0) { i = 0; while (i < n) { alpha_new[i] = alpha_new[i] / norm; i = i + 1; } }
                alpha = alpha_new;
                it = it + 1;
            }
            push(self.alphas, alpha);
            comp = comp + 1;
        }
        return 0;
    }

    fn transform(X) {
        let n = len(X);
        let n_train = len(self.X_fit);
        let k = len(self.alphas);
        let result = [];
        let i = 0;
        while (i < n) {
            let row = [];
            let comp = 0;
            while (comp < k) {
                let val = 0.0;
                let j = 0;
                while (j < n_train) {
                    let kv = 0.0;
                    if (self.kernel == "rbf") { kv = self.rbf_kernel(X[i], self.X_fit[j]); }
                    else { kv = self.linear_kernel(X[i], self.X_fit[j]); }
                    val = val + self.alphas[comp][j] * kv;
                    j = j + 1;
                }
                push(row, val);
                comp = comp + 1;
            }
            push(result, row);
            i = i + 1;
        }
        return result;
    }

    fn fit_transform(X) {
        self.fit(X);
        return self.transform(X);
    }
}

# ── SparsePCA ──
class SparsePCA {
    let n_components = 2;
    let alpha = 1.0;
    let max_iter = 100;
    let components = [];
    let mean = [];

    fn init_sparse_pca(n_components, alpha, max_iter) {
        if (n_components != nullptr) { self.n_components = n_components; }
        if (alpha != nullptr) { self.alpha = alpha; }
        if (max_iter != nullptr) { self.max_iter = max_iter; }
        self.components = [];
        return 0;
    }

    fn fit(X) {
        let n = len(X);
        let d = len(X[0]);
        let k = self.n_components;
        if (k > d) { k = d; }
        self.mean = hml_vector_zeros(d);
        let i = 0;
        while (i < n) {
            let j = 0;
            while (j < d) { self.mean[j] = self.mean[j] + X[i][j]; j = j + 1; }
            i = i + 1;
        }
        let j = 0;
        while (j < d) { self.mean[j] = self.mean[j] / n; j = j + 1; }
        let Xc = [];
        i = 0;
        while (i < n) {
            let row = [];
            j = 0;
            while (j < d) { push(row, X[i][j] - self.mean[j]); j = j + 1; }
            push(Xc, row);
            i = i + 1;
        }
        self.components = [];
        let comp = 0;
        while (comp < k) {
            let v = [];
            j = 0;
            while (j < d) { push(v, hml_random() - 0.5); j = j + 1; }
            let iter = 0;
            while (iter < self.max_iter) {
                let v_new = hml_vector_zeros(d);
                i = 0;
                while (i < n) {
                    let dot = 0.0;
                    j = 0; while (j < d) { dot = dot + Xc[i][j] * v[j]; j = j + 1; }
                    j = 0; while (j < d) { v_new[j] = v_new[j] + dot * Xc[i][j]; j = j + 1; }
                    i = i + 1;
                }
                j = 0;
                while (j < d) {
                    v_new[j] = v_new[j] / n;
                    if (v_new[j] > self.alpha) { v_new[j] = v_new[j] - self.alpha; }
                    else { if (v_new[j] < -self.alpha) { v_new[j] = v_new[j] + self.alpha; } else { v_new[j] = 0.0; } }
                    j = j + 1;
                }
                let norm = 0.0;
                j = 0; while (j < d) { norm = norm + v_new[j] * v_new[j]; j = j + 1; }
                norm = math_sqrt(norm);
                if (norm > 0) { j = 0; while (j < d) { v_new[j] = v_new[j] / norm; j = j + 1; } }
                v = v_new;
                iter = iter + 1;
            }
            push(self.components, v);
            i = 0;
            while (i < n) {
                let dot = 0.0;
                j = 0; while (j < d) { dot = dot + Xc[i][j] * v[j]; j = j + 1; }
                j = 0; while (j < d) { Xc[i][j] = Xc[i][j] - dot * v[j]; j = j + 1; }
                i = i + 1;
            }
            comp = comp + 1;
        }
        return 0;
    }

    fn transform(X) {
        let n = len(X);
        let d = len(X[0]);
        let k = len(self.components);
        let result = [];
        let i = 0;
        while (i < n) {
            let row = [];
            let comp = 0;
            while (comp < k) {
                let dot = 0.0;
                let j = 0;
                while (j < d) { dot = dot + (X[i][j] - self.mean[j]) * self.components[comp][j]; j = j + 1; }
                push(row, dot);
                comp = comp + 1;
            }
            push(result, row);
            i = i + 1;
        }
        return result;
    }

    fn fit_transform(X) {
        self.fit(X);
        return self.transform(X);
    }
}

# ── IncrementalPCA ──
class IncrementalPCA {
    let n_components = 2;
    let batch_size = 100;
    let components = [];
    let mean = [];
    let n_samples_seen = 0;

    fn init_incremental_pca(n_components, batch_size) {
        if (n_components != nullptr) { self.n_components = n_components; }
        if (batch_size != nullptr) { self.batch_size = batch_size; }
        self.components = [];
        self.mean = [];
        self.n_samples_seen = 0;
        return 0;
    }

    fn partial_fit(X) {
        let n = len(X);
        let d = len(X[0]);
        let k = self.n_components;
        if (k > d) { k = d; }
        if (len(self.mean) == 0) {
            self.mean = hml_vector_zeros(d);
            self.components = [];
            let i = 0;
            while (i < k) {
                let row = [];
                let j = 0;
                while (j < d) { push(row, hml_random() - 0.5); j = j + 1; }
                push(self.components, row);
                i = i + 1;
            }
        }
        let i = 0;
        while (i < n) {
            let j = 0;
            while (j < d) {
                self.mean[j] = (self.mean[j] * self.n_samples_seen + X[i][j]) / (self.n_samples_seen + 1);
                j = j + 1;
            }
            self.n_samples_seen = self.n_samples_seen + 1;
            i = i + 1;
        }
        return 0;
    }

    fn transform(X) {
        let n = len(X);
        let d = len(X[0]);
        let k = len(self.components);
        let result = [];
        let i = 0;
        while (i < n) {
            let row = [];
            let comp = 0;
            while (comp < k) {
                let dot = 0.0;
                let j = 0;
                while (j < d) { dot = dot + (X[i][j] - self.mean[j]) * self.components[comp][j]; j = j + 1; }
                push(row, dot);
                comp = comp + 1;
            }
            push(result, row);
            i = i + 1;
        }
        return result;
    }
}

