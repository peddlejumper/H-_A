    fn forward(X) {
        let result = [];
        let i = 0;
        while (i < len(X)) {
            push(result, hml_avg_pool2d(X[i], self.pool_size, self.stride));
            i = i + 1;
        }
        return result;
    }
}

# ── FlattenLayer ──
class FlattenLayer {
    fn init_flatten() {
        return 0;
    }

    fn forward(X) {
        return hml_flatten(X);
    }
}

# ── DropoutLayer ──
class DropoutLayer {
    let rate = 0.5;
    let training = true;

    fn init_dropout(rate) {
        self.rate = rate;
        self.training = true;
        return 0;
    }

    fn forward(X) {
        let result = hml_dropout_forward(X, self.rate, self.training);
        return result["output"];
    }

    fn train_mode() {
        self.training = true;
        return 0;
    }

    fn eval_mode() {
        self.training = false;
        return 0;
    }
}

# ── BatchNorm1D ──
class BatchNorm1D {
    let num_features = 0;
    let gamma = [];
    let beta = [];
    let eps = 0.00001;
    let running_mean = [];
    let running_var = [];
    let momentum = 0.9;
    let training = true;

    fn init_batchnorm1d(num_features, momentum) {
        self.num_features = num_features;
        self.gamma = hml_vector_ones(num_features);
        self.beta = hml_vector_zeros(num_features);
        self.running_mean = hml_vector_zeros(num_features);
        self.running_var = hml_vector_ones(num_features);
        if (momentum == nullptr) { self.momentum = 0.9; }
        else { self.momentum = momentum; }
        self.training = true;
        return 0;
    }

    fn forward(X) {
        if (self.training) {
            let result = hml_batch_norm_forward(X, self.gamma, self.beta, self.eps);
            let i = 0;
            while (i < self.num_features) {
                self.running_mean[i] = self.momentum * self.running_mean[i] + (1.0 - self.momentum) * result["mean"][i];
                self.running_var[i] = self.momentum * self.running_var[i] + (1.0 - self.momentum) * result["var"][i];
                i = i + 1;
            }
            return result["output"];
        }
        let out = [];
        let i = 0;
        while (i < len(X)) {
            let row = [];
            let j = 0;
            while (j < self.num_features) {
                let x_hat = (X[i][j] - self.running_mean[j]) / math_sqrt(self.running_var[j] + self.eps);
                push(row, self.gamma[j] * x_hat + self.beta[j]);
                j = j + 1;
            }
            push(out, row);
            i = i + 1;
        }
        return out;
    }

    fn train_mode() { self.training = true; return 0; }
    fn eval_mode() { self.training = false; return 0; }
}

# ── BatchNorm2D ──
class BatchNorm2D {
    let num_features = 0;
    let gamma = [];
    let beta = [];
    let eps = 0.00001;
    let training = true;

    fn init_batchnorm2d(num_features) {
        self.num_features = num_features;
        self.gamma = hml_vector_ones(num_features);
        self.beta = hml_vector_zeros(num_features);
        self.training = true;
        return 0;
    }

    fn forward(X) {
        let n = len(X);
        let h = len(X[0]);
        let w = len(X[0][0]);
        let flat = [];
        let i = 0;
        while (i < n) {
            let row = [];
            let ki = 0;
            while (ki < h) {
                let kj = 0;
                while (kj < w) {
                    push(row, X[i][ki][kj]);
                    kj = kj + 1;
                }
                ki = ki + 1;
            }
            push(flat, row);
            i = i + 1;
        }
        let bnorm = BatchNorm1D();
        bnorm.init_batchnorm1d(h * w, 0.9);
        bnorm.gamma = self.gamma;
        bnorm.beta = self.beta;
        let out = bnorm.forward(flat);
        return out;
    }

    fn train_mode() { self.training = true; return 0; }
    fn eval_mode() { self.training = false; return 0; }
}

# ── LayerNorm ──
class LayerNorm {
    let normalized_shape = 0;
    let gamma = [];
    let beta = [];
    let eps = 0.00001;

    fn init_layernorm(normalized_shape) {
        self.normalized_shape = normalized_shape;
        self.gamma = hml_vector_ones(normalized_shape);
        self.beta = hml_vector_zeros(normalized_shape);
        return 0;
    }

    fn forward(X) {
        return hml_layer_norm_forward(X, self.gamma, self.beta, self.eps);
    }
}

# ── EmbeddingLayer ──
class EmbeddingLayer {
    let num_embeddings = 0;
    let embedding_dim = 0;
    let table = [];

    fn init_embedding(num_embeddings, embedding_dim) {
        self.num_embeddings = num_embeddings;
        self.embedding_dim = embedding_dim;
        self.table = hml_xavier_init(num_embeddings, embedding_dim);
        return 0;
    }

    fn forward(indices) {
        return hml_embedding_lookup(self.table, indices);
    }
}

# ── RNNCell ──
class RNNCell {
    let input_size = 0;
    let hidden_size = 0;
    let Wxh = [];
    let Whh = [];
    let bh = [];

    fn init_rnncell(input_size, hidden_size) {
        self.input_size = input_size;
        self.hidden_size = hidden_size;
        self.Wxh = hml_xavier_init(input_size, hidden_size);
        self.Whh = hml_xavier_init(hidden_size, hidden_size);
        self.bh = hml_vector_zeros(hidden_size);
        return 0;
    }

    fn forward(x, h_prev) {
        return hml_rnn_cell(x, h_prev, self.Wxh, self.Whh, self.bh);
    }
}

# ── LSTMCell ──
class LSTMCell {
    let input_size = 0;
    let hidden_size = 0;
    let Wf = [];
    let Wi = [];
    let Wc = [];
    let Wo = [];

    fn init_lstmcell(input_size, hidden_size) {
        self.input_size = input_size;
        self.hidden_size = hidden_size;
        self.Wf = hml_xavier_init(input_size + hidden_size, hidden_size);
        self.Wi = hml_xavier_init(input_size + hidden_size, hidden_size);
        self.Wc = hml_xavier_init(input_size + hidden_size, hidden_size);
        self.Wo = hml_xavier_init(input_size + hidden_size, hidden_size);
        return 0;
    }

    fn forward(x, h_prev, c_prev) {
        return hml_lstm_cell(x, h_prev, c_prev, self.Wf, self.Wi, self.Wc, self.Wo);
    }
}

# ── GRUCell ──
class GRUCell {
    let input_size = 0;
    let hidden_size = 0;
    let Wxz = [];
    let Whz = [];
    let Wxr = [];
    let Whr = [];
    let Wxh = [];
    let Whh = [];

    fn init_grucell(input_size, hidden_size) {
        self.input_size = input_size;
        self.hidden_size = hidden_size;
        self.Wxz = hml_xavier_init(input_size, hidden_size);
        self.Whz = hml_xavier_init(hidden_size, hidden_size);
        self.Wxr = hml_xavier_init(input_size, hidden_size);
        self.Whr = hml_xavier_init(hidden_size, hidden_size);
        self.Wxh = hml_xavier_init(input_size, hidden_size);
        self.Whh = hml_xavier_init(hidden_size, hidden_size);
        return 0;
    }

    fn forward(x, h_prev) {
        return hml_gru_cell(x, h_prev, self.Wxz, self.Whz, self.Wxr, self.Whr, self.Wxh, self.Whh);
    }
}

# ── AttentionLayer ──
class AttentionLayer {
    let d_model = 0;

    fn init_attention(d_model) {
        self.d_model = d_model;
        return 0;
    }

    fn forward(Q, K, V) {
        return hml_scaled_dot_product_attention(Q, K, V, nullptr);
    }
}

# ── MultiHeadAttentionLayer ──
class MultiHeadAttentionLayer {
    let d_model = 0;
    let n_heads = 0;
    let Wq = [];
    let Wk = [];
    let Wv = [];
    let Wo = [];

    fn init_multihead_attention(d_model, n_heads) {
        self.d_model = d_model;
        self.n_heads = n_heads;
        self.Wq = hml_xavier_init(d_model, d_model);
        self.Wk = hml_xavier_init(d_model, d_model);
        self.Wv = hml_xavier_init(d_model, d_model);
        self.Wo = hml_xavier_init(d_model, d_model);
        return 0;
    }

    fn forward(Q, K, V) {
        let Q_proj = hml_matrix_multiply(Q, self.Wq);
        let K_proj = hml_matrix_multiply(K, self.Wk);
        let V_proj = hml_matrix_multiply(V, self.Wv);
        let heads = hml_multi_head_attention_split(Q_proj, K_proj, V_proj, self.n_heads);
        let concat = hml_multi_head_attention_concat(heads);
        return hml_matrix_multiply(concat, self.Wo);
    }
}

# ── ResidualBlock ──
class ResidualBlock {
    let layers = [];
    let shortcut = nullptr;

    fn init_residual(layers) {
        self.layers = layers;
        self.shortcut = nullptr;
        return 0;
    }

    fn forward(X) {
        let out = X;
        let i = 0;
        while (i < len(self.layers)) {
            out = self.layers[i].forward(out);
            i = i + 1;
        }
        let result = hml_matrix_add(out, X);
        return result;
    }
}

# ── SequentialModel ──
class SequentialModel {
    let layers = [];
    let compiled = false;

    fn init_sequential(layers) {
        self.layers = layers;
        self.compiled = false;
        return 0;
    }

    fn add(layer) {
        push(self.layers, layer);
        return 0;
    }

    fn forward(X) {
        let out = X;
        let i = 0;
        while (i < len(self.layers)) {
            out = self.layers[i].forward(out);
            i = i + 1;
        }
        return out;
    }

    fn predict(X) {
        let i = 0;
        while (i < len(self.layers)) {
            self.layers[i].eval_mode();
            i = i + 1;
        }
        let out = self.forward(X);
        return out;
    }

    fn score(X, y) {
        let y_pred = self.predict(X);
        return accuracy_score(y, y_pred);
    }
}

