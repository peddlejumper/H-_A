# ── RidgeRegression ──
class RidgeRegression {
    let alpha = 1.0;
    let max_iter = 1000;
    let lr = 0.01;
    let coef = [];
    let intercept = 0.0;

    fn init_ridge_regression(alpha, max_iter, lr) {
        if (alpha != nullptr) { self.alpha = alpha; }
        if (max_iter != nullptr) { self.max_iter = max_iter; }
        if (lr != nullptr) { self.lr = lr; }
        self.coef = [];
        return 0;
    }

    fn fit(X, y) {
        let n = len(X);
        let d = len(X[0]);
        self.coef = hml_vector_zeros(d);
        self.intercept = 0.0;
        let iter = 0;
        while (iter < self.max_iter) {
            let grad = hml_vector_zeros(d);
            let grad_int = 0.0;
            let i = 0;
            while (i < n) {
                let pred = self.intercept;
                let j = 0;
                while (j < d) { pred = pred + self.coef[j] * X[i][j]; j = j + 1; }
                let err = pred - y[i];
                j = 0;
                while (j < d) { grad[j] = grad[j] + err * X[i][j]; j = j + 1; }
                grad_int = grad_int + err;
                i = i + 1;
            }
            let j = 0;
            while (j < d) { grad[j] = grad[j] / n + self.alpha * self.coef[j]; j = j + 1; }
            grad_int = grad_int / n;
            j = 0;
            while (j < d) { self.coef[j] = self.coef[j] - self.lr * grad[j]; j = j + 1; }
            self.intercept = self.intercept - self.lr * grad_int;
            iter = iter + 1;
        }
        return 0;
    }

    fn predict(X) {
        let n = len(X);
        let d = len(self.coef);
        let preds = [];
        let i = 0;
        while (i < n) {
            let val = self.intercept;
            let j = 0;
            while (j < d) { val = val + self.coef[j] * X[i][j]; j = j + 1; }
            push(preds, val);
            i = i + 1;
        }
        return preds;
    }

    fn score(X, y) { return r2_score(y, self.predict(X)); }
}

# ── LassoRegression ──
class LassoRegression {
    let alpha = 1.0;
    let max_iter = 1000;
    let lr = 0.01;
    let coef = [];
    let intercept = 0.0;

    fn init_lasso_regression(alpha, max_iter, lr) {
        if (alpha != nullptr) { self.alpha = alpha; }
        if (max_iter != nullptr) { self.max_iter = max_iter; }
        if (lr != nullptr) { self.lr = lr; }
        self.coef = [];
        return 0;
    }

    fn fit(X, y) {
        let n = len(X);
        let d = len(X[0]);
        self.coef = hml_vector_zeros(d);
        self.intercept = 0.0;
        let iter = 0;
        while (iter < self.max_iter) {
            let i = 0;
            while (i < n) {
                let pred = self.intercept;
                let j = 0;
                while (j < d) { pred = pred + self.coef[j] * X[i][j]; j = j + 1; }
                let err = pred - y[i];
                self.intercept = self.intercept - self.lr * err / n;
                j = 0;
                while (j < d) {
                    let grad = err * X[i][j] / n;
                    self.coef[j] = self.coef[j] - self.lr * grad;
                    if (self.coef[j] > self.alpha * self.lr) { self.coef[j] = self.coef[j] - self.alpha * self.lr; }
                    else { if (self.coef[j] < -self.alpha * self.lr) { self.coef[j] = self.coef[j] + self.alpha * self.lr; } else { self.coef[j] = 0.0; } }
                    j = j + 1;
                }
                i = i + 1;
            }
            iter = iter + 1;
        }
        return 0;
    }

    fn predict(X) {
        let n = len(X);
        let d = len(self.coef);
        let preds = [];
        let i = 0;
        while (i < n) {
            let val = self.intercept;
            let j = 0;
            while (j < d) { val = val + self.coef[j] * X[i][j]; j = j + 1; }
            push(preds, val);
            i = i + 1;
        }
        return preds;
    }

    fn score(X, y) { return r2_score(y, self.predict(X)); }
}

# ── ElasticNetRegression ──
class ElasticNetRegression {
    let alpha = 1.0;
    let l1_ratio = 0.5;
    let max_iter = 1000;
    let lr = 0.01;
    let coef = [];
    let intercept = 0.0;

    fn init_elastic_net(alpha, l1_ratio, max_iter, lr) {
        if (alpha != nullptr) { self.alpha = alpha; }
        if (l1_ratio != nullptr) { self.l1_ratio = l1_ratio; }
        if (max_iter != nullptr) { self.max_iter = max_iter; }
        if (lr != nullptr) { self.lr = lr; }
        self.coef = [];
        return 0;
    }

    fn fit(X, y) {
        let n = len(X);
        let d = len(X[0]);
        self.coef = hml_vector_zeros(d);
        self.intercept = 0.0;
        let l1 = self.alpha * self.l1_ratio;
        let l2 = self.alpha * (1.0 - self.l1_ratio);
        let iter = 0;
        while (iter < self.max_iter) {
            let i = 0;
            while (i < n) {
                let pred = self.intercept;
                let j = 0;
                while (j < d) { pred = pred + self.coef[j] * X[i][j]; j = j + 1; }
                let err = pred - y[i];
                self.intercept = self.intercept - self.lr * err / n;
                j = 0;
                while (j < d) {
                    let grad = err * X[i][j] / n + l2 * self.coef[j];
                    self.coef[j] = self.coef[j] - self.lr * grad;
                    if (self.coef[j] > l1 * self.lr) { self.coef[j] = self.coef[j] - l1 * self.lr; }
                    else { if (self.coef[j] < -l1 * self.lr) { self.coef[j] = self.coef[j] + l1 * self.lr; } else { self.coef[j] = 0.0; } }
                    j = j + 1;
                }
                i = i + 1;
            }
            iter = iter + 1;
        }
        return 0;
    }

    fn predict(X) {
        let n = len(X);
        let d = len(self.coef);
        let preds = [];
        let i = 0;
        while (i < n) {
            let val = self.intercept;
            let j = 0;
            while (j < d) { val = val + self.coef[j] * X[i][j]; j = j + 1; }
            push(preds, val);
            i = i + 1;
        }
        return preds;
    }

    fn score(X, y) { return r2_score(y, self.predict(X)); }
}

# ── BayesianRidgeRegression ──
class BayesianRidgeRegression {
    let alpha_1 = 0.000001;
    let alpha_2 = 0.000001;
    let lambda_1 = 0.000001;
    let lambda_2 = 0.000001;
    let max_iter = 300;
    let coef = [];
    let intercept = 0.0;
    let alpha = 1.0;
    let lambda = 1.0;

    fn init_bayesian_ridge(alpha_1, alpha_2, lambda_1, lambda_2, max_iter) {
        if (alpha_1 != nullptr) { self.alpha_1 = alpha_1; }
        if (alpha_2 != nullptr) { self.alpha_2 = alpha_2; }
        if (lambda_1 != nullptr) { self.lambda_1 = lambda_1; }
        if (lambda_2 != nullptr) { self.lambda_2 = lambda_2; }
        if (max_iter != nullptr) { self.max_iter = max_iter; }
        self.coef = [];
        return 0;
    }

    fn fit(X, y) {
        let n = len(X);
        let d = len(X[0]);
        self.coef = hml_vector_zeros(d);
        self.intercept = 0.0;
        self.alpha = 1.0;
        self.lambda = 1.0;
        let iter = 0;
        while (iter < self.max_iter) {
            let i = 0;
            while (i < n) {
                let pred = self.intercept;
                let j = 0;
                while (j < d) { pred = pred + self.coef[j] * X[i][j]; j = j + 1; }
                let err = pred - y[i];
                self.intercept = self.intercept - 0.01 * err / n;
                j = 0;
                while (j < d) { self.coef[j] = self.coef[j] - 0.01 * (err * X[i][j] / n + self.lambda * self.coef[j]); j = j + 1; }
                i = i + 1;
            }
            iter = iter + 1;
        }
        return 0;
    }

    fn predict(X) {
        let n = len(X);
        let d = len(self.coef);
        let preds = [];
        let i = 0;
        while (i < n) {
            let val = self.intercept;
            let j = 0;
            while (j < d) { val = val + self.coef[j] * X[i][j]; j = j + 1; }
            push(preds, val);
            i = i + 1;
        }
        return preds;
    }

    fn score(X, y) { return r2_score(y, self.predict(X)); }
}

# ── SGDRegressorModel ──
class SGDRegressorModel {
    let loss = "squared_loss";
    let penalty = "l2";
    let alpha = 0.0001;
    let max_iter = 1000;
    let lr = 0.01;
    let coef = [];
    let intercept = 0.0;

    fn init_sgd_regressor(loss, penalty, alpha, max_iter, lr) {
        if (loss != nullptr) { self.loss = loss; }
        if (penalty != nullptr) { self.penalty = penalty; }
        if (alpha != nullptr) { self.alpha = alpha; }
        if (max_iter != nullptr) { self.max_iter = max_iter; }
        if (lr != nullptr) { self.lr = lr; }
        self.coef = [];
        return 0;
    }

    fn fit(X, y) {
        let n = len(X);
        let d = len(X[0]);
        self.coef = hml_vector_zeros(d);
        self.intercept = 0.0;
        let iter = 0;
        while (iter < self.max_iter) {
            let i = 0;
            while (i < n) {
                let pred = self.intercept;
                let j = 0;
                while (j < d) { pred = pred + self.coef[j] * X[i][j]; j = j + 1; }
                let err = pred - y[i];
                self.intercept = self.intercept - self.lr * err;
                j = 0;
                while (j < d) {
                    let grad = err * X[i][j];
                    if (self.penalty == "l2") { grad = grad + self.alpha * self.coef[j]; }
                    self.coef[j] = self.coef[j] - self.lr * grad;
                    j = j + 1;
                }
                i = i + 1;
            }
            self.lr = self.lr * 0.99;
            iter = iter + 1;
        }
        return 0;
    }

    fn predict(X) {
        let n = len(X);
        let d = len(self.coef);
        let preds = [];
        let i = 0;
        while (i < n) {
            let val = self.intercept;
            let j = 0;
            while (j < d) { val = val + self.coef[j] * X[i][j]; j = j + 1; }
            push(preds, val);
            i = i + 1;
        }
        return preds;
    }

    fn score(X, y) { return r2_score(y, self.predict(X)); }
}

# ── SGDClassifierModel ──
class SGDClassifierModel {
    let loss = "hinge";
    let penalty = "l2";
    let alpha = 0.0001;
    let max_iter = 1000;
    let lr = 0.01;
    let coef = [];
    let intercept = 0.0;

    fn init_sgd_classifier(loss, penalty, alpha, max_iter, lr) {
        if (loss != nullptr) { self.loss = loss; }
        if (penalty != nullptr) { self.penalty = penalty; }
        if (alpha != nullptr) { self.alpha = alpha; }
        if (max_iter != nullptr) { self.max_iter = max_iter; }
        if (lr != nullptr) { self.lr = lr; }
        self.coef = [];
        return 0;
    }

    fn fit(X, y) {
        let n = len(X);
        let d = len(X[0]);
        self.coef = hml_vector_zeros(d);
        self.intercept = 0.0;
        let iter = 0;
        while (iter < self.max_iter) {
            let i = 0;
            while (i < n) {
                let y_true = y[i];
                if (y_true == 0) { y_true = -1; }
                let pred = self.intercept;
                let j = 0;
                while (j < d) { pred = pred + self.coef[j] * X[i][j]; j = j + 1; }
                let margin = y_true * pred;
                if (margin < 1.0) {
                    self.intercept = self.intercept + self.lr * (y_true - 2.0 * self.alpha * self.intercept);
                    j = 0;
                    while (j < d) { self.coef[j] = self.coef[j] + self.lr * (y_true * X[i][j] - self.alpha * self.coef[j]); j = j + 1; }
                }
                i = i + 1;
            }
            self.lr = self.lr * 0.99;
            iter = iter + 1;
        }
        return 0;
    }

    fn predict(X) {
        let n = len(X);
        let d = len(self.coef);
        let preds = [];
        let i = 0;
        while (i < n) {
            let val = self.intercept;
            let j = 0;
            while (j < d) { val = val + self.coef[j] * X[i][j]; j = j + 1; }
            if (val >= 0) { push(preds, 1); }
            else { push(preds, 0); }
            i = i + 1;
        }
        return preds;
    }

    fn score(X, y) { return accuracy_score(self.predict(X), y); }
}

# ── PerceptronClassifier ──
class PerceptronClassifier {
    let max_iter = 1000;
    let lr = 0.01;
    let coef = [];
    let intercept = 0.0;

    fn init_perceptron(max_iter, lr) {
        if (max_iter != nullptr) { self.max_iter = max_iter; }
        if (lr != nullptr) { self.lr = lr; }
        self.coef = [];
        return 0;
    }

    fn fit(X, y) {
        let n = len(X);
        let d = len(X[0]);
        self.coef = hml_vector_zeros(d);
        self.intercept = 0.0;
        let iter = 0;
        while (iter < self.max_iter) {
            let errors = 0;
            let i = 0;
            while (i < n) {
                let y_true = y[i];
                if (y_true == 0) { y_true = -1; }
                let pred = self.intercept;
                let j = 0;
                while (j < d) { pred = pred + self.coef[j] * X[i][j]; j = j + 1; }
                if (y_true * pred <= 0) {
                    self.intercept = self.intercept + self.lr * y_true;
                    j = 0;
                    while (j < d) { self.coef[j] = self.coef[j] + self.lr * y_true * X[i][j]; j = j + 1; }
                    errors = errors + 1;
                }
                i = i + 1;
            }
            if (errors == 0) { iter = self.max_iter; }
            iter = iter + 1;
        }
        return 0;
    }

    fn predict(X) {
        let n = len(X);
        let d = len(self.coef);
        let preds = [];
        let i = 0;
        while (i < n) {
            let val = self.intercept;
            let j = 0;
            while (j < d) { val = val + self.coef[j] * X[i][j]; j = j + 1; }
            if (val >= 0) { push(preds, 1); }
            else { push(preds, 0); }
            i = i + 1;
        }
        return preds;
    }

    fn score(X, y) { return accuracy_score(self.predict(X), y); }
}

# ── PassiveAggressiveClassifier ──
class PassiveAggressiveClassifier {
    let C = 1.0;
    let max_iter = 1000;
    let coef = [];
    let intercept = 0.0;

    fn init_passive_aggressive_clf(C, max_iter) {
        if (C != nullptr) { self.C = C; }
        if (max_iter != nullptr) { self.max_iter = max_iter; }
        self.coef = [];
        return 0;
    }

    fn fit(X, y) {
        let n = len(X);
        let d = len(X[0]);
        self.coef = hml_vector_zeros(d);
        self.intercept = 0.0;
        let iter = 0;
        while (iter < self.max_iter) {
            let i = 0;
            while (i < n) {
                let y_true = y[i];
                if (y_true == 0) { y_true = -1; }
                let pred = self.intercept;
                let j = 0;
                while (j < d) { pred = pred + self.coef[j] * X[i][j]; j = j + 1; }
                let loss = 1.0 - y_true * pred;
                if (loss > 0) {
                    let norm_sq = 1.0;
                    j = 0;
                    while (j < d) { norm_sq = norm_sq + X[i][j] * X[i][j]; j = j + 1; }
                    let tau = loss / norm_sq;
                    if (tau > self.C) { tau = self.C; }
                    self.intercept = self.intercept + tau * y_true;
                    j = 0;
                    while (j < d) { self.coef[j] = self.coef[j] + tau * y_true * X[i][j]; j = j + 1; }
                }
                i = i + 1;
            }
            iter = iter + 1;
        }
        return 0;
    }

    fn predict(X) {
        let n = len(X);
        let d = len(self.coef);
        let preds = [];
        let i = 0;
        while (i < n) {
            let val = self.intercept;
            let j = 0;
            while (j < d) { val = val + self.coef[j] * X[i][j]; j = j + 1; }
            if (val >= 0) { push(preds, 1); }
            else { push(preds, 0); }
            i = i + 1;
        }
        return preds;
    }

    fn score(X, y) { return accuracy_score(self.predict(X), y); }
}

# ── PassiveAggressiveRegressor ──
class PassiveAggressiveRegressor {
    let C = 1.0;
    let epsilon = 0.1;
    let max_iter = 1000;
    let coef = [];
    let intercept = 0.0;

    fn init_passive_aggressive_reg(C, epsilon, max_iter) {
        if (C != nullptr) { self.C = C; }
        if (epsilon != nullptr) { self.epsilon = epsilon; }
        if (max_iter != nullptr) { self.max_iter = max_iter; }
        self.coef = [];
        return 0;
    }

    fn fit(X, y) {
        let n = len(X);
        let d = len(X[0]);
        self.coef = hml_vector_zeros(d);
        self.intercept = 0.0;
        let iter = 0;
        while (iter < self.max_iter) {
            let i = 0;
            while (i < n) {
                let pred = self.intercept;
                let j = 0;
                while (j < d) { pred = pred + self.coef[j] * X[i][j]; j = j + 1; }
                let err = y[i] - pred;
                let abs_err = math_fabs(err);
                if (abs_err > self.epsilon) {
                    let sign = 1.0;
                    if (err < 0) { sign = -1.0; }
                    let loss = abs_err - self.epsilon;
                    let norm_sq = 1.0;
                    j = 0;
                    while (j < d) { norm_sq = norm_sq + X[i][j] * X[i][j]; j = j + 1; }
                    let tau = loss / norm_sq;
                    if (tau > self.C) { tau = self.C; }
                    self.intercept = self.intercept + tau * sign;
                    j = 0;
                    while (j < d) { self.coef[j] = self.coef[j] + tau * sign * X[i][j]; j = j + 1; }
                }
                i = i + 1;
            }
            iter = iter + 1;
        }
        return 0;
    }

    fn predict(X) {
        let n = len(X);
        let d = len(self.coef);
        let preds = [];
        let i = 0;
        while (i < n) {
            let val = self.intercept;
            let j = 0;
            while (j < d) { val = val + self.coef[j] * X[i][j]; j = j + 1; }
            push(preds, val);
            i = i + 1;
        }
        return preds;
    }

    fn score(X, y) { return r2_score(y, self.predict(X)); }
}

# ── HuberRegressor ──
class HuberRegressor {
    let epsilon = 1.35;
    let max_iter = 1000;
    let lr = 0.01;
    let coef = [];
    let intercept = 0.0;

    fn init_huber_regressor(epsilon, max_iter, lr) {
        if (epsilon != nullptr) { self.epsilon = epsilon; }
        if (max_iter != nullptr) { self.max_iter = max_iter; }
        if (lr != nullptr) { self.lr = lr; }
        self.coef = [];
        return 0;
    }

    fn fit(X, y) {
        let n = len(X);
        let d = len(X[0]);
        self.coef = hml_vector_zeros(d);
        self.intercept = 0.0;
        let iter = 0;
        while (iter < self.max_iter) {
            let i = 0;
            while (i < n) {
                let pred = self.intercept;
                let j = 0;
                while (j < d) { pred = pred + self.coef[j] * X[i][j]; j = j + 1; }
                let err = pred - y[i];
                let grad = err;
                if (math_fabs(err) > self.epsilon) {
                    if (err > 0) { grad = self.epsilon; }
                    else { grad = -self.epsilon; }
                }
                self.intercept = self.intercept - self.lr * grad;
                j = 0;
                while (j < d) { self.coef[j] = self.coef[j] - self.lr * grad * X[i][j]; j = j + 1; }
                i = i + 1;
            }
            iter = iter + 1;
        }
        return 0;
    }

    fn predict(X) {
        let n = len(X);
        let d = len(self.coef);
        let preds = [];
        let i = 0;
        while (i < n) {
            let val = self.intercept;
            let j = 0;
            while (j < d) { val = val + self.coef[j] * X[i][j]; j = j + 1; }
            push(preds, val);
            i = i + 1;
        }
        return preds;
    }

    fn score(X, y) { return r2_score(y, self.predict(X)); }
}

# ── QuantileRegressor ──
class QuantileRegressor {
    let quantile = 0.5;
    let max_iter = 1000;
    let lr = 0.01;
    let coef = [];
    let intercept = 0.0;

    fn init_quantile_regressor(quantile, max_iter, lr) {
        if (quantile != nullptr) { self.quantile = quantile; }
        if (max_iter != nullptr) { self.max_iter = max_iter; }
        if (lr != nullptr) { self.lr = lr; }
        self.coef = [];
        return 0;
    }

    fn fit(X, y) {
        let n = len(X);
        let d = len(X[0]);
        self.coef = hml_vector_zeros(d);
        self.intercept = 0.0;
        let iter = 0;
        while (iter < self.max_iter) {
            let i = 0;
            while (i < n) {
                let pred = self.intercept;
                let j = 0;
                while (j < d) { pred = pred + self.coef[j] * X[i][j]; j = j + 1; }
                let err = y[i] - pred;
                let grad = 0.0;
                if (err > 0) { grad = -self.quantile; }
                else { grad = 1.0 - self.quantile; }
                self.intercept = self.intercept - self.lr * grad;
                j = 0;
                while (j < d) { self.coef[j] = self.coef[j] - self.lr * grad * X[i][j]; j = j + 1; }
                i = i + 1;
            }
            iter = iter + 1;
        }
        return 0;
    }

    fn predict(X) {
        let n = len(X);
        let d = len(self.coef);
        let preds = [];
        let i = 0;
        while (i < n) {
            let val = self.intercept;
            let j = 0;
            while (j < d) { val = val + self.coef[j] * X[i][j]; j = j + 1; }
            push(preds, val);
            i = i + 1;
        }
        return preds;
    }

    fn score(X, y) { return r2_score(y, self.predict(X)); }
}

# ── LarsRegression ──
class LarsRegression {
    let n_nonzero_coefs = 100;
    let max_iter = 500;
    let coef = [];
    let intercept = 0.0;
    let active = [];
    let alphas = [];

    fn init_lars(n_nonzero_coefs, max_iter) {
        if (n_nonzero_coefs != nullptr) { self.n_nonzero_coefs = n_nonzero_coefs; }
        if (max_iter != nullptr) { self.max_iter = max_iter; }
        self.coef = [];
        self.active = [];
        self.alphas = [];
        return 0;
    }

    fn fit(X, y) {
        let n = len(X);
        let d = len(X[0]);
        self.coef = hml_vector_zeros(d);
        self.intercept = 0.0;
        let residuals = [];
        let y_mean = 0.0;
        let i = 0;
        while (i < n) { y_mean = y_mean + y[i]; i = i + 1; }
        y_mean = y_mean / n;
        self.intercept = y_mean;
        i = 0;
        while (i < n) { push(residuals, y[i] - y_mean); i = i + 1; }
        self.active = [];
        let iter = 0;
        while (iter < self.max_iter and len(self.active) < self.n_nonzero_coefs) {
            let best_corr = 0.0;
            let best_j = -1;
            let j = 0;
            while (j < d) {
                let skip = 0;
                let a = 0;
                while (a < len(self.active)) { if (self.active[a] == j) { skip = 1; } a = a + 1; }
                if (skip == 0) {
                    let corr = 0.0;
                    i = 0;
                    while (i < n) { corr = corr + X[i][j] * residuals[i]; i = i + 1; }
                    corr = math_fabs(corr);
                    if (corr > best_corr) { best_corr = corr; best_j = j; }
                }
                j = j + 1;
            }
            if (best_j == -1) { iter = self.max_iter; }
            else {
                push(self.active, best_j);
                let Xa = [];
                i = 0;
                while (i < n) {
                    let row = [];
                    let a = 0;
                    while (a < len(self.active)) { push(row, X[i][self.active[a]]); a = a + 1; }
                    push(Xa, row);
                    i = i + 1;
                }
                let num_a = len(self.active);
                let lr_local = 0.001;
                let beta = [];
                let a = 0;
                while (a < num_a) { push(beta, 0.0); a = a + 1; }
                let s = 0;
                while (s < 10) {
                    i = 0;
                    while (i < n) {
                        let pred = 0.0;
                        a = 0;
                        while (a < num_a) { pred = pred + Xa[i][a] * beta[a]; a = a + 1; }
                        let err = residuals[i] - pred;
                        a = 0;
                        while (a < num_a) { beta[a] = beta[a] + lr_local * err * Xa[i][a]; a = a + 1; }
                        i = i + 1;
                    }
                    s = s + 1;
                }
                a = 0;
                while (a < num_a) { self.coef[self.active[a]] = self.coef[self.active[a]] + beta[a]; a = a + 1; }
                i = 0;
                while (i < n) {
                    let pred = 0.0;
                    a = 0;
                    while (a < num_a) { pred = pred + Xa[i][a] * beta[a]; a = a + 1; }
                    residuals[i] = residuals[i] - pred;
                    i = i + 1;
                }
            }
            iter = iter + 1;
        }
        return 0;
    }

    fn predict(X) {
        let n = len(X);
        let d = len(self.coef);
        let preds = [];
        let i = 0;
        while (i < n) {
            let val = self.intercept;
            let j = 0;
            while (j < d) { val = val + self.coef[j] * X[i][j]; j = j + 1; }
            push(preds, val);
            i = i + 1;
        }
        return preds;
    }

    fn score(X, y) { return r2_score(y, self.predict(X)); }
}

