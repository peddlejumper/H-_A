# ═══════════════════════════════════════════════════════════════
#  D3 接口情绪修饰符 (D3 Interface Emotion Modifiers)
#  支持人类情绪模拟，给不同情绪的接口不同的特征
# ═══════════════════════════════════════════════════════════════

import "bootstrap/d3system.hto";

# ═══════════════════════════════════════════════════════════════
#  情绪类型枚举 (Emotion Type Enum)
# ═══════════════════════════════════════════════════════════════

fn D3EmotionNeutral() {
    let e = {};
    e["type"] = "neutral";
    e["intensity"] = 0;
    e["valence"] = 0;
    e["arousal"] = 0;
    e["color"] = [128, 128, 128];
    e["range_modifier"] = 1.0;
    e["response_modifier"] = 1.0;
    e["boundary_behavior"] = "stable";
    e["description"] = "neutral baseline";
    return e;
}

