fn hml_tokenize_whitespace(text) {
    let result = [];
    let word = "";
    let i = 0;
    while (i < len(text)) {
        let ch = substring(text, i, 1);
        if (ch == " " or ch == "\t" or ch == "\n" or ch == "\r") {
            if (word != "") {
                push(result, word);
                word = "";
            }
        } else {
            word = word + ch;
        }
        i = i + 1;
    }
    if (word != "") {
        push(result, word);
    }
    return result;
}

fn hml_tokenize_regex(text, delimiter) {
    let result = [];
    let token = "";
    let i = 0;
    while (i < len(text)) {
        let ch = substring(text, i, 1);
        if (ch == delimiter) {
            push(result, token);
            token = "";
        } else {
            token = token + ch;
        }
        i = i + 1;
    }
    push(result, token);
    return result;
}

fn hml_tokenize_wordpunct(text) {
    let result = [];
    let token = "";
    let i = 0;
    while (i < len(text)) {
        let ch = substring(text, i, 1);
        let is_letter = false;
        let cc = ch;
        if ((cc >= "a" and cc <= "z") or (cc >= "A" and cc <= "Z") or (cc >= "0" and cc <= "9")) {
            is_letter = true;
        }
        if (is_letter) {
            token = token + ch;
        } else {
            if (token != "") {
                push(result, token);
                token = "";
            }
            if (ch != " " and ch != "\t" and ch != "\n" and ch != "\r") {
                push(result, ch);
            }
        }
        i = i + 1;
    }
    if (token != "") {
        push(result, token);
    }
    return result;
}

fn hml_tokenize_sentences(text) {
    let result = [];
    let sentence = "";
    let i = 0;
    while (i < len(text)) {
        let ch = substring(text, i, 1);
        sentence = sentence + ch;
        if (ch == "." or ch == "!" or ch == "?") {
            push(result, sentence);
            sentence = "";
        }
        i = i + 1;
    }
    if (sentence != "") {
        push(result, sentence);
    }
    return result;
}

fn hml_lower_case(tokens) {
    let result = [];
    let i = 0;
    while (i < len(tokens)) {
        let token = tokens[i];
        let lowered = "";
        let j = 0;
        while (j < len(token)) {
            let ch = substring(token, j, 1);
            if (ch >= "A" and ch <= "Z") {
                let code = 0;
                if (ch == "A") { code = 97; }
                if (ch == "B") { code = 98; }
                if (ch == "C") { code = 99; }
                if (ch == "D") { code = 100; }
                if (ch == "E") { code = 101; }
                if (ch == "F") { code = 102; }
                if (ch == "G") { code = 103; }
                if (ch == "H") { code = 104; }
                if (ch == "I") { code = 105; }
                if (ch == "J") { code = 106; }
                if (ch == "K") { code = 107; }
                if (ch == "L") { code = 108; }
                if (ch == "M") { code = 109; }
                if (ch == "N") { code = 110; }
                if (ch == "O") { code = 111; }
                if (ch == "P") { code = 112; }
                if (ch == "Q") { code = 113; }
                if (ch == "R") { code = 114; }
                if (ch == "S") { code = 115; }
                if (ch == "T") { code = 116; }
                if (ch == "U") { code = 117; }
                if (ch == "V") { code = 118; }
                if (ch == "W") { code = 119; }
                if (ch == "X") { code = 120; }
                if (ch == "Y") { code = 121; }
                if (ch == "Z") { code = 122; }
                lowered = lowered + chr(code);
            } else {
                lowered = lowered + ch;
            }
            j = j + 1;
        }
        push(result, lowered);
        i = i + 1;
    }
    return result;
}

fn hml_remove_punctuation(text) {
    let result = "";
    let i = 0;
    while (i < len(text)) {
        let ch = substring(text, i, 1);
        let is_punct = false;
        if (ch == "." or ch == "," or ch == "!" or ch == "?" or ch == ";" or ch == ":") {
            is_punct = true;
        }
        if (ch == "\"" or ch == "'" or ch == "(" or ch == ")" or ch == "[" or ch == "]") {
            is_punct = true;
        }
        if (ch == "-" or ch == "_" or ch == "/" or ch == "\\" or ch == "@" or ch == "#") {
            is_punct = true;
        }
        if (ch == "$" or ch == "%" or ch == "^" or ch == "&" or ch == "*" or ch == "~" or ch == "`") {
            is_punct = true;
        }
        if (is_punct == false) {
            result = result + ch;
        }
        i = i + 1;
    }
    return result;
}

fn hml_remove_stopwords(tokens, stopwords) {
    let result = [];
    let i = 0;
    while (i < len(tokens)) {
        let token = tokens[i];
        let is_stop = false;
        let j = 0;
        while (j < len(stopwords)) {
            if (token == stopwords[j]) {
                is_stop = true;
                break;
            }
            j = j + 1;
        }
        if (is_stop == false) {
            push(result, token);
        }
        i = i + 1;
    }
    return result;
}

fn hml_remove_numbers(tokens) {
    let result = [];
    let i = 0;
    while (i < len(tokens)) {
        let token = tokens[i];
        let is_num = true;
        let j = 0;
        while (j < len(token)) {
            let ch = substring(token, j, 1);
            if (ch < "0" or ch > "9") {
                is_num = false;
                break;
            }
            j = j + 1;
        }
        if (is_num == false) {
            push(result, token);
        }
        i = i + 1;
    }
    return result;
}

fn hml_stem_porter(word) {
    let w = word;
    let n = len(w);
    if (n <= 2) { return w; }
    if (n > 4) {
        let last = substring(w, n - 3, 3);
        if (last == "ing") {
            w = substring(w, 0, n - 3);
            n = len(w);
        }
    }
    if (n > 3) {
        let last = substring(w, n - 2, 2);
        if (last == "ed") {
            w = substring(w, 0, n - 2);
            n = len(w);
        }
    }
    if (n > 1) {
        let last = substring(w, n - 1, 1);
        if (last == "s") {
            w = substring(w, 0, n - 1);
            n = len(w);
        }
    }
    if (n > 3) {
        let last = substring(w, n - 2, 2);
        if (last == "ly" or last == "er") {
            w = substring(w, 0, n - 2);
            n = len(w);
        }
    }
    if (n > 4) {
        let last = substring(w, n - 4, 4);
        if (last == "ness") {
            w = substring(w, 0, n - 4);
            n = len(w);
        }
    }
    if (n > 3) {
        let last = substring(w, n - 3, 3);
        if (last == "est") {
            w = substring(w, 0, n - 3);
            n = len(w);
        }
    }
    return w;
}

fn hml_stem_snowball(word) {
    let w = hml_lower_case([word]);
    w = w[0];
    let n = len(w);
    if (n <= 2) { return w; }
    if (n > 5) {
        let last = substring(w, n - 5, 5);
        if (last == "ement") {
            w = substring(w, 0, n - 5);
            n = len(w);
        }
    }
    if (n > 4) {
        let last = substring(w, n - 4, 4);
        if (last == "ment" or last == "ness" or last == "tion" or last == "ence" or last == "able") {
            w = substring(w, 0, n - 4);
            n = len(w);
        }
    }
    if (n > 3) {
        let last = substring(w, n - 3, 3);
        if (last == "ing" or last == "ion" or last == "ize" or last == "ous" or last == "ive" or last == "ful" or last == "est" or last == "ers") {
            w = substring(w, 0, n - 3);
            n = len(w);
        }
    }
    if (n > 2) {
        let last = substring(w, n - 2, 2);
        if (last == "ed" or last == "ly" or last == "er" or last == "al" or last == "ic") {
            w = substring(w, 0, n - 2);
            n = len(w);
        }
    }
    if (n > 1) {
        let last = substring(w, n - 1, 1);
        if (last == "s") {
            w = substring(w, 0, n - 1);
            n = len(w);
        }
    }
    return w;
}

fn hml_lemmatize(word) {
    let w = hml_lower_case([word]);
    w = w[0];
    let n = len(w);
    if (n <= 2) { return w; }
    if (n > 4) {
        let last = substring(w, n - 4, 4);
        if (last == "ming") { return substring(w, 0, n - 4) + "m"; }
        if (last == "king") { return "king"; }
    }
    if (n > 3) {
        let last = substring(w, n - 3, 3);
        if (last == "ies") { return substring(w, 0, n - 3) + "y"; }
        if (last == "ves") { return substring(w, 0, n - 3) + "f"; }
        if (last == "ing") { return substring(w, 0, n - 3); }
        if (last == "men") { return substring(w, 0, n - 3) + "an"; }
    }
    if (n > 2) {
        let last = substring(w, n - 2, 2);
        if (last == "es") { return substring(w, 0, n - 2); }
        if (last == "ed") { return substring(w, 0, n - 2); }
        if (last == "er") { return substring(w, 0, n - 2); }
        if (last == "ly") { return substring(w, 0, n - 2); }
    }
    if (n > 1) {
        let last = substring(w, n - 1, 1);
        if (last == "s") { return substring(w, 0, n - 1); }
    }
    return w;
}

fn hml_ngrams(tokens, n) {
    let result = [];
    let i = 0;
    while (i + n <= len(tokens)) {
        let gram = [];
        let j = 0;
        while (j < n) {
            push(gram, tokens[i + j]);
            j = j + 1;
        }
        push(result, gram);
        i = i + 1;
    }
    return result;
}

fn hml_skip_grams(tokens, n, skip) {
    let result = [];
    let i = 0;
    while (i + n <= len(tokens)) {
        let gram = [];
        let j = 0;
        let pos = i;
        while (j < n) {
            push(gram, tokens[pos]);
            pos = pos + skip + 1;
            j = j + 1;
        }
        if (pos - skip <= len(tokens)) {
            push(result, gram);
        }
        i = i + 1;
    }
    return result;
}

fn hml_char_ngrams(text, n) {
    let result = [];
    let i = 0;
    while (i + n <= len(text)) {
        push(result, substring(text, i, n));
        i = i + 1;
    }
    return result;
}

fn hml_bag_of_words(docs) {
    let vocab = {};
    let vocab_idx = 0;
    let i = 0;
    while (i < len(docs)) {
        let tokens = hml_tokenize_whitespace(docs[i]);
        let j = 0;
        while (j < len(tokens)) {
            let token = tokens[j];
            if (vocab[token] == nullptr) {
                vocab[token] = vocab_idx;
                vocab_idx = vocab_idx + 1;
            }
            j = j + 1;
        }
        i = i + 1;
    }
    let n_vocab = vocab_idx;
    let result = [];
    i = 0;
    while (i < len(docs)) {
        let row = hml_vector_zeros(n_vocab);
        let tokens = hml_tokenize_whitespace(docs[i]);
        let j = 0;
        while (j < len(tokens)) {
            let idx = vocab[tokens[j]];
            if (idx != nullptr) {
                row[idx] = row[idx] + 1;
            }
            j = j + 1;
        }
        push(result, row);
        i = i + 1;
    }
    return result;
}

fn hml_term_frequency(docs) {
    let bow = hml_bag_of_words(docs);
    let result = [];
    let i = 0;
    while (i < len(bow)) {
        let row = [];
        let total = 0.0;
        let j = 0;
        while (j < len(bow[i])) {
            total = total + bow[i][j];
            j = j + 1;
        }
        if (total == 0.0) { total = 1.0; }
        j = 0;
        while (j < len(bow[i])) {
            push(row, bow[i][j] * 1.0 / total);
            j = j + 1;
        }
        push(result, row);
        i = i + 1;
    }
    return result;
}

fn hml_inverse_document_frequency(docs) {
    let bow = hml_bag_of_words(docs);
    let n_docs = len(docs);
    let n_terms = len(bow[0]);
    let idf = [];
    let j = 0;
    while (j < n_terms) {
        let doc_count = 0;
        let i = 0;
        while (i < n_docs) {
            if (bow[i][j] > 0) {
                doc_count = doc_count + 1;
            }
            i = i + 1;
        }
        if (doc_count == 0) {
            push(idf, 0.0);
        } else {
            push(idf, math_log(n_docs * 1.0 / doc_count));
        }
        j = j + 1;
    }
    return idf;
}

fn hml_tfidf(docs) {
    let tf = hml_term_frequency(docs);
    let idf = hml_inverse_document_frequency(docs);
    let result = [];
    let i = 0;
    while (i < len(tf)) {
        let row = [];
        let j = 0;
        while (j < len(tf[i])) {
            push(row, tf[i][j] * idf[j]);
            j = j + 1;
        }
        push(result, row);
        i = i + 1;
    }
    return result;
}

fn hml_cosine_similarity_text(doc1, doc2) {
    let tokens1 = hml_tokenize_whitespace(doc1);
    let tokens2 = hml_tokenize_whitespace(doc2);
    let vocab = {};
    let i = 0;
    while (i < len(tokens1)) {
        let cnt = vocab[tokens1[i]];
        if (cnt == nullptr) {
            vocab[tokens1[i]] = 1;
        } else {
            vocab[tokens1[i]] = cnt + 1;
        }
        i = i + 1;
    }
    i = 0;
    while (i < len(tokens2)) {
        let cnt = vocab[tokens2[i]];
        if (cnt == nullptr) {
            vocab[tokens2[i]] = 1;
        }
        i = i + 1;
    }
    let keys = dict_keys(vocab);
    let vec1 = [];
    let vec2 = [];
    i = 0;
    while (i < len(keys)) {
        let k = keys[i];
        let c1 = 0;
        let j = 0;
        while (j < len(tokens1)) {
            if (tokens1[j] == k) { c1 = c1 + 1; }
            j = j + 1;
        }
        let c2 = 0;
        j = 0;
        while (j < len(tokens2)) {
            if (tokens2[j] == k) { c2 = c2 + 1; }
            j = j + 1;
        }
        push(vec1, c1 * 1.0);
        push(vec2, c2 * 1.0);
        i = i + 1;
    }
    let dot = hml_vector_dot(vec1, vec2);
    let norm1 = hml_vector_norm(vec1);
    let norm2 = hml_vector_norm(vec2);
    if (norm1 == 0.0 or norm2 == 0.0) { return 0.0; }
    return dot / (norm1 * norm2);
}

fn hml_jaccard_similarity_text(doc1, doc2) {
    let tokens1 = hml_tokenize_whitespace(doc1);
    let tokens2 = hml_tokenize_whitespace(doc2);
    let intersection = 0;
    let union_vals = {};
    let i = 0;
    while (i < len(tokens1)) {
        union_vals[tokens1[i]] = 1;
        i = i + 1;
    }
    i = 0;
    while (i < len(tokens2)) {
        let t = tokens2[i];
        if (union_vals[t] != nullptr) {
            intersection = intersection + 1;
        }
        union_vals[t] = 1;
        i = i + 1;
    }
    let union_count = len(dict_keys(union_vals));
    if (union_count == 0) { return 0.0; }
    return intersection * 1.0 / union_count;
}

fn hml_edit_distance(s1, s2) {
    let m = len(s1);
    let n = len(s2);
    let dp = [];
    let i = 0;
    while (i <= m) {
        let row = [];
        let j = 0;
        while (j <= n) {
            push(row, 0);
            j = j + 1;
        }
        push(dp, row);
        i = i + 1;
    }
    i = 0;
    while (i <= m) {
        dp[i][0] = i;
        i = i + 1;
    }
    let j = 0;
    while (j <= n) {
        dp[0][j] = j;
        j = j + 1;
    }
    i = 1;
    while (i <= m) {
        j = 1;
        while (j <= n) {
            let cost = 1;
            if (substring(s1, i - 1, 1) == substring(s2, j - 1, 1)) {
                cost = 0;
            }
            let min_val = dp[i - 1][j] + 1;
            if (dp[i][j - 1] + 1 < min_val) { min_val = dp[i][j - 1] + 1; }
            if (dp[i - 1][j - 1] + cost < min_val) { min_val = dp[i - 1][j - 1] + cost; }
            dp[i][j] = min_val;
            j = j + 1;
        }
        i = i + 1;
    }
    return dp[m][n];
}

fn hml_word_count(text) {
    let tokens = hml_tokenize_whitespace(text);
    let counts = {};
    let i = 0;
    while (i < len(tokens)) {
        let t = tokens[i];
        let cnt = counts[t];
        if (cnt == nullptr) {
            counts[t] = 1;
        } else {
            counts[t] = cnt + 1;
        }
        i = i + 1;
    }
    return counts;
}

fn hml_char_count(text) {
    let counts = {};
    let i = 0;
    while (i < len(text)) {
        let ch = substring(text, i, 1);
        let cnt = counts[ch];
        if (cnt == nullptr) {
            counts[ch] = 1;
        } else {
            counts[ch] = cnt + 1;
        }
        i = i + 1;
    }
    return counts;
}

fn hml_text_length(text) {
    return len(text);
}

fn hml_word_length(text) {
    let tokens = hml_tokenize_whitespace(text);
    return len(tokens);
}

fn hml_text_clean(text) {
    let t = hml_remove_punctuation(text);
    let lowered = hml_lower_case([t]);
    let result = "";
    let i = 0;
    while (i < len(lowered[0])) {
        let ch = substring(lowered[0], i, 1);
        if (ch != " ") {
            result = result + ch;
        }
        i = i + 1;
    }
    return result;
}

fn hml_text_normalize(text) {
    let result = "";
    let i = 0;
    while (i < len(text)) {
        let ch = substring(text, i, 1);
        if (ch >= "A" and ch <= "Z") {
            let code = 0;
            if (ch == "A") { code = 97; }
            if (ch == "B") { code = 98; }
            if (ch == "C") { code = 99; }
            if (ch == "D") { code = 100; }
            if (ch == "E") { code = 101; }
            if (ch == "F") { code = 102; }
            if (ch == "G") { code = 103; }
            if (ch == "H") { code = 104; }
            if (ch == "I") { code = 105; }
            if (ch == "J") { code = 106; }
            if (ch == "K") { code = 107; }
            if (ch == "L") { code = 108; }
            if (ch == "M") { code = 109; }
            if (ch == "N") { code = 110; }
            if (ch == "O") { code = 111; }
            if (ch == "P") { code = 112; }
            if (ch == "Q") { code = 113; }
            if (ch == "R") { code = 114; }
            if (ch == "S") { code = 115; }
            if (ch == "T") { code = 116; }
            if (ch == "U") { code = 117; }
            if (ch == "V") { code = 118; }
            if (ch == "W") { code = 119; }
            if (ch == "X") { code = 120; }
            if (ch == "Y") { code = 121; }
            if (ch == "Z") { code = 122; }
            result = result + chr(code);
        } else {
            result = result + ch;
        }
        i = i + 1;
    }
    return result;
}

fn hml_text_vectorize(docs, vocabulary) {
    let result = [];
    let i = 0;
    while (i < len(docs)) {
        let row = hml_vector_zeros(len(vocabulary));
        let tokens = hml_tokenize_whitespace(docs[i]);
        let j = 0;
        while (j < len(tokens)) {
            let idx = vocabulary[tokens[j]];
            if (idx != nullptr) {
                row[idx] = row[idx] + 1;
            }
            j = j + 1;
        }
        push(result, row);
        i = i + 1;
    }
    return result;
}

fn hml_build_vocabulary(docs, max_features) {
    let word_counts = {};
    let i = 0;
    while (i < len(docs)) {
        let tokens = hml_tokenize_whitespace(docs[i]);
        let j = 0;
        while (j < len(tokens)) {
            let t = tokens[j];
            let cnt = word_counts[t];
            if (cnt == nullptr) {
                word_counts[t] = 1;
            } else {
                word_counts[t] = cnt + 1;
            }
            j = j + 1;
        }
        i = i + 1;
    }
    let vocab = {};
    let keys = dict_keys(word_counts);
    let sorted = [];
    i = 0;
    while (i < len(keys)) {
        push(sorted, {"word": keys[i], "count": word_counts[keys[i]]});
        i = i + 1;
    }
    let si = 0;
    while (si < len(sorted)) {
        let max_idx = si;
        let sj = si + 1;
        while (sj < len(sorted)) {
            if (sorted[sj]["count"] > sorted[max_idx]["count"]) {
                max_idx = sj;
            }
            sj = sj + 1;
        }
        let tmp = sorted[si];
        sorted[si] = sorted[max_idx];
        sorted[max_idx] = tmp;
        si = si + 1;
    }
    i = 0;
    while (i < len(sorted) and i < max_features) {
        vocab[sorted[i]["word"]] = i;
        i = i + 1;
    }
    return vocab;
}

fn hml_text_pad_sequences(sequences, maxlen) {
    let result = [];
    let i = 0;
    while (i < len(sequences)) {
        let seq = sequences[i];
        let padded = [];
        let j = 0;
        while (j < maxlen) {
            if (j < len(seq)) {
                push(padded, seq[j]);
            } else {
                push(padded, 0);
            }
            j = j + 1;
        }
        push(result, padded);
        i = i + 1;
    }
    return result;
}

fn hml_text_truncate_sequences(sequences, maxlen) {
    let result = [];
    let i = 0;
    while (i < len(sequences)) {
        let seq = sequences[i];
        let truncated = [];
        let j = 0;
        while (j < maxlen and j < len(seq)) {
            push(truncated, seq[j]);
            j = j + 1;
        }
        push(result, truncated);
        i = i + 1;
    }
    return result;
}

fn hml_text_one_hot(text, n) {
    let result = hml_vector_zeros(n);
    let i = 0;
    while (i < len(text)) {
        let ch = substring(text, i, 1);
        let h = 0;
        let j = 0;
        while (j < len(ch)) {
            h = h + ch[j];
            j = j + 1;
        }
        let idx = h % n;
        result[idx] = 1.0;
        i = i + 1;
    }
    return result;
}

fn hml_hashing_trick(text, n) {
    let result = hml_vector_zeros(n);
    let tokens = hml_tokenize_whitespace(text);
    let i = 0;
    while (i < len(tokens)) {
        let token = tokens[i];
        let h = 0;
        let j = 0;
        while (j < len(token)) {
            let ch = substring(token, j, 1);
            let k = 0;
            while (k < len(ch)) {
                h = ((h * 31) + ch[k]) % 2147483647;
                k = k + 1;
            }
            j = j + 1;
        }
        let idx = h % n;
        result[idx] = result[idx] + 1.0;
        i = i + 1;
    }
    return result;
}

fn hml_text_to_sequence(text, word_index) {
    let tokens = hml_tokenize_whitespace(text);
    let result = [];
    let i = 0;
    while (i < len(tokens)) {
        let idx = word_index[tokens[i]];
        if (idx != nullptr) {
            push(result, idx);
        }
        i = i + 1;
    }
    return result;
}

fn hml_sequence_to_text(sequence, index_word) {
    let result = "";
    let i = 0;
    while (i < len(sequence)) {
        let word = index_word[sequence[i]];
        if (word != nullptr) {
            if (result != "") {
                result = result + " ";
            }
            result = result + word;
        }
        i = i + 1;
    }
    return result;
}

fn hml_bleu_score(reference, candidate, n) {
    let ref_tokens = hml_tokenize_whitespace(reference);
    let cand_tokens = hml_tokenize_whitespace(candidate);
    let ref_ngrams = hml_ngrams(ref_tokens, n);
    let cand_ngrams = hml_ngrams(cand_tokens, n);
    let match_count = 0;
    let i = 0;
    while (i < len(cand_ngrams)) {
        let j = 0;
        while (j < len(ref_ngrams)) {
            let match = true;
            let k = 0;
            while (k < n) {
                if (cand_ngrams[i][k] != ref_ngrams[j][k]) {
                    match = false;
                    break;
                }
                k = k + 1;
            }
            if (match) {
                match_count = match_count + 1;
                break;
            }
            j = j + 1;
        }
        i = i + 1;
    }
    if (len(cand_ngrams) == 0) { return 0.0; }
    let precision = match_count * 1.0 / len(cand_ngrams);
    let bp = 1.0;
    if (len(cand_tokens) < len(ref_tokens)) {
        bp = math_exp(1.0 - len(ref_tokens) * 1.0 / len(cand_tokens));
    }
    return bp * precision;
}

fn hml_rouge_n(reference, candidate, n) {
    let ref_tokens = hml_tokenize_whitespace(reference);
    let cand_tokens = hml_tokenize_whitespace(candidate);
    let ref_ngrams = hml_ngrams(ref_tokens, n);
    let cand_ngrams = hml_ngrams(cand_tokens, n);
    let match_count = 0;
    let i = 0;
    while (i < len(cand_ngrams)) {
        let j = 0;
        while (j < len(ref_ngrams)) {
            let match = true;
            let k = 0;
            while (k < n) {
                if (cand_ngrams[i][k] != ref_ngrams[j][k]) {
                    match = false;
                    break;
                }
                k = k + 1;
            }
            if (match) {
                match_count = match_count + 1;
                break;
            }
            j = j + 1;
        }
        i = i + 1;
    }
    if (len(ref_ngrams) == 0) { return 0.0; }
    return match_count * 1.0 / len(ref_ngrams);
}

fn hml_rouge_l(reference, candidate) {
    let ref_tokens = hml_tokenize_whitespace(reference);
    let cand_tokens = hml_tokenize_whitespace(candidate);
    let m = len(ref_tokens);
    let n = len(cand_tokens);
    if (m == 0 or n == 0) { return 0.0; }
    let dp = [];
    let i = 0;
    while (i <= m) {
        let row = [];
        let j = 0;
        while (j <= n) {
            push(row, 0);
            j = j + 1;
        }
        push(dp, row);
        i = i + 1;
    }
    i = 1;
    while (i <= m) {
        let j = 1;
        while (j <= n) {
            if (ref_tokens[i - 1] == cand_tokens[j - 1]) {
                dp[i][j] = dp[i - 1][j - 1] + 1;
            } else {
                let mx = dp[i - 1][j];
                if (dp[i][j - 1] > mx) { mx = dp[i][j - 1]; }
                dp[i][j] = mx;
            }
            j = j + 1;
        }
        i = i + 1;
    }
    let lcs = dp[m][n];
    let recall = lcs * 1.0 / m;
    let precision = lcs * 1.0 / n;
    if (recall + precision == 0.0) { return 0.0; }
    return 2.0 * recall * precision / (recall + precision);
}

fn hml_word_error_rate(reference, hypothesis) {
    let ref_tokens = hml_tokenize_whitespace(reference);
    let hyp_tokens = hml_tokenize_whitespace(hypothesis);
    let m = len(ref_tokens);
    let n = len(hyp_tokens);
    if (m == 0) { return 0.0; }
    let dp = [];
    let i = 0;
    while (i <= m) {
        let row = [];
        let j = 0;
        while (j <= n) {
            push(row, 0);
            j = j + 1;
        }
        push(dp, row);
        i = i + 1;
    }
    i = 0;
    while (i <= m) {
        dp[i][0] = i;
        i = i + 1;
    }
    let j = 0;
    while (j <= n) {
        dp[0][j] = j;
        j = j + 1;
    }
    i = 1;
    while (i <= m) {
        j = 1;
        while (j <= n) {
            let cost = 1;
            if (ref_tokens[i - 1] == hyp_tokens[j - 1]) {
                cost = 0;
            }
            let min_val = dp[i - 1][j] + 1;
            if (dp[i][j - 1] + 1 < min_val) { min_val = dp[i][j - 1] + 1; }
            if (dp[i - 1][j - 1] + cost < min_val) { min_val = dp[i - 1][j - 1] + cost; }
            dp[i][j] = min_val;
            j = j + 1;
        }
        i = i + 1;
    }
    return dp[m][n] * 1.0 / m;
}

fn hml_text_confusion_chars(ref, hyp) {
    let m = len(ref);
    let n = len(hyp);
    let dp = [];
    let i = 0;
    while (i <= m) {
        let row = [];
        let j = 0;
        while (j <= n) {
            push(row, 0);
            j = j + 1;
        }
        push(dp, row);
        i = i + 1;
    }
    i = 0;
    while (i <= m) {
        dp[i][0] = i;
        i = i + 1;
    }
    let j = 0;
    while (j <= n) {
        dp[0][j] = j;
        j = j + 1;
    }
    i = 1;
    while (i <= m) {
        j = 1;
        while (j <= n) {
            let cost = 1;
            if (substring(ref, i - 1, 1) == substring(hyp, j - 1, 1)) {
                cost = 0;
            }
            let min_val = dp[i - 1][j] + 1;
            if (dp[i][j - 1] + 1 < min_val) { min_val = dp[i][j - 1] + 1; }
            if (dp[i - 1][j - 1] + cost < min_val) { min_val = dp[i - 1][j - 1] + cost; }
            dp[i][j] = min_val;
            j = j + 1;
        }
        i = i + 1;
    }
    let substitutions = 0;
    let insertions = 0;
    let deletions = 0;
    i = m;
    j = n;
    while (i > 0 or j > 0) {
        if (i > 0 and j > 0 and substring(ref, i - 1, 1) == substring(hyp, j - 1, 1)) {
            i = i - 1;
            j = j - 1;
        } else if (i > 0 and j > 0 and dp[i][j] == dp[i - 1][j - 1] + 1) {
            substitutions = substitutions + 1;
            i = i - 1;
            j = j - 1;
        } else if (i > 0 and dp[i][j] == dp[i - 1][j] + 1) {
            deletions = deletions + 1;
            i = i - 1;
        } else {
            insertions = insertions + 1;
            j = j - 1;
        }
    }
    return {"substitutions": substitutions, "insertions": insertions, "deletions": deletions, "distance": dp[m][n]};
}
# ═══════════════════════════════════════════════════════════════════════════
# SECTION 21: Pipelines
# ═══════════════════════════════════════════════════════════════════════════

class Pipeline {
    let steps = [];
    let fitted = false;

    fn init_pipeline(steps) {
        self.steps = steps;
        self.fitted = false;
        return 0;
    }

    fn fit(X, y) {
        let X_current = X;
        let i = 0;
        while (i < len(self.steps) - 1) {
            let step = self.steps[i];
            let transformer = step[1];
            let fit_method = transformer["fit"];
            if (fit_method != nullptr) {
                transformer["fit"](X_current, y);
            }
            let transform_method = transformer["transform"];
            if (transform_method != nullptr) {
                X_current = transformer["transform"](X_current);
            }
            i = i + 1;
        }
        let last_step = self.steps[len(self.steps) - 1];
        let last_transformer = last_step[1];
        let last_fit = last_transformer["fit"];
        if (last_fit != nullptr) {
            last_transformer["fit"](X_current, y);
        }
        self.fitted = true;
        return 0;
    }

    fn transform(X) {
        let X_current = X;
        let i = 0;
        while (i < len(self.steps) - 1) {
            let transformer = self.steps[i][1];
            let transform_method = transformer["transform"];
            if (transform_method != nullptr) {
                X_current = transformer["transform"](X_current);
            }
            i = i + 1;
        }
        let last_step = self.steps[len(self.steps) - 1];
        let last_transformer = last_step[1];
        let last_transform = last_transformer["transform"];
        if (last_transform != nullptr) {
            X_current = last_transformer["transform"](X_current);
        }
        return X_current;
    }

    fn fit_transform(X, y) {
        self.fit(X, y);
        return self.transform(X);
    }

    fn predict(X) {
        let X_transformed = self.transform(X);
        let last_step = self.steps[len(self.steps) - 1];
        let last_transformer = last_step[1];
        let predict_method = last_transformer["predict"];
        if (predict_method != nullptr) {
            return last_transformer["predict"](X_transformed);
        }
        return [];
    }

    fn score(X, y) {
        let y_pred = self.predict(X);
        return accuracy_score(y, y_pred);
    }
}

class FeatureUnion {
    let transformers = [];
    let fitted = false;

    fn init_feature_union(transformers) {
        self.transformers = transformers;
        self.fitted = false;
        return 0;
    }

    fn fit(X, y) {
        let i = 0;
        while (i < len(self.transformers)) {
            let transformer = self.transformers[i][1];
            let fit_method = transformer["fit"];
            if (fit_method != nullptr) {
                transformer["fit"](X, y);
            }
            i = i + 1;
        }
        self.fitted = true;
        return 0;
    }

    fn transform(X) {
        let all_outputs = [];
        let i = 0;
        while (i < len(self.transformers)) {
            let transformer = self.transformers[i][1];
            let transform_method = transformer["transform"];
            if (transform_method != nullptr) {
                let output = transformer["transform"](X);
                push(all_outputs, output);
            }
            i = i + 1;
        }
        let n_samples = len(X);
        let result = [];
        let s = 0;
        while (s < n_samples) {
            let row = [];
            let t = 0;
            while (t < len(all_outputs)) {
                let out_row = all_outputs[t][s];
                let f = 0;
                while (f < len(out_row)) {
                    push(row, out_row[f]);
                    f = f + 1;
                }
                t = t + 1;
            }
            push(result, row);
            s = s + 1;
        }
        return result;
    }

    fn fit_transform(X, y) {
        self.fit(X, y);
        return self.transform(X);
    }
}

fn hml_make_pipeline(steps) {
    let pipeline = new Pipeline();
    pipeline.init_pipeline(steps);
    return pipeline;
}

fn hml_make_union(transformers) {
    let union_obj = new FeatureUnion();
    union_obj.init_feature_union(transformers);
    return union_obj;
}

class ColumnTransformer {
    let transformers = [];
    let remainder = "drop";
    let fitted = false;
    let column_indices = [];

    fn init_ct(transformers, remainder) {
        self.transformers = transformers;
        if (remainder != nullptr) { self.remainder = remainder; }
        self.fitted = false;
        self.column_indices = [];
        return 0;
    }

    fn fit(X, y) {
        self.column_indices = [];
        let i = 0;
        while (i < len(self.transformers)) {
            let t = self.transformers[i];
            let transformer = t[1];
            let columns = t[2];
            let fit_method = transformer["fit"];
            if (fit_method != nullptr) {
                let subset = [];
                let r = 0;
                while (r < len(X)) {
                    let row = [];
                    let c = 0;
                    while (c < len(columns)) {
                        push(row, X[r][columns[c]]);
                        c = c + 1;
                    }
                    push(subset, row);
                    r = r + 1;
                }
                transformer["fit"](subset, y);
            }
            push(self.column_indices, columns);
            i = i + 1;
        }
        self.fitted = true;
        return 0;
    }

    fn transform(X) {
        let n = len(X);
        let all_outputs = [];
        let i = 0;
        while (i < len(self.transformers)) {
            let transformer = self.transformers[i][1];
            let columns = self.column_indices[i];
            let subset = [];
            let r = 0;
            while (r < n) {
                let row = [];
                let c = 0;
                while (c < len(columns)) {
                    push(row, X[r][columns[c]]);
                    c = c + 1;
                }
                push(subset, row);
                r = r + 1;
            }
            let transform_method = transformer["transform"];
            if (transform_method != nullptr) {
                push(all_outputs, transformer["transform"](subset));
            } else {
                push(all_outputs, subset);
            }
            i = i + 1;
        }
        let result_mat = [];
        let r = 0;
        while (r < n) {
            let row = [];
            let t = 0;
            while (t < len(all_outputs)) {
                let out_row = all_outputs[t][r];
                let f = 0;
                while (f < len(out_row)) {
                    push(row, out_row[f]);
                    f = f + 1;
                }
                t = t + 1;
            }
            push(result_mat, row);
            r = r + 1;
        }
        return result_mat;
    }

    fn fit_transform(X, y) {
        self.fit(X, y);
        return self.transform(X);
    }
}

fn hml_column_transformer(transformers, remainder) {
    let ct = new ColumnTransformer();
    ct.init_ct(transformers, remainder);
    return ct;
}

class FunctionTransformer {
    let func = nullptr;
    let inverse_func = nullptr;

    fn init_ft(func, inverse_func) {
        self.func = func;
        self.inverse_func = inverse_func;
        return 0;
    }

    fn fit(X, y) {
        return 0;
    }

    fn transform(X) {
        return self.func(X);
    }

    fn fit_transform(X, y) {
        return self.transform(X);
    }

    fn inverse_transform(X) {
        if (self.inverse_func != nullptr) {
            return self.inverse_func(X);
        }
        return X;
    }
}

fn hml_function_transformer(func, inverse_func) {
    let ft = new FunctionTransformer();
    ft.init_ft(func, inverse_func);
    return ft;
}

class TransformedTargetRegressor {
    let regressor = nullptr;
    let transformer = nullptr;
    let fitted = false;

    fn init_ttr(regressor, transformer) {
        self.regressor = regressor;
        self.transformer = transformer;
        self.fitted = false;
        return 0;
    }

    fn fit(X, y) {
        let transform_method = self.transformer["transform"];
        let y_transformed = y;
        if (transform_method != nullptr) {
            y_transformed = self.transformer["transform"](y);
        }
        self.regressor["fit"](X, y_transformed);
        self.fitted = true;
        return 0;
    }

    fn predict(X) {
        let y_pred = self.regressor["predict"](X);
        let inverse_method = self.transformer["inverse_transform"];
        if (inverse_method != nullptr) {
            return self.transformer["inverse_transform"](y_pred);
        }
        return y_pred;
    }

    fn score(X, y) {
        let y_pred = self.predict(X);
        return r2_score(y, y_pred);
    }
}

fn hml_transformed_target_regressor(regressor, transformer) {
    let ttr = new TransformedTargetRegressor();
    ttr.init_ttr(regressor, transformer);
    return ttr;
