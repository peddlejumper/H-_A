# ── AdaMaxOptimizer ──
class AdaMaxOptimizer {
    let lr = 0.002;
    let beta1 = 0.9;
    let beta2 = 0.999;
    let eps = 0.00000001;
    let m = [];
    let u = [];
    let t = 0;

    fn init_adamax(lr, beta1, beta2) {
        self.lr = lr;
        if (beta1 == nullptr) { self.beta1 = 0.9; }
        else { self.beta1 = beta1; }
        if (beta2 == nullptr) { self.beta2 = 0.999; }
        else { self.beta2 = beta2; }
        self.m = [];
        self.u = [];
        self.t = 0;
        return 0;
    }

    fn update(params, grads) {
        self.t = self.t + 1;
        if (len(self.m) == 0) {
            let i = 0;
            while (i < len(params)) { push(self.m, []); push(self.u, []); i = i + 1; }
            i = 0;
            while (i < len(params)) {
                let j = 0;
                while (j < len(params[i])) { push(self.m[i], 0.0); push(self.u[i], 0.0); j = j + 1; }
                i = i + 1;
            }
        }
        let i = 0;
        while (i < len(params)) {
            let j = 0;
            while (j < len(params[i])) {
                self.m[i][j] = self.beta1 * self.m[i][j] + (1.0 - self.beta1) * grads[i][j];
                let u_val = self.beta2 * self.u[i][j];
                let g_abs = grads[i][j];
                if (g_abs < 0) { g_abs = -g_abs; }
                if (g_abs > u_val) { u_val = g_abs; }
                self.u[i][j] = u_val;
                let m_hat = self.m[i][j] / (1.0 - math_pow(self.beta1, self.t));
                params[i][j] = params[i][j] - self.lr * m_hat / (self.u[i][j] + self.eps);
                j = j + 1;
            }
            i = i + 1;
        }
        return params;
    }
}

# ── NadamOptimizer ──
class NadamOptimizer {
    let lr = 0.002;
    let beta1 = 0.9;
    let beta2 = 0.999;
    let eps = 0.00000001;
    let m = [];
    let v = [];
    let t = 0;

    fn init_nadam(lr, beta1, beta2) {
        self.lr = lr;
        if (beta1 == nullptr) { self.beta1 = 0.9; }
        else { self.beta1 = beta1; }
        if (beta2 == nullptr) { self.beta2 = 0.999; }
        else { self.beta2 = beta2; }
        self.m = [];
        self.v = [];
        self.t = 0;
        return 0;
    }

    fn update(params, grads) {
        self.t = self.t + 1;
        if (len(self.m) == 0) {
            let i = 0;
            while (i < len(params)) { push(self.m, []); push(self.v, []); i = i + 1; }
            i = 0;
            while (i < len(params)) {
                let j = 0;
                while (j < len(params[i])) { push(self.m[i], 0.0); push(self.v[i], 0.0); j = j + 1; }
                i = i + 1;
            }
        }
        let i = 0;
        while (i < len(params)) {
            let j = 0;
            while (j < len(params[i])) {
                self.m[i][j] = self.beta1 * self.m[i][j] + (1.0 - self.beta1) * grads[i][j];
                self.v[i][j] = self.beta2 * self.v[i][j] + (1.0 - self.beta2) * grads[i][j] * grads[i][j];
                let m_hat = self.m[i][j] / (1.0 - math_pow(self.beta1, self.t));
                let v_hat = self.v[i][j] / (1.0 - math_pow(self.beta2, self.t));
                let m_nadam = self.beta1 * m_hat + (1.0 - self.beta1) * grads[i][j] / (1.0 - math_pow(self.beta1, self.t));
                params[i][j] = params[i][j] - self.lr * m_nadam / (math_sqrt(v_hat) + self.eps);
                j = j + 1;
            }
            i = i + 1;
        }
        return params;
    }
}

# ── RAdamOptimizer ──
class RAdamOptimizer {
    let lr = 0.001;
    let beta1 = 0.9;
    let beta2 = 0.999;
    let eps = 0.00000001;
    let m = [];
    let v = [];
    let t = 0;

    fn init_radam(lr, beta1, beta2) {
        self.lr = lr;
        if (beta1 == nullptr) { self.beta1 = 0.9; }
        else { self.beta1 = beta1; }
        if (beta2 == nullptr) { self.beta2 = 0.999; }
        else { self.beta2 = beta2; }
        self.m = [];
        self.v = [];
        self.t = 0;
        return 0;
    }

    fn update(params, grads) {
        self.t = self.t + 1;
        if (len(self.m) == 0) {
            let i = 0;
            while (i < len(params)) { push(self.m, []); push(self.v, []); i = i + 1; }
            i = 0;
            while (i < len(params)) {
                let j = 0;
                while (j < len(params[i])) { push(self.m[i], 0.0); push(self.v[i], 0.0); j = j + 1; }
                i = i + 1;
            }
        }
        let rho_inf = 2.0 / (1.0 - self.beta2) - 1.0;
        let rho_t = rho_inf - 2.0 * self.t * math_pow(self.beta2, self.t) / (1.0 - math_pow(self.beta2, self.t));
        let i = 0;
        while (i < len(params)) {
            let j = 0;
            while (j < len(params[i])) {
                self.m[i][j] = self.beta1 * self.m[i][j] + (1.0 - self.beta1) * grads[i][j];
                self.v[i][j] = self.beta2 * self.v[i][j] + (1.0 - self.beta2) * grads[i][j] * grads[i][j];
                let m_hat = self.m[i][j] / (1.0 - math_pow(self.beta1, self.t));
                if (rho_t > 4.0) {
                    let v_hat = self.v[i][j] / (1.0 - math_pow(self.beta2, self.t));
                    let r = math_sqrt((rho_t - 4.0) * (rho_t - 2.0) * rho_inf / ((rho_inf - 4.0) * (rho_inf - 2.0) * rho_t));
                    params[i][j] = params[i][j] - self.lr * r * m_hat / (math_sqrt(v_hat) + self.eps);
                } else {
                    params[i][j] = params[i][j] - self.lr * m_hat;
                }
                j = j + 1;
            }
            i = i + 1;
        }
        return params;
    }
}

# ── RangerOptimizer ──
class RangerOptimizer {
    let radam = nullptr;
    let lookahead_alpha = 0.5;
    let lookahead_k = 6;
    let slow_params = [];
    let step = 0;

    fn init_ranger(lr, alpha, k) {
        self.radam = new RAdamOptimizer();
        self.radam.init_radam(lr, 0.9, 0.999);
        if (alpha == nullptr) { self.lookahead_alpha = 0.5; }
        else { self.lookahead_alpha = alpha; }
        if (k == nullptr) { self.lookahead_k = 6; }
        else { self.lookahead_k = k; }
        self.slow_params = [];
        self.step = 0;
        return 0;
    }

    fn update(params, grads) {
        self.step = self.step + 1;
        if (len(self.slow_params) == 0) {
            let i = 0;
            while (i < len(params)) {
                let row = [];
                let j = 0;
                while (j < len(params[i])) { push(row, params[i][j]); j = j + 1; }
                push(self.slow_params, row);
                i = i + 1;
            }
        }
        params = self.radam.update(params, grads);
        if (self.step % self.lookahead_k == 0) {
            let i = 0;
            while (i < len(params)) {
                let j = 0;
                while (j < len(params[i])) {
                    self.slow_params[i][j] = self.slow_params[i][j] + self.lookahead_alpha * (params[i][j] - self.slow_params[i][j]);
                    params[i][j] = self.slow_params[i][j];
                    j = j + 1;
                }
                i = i + 1;
            }
        }
        return params;
    }
}

# ── SGDWMomentum ──
class SGDWMomentum {
    let lr = 0.01;
    let momentum = 0.9;
    let weight_decay = 0.0005;
    let velocity = [];

    fn init_sgdw(lr, momentum, weight_decay) {
        self.lr = lr;
        if (momentum == nullptr) { self.momentum = 0.9; }
        else { self.momentum = momentum; }
        if (weight_decay == nullptr) { self.weight_decay = 0.0005; }
        else { self.weight_decay = weight_decay; }
        self.velocity = [];
        return 0;
    }

    fn update(params, grads) {
        if (len(self.velocity) == 0) {
            let i = 0;
            while (i < len(params)) { push(self.velocity, []); i = i + 1; }
            i = 0;
            while (i < len(params)) {
                let j = 0;
                while (j < len(params[i])) { push(self.velocity[i], 0.0); j = j + 1; }
                i = i + 1;
            }
        }
        let i = 0;
        while (i < len(params)) {
            let j = 0;
            while (j < len(params[i])) {
                params[i][j] = params[i][j] - self.lr * self.weight_decay * params[i][j];
                self.velocity[i][j] = self.momentum * self.velocity[i][j] + self.lr * grads[i][j];
                params[i][j] = params[i][j] - self.velocity[i][j];
                j = j + 1;
            }
            i = i + 1;
        }
        return params;
    }
}

# ── NovogradOptimizer ──
class NovogradOptimizer {
    let lr = 0.01;
    let beta1 = 0.9;
    let beta2 = 0.999;
    let eps = 0.00000001;
    let weight_decay = 0.0;
    let m = [];
    let v = [];
    let t = 0;

    fn init_novograd(lr, beta1, beta2, weight_decay) {
        self.lr = lr;
        if (beta1 == nullptr) { self.beta1 = 0.9; }
        else { self.beta1 = beta1; }
        if (beta2 == nullptr) { self.beta2 = 0.999; }
        else { self.beta2 = beta2; }
        if (weight_decay == nullptr) { self.weight_decay = 0.0; }
        else { self.weight_decay = weight_decay; }
        self.m = [];
        self.v = [];
        self.t = 0;
        return 0;
    }

    fn update(params, grads) {
        self.t = self.t + 1;
        if (len(self.m) == 0) {
            let i = 0;
            while (i < len(params)) { push(self.m, []); push(self.v, []); i = i + 1; }
            i = 0;
            while (i < len(params)) {
                let j = 0;
                while (j < len(params[i])) { push(self.m[i], 0.0); push(self.v[i], 0.0); j = j + 1; }
                i = i + 1;
            }
        }
        let i = 0;
        while (i < len(params)) {
            let j = 0;
            while (j < len(params[i])) {
                self.m[i][j] = self.beta1 * self.m[i][j] + (1.0 - self.beta1) * grads[i][j];
                self.v[i][j] = self.beta2 * self.v[i][j] + (1.0 - self.beta2) * grads[i][j] * grads[i][j];
                let m_hat = self.m[i][j] / (1.0 - math_pow(self.beta1, self.t));
                let v_hat = self.v[i][j] / (1.0 - math_pow(self.beta2, self.t));
                params[i][j] = params[i][j] - self.lr * (m_hat / (math_sqrt(v_hat) + self.eps) + self.weight_decay * params[i][j]);
                j = j + 1;
            }
            i = i + 1;
        }
        return params;
    }
}

# ── LARS ──
class LARS {
    let lr = 0.01;
    let momentum = 0.9;
    let weight_decay = 0.0005;
    let trust_coef = 0.001;
    let eps = 0.00000001;
    let velocity = [];

    fn init_lars(lr, momentum, weight_decay, trust_coef) {
        self.lr = lr;
        if (momentum == nullptr) { self.momentum = 0.9; }
        else { self.momentum = momentum; }
        if (weight_decay == nullptr) { self.weight_decay = 0.0005; }
        else { self.weight_decay = weight_decay; }
        if (trust_coef == nullptr) { self.trust_coef = 0.001; }
        else { self.trust_coef = trust_coef; }
        self.velocity = [];
        return 0;
    }

    fn update(params, grads) {
        if (len(self.velocity) == 0) {
            let i = 0;
            while (i < len(params)) { push(self.velocity, []); i = i + 1; }
            i = 0;
            while (i < len(params)) {
                let j = 0;
                while (j < len(params[i])) { push(self.velocity[i], 0.0); j = j + 1; }
                i = i + 1;
            }
        }
        let i = 0;
        while (i < len(params)) {
            let p_norm = 0.0;
            let g_norm = 0.0;
            let j = 0;
            while (j < len(params[i])) {
                p_norm = p_norm + params[i][j] * params[i][j];
                g_norm = g_norm + grads[i][j] * grads[i][j];
                j = j + 1;
            }
            p_norm = math_sqrt(p_norm);
            g_norm = math_sqrt(g_norm);
            let lr_local = self.lr;
            if (p_norm > 0 and g_norm > 0) {
                lr_local = self.lr * self.trust_coef * p_norm / (g_norm + self.weight_decay * p_norm + self.eps);
            }
            j = 0;
            while (j < len(params[i])) {
                self.velocity[i][j] = self.momentum * self.velocity[i][j] + lr_local * (grads[i][j] + self.weight_decay * params[i][j]);
                params[i][j] = params[i][j] - self.velocity[i][j];
                j = j + 1;
            }
            i = i + 1;
        }
        return params;
    }
}

# ── LARSMOptimizer ──
class LARSMOptimizer {
    let lars = nullptr;

    fn init_larsm(lr, momentum, weight_decay) {
        self.lars = new LARS();
        self.lars.init_lars(lr, momentum, weight_decay, 0.001);
        return 0;
    }

    fn update(params, grads) {
        return self.lars.update(params, grads);
    }
}

# ── LambOptimizerWrapper ──
class LambOptimizerWrapper {
    let lr = 0.001;
    let beta1 = 0.9;
    let beta2 = 0.999;
    let eps = 0.00000001;
    let weight_decay = 0.01;
    let m = [];
    let v = [];
    let t = 0;

    fn init_lamb(lr, beta1, beta2, weight_decay) {
        self.lr = lr;
        if (beta1 == nullptr) { self.beta1 = 0.9; }
        else { self.beta1 = beta1; }
        if (beta2 == nullptr) { self.beta2 = 0.999; }
        else { self.beta2 = beta2; }
        if (weight_decay == nullptr) { self.weight_decay = 0.01; }
        else { self.weight_decay = weight_decay; }
        self.m = [];
        self.v = [];
        self.t = 0;
        return 0;
    }

    fn update(params, grads) {
        self.t = self.t + 1;
        if (len(self.m) == 0) {
            let i = 0;
            while (i < len(params)) { push(self.m, []); push(self.v, []); i = i + 1; }
            i = 0;
            while (i < len(params)) {
                let j = 0;
                while (j < len(params[i])) { push(self.m[i], 0.0); push(self.v[i], 0.0); j = j + 1; }
                i = i + 1;
            }
        }
        let i = 0;
        while (i < len(params)) {
            let j = 0;
            while (j < len(params[i])) {
                self.m[i][j] = self.beta1 * self.m[i][j] + (1.0 - self.beta1) * grads[i][j];
                self.v[i][j] = self.beta2 * self.v[i][j] + (1.0 - self.beta2) * grads[i][j] * grads[i][j];
                let m_hat = self.m[i][j] / (1.0 - math_pow(self.beta1, self.t));
                let v_hat = self.v[i][j] / (1.0 - math_pow(self.beta2, self.t));
                let update = m_hat / (math_sqrt(v_hat) + self.eps) + self.weight_decay * params[i][j];
                let p_norm = params[i][j];
                if (p_norm < 0) { p_norm = -p_norm; }
                let u_norm = update;
                if (u_norm < 0) { u_norm = -u_norm; }
                let ratio = 1.0;
                if (p_norm > 0 and u_norm > 0) { ratio = p_norm / u_norm; }
                if (ratio > 10.0) { ratio = 10.0; }
                params[i][j] = params[i][j] - self.lr * ratio * update;
                j = j + 1;
            }
            i = i + 1;
        }
        return params;
    }
}

# ── AdaBoundOptimizer ──
class AdaBoundOptimizer {
    let lr = 0.001;
    let beta1 = 0.9;
    let beta2 = 0.999;
    let eps = 0.00000001;
    let final_lr = 0.1;
    let gamma_factor = 0.001;
    let m = [];
    let v = [];
    let t = 0;

    fn init_adabound(lr, final_lr, gamma_factor) {
        self.lr = lr;
        if (final_lr == nullptr) { self.final_lr = 0.1; }
        else { self.final_lr = final_lr; }
        if (gamma_factor == nullptr) { self.gamma_factor = 0.001; }
        else { self.gamma_factor = gamma_factor; }
        self.m = [];
        self.v = [];
        self.t = 0;
        return 0;
    }

    fn update(params, grads) {
        self.t = self.t + 1;
        if (len(self.m) == 0) {
            let i = 0;
            while (i < len(params)) { push(self.m, []); push(self.v, []); i = i + 1; }
            i = 0;
            while (i < len(params)) {
                let j = 0;
                while (j < len(params[i])) { push(self.m[i], 0.0); push(self.v[i], 0.0); j = j + 1; }
                i = i + 1;
            }
        }
        let i = 0;
        while (i < len(params)) {
            let j = 0;
            while (j < len(params[i])) {
                self.m[i][j] = self.beta1 * self.m[i][j] + (1.0 - self.beta1) * grads[i][j];
                self.v[i][j] = self.beta2 * self.v[i][j] + (1.0 - self.beta2) * grads[i][j] * grads[i][j];
                let m_hat = self.m[i][j] / (1.0 - math_pow(self.beta1, self.t));
                let v_hat = self.v[i][j] / (1.0 - math_pow(self.beta2, self.t));
                let step_size = 1.0 / (math_sqrt(v_hat) + self.eps);
                let lower = self.final_lr * (1.0 - 1.0 / (self.gamma_factor * self.t + 1.0));
                let upper = self.final_lr * (1.0 + 1.0 / (self.gamma_factor * self.t + 1.0));
                if (step_size < lower) { step_size = lower; }
                if (step_size > upper) { step_size = upper; }
                params[i][j] = params[i][j] - self.lr * step_size * m_hat;
                j = j + 1;
            }
            i = i + 1;
        }
        return params;
    }
}

