    }

    fn set_params(params) {
        return 0;
    }
}

# ── MetaEstimator ──
class MetaEstimator {
    let base_estimator = nullptr;

    fn init_meta_estimator(base_estimator) {
        self.base_estimator = base_estimator;
        return 0;
    }

    fn fit(X, y) {
        if (self.base_estimator != nullptr) {
            self.base_estimator["fit"](X, y);
        }
        return 0;
    }

    fn predict(X) {
        if (self.base_estimator != nullptr) {
            return self.base_estimator["predict"](X);
        }
        return [];
    }

    fn score(X, y) {
        if (self.base_estimator != nullptr and self.base_estimator["score"] != nullptr) {
            return self.base_estimator["score"](X, y);
        }
        return 0.0;
    }
}

# ── CalibratedClassifier ──
class CalibratedClassifier {
    let base_estimator = nullptr;
    let method = "sigmoid";
    let params = [];

    fn init_calibrated_clf(base_estimator, method) {
        self.base_estimator = base_estimator;
        if (method != nullptr) { self.method = method; }
        self.params = [];
        return 0;
    }

    fn fit(X, y) {
        if (self.base_estimator != nullptr) {
            self.base_estimator["fit"](X, y);
        }
        let raw_preds = self.base_estimator["predict"](X);
        let pos = 0;
        let neg = 0;
        let i = 0;
        while (i < len(raw_preds)) {
            if (raw_preds[i] == y[i]) { pos = pos + 1; }
            else { neg = neg + 1; }
            i = i + 1;
        }
        let total = pos + neg;
        if (total > 0) { self.params = [pos * 1.0 / total, neg * 1.0 / total]; }
        return 0;
    }

    fn predict_proba(X) {
        let raw_preds = self.base_estimator["predict"](X);
        let probs = [];
        let i = 0;
        while (i < len(raw_preds)) {
            if (raw_preds[i] == 1) { push(probs, [self.params[0], self.params[1]]); }
            else { push(probs, [self.params[1], self.params[0]]); }
            i = i + 1;
        }
        return probs;
    }

    fn predict(X) {
        if (self.base_estimator != nullptr) {
            return self.base_estimator["predict"](X);
        }
        return [];
    }

    fn score(X, y) { return accuracy_score(self.predict(X), y); }
}

# ── VotingRegressor ──
class VotingRegressor {
    let estimators = [];
    let weights = [];

    fn init_voting_regressor(estimators, weights) {
        self.estimators = estimators;
        self.weights = weights;
        return 0;
    }

    fn fit(X, y) {
        let k = len(self.estimators);
        let i = 0;
        while (i < k) {
            self.estimators[i]["fit"](X, y);
            i = i + 1;
        }
        return 0;
    }

    fn predict(X) {
        let n = len(X);
        let k = len(self.estimators);
        let preds = hml_vector_zeros(n);
        let i = 0;
        while (i < n) {
            let total = 0.0;
            let total_w = 0.0;
            let j = 0;
            while (j < k) {
                let p = self.estimators[j]["predict"]([X[i]]);
                let w = 1.0;
                if (j < len(self.weights)) { w = self.weights[j]; }
                total = total + w * p[0];
                total_w = total_w + w;
                j = j + 1;
            }
            if (total_w > 0) { preds[i] = total / total_w; }
            i = i + 1;
        }
        return preds;
    }

    fn score(X, y) { return r2_score(y, self.predict(X)); }
}

# ── StackingCV ──
class StackingCV {
    let base_estimators = [];
    let meta_estimator = nullptr;
    let cv = 5;

    fn init_stacking_cv(base_estimators, meta_estimator, cv) {
        self.base_estimators = base_estimators;
        self.meta_estimator = meta_estimator;
        if (cv != nullptr) { self.cv = cv; }
        return 0;
    }

    fn fit(X, y) {
        let n = len(X);
        let k = len(self.base_estimators);
        let meta_features = [];
        let i = 0;
        while (i < n) {
            let row = [];
            let j = 0;
            while (j < k) { push(row, 0.0); j = j + 1; }
            push(meta_features, row);
            i = i + 1;
        }
        let fold_size = math_floor(n / self.cv);
        let fold = 0;
        while (fold < self.cv) {
            let val_start = fold * fold_size;
            let val_end = val_start + fold_size;
            if (fold == self.cv - 1) { val_end = n; }
            let X_train = [];
            let y_train = [];
            let X_val = [];
            let y_val = [];
            i = 0;
            while (i < n) {
                if (i >= val_start and i < val_end) {
                    push(X_val, X[i]);
                    push(y_val, y[i]);
                }
                else {
                    push(X_train, X[i]);
                    push(y_train, y[i]);
                }
                i = i + 1;
            }
            let j = 0;
            while (j < k) {
                self.base_estimators[j]["fit"](X_train, y_train);
                let val_preds = self.base_estimators[j]["predict"](X_val);
                let m = 0;
                while (m < len(val_preds)) { meta_features[val_start + m][j] = val_preds[m]; m = m + 1; }
                j = j + 1;
            }
            fold = fold + 1;
        }
        if (self.meta_estimator != nullptr) {
            self.meta_estimator["fit"](meta_features, y);
        }
        return 0;
    }

    fn predict(X) {
        let n = len(X);
        let k = len(self.base_estimators);
        let meta_features = [];
        let i = 0;
        while (i < n) {
            let row = [];
            let j = 0;
            while (j < k) {
                let pred = self.base_estimators[j]["predict"]([X[i]]);
                push(row, pred[0]);
                j = j + 1;
            }
            push(meta_features, row);
            i = i + 1;
        }
        if (self.meta_estimator != nullptr) { return self.meta_estimator["predict"](meta_features); }
        return meta_features;
    }

    fn score(X, y) { return accuracy_score(self.predict(X), y); }
}

