# ── DenseLayer ──
class DenseLayer {
    let input_dim = 0;
    let output_dim = 0;
    let weights = [];
    let bias = [];
    let activation = nullptr;
    let lr = 0.01;

    fn init_dense(input_dim, output_dim, activation, lr) {
        self.input_dim = input_dim;
        self.output_dim = output_dim;
        self.weights = hml_xavier_init(input_dim, output_dim);
        self.bias = hml_vector_zeros(output_dim);
        if (activation == nullptr) { self.activation = nullptr; }
        else { self.activation = activation; }
        self.lr = lr;
        return 0;
    }

    fn forward(X) {
        let out = hml_matrix_multiply(X, self.weights);
        let i = 0;
        while (i < len(out)) {
            let j = 0;
            while (j < len(out[0])) {
                out[i][j] = out[i][j] + self.bias[j];
                j = j + 1;
            }
            i = i + 1;
        }
        if (self.activation != nullptr) {
            out = self.activation(out);
        }
        return out;
    }

    fn get_params() {
        return [self.weights, self.bias];
    }

    fn set_params(weights, bias) {
        self.weights = weights;
        self.bias = bias;
        return 0;
    }
}

# ── Conv1DLayer ──
class Conv1DLayer {
    let in_channels = 0;
    let out_channels = 0;
    let kernel_size = 0;
    let stride = 1;
    let filters = [];
    let bias = [];

    fn init_conv1d(in_channels, out_channels, kernel_size, stride) {
        self.in_channels = in_channels;
        self.out_channels = out_channels;
        self.kernel_size = kernel_size;
        self.stride = stride;
        self.filters = [];
        let oc = 0;
        while (oc < out_channels) {
            let filter = [];
            let ic = 0;
            while (ic < in_channels) {
                push(filter, hml_he_init(kernel_size));
                ic = ic + 1;
            }
            push(self.filters, filter);
            oc = oc + 1;
        }
        self.bias = hml_vector_zeros(out_channels);
        return 0;
    }

    fn forward(X) {
        let outputs = [];
        let oc = 0;
        while (oc < self.out_channels) {
            let channel_out = [];
            let ic = 0;
            while (ic < self.in_channels) {
                let out = hml_conv1d(X[ic], self.filters[oc][ic], self.stride);
                push(channel_out, out);
                ic = ic + 1;
            }
            let combined = hml_vector_zeros(len(channel_out[0]));
            let ci = 0;
            while (ci < len(channel_out)) {
                let j = 0;
                while (j < len(channel_out[ci])) {
                    combined[j] = combined[j] + channel_out[ci][j];
                    j = j + 1;
                }
                ci = ci + 1;
            }
            let j = 0;
            while (j < len(combined)) {
                combined[j] = combined[j] + self.bias[oc];
                j = j + 1;
            }
            push(outputs, combined);
            oc = oc + 1;
        }
        return outputs;
    }
}

# ── Conv2DLayer ──
class Conv2DLayer {
    let in_channels = 0;
    let out_channels = 0;
    let kernel_size = 0;
    let stride = 1;
    let filters = [];
    let bias = [];

    fn init_conv2d(in_channels, out_channels, kernel_size, stride) {
        self.in_channels = in_channels;
        self.out_channels = out_channels;
        self.kernel_size = kernel_size;
        self.stride = stride;
        self.filters = [];
        let oc = 0;
        while (oc < out_channels) {
            let filter = [];
            let ic = 0;
            while (ic < in_channels) {
                push(filter, hml_xavier_init(kernel_size, kernel_size));
                ic = ic + 1;
            }
            push(self.filters, filter);
            oc = oc + 1;
        }
        self.bias = hml_vector_zeros(out_channels);
        return 0;
    }

    fn forward(X) {
        let outputs = [];
        let oc = 0;
        while (oc < self.out_channels) {
            let channel_out = [];
            let ic = 0;
            while (ic < self.in_channels) {
                let out = hml_conv2d(X[ic], self.filters[oc][ic], self.stride);
                push(channel_out, out);
                ic = ic + 1;
            }
            let combined = hml_matrix_zeros(len(channel_out[0]), len(channel_out[0][0]));
            let ci = 0;
            while (ci < len(channel_out)) {
                let i = 0;
                while (i < len(channel_out[ci])) {
                    let j = 0;
                    while (j < len(channel_out[ci][i])) {
                        combined[i][j] = combined[i][j] + channel_out[ci][i][j];
                        j = j + 1;
                    }
                    i = i + 1;
                }
                ci = ci + 1;
            }
            let i = 0;
            while (i < len(combined)) {
                let j = 0;
                while (j < len(combined[i])) {
                    combined[i][j] = combined[i][j] + self.bias[oc];
                    j = j + 1;
                }
                i = i + 1;
            }
            push(outputs, combined);
            oc = oc + 1;
        }
        return outputs;
    }
}

# ── MaxPool1DLayer ──
class MaxPool1DLayer {
    let pool_size = 2;
    let stride = 2;

    fn init_maxpool1d(pool_size, stride) {
        self.pool_size = pool_size;
        self.stride = stride;
        return 0;
    }

    fn forward(X) {
        let result = [];
        let i = 0;
        while (i < len(X)) {
            push(result, hml_max_pool1d(X[i], self.pool_size, self.stride));
            i = i + 1;
        }
        return result;
    }
}

# ── MaxPool2DLayer ──
class MaxPool2DLayer {
    let pool_size = 2;
    let stride = 2;

    fn init_maxpool2d(pool_size, stride) {
        self.pool_size = pool_size;
        self.stride = stride;
        return 0;
    }

    fn forward(X) {
        let result = [];
        let i = 0;
        while (i < len(X)) {
            push(result, hml_max_pool2d(X[i], self.pool_size, self.stride));
            i = i + 1;
        }
        return result;
    }
}

# ── AvgPool1DLayer ──
class AvgPool1DLayer {
    let pool_size = 2;
    let stride = 2;

    fn init_avgpool1d(pool_size, stride) {
        self.pool_size = pool_size;
        self.stride = stride;
        return 0;
    }

    fn forward(X) {
        let result = [];
        let i = 0;
        while (i < len(X)) {
            let in_len = len(X[i]);
            let out_len = math_floor((in_len - self.pool_size) * 1.0 / self.stride) + 1;
            let row = [];
            let j = 0;
            while (j < out_len) {
                let s = 0.0;
                let cnt = 0;
                let k = 0;
                while (k < self.pool_size) {
                    let idx = j * self.stride + k;
                    if (idx < in_len) { s = s + X[i][idx]; cnt = cnt + 1; }
                    k = k + 1;
                }
                if (cnt > 0) { push(row, s * 1.0 / cnt); }
                else { push(row, 0.0); }
                j = j + 1;
            }
            push(result, row);
            i = i + 1;
        }
        return result;
    }
}

# ── AvgPool2DLayer ──
class AvgPool2DLayer {
    let pool_size = 2;
    let stride = 2;

    fn init_avgpool2d(pool_size, stride) {
        self.pool_size = pool_size;
        self.stride = stride;
        return 0;
    }

    fn forward(X) {
        let result = [];
        let i = 0;
        while (i < len(X)) {
            push(result, hml_avg_pool2d(X[i], self.pool_size, self.stride));
            i = i + 1;
        }
        return result;
    }
}

# ── FlattenLayer ──
class FlattenLayer {
    fn init_flatten() {
        return 0;
    }

    fn forward(X) {
        return hml_flatten(X);
    }
}

# ── DropoutLayer ──
class DropoutLayer {
    let rate = 0.5;
    let training = true;

    fn init_dropout(rate) {
        self.rate = rate;
        self.training = true;
        return 0;
    }

    fn forward(X) {
        let result = hml_dropout_forward(X, self.rate, self.training);
        return result["output"];
    }

    fn train_mode() {
        self.training = true;
        return 0;
    }

    fn eval_mode() {
        self.training = false;
        return 0;
    }
}

# ── BatchNorm1D ──
class BatchNorm1D {
    let num_features = 0;
    let gamma = [];
    let beta = [];
    let eps = 0.00001;
    let running_mean = [];
    let running_var = [];
    let momentum = 0.9;
    let training = true;

    fn init_batchnorm1d(num_features, momentum) {
        self.num_features = num_features;
        self.gamma = hml_vector_ones(num_features);
        self.beta = hml_vector_zeros(num_features);
        self.running_mean = hml_vector_zeros(num_features);
        self.running_var = hml_vector_ones(num_features);
        if (momentum == nullptr) { self.momentum = 0.9; }
        else { self.momentum = momentum; }
        self.training = true;
        return 0;
    }

    fn forward(X) {
        if (self.training) {
            let result = hml_batch_norm_forward(X, self.gamma, self.beta, self.eps);
            let i = 0;
            while (i < self.num_features) {
                self.running_mean[i] = self.momentum * self.running_mean[i] + (1.0 - self.momentum) * result["mean"][i];
                self.running_var[i] = self.momentum * self.running_var[i] + (1.0 - self.momentum) * result["var"][i];
                i = i + 1;
            }
            return result["output"];
        }
        let out = [];
        let i = 0;
        while (i < len(X)) {
            let row = [];
            let j = 0;
            while (j < self.num_features) {
                let x_hat = (X[i][j] - self.running_mean[j]) / math_sqrt(self.running_var[j] + self.eps);
                push(row, self.gamma[j] * x_hat + self.beta[j]);
                j = j + 1;
            }
            push(out, row);
            i = i + 1;
        }
        return out;
    }

    fn train_mode() { self.training = true; return 0; }
    fn eval_mode() { self.training = false; return 0; }
}

# ── BatchNorm2D ──
class BatchNorm2D {
    let num_features = 0;
    let gamma = [];
    let beta = [];
    let eps = 0.00001;
    let training = true;

    fn init_batchnorm2d(num_features) {
        self.num_features = num_features;
        self.gamma = hml_vector_ones(num_features);
        self.beta = hml_vector_zeros(num_features);
        self.training = true;
        return 0;
    }

    fn forward(X) {
        let n = len(X);
        let h = len(X[0]);
        let w = len(X[0][0]);
        let flat = [];
        let i = 0;
        while (i < n) {
            let row = [];
            let ki = 0;
            while (ki < h) {
                let kj = 0;
                while (kj < w) {
                    push(row, X[i][ki][kj]);
                    kj = kj + 1;
                }
                ki = ki + 1;
            }
            push(flat, row);
            i = i + 1;
        }
        let bnorm = BatchNorm1D();
        bnorm.init_batchnorm1d(h * w, 0.9);
        bnorm.gamma = self.gamma;
        bnorm.beta = self.beta;
        let out = bnorm.forward(flat);
        return out;
    }

    fn train_mode() { self.training = true; return 0; }
    fn eval_mode() { self.training = false; return 0; }
}

# ── LayerNorm ──
