# SECTION 28: Advanced Clustering & Mixture Models
# ═══════════════════════════════════════════════════════════════════════════

fn hml_region_query(X, point_idx, eps) {
    let neighbors = [];
    let i = 0;
    while (i < len(X)) {
        let dist = 0.0;
        let j = 0;
        while (j < len(X[0])) {
            let d = X[point_idx][j] - X[i][j];
            dist = dist + d * d;
            j = j + 1;
        }
        if (math_sqrt(dist) <= eps) { push(neighbors, i); }
        i = i + 1;
    }
    return neighbors;
}

fn hml_dbscan(X, eps, min_samples) {
    let n = len(X);
    let labels = [];
    let i = 0;
    while (i < n) { push(labels, -1); i = i + 1; }
    let cluster_id = 0;
    i = 0;
    while (i < n) {
        if (labels[i] != -1) { i = i + 1; continue; }
        let neighbors = hml_region_query(X, i, eps);
        if (len(neighbors) < min_samples) {
            labels[i] = -2;
            i = i + 1;
            continue;
        }
        labels[i] = cluster_id;
        let seed = [];
        let j = 0;
        while (j < len(neighbors)) { push(seed, neighbors[j]); j = j + 1; }
        j = 0;
        while (j < len(seed)) {
            let pt = seed[j];
            if (labels[pt] == -2) {
                labels[pt] = cluster_id;
            }
            if (labels[pt] != -1) { j = j + 1; continue; }
            labels[pt] = cluster_id;
            let n2 = hml_region_query(X, pt, eps);
            if (len(n2) >= min_samples) {
                let k = 0;
                while (k < len(n2)) { push(seed, n2[k]); k = k + 1; }
            }
            j = j + 1;
        }
        cluster_id = cluster_id + 1;
        i = i + 1;
    }
    return labels;
}

fn hml_hierarchical_linkage_single(cluster1, cluster2) {
    let min_d = 1000000000;
    let i = 0;
    while (i < len(cluster1)) {
        let j = 0;
        while (j < len(cluster2)) {
            let d = 0.0;
            let k = 0;
            while (k < len(cluster1[0])) {
                let diff = cluster1[i][k] - cluster2[j][k];
                d = d + diff * diff;
                k = k + 1;
            }
            d = math_sqrt(d);
            if (d < min_d) { min_d = d; }
            j = j + 1;
        }
        i = i + 1;
    }
    return min_d;
}

fn hml_hierarchical_linkage_complete(cluster1, cluster2) {
    let max_d = 0.0;
    let i = 0;
    while (i < len(cluster1)) {
        let j = 0;
        while (j < len(cluster2)) {
            let d = 0.0;
            let k = 0;
            while (k < len(cluster1[0])) {
                let diff = cluster1[i][k] - cluster2[j][k];
                d = d + diff * diff;
                k = k + 1;
            }
            d = math_sqrt(d);
            if (d > max_d) { max_d = d; }
            j = j + 1;
        }
        i = i + 1;
    }
    return max_d;
}

fn hml_hierarchical_linkage_average(cluster1, cluster2) {
    let total = 0.0;
    let cnt = 0;
    let i = 0;
    while (i < len(cluster1)) {
        let j = 0;
        while (j < len(cluster2)) {
            let d = 0.0;
            let k = 0;
            while (k < len(cluster1[0])) {
                let diff = cluster1[i][k] - cluster2[j][k];
                d = d + diff * diff;
                k = k + 1;
            }
            total = total + math_sqrt(d);
            cnt = cnt + 1;
            j = j + 1;
        }
        i = i + 1;
    }
    return total * 1.0 / cnt;
}

fn hml_hierarchical_linkage_ward(cluster1, cluster2) {
    let combined = [];
    let i = 0;
    while (i < len(cluster1)) { push(combined, cluster1[i]); i = i + 1; }
    i = 0;
    while (i < len(cluster2)) { push(combined, cluster2[i]); i = i + 1; }
    let n = len(combined);
    let d = len(combined[0]);
    let centroid = hml_vector_zeros(d);
    i = 0;
    while (i < n) {
        let j = 0;
        while (j < d) { centroid[j] = centroid[j] + combined[i][j]; j = j + 1; }
        i = i + 1;
    }
    let j = 0;
    while (j < d) { centroid[j] = centroid[j] * 1.0 / n; j = j + 1; }
    let ess = 0.0;
    i = 0;
    while (i < n) {
        let j = 0;
        while (j < d) {
            let diff = combined[i][j] - centroid[j];
            ess = ess + diff * diff;
            j = j + 1;
        }
        i = i + 1;
    }
    return ess;
}

fn hml_dendrogram_cut(Z, n_clusters) {
    return Z;
}

fn hml_hierarchical_agglomerative(X, n_clusters, linkage) {
    let n = len(X);
    let clusters = [];
    let i = 0;
    while (i < n) { push(clusters, [X[i]]); i = i + 1; }
    let labels = [];
    i = 0;
    while (i < n) { push(labels, i); i = i + 1; }
    let current_n = n;
    let link_fn = hml_hierarchical_linkage_single;
    if (linkage == 1) { link_fn = hml_hierarchical_linkage_complete; }
    if (linkage == 2) { link_fn = hml_hierarchical_linkage_average; }
    if (linkage == 3) { link_fn = hml_hierarchical_linkage_ward; }
    while (current_n > n_clusters) {
        let min_d = 1000000000;
        let min_i = 0;
        let min_j = 0;
        let a = 0;
        while (a < current_n - 1) {
            let b = a + 1;
            while (b < current_n) {
                let d = link_fn(clusters[a], clusters[b]);
                if (d < min_d) { min_d = d; min_i = a; min_j = b; }
                b = b + 1;
            }
            a = a + 1;
        }
        let merged = [];
        a = 0;
        while (a < len(clusters[min_i])) { push(merged, clusters[min_i][a]); a = a + 1; }
        a = 0;
        while (a < len(clusters[min_j])) { push(merged, clusters[min_j][a]); a = a + 1; }
        let new_clusters = [];
        a = 0;
        while (a < current_n) {
            if (a != min_i and a != min_j) { push(new_clusters, clusters[a]); }
            a = a + 1;
        }
        push(new_clusters, merged);
        clusters = new_clusters;
        current_n = current_n - 1;
    }
    let result = [];
    i = 0;
    while (i < n) { push(result, 0); i = i + 1; }
    let c = 0;
    while (c < current_n) {
        let j = 0;
        while (j < len(clusters[c])) {
            let pt = clusters[c][j];
            let found = false;
            let k = 0;
            while (k < n) {
                let match = true;
                let f = 0;
                while (f < len(pt)) {
                    if (pt[f] != X[k][f]) { match = false; break; }
                    f = f + 1;
                }
                if (match) { result[k] = c; found = true; break; }
                k = k + 1;
            }
            j = j + 1;
        }
        c = c + 1;
    }
    return result;
}

fn hml_spectral_affinity_matrix(X, sigma) {
    let n = len(X);
    let A = hml_matrix_zeros(n, n);
    let i = 0;
    while (i < n) {
        let j = i + 1;
        while (j < n) {
            let dist = 0.0;
            let d = 0;
            while (d < len(X[0])) {
                let diff = X[i][d] - X[j][d];
                dist = dist + diff * diff;
                d = d + 1;
            }
            let w = math_exp(-dist / (2.0 * sigma * sigma));
            A[i][j] = w;
            A[j][i] = w;
            j = j + 1;
        }
        i = i + 1;
    }
    return A;
}

fn hml_spectral_laplacian(affinity) {
    let n = len(affinity);
    let L = hml_matrix_zeros(n, n);
    let i = 0;
    while (i < n) {
        let deg = 0.0;
        let j = 0;
        while (j < n) { deg = deg + affinity[i][j]; j = j + 1; }
        let j = 0;
        while (j < n) {
            L[i][j] = -affinity[i][j];
            if (i == j) { L[i][j] = deg - affinity[i][i]; }
            j = j + 1;
        }
        i = i + 1;
    }
    return L;
}

fn hml_spectral_clustering(X, n_clusters, sigma) {
    let A = hml_spectral_affinity_matrix(X, sigma);
    let L = hml_spectral_laplacian(A);
    let n = len(X);
    let kmeans_input = [];
    let i = 0;
    while (i < n) {
        let row = [];
        let j = 0;
        while (j < n_clusters) { push(row, hml_random()); j = j + 1; }
        push(kmeans_input, row);
        i = i + 1;
    }
    let labels = [];
    i = 0;
    while (i < n) {
        let best = 0;
        let best_dist = 1000000000;
        let c = 0;
        while (c < n_clusters) {
            let dist = 0.0;
            let j = 0;
            while (j < n_clusters) {
                let d = kmeans_input[i][j] - kmeans_input[c][j];
                dist = dist + d * d;
                j = j + 1;
            }
            if (dist < best_dist) { best_dist = dist; best = c; }
            c = c + 1;
        }
        push(labels, best);
        i = i + 1;
    }
    return labels;
}

fn hml_mean_shift_kernel(distance, bandwidth) {
    if (distance < bandwidth) { return 1.0; }
    return 0.0;
}

fn hml_mean_shift(X, bandwidth, max_iter) {
    let n = len(X);
    let d = len(X[0]);
    let points = [];
    let i = 0;
    while (i < n) {
        let pt = [];
        let j = 0;
        while (j < d) { push(pt, X[i][j]); j = j + 1; }
        push(points, pt);
        i = i + 1;
    }
    let iter = 0;
    while (iter < max_iter) {
        let new_points = [];
        i = 0;
        while (i < n) {
            let shift = hml_vector_zeros(d);
            let total_weight = 0.0;
            let j = 0;
            while (j < n) {
                let dist = 0.0;
                let k = 0;
                while (k < d) {
                    let diff = points[i][k] - points[j][k];
                    dist = dist + diff * diff;
                    k = k + 1;
                }
                dist = math_sqrt(dist);
                let w = hml_mean_shift_kernel(dist, bandwidth);
                let k = 0;
                while (k < d) { shift[k] = shift[k] + w * points[j][k]; k = k + 1; }
                total_weight = total_weight + w;
                j = j + 1;
            }
            let new_pt = [];
            let k = 0;
            while (k < d) {
                if (total_weight > 0) { push(new_pt, shift[k] / total_weight); }
                else { push(new_pt, points[i][k]); }
                k = k + 1;
            }
            push(new_points, new_pt);
            i = i + 1;
        }
        points = new_points;
        iter = iter + 1;
    }
    let labels = [];
    i = 0;
    while (i < n) { push(labels, i); i = i + 1; }
    i = 0;
    while (i < n) {
        let j = 0;
        while (j < n) {
            let dist = 0.0;
            let k = 0;
            while (k < d) {
                let diff = points[i][k] - points[j][k];
                dist = dist + diff * diff;
                k = k + 1;
            }
            if (math_sqrt(dist) < bandwidth * 0.5) { labels[j] = labels[i]; }
            j = j + 1;
        }
        i = i + 1;
    }
    return labels;
}

fn hml_gmm_e_step(X, means, covs, weights) {
    let n = len(X);
    let k = len(means);
    let d = len(X[0]);
    let resp = hml_matrix_zeros(n, k);
    let i = 0;
    while (i < n) {
        let total = 0.0;
        let c = 0;
        while (c < k) {
            let log_prob = math_log(weights[c] + 0.000000000000001);
            let j = 0;
            while (j < d) {
                let diff = X[i][j] - means[c][j];
                let var_j = covs[c][j];
                if (var_j <= 0) { var_j = 0.000000001; }
                log_prob = log_prob - 0.5 * math_log(2.0 * 3.141592653589793 * var_j) - (diff * diff) * 1.0 / (2.0 * var_j);
                j = j + 1;
            }
            resp[i][c] = math_exp(log_prob);
            total = total + resp[i][c];
            c = c + 1;
        }
        if (total > 0) {
            c = 0;
            while (c < k) { resp[i][c] = resp[i][c] / total; c = c + 1; }
        }
        i = i + 1;
    }
    return resp;
}

fn hml_gmm_m_step(X, responsibilities) {
    let n = len(X);
    let k = len(responsibilities[0]);
    let d = len(X[0]);
    let Nk = hml_vector_zeros(k);
    let means = [];
    let covs = [];
    let c = 0;
    while (c < k) {
        let i = 0;
        while (i < n) { Nk[c] = Nk[c] + responsibilities[i][c]; i = i + 1; }
        let mean_c = hml_vector_zeros(d);
        i = 0;
        while (i < n) {
            let j = 0;
            while (j < d) { mean_c[j] = mean_c[j] + responsibilities[i][c] * X[i][j]; j = j + 1; }
            i = i + 1;
        }
        if (Nk[c] > 0) {
            let j = 0;
            while (j < d) { mean_c[j] = mean_c[j] / Nk[c]; j = j + 1; }
        }
        push(means, mean_c);
        let cov_c = hml_vector_zeros(d);
        i = 0;
        while (i < n) {
            let j = 0;
            while (j < d) {
                let diff = X[i][j] - mean_c[j];
                cov_c[j] = cov_c[j] + responsibilities[i][c] * diff * diff;
                j = j + 1;
            }
            i = i + 1;
        }
        if (Nk[c] > 0) {
            let j = 0;
            while (j < d) { cov_c[j] = cov_c[j] / Nk[c] + 0.000001; j = j + 1; }
        }
        push(covs, cov_c);
        c = c + 1;
    }
    let weights = [];
    c = 0;
    while (c < k) { push(weights, Nk[c] * 1.0 / n + 0.000000000000001); c = c + 1; }
    return {"means": means, "covs": covs, "weights": weights};
}

fn hml_gmm_fit(X, n_components, max_iter) {
    let n = len(X);
    let d = len(X[0]);
    let means = [];
    let covs = [];
    let i = 0;
    while (i < n_components) {
        let idx = hml_randint(0, n - 1);
        let mean = [];
        let j = 0;
        while (j < d) { push(mean, X[idx][j]); j = j + 1; }
        push(means, mean);
        let cov = [];
        j = 0;
        while (j < d) { push(cov, 1.0); j = j + 1; }
        push(covs, cov);
        i = i + 1;
    }
    let weights = [];
    i = 0;
    while (i < n_components) { push(weights, 1.0 / n_components); i = i + 1; }
    let iter = 0;
    while (iter < max_iter) {
        let resp = hml_gmm_e_step(X, means, covs, weights);
        let update = hml_gmm_m_step(X, resp);
        means = update["means"];
        covs = update["covs"];
        weights = update["weights"];
        iter = iter + 1;
    }
    return {"means": means, "covs": covs, "weights": weights};
}

fn hml_gmm_predict(X, means, covs, weights) {
    let resp = hml_gmm_e_step(X, means, covs, weights);
    let n = len(X);
    let preds = [];
    let i = 0;
    while (i < n) {
        let best = 0;
        let best_val = resp[i][0];
        let c = 1;
        while (c < len(means)) {
            if (resp[i][c] > best_val) { best_val = resp[i][c]; best = c; }
            c = c + 1;
        }
        push(preds, best);
        i = i + 1;
    }
    return preds;
}

fn hml_gmm_score_samples(X, means, covs, weights) {
    let n = len(X);
    let k = len(means);
    let d = len(X[0]);
    let scores = [];
    let i = 0;
    while (i < n) {
        let log_prob = -1000000000;
        let c = 0;
        while (c < k) {
            let lp = math_log(weights[c] + 0.000000000000001);
            let j = 0;
            while (j < d) {
                let diff = X[i][j] - means[c][j];
                let var_j = covs[c][j];
                if (var_j <= 0) { var_j = 0.000000001; }
                lp = lp - 0.5 * math_log(2.0 * 3.141592653589793 * var_j) - (diff * diff) * 1.0 / (2.0 * var_j);
                j = j + 1;
            }
            if (lp > log_prob) { log_prob = lp; }
            c = c + 1;
        }
        push(scores, log_prob);
        i = i + 1;
    }
    return scores;
}

fn hml_silhouette_score(X, labels) {
    let n = len(X);
    let unique_labels = hml_unique(labels);
    let k = len(unique_labels);
    if (k < 2) { return 0.0; }
    let total = 0.0;
    let i = 0;
    while (i < n) {
        let a = 0.0;
        let a_cnt = 0;
        let b_list = [];
        let u = 0;
        while (u < k) { push(b_list, 0.0); u = u + 1; }
        let b_cnts = [];
        u = 0;
        while (u < k) { push(b_cnts, 0); u = u + 1; }
        let j = 0;
        while (j < n) {
            if (i == j) { j = j + 1; continue; }
            let dist = 0.0;
            let d = 0;
            while (d < len(X[0])) {
                let diff = X[i][d] - X[j][d];
                dist = dist + diff * diff;
                d = d + 1;
            }
            dist = math_sqrt(dist);
            if (labels[i] == labels[j]) {
                a = a + dist;
                a_cnt = a_cnt + 1;
            } else {
                let u = 0;
                while (u < k) {
                    if (unique_labels[u] == labels[j]) {
                        b_list[u] = b_list[u] + dist;
                        b_cnts[u] = b_cnts[u] + 1;
                    }
                    u = u + 1;
                }
            }
            j = j + 1;
        }
        if (a_cnt > 0) { a = a * 1.0 / a_cnt; }
        let b_min = 1000000000;
        let u = 0;
        while (u < k) {
            if (unique_labels[u] != labels[i] and b_cnts[u] > 0) {
                let b_val = b_list[u] * 1.0 / b_cnts[u];
                if (b_val < b_min) { b_min = b_val; }
            }
            u = u + 1;
        }
        if (a_cnt > 0 and b_min < 100000000) {
            let denom = a;
            if (b_min > denom) { denom = b_min; }
            total = total + (b_min - a) / denom;
        }
        i = i + 1;
    }
    return total * 1.0 / n;
}

fn hml_calinski_harabasz_score(X, labels) {
    let n = len(X);
    let d = len(X[0]);
    let unique_labels = hml_unique(labels);
    let k = len(unique_labels);
    if (k < 2 or k >= n) { return 0.0; }
    let overall_mean = hml_vector_zeros(d);
    let i = 0;
    while (i < n) {
        let j = 0;
        while (j < d) { overall_mean[j] = overall_mean[j] + X[i][j]; j = j + 1; }
        i = i + 1;
    }
    let j = 0;
    while (j < d) { overall_mean[j] = overall_mean[j] * 1.0 / n; j = j + 1; }
    let ss_b = 0.0;
    let ss_w = 0.0;
    let u = 0;
    while (u < k) {
        let cluster_pts = [];
        i = 0;
        while (i < n) {
            if (labels[i] == unique_labels[u]) { push(cluster_pts, X[i]); }
            i = i + 1;
        }
        let nk = len(cluster_pts);
        if (nk == 0) { u = u + 1; continue; }
        let cluster_mean = hml_vector_zeros(d);
        i = 0;
        while (i < nk) {
            j = 0;
            while (j < d) { cluster_mean[j] = cluster_mean[j] + cluster_pts[i][j]; j = j + 1; }
            i = i + 1;
        }
        j = 0;
        while (j < d) { cluster_mean[j] = cluster_mean[j] * 1.0 / nk; j = j + 1; }
        let b_dist = 0.0;
        j = 0;
        while (j < d) {
            let diff = cluster_mean[j] - overall_mean[j];
            b_dist = b_dist + diff * diff;
            j = j + 1;
        }
        ss_b = ss_b + nk * b_dist;
        i = 0;
        while (i < nk) {
            j = 0;
            while (j < d) {
                let diff = cluster_pts[i][j] - cluster_mean[j];
                ss_w = ss_w + diff * diff;
                j = j + 1;
            }
            i = i + 1;
        }
        u = u + 1;
    }
    if (ss_w == 0) { return 0.0; }
    return (ss_b * 1.0 / (k - 1)) / (ss_w * 1.0 / (n - k));
}

fn hml_davies_bouldin_score(X, labels) {
    let n = len(X);
    let unique_labels = hml_unique(labels);
    let k = len(unique_labels);
    if (k < 2) { return 0.0; }
    let centroids = [];
    let dispersions = [];
    let u = 0;
    while (u < k) {
        let cluster_pts = [];
        let i = 0;
        while (i < n) {
            if (labels[i] == unique_labels[u]) { push(cluster_pts, X[i]); }
            i = i + 1;
        }
        let nk = len(cluster_pts);
        if (nk == 0) { push(centroids, hml_vector_zeros(len(X[0]))); push(dispersions, 0.0); u = u + 1; continue; }
        let centroid = hml_vector_zeros(len(X[0]));
        i = 0;
        while (i < nk) {
            let j = 0;
            while (j < len(X[0])) { centroid[j] = centroid[j] + cluster_pts[i][j]; j = j + 1; }
            i = i + 1;
        }
        let j = 0;
        while (j < len(X[0])) { centroid[j] = centroid[j] * 1.0 / nk; j = j + 1; }
        push(centroids, centroid);
        let disp = 0.0;
        i = 0;
        while (i < nk) {
            let dist = 0.0;
            j = 0;
            while (j < len(X[0])) {
                let diff = cluster_pts[i][j] - centroid[j];
                dist = dist + diff * diff;
                j = j + 1;
            }
            disp = disp + math_sqrt(dist);
            i = i + 1;
        }
        push(dispersions, disp * 1.0 / nk);
        u = u + 1;
    }
    let total = 0.0;
    let i = 0;
    while (i < k) {
        let max_ratio = 0.0;
        let j = 0;
        while (j < k) {
            if (i != j) {
                let cd = 0.0;
                let d = 0;
                while (d < len(X[0])) {
                    let diff = centroids[i][d] - centroids[j][d];
                    cd = cd + diff * diff;
                    d = d + 1;
                }
                cd = math_sqrt(cd);
                if (cd > 0) {
                    let ratio = (dispersions[i] + dispersions[j]) / cd;
                    if (ratio > max_ratio) { max_ratio = ratio; }
                }
            }
            j = j + 1;
        }
        total = total + max_ratio;
        i = i + 1;
    }
    return total * 1.0 / k;
}

fn hml_adjusted_rand_score(labels_true, labels_pred) {
    let n = len(labels_true);
    let classes_true = hml_unique(labels_true);
    let classes_pred = hml_unique(labels_pred);
    let n_true = len(classes_true);
    let n_pred = len(classes_pred);
    let contingency = hml_matrix_zeros(n_true, n_pred);
    let i = 0;
    while (i < n) {
        let ti = 0; while (labels_true[i] != classes_true[ti]) { ti = ti + 1; }
        let pj = 0; while (labels_pred[i] != classes_pred[pj]) { pj = pj + 1; }
        contingency[ti][pj] = contingency[ti][pj] + 1;
        i = i + 1;
    }
    let sum_comb = 0.0;
    i = 0;
    while (i < n_true) {
        let j = 0;
        while (j < n_pred) {
            let val = contingency[i][j];
            sum_comb = sum_comb + val * (val - 1) * 0.5;
            j = j + 1;
        }
        i = i + 1;
    }
    let sum_a = 0.0;
    i = 0;
    while (i < n_true) {
        let row_sum = 0;
        let j = 0;
        while (j < n_pred) { row_sum = row_sum + contingency[i][j]; j = j + 1; }
        sum_a = sum_a + row_sum * (row_sum - 1) * 0.5;
        i = i + 1;
    }
    let sum_b = 0.0;
    let j = 0;
    while (j < n_pred) {
        let col_sum = 0;
        i = 0;
        while (i < n_true) { col_sum = col_sum + contingency[i][j]; i = i + 1; }
        sum_b = sum_b + col_sum * (col_sum - 1) * 0.5;
        j = j + 1;
    }
    let expected = sum_a * sum_b / (n * (n - 1) * 0.5);
    let max_sum = (sum_a + sum_b) * 0.5;
    if (max_sum == expected) { return 0.0; }
    return (sum_comb - expected) / (max_sum - expected);
}

fn hml_normalized_mutual_info(labels_true, labels_pred) {
    let n = len(labels_true);
    let classes_true = hml_unique(labels_true);
    let classes_pred = hml_unique(labels_pred);
    let r = len(classes_true);
    let c = len(classes_pred);
    let contingency = hml_matrix_zeros(r, c);
    let i = 0;
    while (i < n) {
        let ti = 0; while (labels_true[i] != classes_true[ti]) { ti = ti + 1; }
        let pj = 0; while (labels_pred[i] != classes_pred[pj]) { pj = pj + 1; }
        contingency[ti][pj] = contingency[ti][pj] + 1.0;
        i = i + 1;
    }
    let mi = 0.0;
    i = 0;
    while (i < r) {
        let j = 0;
        while (j < c) {
            if (contingency[i][j] > 0) {
                let row_sum = 0.0;
                let k = 0; while (k < c) { row_sum = row_sum + contingency[i][k]; k = k + 1; }
                let col_sum = 0.0;
                k = 0; while (k < r) { col_sum = col_sum + contingency[k][j]; k = k + 1; }
                mi = mi + (contingency[i][j] * 1.0 / n) * math_log((contingency[i][j] * n) * 1.0 / (row_sum * col_sum));
            }
            j = j + 1;
        }
        i = i + 1;
    }
    let h_true = 0.0;
    i = 0;
    while (i < r) {
        let row_sum = 0.0;
        let j = 0; while (j < c) { row_sum = row_sum + contingency[i][j]; j = j + 1; }
        if (row_sum > 0) { h_true = h_true - (row_sum * 1.0 / n) * math_log(row_sum * 1.0 / n); }
        i = i + 1;
    }
    let h_pred = 0.0;
    let j = 0;
    while (j < c) {
        let col_sum = 0.0;
        i = 0; while (i < r) { col_sum = col_sum + contingency[i][j]; i = i + 1; }
        if (col_sum > 0) { h_pred = h_pred - (col_sum * 1.0 / n) * math_log(col_sum * 1.0 / n); }
        j = j + 1;
    }
    let denom = (h_true + h_pred) * 0.5;
    if (denom == 0) { return 0.0; }
    return 2.0 * mi / (h_true + h_pred);
}

fn hml_v_measure(labels_true, labels_pred) {
    let homogeneity = hml_normalized_mutual_info(labels_true, labels_pred);
    let completeness = hml_normalized_mutual_info(labels_pred, labels_true);
    if (homogeneity + completeness == 0) { return 0.0; }
    return 2.0 * homogeneity * completeness / (homogeneity + completeness);
}

fn hml_fowlkes_mallows_score(labels_true, labels_pred) {
    let n = len(labels_true);
    let classes_true = hml_unique(labels_true);
    let classes_pred = hml_unique(labels_pred);
    let r = len(classes_true);
    let c = len(classes_pred);
    let contingency = hml_matrix_zeros(r, c);
    let i = 0;
    while (i < n) {
        let ti = 0; while (labels_true[i] != classes_true[ti]) { ti = ti + 1; }
        let pj = 0; while (labels_pred[i] != classes_pred[pj]) { pj = pj + 1; }
        contingency[ti][pj] = contingency[ti][pj] + 1;
        i = i + 1;
    }
    let tp = 0.0;
    i = 0;
    while (i < r) {
        let j = 0;
        while (j < c) { tp = tp + contingency[i][j] * (contingency[i][j] - 1); j = j + 1; }
        i = i + 1;
    }
    tp = tp * 0.5;
    let sum_p = 0.0;
    i = 0;
    while (i < r) {
        let row_sum = 0;
        let j = 0; while (j < c) { row_sum = row_sum + contingency[i][j]; j = j + 1; }
        sum_p = sum_p + row_sum * (row_sum - 1);
        i = i + 1;
    }
    sum_p = sum_p * 0.5;
    let sum_q = 0.0;
    let j = 0;
    while (j < c) {
        let col_sum = 0;
        i = 0; while (i < r) { col_sum = col_sum + contingency[i][j]; i = i + 1; }
        sum_q = sum_q + col_sum * (col_sum - 1);
        j = j + 1;
    }
    sum_q = sum_q * 0.5;
    let denom = math_sqrt(sum_p * sum_q);
    if (denom == 0) { return 0.0; }
    return tp / denom;
}
