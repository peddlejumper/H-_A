# ── AttentionLayer ──
class AttentionLayer {
    let d_model = 0;

    fn init_attention(d_model) {
        self.d_model = d_model;
        return 0;
    }

    fn forward(Q, K, V) {
        return hml_scaled_dot_product_attention(Q, K, V, nullptr);
    }
}

# ── MultiHeadAttentionLayer ──
class MultiHeadAttentionLayer {
    let d_model = 0;
    let n_heads = 0;
    let Wq = [];
    let Wk = [];
    let Wv = [];
    let Wo = [];

    fn init_multihead_attention(d_model, n_heads) {
        self.d_model = d_model;
        self.n_heads = n_heads;
        self.Wq = hml_xavier_init(d_model, d_model);
        self.Wk = hml_xavier_init(d_model, d_model);
        self.Wv = hml_xavier_init(d_model, d_model);
        self.Wo = hml_xavier_init(d_model, d_model);
        return 0;
    }

    fn forward(Q, K, V) {
        let Q_proj = hml_matrix_multiply(Q, self.Wq);
        let K_proj = hml_matrix_multiply(K, self.Wk);
        let V_proj = hml_matrix_multiply(V, self.Wv);
        let heads = hml_multi_head_attention_split(Q_proj, K_proj, V_proj, self.n_heads);
        let concat = hml_multi_head_attention_concat(heads);
        return hml_matrix_multiply(concat, self.Wo);
    }
}

# ── ResidualBlock ──
class ResidualBlock {
    let layers = [];
    let shortcut = nullptr;

    fn init_residual(layers) {
        self.layers = layers;
        self.shortcut = nullptr;
        return 0;
    }

    fn forward(X) {
        let out = X;
        let i = 0;
        while (i < len(self.layers)) {
            out = self.layers[i].forward(out);
            i = i + 1;
        }
        let result = hml_matrix_add(out, X);
        return result;
    }
}

# ── SequentialModel ──
class SequentialModel {
    let layers = [];
    let compiled = false;

    fn init_sequential(layers) {
        self.layers = layers;
        self.compiled = false;
        return 0;
    }

    fn add(layer) {
        push(self.layers, layer);
        return 0;
    }

    fn forward(X) {
        let out = X;
        let i = 0;
        while (i < len(self.layers)) {
            out = self.layers[i].forward(out);
            i = i + 1;
        }
        return out;
    }

    fn predict(X) {
        let i = 0;
        while (i < len(self.layers)) {
            self.layers[i].eval_mode();
            i = i + 1;
        }
        let out = self.forward(X);
        return out;
    }

    fn score(X, y) {
        let y_pred = self.predict(X);
        return accuracy_score(y, y_pred);
    }
}

