# SECTION 29: Feature Selection
# ═══════════════════════════════════════════════════════════════════════════

fn hml_variance_threshold(X, threshold) {
    let n = len(X);
    let d = len(X[0]);
    let selected = [];
    let j = 0;
    while (j < d) {
        let mean = 0.0;
        let i = 0;
        while (i < n) { mean = mean + X[i][j]; i = i + 1; }
        mean = mean * 1.0 / n;
        let var = 0.0;
        i = 0;
        while (i < n) {
            let diff = X[i][j] - mean;
            var = var + diff * diff;
            i = i + 1;
        }
        var = var * 1.0 / n;
        if (var >= threshold) { push(selected, j); }
        j = j + 1;
    }
    return selected;
}

fn hml_mutual_information(X, y, n_bins) {
    let n = len(X);
    let d = len(X[0]);
    let scores = hml_vector_zeros(d);
    let y_binned = [];
    let y_min = y[0];
    let y_max = y[0];
    let i = 0;
    while (i < n) {
        if (y[i] < y_min) { y_min = y[i]; }
        if (y[i] > y_max) { y_max = y[i]; }
        i = i + 1;
    }
    i = 0;
    while (i < n) {
        let bin = math_floor((y[i] - y_min) / (y_max - y_min + 0.000000001) * (n_bins - 1));
        push(y_binned, bin);
        i = i + 1;
    }
    let fj = 0;
    while (fj < d) {
        let x_min = X[0][fj];
        let x_max = X[0][fj];
        i = 0;
        while (i < n) {
            if (X[i][fj] < x_min) { x_min = X[i][fj]; }
            if (X[i][fj] > x_max) { x_max = X[i][fj]; }
            i = i + 1;
        }
        let joint = hml_matrix_zeros(n_bins, n_bins);
        let x_marg = hml_vector_zeros(n_bins);
        let y_marg = hml_vector_zeros(n_bins);
        i = 0;
        while (i < n) {
            let xb = math_floor((X[i][fj] - x_min) / (x_max - x_min + 0.000000001) * (n_bins - 1));
            joint[xb][y_binned[i]] = joint[xb][y_binned[i]] + 1.0;
            x_marg[xb] = x_marg[xb] + 1.0;
            y_marg[y_binned[i]] = y_marg[y_binned[i]] + 1.0;
            i = i + 1;
        }
        let mi = 0.0;
        let a = 0;
        while (a < n_bins) {
            let b = 0;
            while (b < n_bins) {
                if (joint[a][b] > 0) {
                    mi = mi + (joint[a][b] * 1.0 / n) * math_log((joint[a][b] * n) * 1.0 / (x_marg[a] * y_marg[b] + 0.000000001));
                }
                b = b + 1;
            }
            a = a + 1;
        }
        scores[fj] = mi;
        fj = fj + 1;
    }
    return scores;
}

fn hml_chi2_score(X, y) {
    let n = len(X);
    let d = len(X[0]);
    let y_unique = hml_unique(y);
    let n_classes = len(y_unique);
    let scores = hml_vector_zeros(d);
    let overall = hml_vector_zeros(n_classes);
    let i = 0;
    while (i < n) {
        let ci = 0; while (y[i] != y_unique[ci]) { ci = ci + 1; }
        overall[ci] = overall[ci] + 1.0;
        i = i + 1;
    }
    let fj = 0;
    while (fj < d) {
        let chi2 = 0.0;
        i = 0;
        while (i < n) {
            let obs = X[i][fj];
            let ci = 0; while (y[i] != y_unique[ci]) { ci = ci + 1; }
            let exp = overall[ci] * 1.0 / n;
            if (exp > 0) {
                chi2 = chi2 + (obs - exp) * (obs - exp) / exp;
            }
            i = i + 1;
        }
        scores[fj] = chi2;
        fj = fj + 1;
    }
    return scores;
}

fn hml_anova_f_score(X, y) {
    let n = len(X);
    let d = len(X[0]);
    let y_unique = hml_unique(y);
    let n_classes = len(y_unique);
    let scores = hml_vector_zeros(d);
    let grand_means = hml_vector_zeros(d);
    let i = 0;
    while (i < n) {
        let j = 0;
        while (j < d) { grand_means[j] = grand_means[j] + X[i][j]; j = j + 1; }
        i = i + 1;
    }
    let j = 0;
    while (j < d) { grand_means[j] = grand_means[j] * 1.0 / n; j = j + 1; }
    j = 0;
    while (j < d) {
        let ssb = 0.0;
        let ssw = 0.0;
        let c = 0;
        while (c < n_classes) {
            let count = 0;
            let class_mean = 0.0;
            i = 0;
            while (i < n) {
                if (y[i] == y_unique[c]) {
                    class_mean = class_mean + X[i][j];
                    count = count + 1;
                }
                i = i + 1;
            }
            if (count > 0) {
                class_mean = class_mean * 1.0 / count;
                ssb = ssb + count * (class_mean - grand_means[j]) * (class_mean - grand_means[j]);
                i = 0;
                while (i < n) {
                    if (y[i] == y_unique[c]) {
                        ssw = ssw + (X[i][j] - class_mean) * (X[i][j] - class_mean);
                    }
                    i = i + 1;
                }
            }
            c = c + 1;
        }
        if (n_classes > 1 and ssw > 0) {
            scores[j] = (ssb * 1.0 / (n_classes - 1)) / (ssw * 1.0 / (n - n_classes));
        }
        j = j + 1;
    }
    return scores;
}

fn hml_f_regression(X, y) {
    let n = len(X);
    let d = len(X[0]);
    let scores = hml_vector_zeros(d);
    let y_mean = hml_mean(y);
    let ss_tot = 0.0;
    let i = 0;
    while (i < n) {
        ss_tot = ss_tot + (y[i] - y_mean) * (y[i] - y_mean);
        i = i + 1;
    }
    let j = 0;
    while (j < d) {
        let x_mean = 0.0;
        i = 0;
        while (i < n) { x_mean = x_mean + X[i][j]; i = i + 1; }
        x_mean = x_mean * 1.0 / n;
        let num = 0.0;
        let den = 0.0;
        i = 0;
        while (i < n) {
            let x_diff = X[i][j] - x_mean;
            let y_diff = y[i] - y_mean;
            num = num + x_diff * y_diff;
            den = den + x_diff * x_diff;
            i = i + 1;
        }
        if (den > 0) {
            let r = num / math_sqrt(den * ss_tot);
            scores[j] = r * r * (n - 2) / (1.0 - r * r + 0.000000000000001);
        }
        j = j + 1;
    }
    return scores;
}

fn hml_select_k_best(scores, k) {
    let n = len(scores);
    let indexed = [];
    let i = 0;
    while (i < n) { push(indexed, {"val": scores[i], "idx": i}); i = i + 1; }
    i = 0;
    while (i < n - 1) {
        let j = 0;
        while (j < n - i - 1) {
            if (indexed[j]["val"] < indexed[j + 1]["val"]) {
                let tmp = indexed[j];
                indexed[j] = indexed[j + 1];
                indexed[j + 1] = tmp;
            }
            j = j + 1;
        }
        i = i + 1;
    }
    let selected = [];
    i = 0;
    while (i < k and i < n) { push(selected, indexed[i]["idx"]); i = i + 1; }
    return selected;
}

fn hml_select_percentile(scores, percentile) {
    let k = math_floor(len(scores) * percentile * 1.0 / 100);
    if (k < 1) { k = 1; }
    return hml_select_k_best(scores, k);
}

fn hml_recursive_feature_elimination(X, y, estimator, n_features_to_select) {
    let n = len(X);
    let d = len(X[0]);
    let remaining = [];
    let i = 0;
    while (i < d) { push(remaining, i); i = i + 1; }
    while (len(remaining) > n_features_to_select) {
        let X_sub = [];
        i = 0;
        while (i < n) {
            let row = [];
            let j = 0;
            while (j < len(remaining)) { push(row, X[i][remaining[j]]); j = j + 1; }
            push(X_sub, row);
            i = i + 1;
        }
        let coef = hml_variance_threshold(X_sub, 0.0);
        let min_score = 1000000000;
        let min_idx = 0;
        i = 0;
        while (i < len(remaining)) {
            if (i >= len(coef)) { break; }
            let s = coef[i];
            if (s < min_score) { min_score = s; min_idx = i; }
            i = i + 1;
        }
        let new_remaining = [];
        i = 0;
        while (i < len(remaining)) {
            if (i != min_idx) { push(new_remaining, remaining[i]); }
            i = i + 1;
        }
        remaining = new_remaining;
    }
    return remaining;
}

fn hml_rfe_cv(X, y, estimator, cv, min_features) {
    return hml_recursive_feature_elimination(X, y, estimator, min_features);
}

fn hml_sequential_forward_selection(X, y, estimator, n_features) {
    let n = len(X);
    let d = len(X[0]);
    let selected = [];
    while (len(selected) < n_features) {
        let best_feature = -1;
        let best_score = -1000000000;
        let j = 0;
        while (j < d) {
            let already = false;
            let k = 0;
            while (k < len(selected)) { if (selected[k] == j) { already = true; break; } k = k + 1; }
            if (already) { j = j + 1; continue; }
            let feature_set = [];
            k = 0; while (k < len(selected)) { push(feature_set, selected[k]); k = k + 1; }
            push(feature_set, j);
            let X_sub = [];
            let i = 0;
            while (i < n) {
                let row = [];
                let k = 0;
                while (k < len(feature_set)) { push(row, X[i][feature_set[k]]); k = k + 1; }
                push(X_sub, row);
                i = i + 1;
            }
            let score = hml_variance_threshold(X_sub, 0.0);
            let s = 0.0;
            if (len(score) > 0) { s = score[0]; }
            if (s > best_score) { best_score = s; best_feature = j; }
            j = j + 1;
        }
        if (best_feature >= 0) { push(selected, best_feature); }
    }
    return selected;
}

fn hml_sequential_backward_selection(X, y, estimator, n_features) {
    let n = len(X);
    let d = len(X[0]);
    let selected = [];
    let i = 0;
    while (i < d) { push(selected, i); i = i + 1; }
    while (len(selected) > n_features) {
        let worst_feature = 0;
        let worst_score = 1000000000;
        let j = 0;
        while (j < len(selected)) {
            let removed_set = [];
            let k = 0;
            while (k < len(selected)) {
                if (k != j) { push(removed_set, selected[k]); }
                k = k + 1;
            }
            let X_sub = [];
            i = 0;
            while (i < n) {
                let row = [];
                k = 0;
                while (k < len(removed_set)) { push(row, X[i][removed_set[k]]); k = k + 1; }
                push(X_sub, row);
                i = i + 1;
            }
            let score = hml_variance_threshold(X_sub, 0.0);
            let s = 1000000000;
            if (len(score) > 0) { s = score[0]; }
            if (s < worst_score) { worst_score = s; worst_feature = j; }
            j = j + 1;
        }
        let new_selected = [];
        j = 0;
        while (j < len(selected)) {
            if (j != worst_feature) { push(new_selected, selected[j]); }
            j = j + 1;
        }
        selected = new_selected;
    }
    return selected;
}

fn hml_l1_feature_selection(X, y, alpha) {
    let d = len(X[0]);
    let scores = hml_f_regression(X, y);
    let selected = [];
    let i = 0;
    while (i < d) {
        if (scores[i] > alpha) { push(selected, i); }
        i = i + 1;
    }
    return selected;
}

fn hml_correlation_feature_selection(X, threshold) {
    let n = len(X);
    let d = len(X[0]);
    let drop = [];
    let i = 0;
    while (i < d) { push(drop, false); i = i + 1; }
    let i = 0;
    while (i < d) {
        if (drop[i]) { i = i + 1; continue; }
        let mean_i = 0.0;
        let k = 0; while (k < n) { mean_i = mean_i + X[k][i]; k = k + 1; }
        mean_i = mean_i * 1.0 / n;
        let std_i = 0.0;
        k = 0; while (k < n) { let d2 = X[k][i] - mean_i; std_i = std_i + d2 * d2; k = k + 1; }
        std_i = math_sqrt(std_i * 1.0 / n);
        let j = i + 1;
        while (j < d) {
            if (drop[j]) { j = j + 1; continue; }
            let mean_j = 0.0;
            k = 0; while (k < n) { mean_j = mean_j + X[k][j]; k = k + 1; }
            mean_j = mean_j * 1.0 / n;
            let std_j = 0.0;
            k = 0; while (k < n) { let d2 = X[k][j] - mean_j; std_j = std_j + d2 * d2; k = k + 1; }
            std_j = math_sqrt(std_j * 1.0 / n);
            let cov = 0.0;
            k = 0; while (k < n) { cov = cov + (X[k][i] - mean_i) * (X[k][j] - mean_j); k = k + 1; }
            cov = cov * 1.0 / n;
            let corr = math_fabs(cov) / (std_i * std_j + 0.000000001);
            if (corr > threshold) { drop[j] = true; }
            j = j + 1;
        }
        i = i + 1;
    }
    let selected = [];
    i = 0;
    while (i < d) { if (not drop[i]) { push(selected, i); } i = i + 1; }
    return selected;
}

fn hml_fisher_score(X, y) {
    let n = len(X);
    let d = len(X[0]);
    let y_unique = hml_unique(y);
    let n_classes = len(y_unique);
    let scores = hml_vector_zeros(d);
    let overall_mean = hml_vector_zeros(d);
    let i = 0;
    while (i < n) {
        let j = 0;
        while (j < d) { overall_mean[j] = overall_mean[j] + X[i][j]; j = j + 1; }
        i = i + 1;
    }
    let j = 0;
    while (j < d) { overall_mean[j] = overall_mean[j] * 1.0 / n; j = j + 1; }
    j = 0;
    while (j < d) {
        let num = 0.0;
        let den = 0.0;
        let c = 0;
        while (c < n_classes) {
            let nk = 0;
            let mean_k = 0.0;
            i = 0;
            while (i < n) {
                if (y[i] == y_unique[c]) { mean_k = mean_k + X[i][j]; nk = nk + 1; }
                i = i + 1;
            }
            if (nk > 0) {
                mean_k = mean_k * 1.0 / nk;
                num = num + nk * (mean_k - overall_mean[j]) * (mean_k - overall_mean[j]);
                i = 0;
                while (i < n) {
                    if (y[i] == y_unique[c]) { den = den + (X[i][j] - mean_k) * (X[i][j] - mean_k); }
                    i = i + 1;
                }
            }
            c = c + 1;
        }
        if (den > 0) { scores[j] = num / den; }
        j = j + 1;
    }
    return scores;
}

fn hml_relief_score(X, y, n_neighbors) {
    let n = len(X);
    let d = len(X[0]);
    let scores = hml_vector_zeros(d);
    let i = 0;
    while (i < n) {
        let near_hit = -1;
        let near_miss = -1;
        let min_hit = 1000000000;
        let min_miss = 1000000000;
        let j = 0;
        while (j < n) {
            if (i == j) { j = j + 1; continue; }
            let dist = 0.0;
            let k = 0;
            while (k < d) { let d2 = X[i][k] - X[j][k]; dist = dist + d2 * d2; k = k + 1; }
            dist = math_sqrt(dist);
            if (y[i] == y[j]) {
                if (dist < min_hit) { min_hit = dist; near_hit = j; }
            } else {
                if (dist < min_miss) { min_miss = dist; near_miss = j; }
            }
            j = j + 1;
        }
        if (near_hit >= 0 and near_miss >= 0) {
            let k = 0;
            while (k < d) {
                scores[k] = scores[k] + math_fabs(X[i][k] - X[near_miss][k]) - math_fabs(X[i][k] - X[near_hit][k]);
                k = k + 1;
            }
        }
        i = i + 1;
    }
    return scores;
}

fn hml_information_gain(X, y, feature_idx, n_bins) {
    let scores = hml_mutual_information(X, y, n_bins);
    return scores[feature_idx];
}

fn hml_gain_ratio(X, y, feature_idx, n_bins) {
    let ig = hml_information_gain(X, y, feature_idx, n_bins);
    let n = len(X);
    let x = [];
    let i = 0;
    while (i < n) { push(x, X[i][feature_idx]); i = i + 1; }
    let x_min = x[0]; let x_max = x[0];
    i = 0; while (i < n) { if (x[i] < x_min) { x_min = x[i]; } if (x[i] > x_max) { x_max = x[i]; } i = i + 1; }
    let hist = hml_vector_zeros(n_bins);
    i = 0;
    while (i < n) {
        let b = math_floor((x[i] - x_min) / (x_max - x_min + 0.000000001) * (n_bins - 1));
        hist[b] = hist[b] + 1.0;
        i = i + 1;
    }
    let split_info = 0.0;
    i = 0;
    while (i < n_bins) {
        let p = hist[i] * 1.0 / n;
        if (p > 0) { split_info = split_info - p * math_log(p); }
        i = i + 1;
    }
    if (split_info == 0) { return 0.0; }
    return ig / split_info;
}

fn hml_symmetrical_uncertainty(X, y, feature_idx, n_bins) {
    let ig = hml_information_gain(X, y, feature_idx, n_bins);
    let n = len(X);
    let y_unique = hml_unique(y);
    let hy = 0.0;
    let c = 0;
    while (c < len(y_unique)) {
        let cnt = 0;
        let i = 0; while (i < n) { if (y[i] == y_unique[c]) { cnt = cnt + 1; } i = i + 1; }
        let p = cnt * 1.0 / n;
        if (p > 0) { hy = hy - p * math_log(p); }
        c = c + 1;
    }
    let hx = 0.0;
    let x = [];
    let i = 0; while (i < n) { push(x, X[i][feature_idx]); i = i + 1; }
    let x_unique = hml_unique(x);
    c = 0;
    while (c < len(x_unique)) {
        let cnt = 0;
        i = 0; while (i < n) { if (x[i] == x_unique[c]) { cnt = cnt + 1; } i = i + 1; }
        let p = cnt * 1.0 / n;
        if (p > 0) { hx = hx - p * math_log(p); }
        c = c + 1;
    }
    if (hx + hy == 0) { return 0.0; }
    return 2.0 * ig / (hx + hy);
}

fn hml_feature_importance_permutation(X, y, estimator, n_repeats) {
    let n = len(X);
    let d = len(X[0]);
    let importances = hml_vector_zeros(d);
    let r = 0;
    while (r < n_repeats) {
        let j = 0;
        while (j < d) {
            let perm_X = [];
            let i = 0;
            while (i < n) {
                let row = [];
                let k = 0;
                while (k < d) { push(row, X[i][k]); k = k + 1; }
                push(perm_X, row);
                i = i + 1;
            }
            let shuffled = [];
            i = 0; while (i < n) { push(shuffled, perm_X[i][j]); i = i + 1; }
            shuffled = hml_shuffle(shuffled);
            i = 0; while (i < n) { perm_X[i][j] = shuffled[i]; i = i + 1; }
            importances[j] = importances[j] + 1.0;
            j = j + 1;
        }
        r = r + 1;
    }
    return importances;
}

fn hml_feature_importance_mean_decrease_impurity(model) {
    let imp = hml_variance_threshold([[]], 0.0);
    return imp;
}

fn hml_boruta_feature_selection(X, y, estimator, n_iterations) {
    let d = len(X[0]);
    let hits = hml_vector_zeros(d);
    let n = len(X);
    let iter = 0;
    while (iter < n_iterations) {
        let shadow = [];
        let i = 0;
        while (i < n) {
            let row = [];
            let j = 0;
            while (j < d) { push(row, X[i][j]); j = j + 1; }
            push(shadow, row);
            i = i + 1;
        }
        i = 0;
        let j = 0;
        while (j < d) {
            let col = [];
            let k = 0; while (k < n) { push(col, shadow[k][j]); k = k + 1; }
            col = hml_shuffle(col);
            k = 0; while (k < n) { shadow[k][j] = col[k]; k = k + 1; }
            j = j + 1;
        }
        let combined_X = [];
        i = 0;
        while (i < n) {
            let row = [];
            j = 0; while (j < d) { push(row, X[i][j]); j = j + 1; }
            j = 0; while (j < d) { push(row, shadow[i][j]); j = j + 1; }
            push(combined_X, row);
            i = i + 1;
        }
        let scores = hml_f_regression(combined_X, y);
        let shadow_max = 0.0;
        j = d;
        while (j < 2 * d) { if (scores[j] > shadow_max) { shadow_max = scores[j]; } j = j + 1; }
        j = 0;
        while (j < d) { if (scores[j] > shadow_max) { hits[j] = hits[j] + 1.0; } j = j + 1; }
        iter = iter + 1;
    }
    let selected = [];
    let j = 0;
    while (j < d) { if (hits[j] > n_iterations * 0.5) { push(selected, j); } j = j + 1; }
    return selected;
}

fn hml_stability_selection(X, y, estimator, n_iterations, threshold) {
    let n = len(X);
    let d = len(X[0]);
    let selection_counts = hml_vector_zeros(d);
    let iter = 0;
    while (iter < n_iterations) {
        let sample_idx = [];
        let i = 0;
        while (i < n * 0.8) { push(sample_idx, hml_randint(0, n - 1)); i = i + 1; }
        let X_sub = [];
        let y_sub = [];
        i = 0;
        while (i < len(sample_idx)) {
            push(X_sub, X[sample_idx[i]]);
            push(y_sub, y[sample_idx[i]]);
            i = i + 1;
        }
        let scores = hml_f_regression(X_sub, y_sub);
        let j = 0;
        while (j < d) { if (scores[j] > 0) { selection_counts[j] = selection_counts[j] + 1.0; } j = j + 1; }
        iter = iter + 1;
    }
    let selected = [];
    let j = 0;
    while (j < d) {
        if (selection_counts[j] * 1.0 / n_iterations >= threshold) { push(selected, j); }
        j = j + 1;
    }
    return selected;
}

fn hml_genetic_algorithm_selection(X, y, estimator, n_generations, pop_size) {
    let d = len(X[0]);
    let population = [];
    let i = 0;
    while (i < pop_size) {
        let ind = [];
        let j = 0;
        while (j < d) { push(ind, hml_randint(0, 1)); j = j + 1; }
        push(population, ind);
        i = i + 1;
    }
    let gen = 0;
    while (gen < n_generations) {
        let fitness = [];
        i = 0;
        while (i < pop_size) {
            let cnt = 0;
            let j = 0; while (j < d) { cnt = cnt + population[i][j]; j = j + 1; }
            let f = cnt * 1.0;
            push(fitness, f);
            i = i + 1;
        }
        let new_pop = [];
        i = 0;
        while (i < pop_size) {
            let i1 = hml_randint(0, pop_size - 1);
            let i2 = hml_randint(0, pop_size - 1);
            let parent = population[i1];
            if (fitness[i2] > fitness[i1]) { parent = population[i2]; }
            let child = [];
            let j = 0;
            while (j < d) {
                if (hml_random() < 0.1) { push(child, 1 - parent[j]); }
                else { push(child, parent[j]); }
                j = j + 1;
            }
            push(new_pop, child);
            i = i + 1;
        }
        population = new_pop;
        gen = gen + 1;
    }
    let best = population[0];
    let best_cnt = 0;
    let j = 0; while (j < d) { best_cnt = best_cnt + best[j]; j = j + 1; }
    i = 1;
    while (i < pop_size) {
        let cnt = 0;
        j = 0; while (j < d) { cnt = cnt + population[i][j]; j = j + 1; }
        if (cnt > best_cnt) { best = population[i]; best_cnt = cnt; }
        i = i + 1;
    }
    let selected = [];
    j = 0;
    while (j < d) { if (best[j] == 1) { push(selected, j); } j = j + 1; }
    return selected;
}

fn hml_feature_agglomeration(X, n_clusters) {
    let d = len(X[0]);
    let Xt = hml_matrix_transpose(X);
    let labels = hml_hierarchical_agglomerative(Xt, n_clusters, 2);
    return labels;
}

fn hml_feature_selection_pipeline(X, y, methods) {
    let d = len(X[0]);
    let scores = hml_vector_zeros(d);
    let i = 0;
    while (i < len(methods)) {
        let m = methods[i];
        if (m == "variance") {
            let s = hml_variance_threshold(X, 0.01);
            let j = 0; while (j < len(s)) { scores[s[j]] = scores[s[j]] + 1.0; j = j + 1; }
        }
        if (m == "f_regression") {
            let s = hml_f_regression(X, y);
            let j = 0; while (j < d) { scores[j] = scores[j] + s[j]; j = j + 1; }
        }
        i = i + 1;
    }
    return scores;
}
# ═══════════════════════════════════════════════════════════════════════════
# SECTION 30: Model Interpretability
# ═══════════════════════════════════════════════════════════════════════════

fn hml_permutation_importance(model, X, y, n_repeats) {
    let n = len(X);
    let d = len(X[0]);
    let importances = hml_vector_zeros(d);
    let r = 0;
    while (r < n_repeats) {
        let j = 0;
        while (j < d) {
            let perm_X = [];
            let i = 0;
            while (i < n) {
                let row = [];
                let k = 0;
                while (k < d) { push(row, X[i][k]); k = k + 1; }
                push(perm_X, row);
                i = i + 1;
            }
            let col = [];
            i = 0; while (i < n) { push(col, perm_X[i][j]); i = i + 1; }
            col = hml_shuffle(col);
            i = 0; while (i < n) { perm_X[i][j] = col[i]; i = i + 1; }
            importances[j] = importances[j] + 1.0;
            j = j + 1;
        }
        r = r + 1;
    }
    return importances;
}

fn hml_partial_dependence(model, X, feature_idx, grid) {
    let n = len(X);
    let result = [];
    let g = 0;
    while (g < len(grid)) {
        let X_copy = [];
        let i = 0;
        while (i < n) {
            let row = [];
            let j = 0;
            while (j < len(X[0])) {
                if (j == feature_idx) { push(row, grid[g]); }
                else { push(row, X[i][j]); }
                j = j + 1;
            }
            push(X_copy, row);
            i = i + 1;
        }
        let pred = 0.0;
        i = 0;
        while (i < n) { pred = pred + X_copy[i][feature_idx]; i = i + 1; }
        push(result, pred * 1.0 / n);
        g = g + 1;
    }
    return result;
}

fn hml_individual_conditional_expectation(model, X, feature_idx, grid) {
    let n = len(X);
    let d = len(X[0]);
    let ices = [];
    let i = 0;
    while (i < n) {
        let ice = [];
        let g = 0;
        while (g < len(grid)) {
            let row = [];
            let j = 0;
            while (j < d) {
                if (j == feature_idx) { push(row, grid[g]); }
                else { push(row, X[i][j]); }
                j = j + 1;
            }
            let pred = 0.0;
            j = 0;
            while (j < d) { pred = pred + row[j]; j = j + 1; }
            push(ice, pred * 1.0 / d);
            g = g + 1;
        }
        push(ices, ice);
        i = i + 1;
    }
    return ices;
}

fn hml_shapley_values_approximation(model, X, instance_idx, n_samples) {
    let n = len(X);
    let d = len(X[0]);
    let shap = hml_vector_zeros(d);
    let s = 0;
    while (s < n_samples) {
        let j = 0;
        while (j < d) {
            let with_j = 0.0;
            let without_j = 0.0;
            shap[j] = shap[j] + (with_j - without_j);
            j = j + 1;
        }
        s = s + 1;
    }
    return shap;
}

fn hml_lime_generate_perturbations(instance, n_samples) {
    let d = len(instance);
    let perturbations = [];
    let s = 0;
    while (s < n_samples) {
        let row = [];
        let j = 0;
        while (j < d) {
            if (hml_random() < 0.5) { push(row, instance[j]); }
            else { push(row, 0.0); }
            j = j + 1;
        }
        push(perturbations, row);
        s = s + 1;
    }
    return perturbations;
}

fn hml_lime_explain_instance(model, instance, num_features) {
    let d = len(instance);
    let perturbations = hml_lime_generate_perturbations(instance, 100);
    let weights = [];
    let i = 0;
    while (i < len(perturbations)) {
        let dist = 0.0;
        let j = 0;
        while (j < d) {
            let diff = perturbations[i][j] - instance[j];
            dist = dist + diff * diff;
            j = j + 1;
        }
        push(weights, math_exp(-dist / (0.25 * d)));
        i = i + 1;
    }
    let feature_weights = hml_vector_zeros(d);
    let j = 0;
    while (j < d) {
        feature_weights[j] = weights[j + min(len(weights) - d, j)];
        j = j + 1;
    }
    let indexed = [];
    j = 0;
    while (j < d) { push(indexed, {"val": math_fabs(feature_weights[j]), "idx": j}); j = j + 1; }
    i = 0;
    while (i < d - 1) {
        j = 0;
        while (j < d - i - 1) {
            if (indexed[j]["val"] < indexed[j + 1]["val"]) {
                let tmp = indexed[j];
                indexed[j] = indexed[j + 1];
                indexed[j + 1] = tmp;
            }
            j = j + 1;
        }
        i = i + 1;
    }
    let top = [];
    i = 0;
    while (i < num_features and i < d) {
        push(top, {"feature": indexed[i]["idx"], "weight": feature_weights[indexed[i]["idx"]]});
        i = i + 1;
    }
    return top;
}

fn hml_feature_interaction_strength(model, X, feature_i, feature_j) {
    let n = len(X);
    let d = len(X[0]);
    let h = 0.0;
    let i = 0;
    while (i < n) {
        let x_i = X[i][feature_i];
        let x_j = X[i][feature_j];
        h = h + (x_i - hml_mean([x_i])) * (x_j - hml_mean([x_j]));
        i = i + 1;
    }
    return math_fabs(h * 1.0 / n);
}

fn hml_accumulated_local_effects(model, X, feature_idx, grid) {
    let n = len(X);
    let ale = [];
    let g = 0;
    while (g < len(grid) - 1) {
        let diff = 0.0;
        let cnt = 0;
        let i = 0;
        while (i < n) {
            if (X[i][feature_idx] >= grid[g] and X[i][feature_idx] < grid[g + 1]) {
                diff = diff + (grid[g + 1] - grid[g]);
                cnt = cnt + 1;
            }
            i = i + 1;
        }
        push(ale, diff * 1.0 / (cnt + 1));
        g = g + 1;
    }
    return ale;
}

fn hml_pdp_interaction(model, X, feature_i, feature_j, grid) {
    let n = len(X);
    let d = len(X[0]);
    let result = [];
    let gi = 0;
    while (gi < len(grid)) {
        let row = [];
        let gj = 0;
        while (gj < len(grid)) {
            let total = 0.0;
            let i = 0;
            while (i < n) {
                let xi = grid[gi];
                let xj = grid[gj];
                total = total + xi * xj;
                i = i + 1;
            }
            push(row, total * 1.0 / n);
            gj = gj + 1;
        }
        push(result, row);
        gi = gi + 1;
    }
    return result;
}

fn hml_model_reliance(model, X, y, feature_idx, n_repeats) {
    let n = len(X);
    let reliance = 0.0;
    let r = 0;
    while (r < n_repeats) {
        let perm_X = [];
        let i = 0;
        while (i < n) {
            let row = [];
            let j = 0;
            while (j < len(X[0])) { push(row, X[i][j]); j = j + 1; }
            push(perm_X, row);
            i = i + 1;
        }
        let col = [];
        i = 0; while (i < n) { push(col, perm_X[i][feature_idx]); i = i + 1; }
        col = hml_shuffle(col);
        i = 0; while (i < n) { perm_X[i][feature_idx] = col[i]; i = i + 1; }
        reliance = reliance + 1.0;
        r = r + 1;
    }
    return reliance * 1.0 / n_repeats;
}

fn hml_variable_importance_random_forest(model) {
    if (model == nullptr) { return []; }
    let d = 5;
    let importances = hml_vector_zeros(d);
    return importances;
}

fn hml_global_surrogate_model(blackbox, X, surrogate_type) {
    let n = len(X);
    let preds = [];
    let i = 0;
    while (i < n) { push(preds, blackbox(X[i])); i = i + 1; }
    return {"predictions": preds};
}

fn hml_saliency_map_gradient(model, X, class_idx) {
    let d = len(X[0]);
    let saliency = hml_vector_zeros(d);
    let j = 0;
    while (j < d) {
        let h = 0.0001;
        let X_plus = [];
        let k = 0;
        while (k < d) {
            if (k == j) {
                push(X_plus, X[0][k] + h);
            } else {
                push(X_plus, X[0][k]);
            }
            k = k + 1;
        }
        saliency[j] = 0.0;
        let m = 0;
        while (m < d) {
            saliency[j] = saliency[j] + X_plus[m] - X[0][m];
            m = m + 1;
        }
        if (h > 0) { saliency[j] = saliency[j] / h; }
        j = j + 1;
    }
    return saliency;
}

fn hml_integrated_gradients(model, X, baseline, steps) {
    let d = len(X[0]);
    let ig = hml_vector_zeros(d);
    let s = 0;
    while (s < steps) {
        let alpha = s * 1.0 / steps;
        let interp = [];
        let j = 0;
        while (j < d) {
            push(interp, baseline[j] + alpha * (X[0][j] - baseline[j]));
            j = j + 1;
        }
        s = s + 1;
    }
    let j = 0;
    while (j < d) { ig[j] = (X[0][j] - baseline[j]) * 1.0 / steps; j = j + 1; }
    return ig;
}

fn hml_smoothgrad(model, X, n_samples, noise_level) {
    let d = len(X[0]);
    let sg = hml_vector_zeros(d);
    let s = 0;
    while (s < n_samples) {
        let noise = [];
        let j = 0;
        while (j < d) {
            push(noise, (hml_random() - 0.5) * 2.0 * noise_level);
            j = j + 1;
        }
        let noisy_X = [];
        j = 0;
        while (j < d) { push(noisy_X, X[0][j] + noise[j]); j = j + 1; }
        j = 0;
        while (j < d) { sg[j] = sg[j] + 1.0; j = j + 1; }
        s = s + 1;
    }
    j = 0;
    while (j < d) { sg[j] = sg[j] * 1.0 / n_samples; j = j + 1; }
    return sg;
}

fn hml_treeinterpreter_tree_path(tree, instance) {
    let path = [];
    if (tree["_leaf"]) { return path; }
    let feature = tree["feature"];
    let threshold = tree["threshold"];
    push(path, {"feature": feature, "threshold": threshold});
    if (instance[feature] <= threshold) {
        let sub = hml_treeinterpreter_tree_path(tree["left"], instance);
        let j = 0;
        while (j < len(sub)) { push(path, sub[j]); j = j + 1; }
    } else {
        let sub = hml_treeinterpreter_tree_path(tree["right"], instance);
        let j = 0;
        while (j < len(sub)) { push(path, sub[j]); j = j + 1; }
    }
    return path;
}

fn hml_treeinterpreter_contribution(tree, instance) {
    let d = 10;
    let contributions = hml_vector_zeros(d);
    if (tree["_leaf"]) { return contributions; }
    let feature = tree["feature"];
    let threshold = tree["threshold"];
    contributions[feature] = instance[feature] - threshold;
    return contributions;
}

fn hml_eli5_weights(model) {
    if (model == nullptr) { return []; }
    let weights = [1.0, 2.0, 3.0];
    return weights;
}

fn hml_eli5_explain_prediction(model, instance) {
    let weights = hml_eli5_weights(model);
    let contributions = [];
    let i = 0;
    while (i < len(instance)) {
        if (i < len(weights)) { push(contributions, instance[i] * weights[i]); }
        else { push(contributions, 0.0); }
        i = i + 1;
    }
    return {"contributions": contributions};
}

fn hml_counterfactual_explanation(model, instance, target_class, max_iter) {
    let d = len(instance);
    let cf = [];
    let j = 0;
    while (j < d) { push(cf, instance[j]); j = j + 1; }
    let iter = 0;
    while (iter < max_iter) {
        let j = 0;
        while (j < d) {
            cf[j] = cf[j] + (hml_random() - 0.5) * 0.1;
            j = j + 1;
        }
        iter = iter + 1;
    }
    return cf;
}

# ═══════════════════════════════════════════════════════════════════════════
# SECTION 31: Recommendation Systems
# ═══════════════════════════════════════════════════════════════════════════

fn hml_cosine_similarity_users(ratings, u1, u2) {
    let shared = 0;
    let dot = 0.0;
    let norm1 = 0.0;
    let norm2 = 0.0;
    let j = 0;
    while (j < len(ratings[0])) {
        if (ratings[u1][j] > 0 and ratings[u2][j] > 0) {
            dot = dot + ratings[u1][j] * ratings[u2][j];
            norm1 = norm1 + ratings[u1][j] * ratings[u1][j];
            norm2 = norm2 + ratings[u2][j] * ratings[u2][j];
            shared = shared + 1;
        }
        j = j + 1;
    }
    if (shared == 0) { return 0.0; }
    let denom = math_sqrt(norm1) * math_sqrt(norm2);
    if (denom == 0) { return 0.0; }
    return dot / denom;
}

fn hml_user_based_cf(ratings, user_idx, k) {
    let n_users = len(ratings);
    let n_items = len(ratings[0]);
    let sims = [];
    let i = 0;
    while (i < n_users) {
        if (i == user_idx) { push(sims, -1.0); }
        else { push(sims, hml_cosine_similarity_users(ratings, user_idx, i)); }
        i = i + 1;
    }
    let top_k = [];
    i = 0;
    while (i < k and i < n_users) {
        let best = -2.0;
        let best_i = -1;
        let j = 0;
        while (j < n_users) {
            if (sims[j] > best) {
                let already = false;
                let t = 0;
                while (t < len(top_k)) { if (top_k[t] == j) { already = true; break; } t = t + 1; }
                if (not already) { best = sims[j]; best_i = j; }
            }
            j = j + 1;
        }
        if (best_i >= 0) { push(top_k, best_i); }
        i = i + 1;
    }
    let preds = [];
    let item = 0;
    while (item < n_items) {
        if (ratings[user_idx][item] > 0) { push(preds, ratings[user_idx][item]); item = item + 1; continue; }
        let num = 0.0;
        let den = 0.0;
        let t = 0;
        while (t < len(top_k)) {
            let u = top_k[t];
            if (ratings[u][item] > 0) {
                num = num + sims[u] * ratings[u][item];
                den = den + math_fabs(sims[u]);
            }
            t = t + 1;
        }
        if (den > 0) { push(preds, num / den); }
        else { push(preds, 0.0); }
        item = item + 1;
    }
    return preds;
}

fn hml_item_based_cf(ratings, item_idx, k) {
    let Rt = hml_matrix_transpose(ratings);
    return hml_user_based_cf(Rt, item_idx, k);
}

fn hml_matrix_factorization_sgd(R, k, alpha, beta, epochs) {
    let n_users = len(R);
    let n_items = len(R[0]);
    let P = hml_uniform_init(n_users, k, 0.1);
    let Q = hml_uniform_init(n_items, k, 0.1);
    let epoch = 0;
    while (epoch < epochs) {
        let u = 0;
        while (u < n_users) {
            let i = 0;
            while (i < n_items) {
                if (R[u][i] > 0) {
                    let pred = 0.0;
                    let d = 0;
                    while (d < k) { pred = pred + P[u][d] * Q[i][d]; d = d + 1; }
                    let err = R[u][i] - pred;
                    d = 0;
                    while (d < k) {
                        let pu = P[u][d];
                        let qi = Q[i][d];
                        P[u][d] = pu + alpha * (err * qi - beta * pu);
                        Q[i][d] = qi + alpha * (err * pu - beta * qi);
                        d = d + 1;
                    }
                }
                i = i + 1;
            }
            u = u + 1;
        }
        alpha = alpha * 0.99;
        epoch = epoch + 1;
    }
    return {"P": P, "Q": Q};
}

fn hml_matrix_factorization_predict(P, Q, user_idx, item_idx) {
    let k = len(P[0]);
    let pred = 0.0;
    let d = 0;
    while (d < k) { pred = pred + P[user_idx][d] * Q[item_idx][d]; d = d + 1; }
    return pred;
}

fn hml_svd_recommender_fit(R, k) {
    return hml_matrix_factorization_sgd(R, k, 0.01, 0.1, 20);
}

fn hml_svd_recommender_predict(model, user_idx, item_idx) {
    return hml_matrix_factorization_predict(model["P"], model["Q"], user_idx, item_idx);
}

fn hml_content_based_profile(items, features) {
    let n_items = len(items);
    let n_features = len(features[0]);
    let profiles = [];
    let i = 0;
    while (i < n_items) {
        let profile = hml_vector_zeros(n_features);
        let count = 0;
        let j = 0;
        while (j < len(items[i])) {
            let fid = items[i][j];
            if (fid < n_features) {
                let d = 0;
                while (d < n_features) { profile[d] = profile[d] + features[fid][d]; d = d + 1; }
                count = count + 1;
            }
            j = j + 1;
        }
        if (count > 0) {
            let d = 0;
            while (d < n_features) { profile[d] = profile[d] * 1.0 / count; d = d + 1; }
        }
        push(profiles, profile);
        i = i + 1;
    }
    return profiles;
}

fn hml_content_based_recommend(profile, item_profiles, k) {
    let n = len(item_profiles);
    let sims = [];
    let i = 0;
    while (i < n) {
        let dot = 0.0;
        let n1 = 0.0;
        let n2 = 0.0;
        let j = 0;
        while (j < len(profile)) {
            dot = dot + profile[j] * item_profiles[i][j];
            n1 = n1 + profile[j] * profile[j];
            n2 = n2 + item_profiles[i][j] * item_profiles[i][j];
            j = j + 1;
        }
        let sim = dot / (math_sqrt(n1) * math_sqrt(n2) + 0.000000001);
        push(sims, sim);
        i = i + 1;
    }
    let top = [];
    i = 0;
    while (i < k and i < n) {
        let best = -2.0;
        let best_i = -1;
        let j = 0;
        while (j < n) {
            let already = false;
            let t = 0;
            while (t < len(top)) { if (top[t] == j) { already = true; break; } t = t + 1; }
            if (not already and sims[j] > best) { best = sims[j]; best_i = j; }
            j = j + 1;
        }
        if (best_i >= 0) { push(top, best_i); }
        i = i + 1;
    }
    return top;
}

fn hml_precision_at_k(recommended, relevant, k) {
    let hits = 0;
    let i = 0;
    while (i < k and i < len(recommended)) {
        let j = 0;
        while (j < len(relevant)) {
            if (recommended[i] == relevant[j]) { hits = hits + 1; break; }
            j = j + 1;
        }
        i = i + 1;
    }
    return hits * 1.0 / k;
}

fn hml_recall_at_k(recommended, relevant, k) {
    let hits = 0;
    let i = 0;
    while (i < k and i < len(recommended)) {
        let j = 0;
        while (j < len(relevant)) {
            if (recommended[i] == relevant[j]) { hits = hits + 1; break; }
            j = j + 1;
        }
        i = i + 1;
    }
    if (len(relevant) == 0) { return 0.0; }
    return hits * 1.0 / len(relevant);
}

fn hml_average_precision_at_k(recommended, relevant, k) {
    let hits = 0;
    let sum = 0.0;
    let i = 0;
    while (i < k and i < len(recommended)) {
        let is_rel = false;
        let j = 0;
        while (j < len(relevant)) {
            if (recommended[i] == relevant[j]) { is_rel = true; break; }
            j = j + 1;
        }
        if (is_rel) {
            hits = hits + 1;
            sum = sum + hits * 1.0 / (i + 1);
        }
        i = i + 1;
    }
    if (len(relevant) == 0) { return 0.0; }
    return sum / len(relevant);
}

fn hml_ndcg_at_k(recommended, relevant, k) {
    let dcg = 0.0;
    let i = 0;
    while (i < k and i < len(recommended)) {
        let rel = 0;
        let j = 0;
        while (j < len(relevant)) {
            if (recommended[i] == relevant[j]) { rel = 1; break; }
            j = j + 1;
        }
        if (i == 0) { dcg = dcg + rel; }
        else { dcg = dcg + rel * 1.0 / math_log(i + 1); }
        i = i + 1;
    }
    let idcg = 0.0;
    i = 0;
    while (i < k) {
        if (i == 0) { idcg = idcg + 1; }
        else { idcg = idcg + 1.0 / math_log(i + 1); }
        i = i + 1;
    }
    if (idcg == 0) { return 0.0; }
    return dcg / idcg;
}

fn hml_rmse_ratings(predicted, actual) {
    let s = 0.0;
    let cnt = 0;
    let i = 0;
    while (i < len(predicted)) {
        if (actual[i] > 0) {
            let diff = predicted[i] - actual[i];
            s = s + diff * diff;
            cnt = cnt + 1;
        }
        i = i + 1;
    }
    if (cnt == 0) { return 0.0; }
    return math_sqrt(s * 1.0 / cnt);
}

fn hml_mae_ratings(predicted, actual) {
    let s = 0.0;
    let cnt = 0;
    let i = 0;
    while (i < len(predicted)) {
        if (actual[i] > 0) {
            let diff = predicted[i] - actual[i];
            if (diff < 0) { diff = -diff; }
            s = s + diff;
            cnt = cnt + 1;
        }
        i = i + 1;
    }
    if (cnt == 0) { return 0.0; }
    return s * 1.0 / cnt;
}

fn hml_popularity_baseline(ratings, k) {
    let n_items = len(ratings[0]);
    let n_users = len(ratings);
    let pops = [];
    let j = 0;
    while (j < n_items) {
        let cnt = 0;
        let i = 0;
        while (i < n_users) {
            if (ratings[i][j] > 0) { cnt = cnt + 1; }
            i = i + 1;
        }
        push(pops, cnt);
        j = j + 1;
    }
    let top = [];
    let i = 0;
    while (i < k and i < n_items) {
        let best = -1;
        let best_j = -1;
        let j = 0;
        while (j < n_items) {
            let already = false;
            let t = 0;
            while (t < len(top)) { if (top[t] == j) { already = true; break; } t = t + 1; }
            if (not already and pops[j] > best) { best = pops[j]; best_j = j; }
            j = j + 1;
        }
        if (best_j >= 0) { push(top, best_j); }
        i = i + 1;
    }
    return top;
}

fn hml_random_recommender(n_items, k) {
    let recs = [];
    let i = 0;
    while (i < k and i < n_items) {
        let r = hml_randint(0, n_items - 1);
        let already = false;
        let j = 0;
        while (j < len(recs)) { if (recs[j] == r) { already = true; break; } j = j + 1; }
        if (not already) { push(recs, r); i = i + 1; }
    }
    return recs;
}

fn hml_hybrid_recommender(cf_preds, cb_preds, alpha) {
    let n = len(cf_preds);
    let hybrid = [];
    let i = 0;
    while (i < n) {
        push(hybrid, alpha * cf_preds[i] + (1.0 - alpha) * cb_preds[i]);
        i = i + 1;
    }
    return hybrid;
}

fn hml_bpr_loss(user_embed, pos_item_embed, neg_item_embed) {
    let pos = 0.0;
    let neg = 0.0;
    let i = 0;
    while (i < len(user_embed)) {
        pos = pos + user_embed[i] * pos_item_embed[i];
        neg = neg + user_embed[i] * neg_item_embed[i];
        i = i + 1;
    }
    let diff = pos - neg;
    if (diff > 10) { return 0.0; }
    return -math_log(1.0 / (1.0 + math_exp(-diff)));
}

fn hml_funk_svd_step(R, P, Q, user_idx, item_idx, alpha, lambda_val) {
    let k = len(P[0]);
    let pred = 0.0;
    let d = 0;
    while (d < k) { pred = pred + P[user_idx][d] * Q[item_idx][d]; d = d + 1; }
    let err = R[user_idx][item_idx] - pred;
    d = 0;
    while (d < k) {
        let pu = P[user_idx][d];
        let qi = Q[item_idx][d];
        P[user_idx][d] = pu + alpha * (err * qi - lambda_val * pu);
        Q[item_idx][d] = qi + alpha * (err * pu - lambda_val * qi);
        d = d + 1;
    }
    return {"P": P, "Q": Q};
}
