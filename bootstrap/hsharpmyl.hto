# ── PipelineVerbose ──
class PipelineVerbose {
    let steps = [];
    let verbose = 0;

    fn init_pipeline_verbose(steps, verbose) {
        self.steps = steps;
        if (verbose != nullptr) { self.verbose = verbose; }
        return 0;
    }

    fn fit(X, y) {
        let current = X;
        let i = 0;
        while (i < len(self.steps)) {
            let step = self.steps[i];
            if (step["fit"] != nullptr) {
                if (step["needs_y"] == 1) {
                    step["fit"](current, y);
                }
                else {
                    step["fit"](current);
                }
            }
            if (step["transform"] != nullptr) {
                current = step["transform"](current);
            }
            i = i + 1;
        }
        return 0;
    }

    fn predict(X) {
        let current = X;
        let i = 0;
        while (i < len(self.steps)) {
            let step = self.steps[i];
            if (step["transform"] != nullptr) {
                current = step["transform"](current);
            }
            i = i + 1;
        }
        let last = self.steps[len(self.steps) - 1];
        if (last["predict"] != nullptr) { return last["predict"](current); }
        return current;
    }

    fn transform(X) {
        let current = X;
        let i = 0;
        while (i < len(self.steps)) {
            let step = self.steps[i];
            if (step["transform"] != nullptr) {
                current = step["transform"](current);
            }
            i = i + 1;
        }
        return current;
    }

    fn fit_transform(X, y) {
        self.fit(X, y);
        return self.transform(X);
    }

    fn score(X, y) {
        let last = self.steps[len(self.steps) - 1];
        if (last["score"] != nullptr) { return last["score"](X, y); }
        return 0.0;
    }
}

# ── FeatureUnionExtended ──
class FeatureUnionExtended {
    let transformers = [];
    let weights = [];

    fn init_feature_union(transformers, weights) {
        self.transformers = transformers;
        self.weights = weights;
        return 0;
    }

    fn fit(X, y) {
        let i = 0;
        while (i < len(self.transformers)) {
            if (self.transformers[i]["fit"] != nullptr) {
                self.transformers[i]["fit"](X, y);
            }
            i = i + 1;
        }
        return 0;
    }

    fn transform(X) {
        let n = len(X);
        let result = [];
        let i = 0;
        while (i < n) {
            let combined = [];
            let t = 0;
            while (t < len(self.transformers)) {
                let feats = self.transformers[t]["transform"]([X[i]]);
                let w = 1.0;
                if (t < len(self.weights)) { w = self.weights[t]; }
                let f = 0;
                while (f < len(feats[0])) { push(combined, feats[0][f] * w); f = f + 1; }
                t = t + 1;
            }
            push(result, combined);
            i = i + 1;
        }
        return result;
    }

    fn fit_transform(X, y) {
        self.fit(X, y);
        return self.transform(X);
    }
}

# ── ParallelPipeline ──
class ParallelPipeline {
    let estimators = [];
    let results = [];

    fn init_parallel_pipeline(estimators) {
        self.estimators = estimators;
        self.results = [];
        return 0;
    }

    fn fit(X, y) {
        let k = len(self.estimators);
        let i = 0;
        while (i < k) {
            self.estimators[i]["fit"](X, y);
            i = i + 1;
        }
        return 0;
    }

    fn predict(X) {
        let n = len(X);
        let k = len(self.estimators);
        let preds = [];
        let i = 0;
        while (i < n) {
            let votes = {};
            let j = 0;
            while (j < k) {
                let p = self.estimators[j]["predict"]([X[i]]);
                let v = p[0];
                let c = 0;
                if (dict_keys(votes) != []) {
                    let keys = dict_keys(votes);
                    let found = 0;
                    let kk = 0;
                    while (kk < len(keys)) { if (keys[kk] == v) { found = 1; } kk = kk + 1; }
                    if (found == 1) { c = votes[v]; }
                }
                votes[v] = c + 1;
                j = j + 1;
            }
            let best = 0;
            let best_c = 0;
            let keys = dict_keys(votes);
            let kk = 0;
            while (kk < len(keys)) {
                if (votes[keys[kk]] > best_c) { best_c = votes[keys[kk]]; best = keys[kk]; }
                kk = kk + 1;
            }
            push(preds, best);
            i = i + 1;
        }
        return preds;
    }

    fn score(X, y) { return accuracy_score(self.predict(X), y); }
}

# ── DAGPipeline ──
class DAGPipeline {
    let nodes = {};
    let edges = [];
    let outputs = {};

    fn init_dag_pipeline() {
        self.nodes = {};
        self.edges = [];
        self.outputs = {};
        return 0;
    }

    fn add_node(name, estimator) {
        self.nodes[name] = estimator;
        return 0;
    }

    fn add_edge(from_name, to_name) {
        push(self.edges, {"from": from_name, "to": to_name});
        return 0;
    }

    fn fit(X, y) {
        self.outputs = {};
        self.outputs["__input__"] = X;
        let keys = dict_keys(self.nodes);
        let i = 0;
        while (i < len(keys)) {
            let name = keys[i];
            let node = self.nodes[name];
            let input_data = X;
            let j = 0;
            while (j < len(self.edges)) {
                if (self.edges[j]["to"] == name) {
                    input_data = self.outputs[self.edges[j]["from"]];
                }
                j = j + 1;
            }
            if (node["fit"] != nullptr) {
                node["fit"](input_data, y);
            }
            if (node["transform"] != nullptr) {
                self.outputs[name] = node["transform"](input_data);
            }
            else { self.outputs[name] = input_data; }
            i = i + 1;
        }
        return 0;
    }

    fn predict(X) {
        self.outputs = {};
        self.outputs["__input__"] = X;
        let keys = dict_keys(self.nodes);
        let i = 0;
        while (i < len(keys)) {
            let name = keys[i];
            let node = self.nodes[name];
            let input_data = X;
            let j = 0;
            while (j < len(self.edges)) {
                if (self.edges[j]["to"] == name) {
                    input_data = self.outputs[self.edges[j]["from"]];
                }
                j = j + 1;
            }
            if (node["transform"] != nullptr) {
                self.outputs[name] = node["transform"](input_data);
            }
            else { self.outputs[name] = input_data; }
            i = i + 1;
        }
        let last_key = keys[len(keys) - 1];
        let last = self.nodes[last_key];
        if (last["predict"] != nullptr) { return last["predict"](self.outputs[last_key]); }
        return self.outputs[last_key];
    }
}

