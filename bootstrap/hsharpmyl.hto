# SECTION 42: Ensemble Methods
# ═══════════════════════════════════════════════════════════════════════════

# ── RandomForestClassifier ──
class RandomForestClassifier {
    let n_estimators = 100;
    let max_depth = 10;
    let min_samples_split = 2;
    let max_features = nullptr;
    let estimators = [];
    let feature_importances = [];
    let n_classes = 0;

    fn init_random_forest_classifier(n_estimators, max_depth, min_samples_split, max_features) {
        if (n_estimators != nullptr) { self.n_estimators = n_estimators; }
        if (max_depth != nullptr) { self.max_depth = max_depth; }
        if (min_samples_split != nullptr) { self.min_samples_split = min_samples_split; }
        if (max_features != nullptr) { self.max_features = max_features; }
        self.estimators = [];
        return 0;
    }

    fn fit(X, y) {
        let n = len(X);
        let d = len(X[0]);
        let classes = hml_unique(y);
        self.n_classes = len(classes);
        let n_feat = d;
        if (self.max_features != nullptr) { n_feat = math_floor(math_sqrt(d * 1.0)); }
        let t = 0;
        while (t < self.n_estimators) {
            let sample_idx = [];
            let i = 0;
            while (i < n) {
                let r = hml_randint(0, n - 1);
                push(sample_idx, r);
                i = i + 1;
            }
            let tree = {
                "type": "decision_tree",
                "depth": self.max_depth,
                "min_split": self.min_samples_split,
                "n_features": n_feat,
                "selected_features": [],
                "root": nullptr
            };
            let k = 0;
            while (k < n_feat) {
                let fidx = hml_randint(0, d - 1);
                push(tree["selected_features"], fidx);
                k = k + 1;
            }
            let depth = 0;
            let node = self.build_tree_sample(X, y, sample_idx, depth, tree["selected_features"]);
            tree["root"] = node;
            push(self.estimators, tree);
            t = t + 1;
        }
        self.compute_feature_importances();
        return 0;
    }

    fn build_tree_sample(X, y, indices, depth, features) {
        let n = len(indices);
        if (n == 0) { return {"leaf": 0, "count": n}; }
        if (depth >= self.max_depth) {
            let votes = [];
            let i = 0;
            while (i < n) { push(votes, y[indices[i]]); i = i + 1; }
            return {"leaf": self.majority_vote(votes), "count": n};
        }
        if (n < self.min_samples_split) {
            let votes = [];
            let i = 0;
            while (i < n) { push(votes, y[indices[i]]); i = i + 1; }
            return {"leaf": self.majority_vote(votes), "count": n};
        }
        let all_same = 1;
        let i = 1;
        while (i < n) {
            if (y[indices[i]] != y[indices[0]]) { all_same = 0; }
            i = i + 1;
        }
        if (all_same == 1) { return {"leaf": y[indices[0]], "count": n}; }
        let best_feat = features[0];
        let best_thresh = 0.0;
        let best_gini = 1000000000.0;
        let f = 0;
        while (f < len(features)) {
            let feat = features[f];
            let vals = [];
            i = 0;
            while (i < n) { push(vals, X[indices[i]][feat]); i = i + 1; }
            let mean_val = 0.0;
            i = 0;
            while (i < n) { mean_val = mean_val + vals[i]; i = i + 1; }
            mean_val = mean_val / n;
            let left_y = [];
            let right_y = [];
            i = 0;
            while (i < n) {
                if (vals[i] <= mean_val) { push(left_y, y[indices[i]]); }
                else { push(right_y, y[indices[i]]); }
                i = i + 1;
            }
            let gini = self.gini_impurity_split(left_y, right_y);
            if (gini < best_gini) { best_gini = gini; best_feat = feat; best_thresh = mean_val; }
            f = f + 1;
        }
        let left_indices = [];
        let right_indices = [];
        i = 0;
        while (i < n) {
            if (X[indices[i]][best_feat] <= best_thresh) { push(left_indices, indices[i]); }
            else { push(right_indices, indices[i]); }
            i = i + 1;
        }
        return {
            "feature": best_feat,
            "threshold": best_thresh,
            "left": self.build_tree_sample(X, y, left_indices, depth + 1, features),
            "right": self.build_tree_sample(X, y, right_indices, depth + 1, features)
        };
    }

    fn gini_impurity_split(left_y, right_y) {
        let total = len(left_y) + len(right_y);
        if (total == 0) { return 0.0; }
        let gini_left = self.gini_impurity(left_y);
        let gini_right = self.gini_impurity(right_y);
        return (len(left_y) * gini_left + len(right_y) * gini_right) / total;
    }

    fn gini_impurity(y_vals) {
        let n = len(y_vals);
        if (n == 0) { return 0.0; }
        let counts = {};
        let i = 0;
        while (i < n) {
            let key = y_vals[i];
            let c = 0;
            if (dict_keys(counts) != []) {
                let keys = dict_keys(counts);
                let found = 0;
                let kk = 0;
                while (kk < len(keys)) { if (keys[kk] == key) { found = 1; } kk = kk + 1; }
                if (found == 1) { c = counts[key]; }
            }
            counts[key] = c + 1;
            i = i + 1;
        }
        let gini = 1.0;
        let keys = dict_keys(counts);
        let k = 0;
        while (k < len(keys)) {
            let p = counts[keys[k]] * 1.0 / n;
            gini = gini - p * p;
            k = k + 1;
        }
        return gini;
    }

    fn majority_vote(votes) {
        let counts = {};
        let i = 0;
        while (i < len(votes)) {
            let key = votes[i];
            let c = 0;
            if (dict_keys(counts) != []) {
                let keys = dict_keys(counts);
                let found = 0;
                let kk = 0;
                while (kk < len(keys)) { if (keys[kk] == key) { found = 1; } kk = kk + 1; }
                if (found == 1) { c = counts[key]; }
            }
            counts[key] = c + 1;
            i = i + 1;
        }
        let best = votes[0];
        let best_c = 0;
        let keys = dict_keys(counts);
        let k = 0;
        while (k < len(keys)) {
            if (counts[keys[k]] > best_c) { best_c = counts[keys[k]]; best = keys[k]; }
            k = k + 1;
        }
        return best;
    }

    fn predict_one(tree, x) {
        if (tree["leaf"] != nullptr) { return tree["leaf"]; }
        if (x[tree["feature"]] <= tree["threshold"]) { return self.predict_one(tree["left"], x); }
        return self.predict_one(tree["right"], x);
    }

    fn predict(X) {
        let n = len(X);
        let preds = [];
        let i = 0;
        while (i < n) {
            let votes = {};
            let t = 0;
            while (t < self.n_estimators) {
                let vote = self.predict_one(self.estimators[t]["root"], X[i]);
                let c = 0;
                if (dict_keys(votes) != []) {
                    let keys = dict_keys(votes);
                    let found = 0;
                    let kk = 0;
                    while (kk < len(keys)) { if (keys[kk] == vote) { found = 1; } kk = kk + 1; }
                    if (found == 1) { c = votes[vote]; }
                }
                votes[vote] = c + 1;
                t = t + 1;
            }
            let best_vote = 0;
            let best_cnt = 0;
            let keys = dict_keys(votes);
            let k = 0;
            while (k < len(keys)) {
                if (votes[keys[k]] > best_cnt) { best_cnt = votes[keys[k]]; best_vote = keys[k]; }
                k = k + 1;
            }
            push(preds, best_vote);
            i = i + 1;
        }
        return preds;
    }

    fn compute_feature_importances() {
        let d = 0;
        if (len(self.estimators) > 0) { d = len(self.estimators[0]["selected_features"]); }
        self.feature_importances = hml_vector_zeros(d);
        return 0;
    }

    fn score(X, y) {
        let y_pred = self.predict(X);
        return accuracy_score(y, y_pred);
    }
}

# ── RandomForestRegressor ──
class RandomForestRegressor {
    let n_estimators = 100;
    let max_depth = 10;
    let min_samples_split = 2;
    let max_features = nullptr;
    let estimators = [];

    fn init_random_forest_regressor(n_estimators, max_depth, min_samples_split, max_features) {
        if (n_estimators != nullptr) { self.n_estimators = n_estimators; }
        if (max_depth != nullptr) { self.max_depth = max_depth; }
        if (min_samples_split != nullptr) { self.min_samples_split = min_samples_split; }
        if (max_features != nullptr) { self.max_features = max_features; }
        self.estimators = [];
        return 0;
    }

    fn fit(X, y) {
        let n = len(X);
        let d = len(X[0]);
        let n_feat = d;
        if (self.max_features != nullptr) { n_feat = math_floor(math_sqrt(d * 1.0)); }
        let t = 0;
        while (t < self.n_estimators) {
            let sample_idx = [];
            let i = 0;
            while (i < n) {
                let r = hml_randint(0, n - 1);
                push(sample_idx, r);
                i = i + 1;
            }
            let tree = {
                "type": "regression_tree",
                "depth": self.max_depth,
                "min_split": self.min_samples_split,
                "n_features": n_feat,
                "selected_features": [],
                "root": nullptr
            };
            let k = 0;
            while (k < n_feat) {
                let fidx = hml_randint(0, d - 1);
                push(tree["selected_features"], fidx);
                k = k + 1;
            }
            let depth = 0;
            let node = self.build_tree_reg_sample(X, y, sample_idx, depth, tree["selected_features"]);
            tree["root"] = node;
            push(self.estimators, tree);
            t = t + 1;
        }
        return 0;
    }

    fn build_tree_reg_sample(X, y, indices, depth, features) {
        let n = len(indices);
        if (n == 0) { return {"leaf": 0.0, "count": n}; }
        if (depth >= self.max_depth or n < self.min_samples_split) {
            let mean_val = 0.0;
            let i = 0;
            while (i < n) { mean_val = mean_val + y[indices[i]]; i = i + 1; }
            return {"leaf": mean_val / n, "count": n};
        }
        let best_feat = features[0];
        let best_thresh = 0.0;
        let best_var = 1000000000.0;
        let f = 0;
        while (f < len(features)) {
            let feat = features[f];
            let vals = [];
            let i = 0;
            while (i < n) { push(vals, X[indices[i]][feat]); i = i + 1; }
            let mean_val = 0.0;
            i = 0;
            while (i < n) { mean_val = mean_val + vals[i]; i = i + 1; }
            mean_val = mean_val / n;
            let left_y = [];
            let right_y = [];
            i = 0;
            while (i < n) {
                if (vals[i] <= mean_val) { push(left_y, y[indices[i]]); }
                else { push(right_y, y[indices[i]]); }
                i = i + 1;
            }
            let var_left = 0.0;
            let var_right = 0.0;
            if (len(left_y) > 0) {
                let m = 0.0;
                let j = 0; while (j < len(left_y)) { m = m + left_y[j]; j = j + 1; }
                m = m / len(left_y);
                j = 0; while (j < len(left_y)) { let d = left_y[j] - m; var_left = var_left + d * d; j = j + 1; }
            }
            if (len(right_y) > 0) {
                let m = 0.0;
                let j = 0; while (j < len(right_y)) { m = m + right_y[j]; j = j + 1; }
                m = m / len(right_y);
                j = 0; while (j < len(right_y)) { let d = right_y[j] - m; var_right = var_right + d * d; j = j + 1; }
            }
            let total_var = var_left + var_right;
            if (total_var < best_var) { best_var = total_var; best_feat = feat; best_thresh = mean_val; }
            f = f + 1;
        }
        let left_indices = [];
        let right_indices = [];
        let i = 0;
        while (i < n) {
            if (X[indices[i]][best_feat] <= best_thresh) { push(left_indices, indices[i]); }
            else { push(right_indices, indices[i]); }
            i = i + 1;
        }
        if (len(left_indices) == 0 or len(right_indices) == 0) {
            let mean_val = 0.0;
            i = 0;
            while (i < n) { mean_val = mean_val + y[indices[i]]; i = i + 1; }
            return {"leaf": mean_val / n, "count": n};
        }
        return {
            "feature": best_feat,
            "threshold": best_thresh,
            "left": self.build_tree_reg_sample(X, y, left_indices, depth + 1, features),
            "right": self.build_tree_reg_sample(X, y, right_indices, depth + 1, features)
        };
    }

    fn predict_one(tree, x) {
        if (tree["leaf"] != nullptr) { return tree["leaf"]; }
        if (x[tree["feature"]] <= tree["threshold"]) { return self.predict_one(tree["left"], x); }
        return self.predict_one(tree["right"], x);
    }

    fn predict(X) {
        let n = len(X);
        let preds = hml_vector_zeros(n);
        let i = 0;
        while (i < n) {
            let total = 0.0;
            let t = 0;
            while (t < self.n_estimators) {
                total = total + self.predict_one(self.estimators[t]["root"], X[i]);
                t = t + 1;
            }
            preds[i] = total / self.n_estimators;
            i = i + 1;
        }
        return preds;
    }

    fn score(X, y) {
        let y_pred = self.predict(X);
        return r2_score(y, y_pred);
    }
}

# ── ExtraTreesClassifier ──
class ExtraTreesClassifier {
    let n_estimators = 100;
    let max_depth = 10;
    let estimators = [];

    fn init_extra_trees(n_estimators, max_depth) {
        if (n_estimators != nullptr) { self.n_estimators = n_estimators; }
        if (max_depth != nullptr) { self.max_depth = max_depth; }
        self.estimators = [];
        return 0;
    }

    fn fit(X, y) {
        let n = len(X);
        let d = len(X[0]);
        let t = 0;
        while (t < self.n_estimators) {
            let sample_idx = [];
            let i = 0;
            while (i < n) {
                let r = hml_randint(0, n - 1);
                push(sample_idx, r);
                i = i + 1;
            }
            let feat = hml_randint(0, d - 1);
            let thresh_vals = [];
            i = 0;
            while (i < n) { push(thresh_vals, X[sample_idx[i]][feat]); i = i + 1; }
            let min_v = thresh_vals[0];
            let max_v = thresh_vals[0];
            i = 1;
            while (i < len(thresh_vals)) {
                if (thresh_vals[i] < min_v) { min_v = thresh_vals[i]; }
                if (thresh_vals[i] > max_v) { max_v = thresh_vals[i]; }
                i = i + 1;
            }
            let random_thresh = min_v + hml_random() * (max_v - min_v);
            let tree = {
                "feature": feat,
                "threshold": random_thresh,
                "max_depth": self.max_depth,
                "n_classes": len(hml_unique(y)),
                "left_count": 0,
                "right_count": 0,
                "left_class": 0,
                "right_class": 0
            };
            let left_y = [];
            let right_y = [];
            i = 0;
            while (i < n) {
                if (X[sample_idx[i]][feat] <= random_thresh) {
                    push(left_y, y[sample_idx[i]]);
                    tree["left_count"] = tree["left_count"] + 1;
                }
                else {
                    push(right_y, y[sample_idx[i]]);
                    tree["right_count"] = tree["right_count"] + 1;
                }
                i = i + 1;
            }
            if (len(left_y) > 0) { tree["left_class"] = left_y[0]; }
            if (len(right_y) > 0) { tree["right_class"] = right_y[0]; }
            push(self.estimators, tree);
            t = t + 1;
        }
        return 0;
    }

    fn predict_one(tree, x) {
        if (x[tree["feature"]] <= tree["threshold"]) { return tree["left_class"]; }
        return tree["right_class"];
    }

    fn predict(X) {
        let n = len(X);
        let preds = [];
        let i = 0;
        while (i < n) {
            let votes = {};
            let t = 0;
            while (t < self.n_estimators) {
                let v = self.predict_one(self.estimators[t], X[i]);
                let c = 0;
                if (dict_keys(votes) != []) {
                    let keys = dict_keys(votes);
                    let found = 0;
                    let kk = 0;
                    while (kk < len(keys)) { if (keys[kk] == v) { found = 1; } kk = kk + 1; }
                    if (found == 1) { c = votes[v]; }
                }
                votes[v] = c + 1;
                t = t + 1;
            }
            let best = 0;
            let best_c = 0;
            let keys = dict_keys(votes);
            let k = 0;
            while (k < len(keys)) {
                if (votes[keys[k]] > best_c) { best_c = votes[keys[k]]; best = keys[k]; }
                k = k + 1;
            }
            push(preds, best);
            i = i + 1;
        }
        return preds;
    }

    fn score(X, y) { return accuracy_score(self.predict(X), y); }
}

# ── ExtraTreesRegressor ──
class ExtraTreesRegressor {
    let n_estimators = 100;
    let max_depth = 10;
    let estimators = [];

    fn init_extra_trees_reg(n_estimators, max_depth) {
        if (n_estimators != nullptr) { self.n_estimators = n_estimators; }
        if (max_depth != nullptr) { self.max_depth = max_depth; }
        self.estimators = [];
        return 0;
    }

    fn fit(X, y) {
        let n = len(X);
        let d = len(X[0]);
        let t = 0;
        while (t < self.n_estimators) {
            let sample_idx = [];
            let i = 0;
            while (i < n) {
                let r = hml_randint(0, n - 1);
                push(sample_idx, r);
                i = i + 1;
            }
            let feat = hml_randint(0, d - 1);
            let thresh_vals = [];
            i = 0;
            while (i < n) { push(thresh_vals, X[sample_idx[i]][feat]); i = i + 1; }
            let min_v = thresh_vals[0];
            let max_v = thresh_vals[0];
            i = 1;
            while (i < len(thresh_vals)) {
                if (thresh_vals[i] < min_v) { min_v = thresh_vals[i]; }
                if (thresh_vals[i] > max_v) { max_v = thresh_vals[i]; }
                i = i + 1;
            }
            let random_thresh = min_v + hml_random() * (max_v - min_v);
            let left_y = [];
            let right_y = [];
            i = 0;
            while (i < n) {
                if (X[sample_idx[i]][feat] <= random_thresh) { push(left_y, y[sample_idx[i]]); }
                else { push(right_y, y[sample_idx[i]]); }
                i = i + 1;
            }
            let left_mean = 0.0;
            if (len(left_y) > 0) {
                let j = 0; while (j < len(left_y)) { left_mean = left_mean + left_y[j]; j = j + 1; }
                left_mean = left_mean / len(left_y);
            }
            let right_mean = 0.0;
            if (len(right_y) > 0) {
                let j = 0; while (j < len(right_y)) { right_mean = right_mean + right_y[j]; j = j + 1; }
                right_mean = right_mean / len(right_y);
            }
            let tree = {"feature": feat, "threshold": random_thresh, "left_val": left_mean, "right_val": right_mean};
            push(self.estimators, tree);
            t = t + 1;
        }
        return 0;
    }

    fn predict(X) {
        let n = len(X);
        let preds = hml_vector_zeros(n);
        let i = 0;
        while (i < n) {
            let total = 0.0;
            let t = 0;
            while (t < self.n_estimators) {
                if (X[i][self.estimators[t]["feature"]] <= self.estimators[t]["threshold"]) {
                    total = total + self.estimators[t]["left_val"];
                }
                else { total = total + self.estimators[t]["right_val"]; }
                t = t + 1;
            }
            preds[i] = total / self.n_estimators;
            i = i + 1;
        }
        return preds;
    }

    fn score(X, y) { return r2_score(y, self.predict(X)); }
}

# ── StackingClassifier ──
class StackingClassifier {
    let base_estimators = [];
    let meta_estimator = nullptr;

    fn init_stacking_classifier(base_estimators, meta_estimator) {
        self.base_estimators = base_estimators;
        self.meta_estimator = meta_estimator;
        return 0;
    }

    fn fit(X, y) {
        let n = len(X);
        let k = len(self.base_estimators);
        let meta_features = [];
        let i = 0;
        while (i < k) {
            self.base_estimators[i]["fit"](X, y);
            i = i + 1;
        }
        i = 0;
        while (i < n) {
            let row = [];
            let j = 0;
            while (j < k) {
                let pred = self.base_estimators[j]["predict"]([X[i]]);
                push(row, pred[0]);
                j = j + 1;
            }
            push(meta_features, row);
            i = i + 1;
        }
        if (self.meta_estimator != nullptr) {
            self.meta_estimator["fit"](meta_features, y);
        }
        return 0;
    }

    fn predict(X) {
        let n = len(X);
        let k = len(self.base_estimators);
        let meta_features = [];
        let i = 0;
        while (i < n) {
            let row = [];
            let j = 0;
            while (j < k) {
                let pred = self.base_estimators[j]["predict"]([X[i]]);
                push(row, pred[0]);
                j = j + 1;
            }
            push(meta_features, row);
            i = i + 1;
        }
        if (self.meta_estimator != nullptr) { return self.meta_estimator["predict"](meta_features); }
        let preds = [];
        i = 0;
        while (i < n) { push(preds, meta_features[i][0]); i = i + 1; }
        return preds;
    }

    fn score(X, y) { return accuracy_score(self.predict(X), y); }
}

# ── StackingRegressor ──
class StackingRegressor {
    let base_estimators = [];
    let meta_estimator = nullptr;

    fn init_stacking_regressor(base_estimators, meta_estimator) {
        self.base_estimators = base_estimators;
        self.meta_estimator = meta_estimator;
        return 0;
    }

    fn fit(X, y) {
        let n = len(X);
        let k = len(self.base_estimators);
        let i = 0;
        while (i < k) {
            self.base_estimators[i]["fit"](X, y);
            i = i + 1;
        }
        let meta_features = [];
        i = 0;
        while (i < n) {
            let row = [];
            let j = 0;
            while (j < k) {
                let pred = self.base_estimators[j]["predict"]([X[i]]);
                push(row, pred[0]);
                j = j + 1;
            }
            push(meta_features, row);
            i = i + 1;
        }
        if (self.meta_estimator != nullptr) {
            self.meta_estimator["fit"](meta_features, y);
        }
        return 0;
    }

    fn predict(X) {
        let n = len(X);
        let k = len(self.base_estimators);
        let meta_features = [];
        let i = 0;
        while (i < n) {
            let row = [];
            let j = 0;
            while (j < k) {
                let pred = self.base_estimators[j]["predict"]([X[i]]);
                push(row, pred[0]);
                j = j + 1;
            }
            push(meta_features, row);
            i = i + 1;
        }
        if (self.meta_estimator != nullptr) { return self.meta_estimator["predict"](meta_features); }
        return meta_features[0];
    }

    fn score(X, y) { return r2_score(y, self.predict(X)); }
}

# ── BlendingClassifier ──
class BlendingClassifier {
    let base_estimators = [];
    let meta_estimator = nullptr;
    let holdout_ratio = 0.2;

    fn init_blending(base_estimators, meta_estimator, holdout_ratio) {
        self.base_estimators = base_estimators;
        self.meta_estimator = meta_estimator;
        if (holdout_ratio != nullptr) { self.holdout_ratio = holdout_ratio; }
        return 0;
    }

    fn fit(X, y) {
        let n = len(X);
        let split = math_floor(n * (1.0 - self.holdout_ratio));
        if (split < 1) { split = 1; }
        if (split >= n) { split = n - 1; }
        let X_train = [];
        let y_train = [];
        let X_hold = [];
        let y_hold = [];
        let i = 0;
        while (i < split) { push(X_train, X[i]); push(y_train, y[i]); i = i + 1; }
        while (i < n) { push(X_hold, X[i]); push(y_hold, y[i]); i = i + 1; }
        let k = len(self.base_estimators);
        i = 0;
        while (i < k) {
            self.base_estimators[i]["fit"](X_train, y_train);
            i = i + 1;
        }
        let n_hold = len(X_hold);
        let meta_features = [];
        i = 0;
        while (i < n_hold) {
            let row = [];
            let j = 0;
            while (j < k) {
                let pred = self.base_estimators[j]["predict"]([X_hold[i]]);
                push(row, pred[0]);
                j = j + 1;
            }
            push(meta_features, row);
            i = i + 1;
        }
        if (self.meta_estimator != nullptr) {
            self.meta_estimator["fit"](meta_features, y_hold);
        }
        return 0;
    }

    fn predict(X) { return self.predict_proba_vote(X); }

    fn predict_proba_vote(X) {
        let n = len(X);
        let k = len(self.base_estimators);
        let meta_features = [];
        let i = 0;
        while (i < n) {
            let row = [];
            let j = 0;
            while (j < k) {
                let pred = self.base_estimators[j]["predict"]([X[i]]);
                push(row, pred[0]);
                j = j + 1;
            }
            push(meta_features, row);
            i = i + 1;
        }
        if (self.meta_estimator != nullptr) { return self.meta_estimator["predict"](meta_features); }
        let preds = [];
        i = 0;
        while (i < n) { push(preds, meta_features[i][0]); i = i + 1; }
        return preds;
    }

    fn score(X, y) { return accuracy_score(self.predict(X), y); }
}

# ── WeightedEnsemble ──
class WeightedEnsemble {
    let estimators = [];
    let weights = [];

    fn init_weighted_ensemble(estimators, weights) {
        self.estimators = estimators;
        self.weights = weights;
        return 0;
    }

    fn fit(X, y) {
        let k = len(self.estimators);
        let i = 0;
        while (i < k) {
            self.estimators[i]["fit"](X, y);
            i = i + 1;
        }
        return 0;
    }

    fn predict(X) {
        let n = len(X);
        let k = len(self.estimators);
        let preds = hml_vector_zeros(n);
        let i = 0;
        while (i < n) {
            let w_sum = 0.0;
            let j = 0;
            while (j < k) {
                let p = self.estimators[j]["predict"]([X[i]]);
                preds[i] = preds[i] + self.weights[j] * p[0];
                w_sum = w_sum + self.weights[j];
                j = j + 1;
            }
            if (w_sum > 0) { preds[i] = preds[i] / w_sum; }
            i = i + 1;
        }
        return preds;
    }

    fn predict_class(X) {
        let n = len(X);
        let k = len(self.estimators);
        let classes = [];
        let i = 0;
        while (i < n) {
            let votes = {};
            let j = 0;
            while (j < k) {
                let p = self.estimators[j]["predict"]([X[i]]);
                let v = p[0];
                let c = 0;
                if (dict_keys(votes) != []) {
                    let keys = dict_keys(votes);
                    let found = 0;
                    let kk = 0;
                    while (kk < len(keys)) { if (keys[kk] == v) { found = 1; } kk = kk + 1; }
                    if (found == 1) { c = votes[v]; }
                }
                votes[v] = c + self.weights[j];
                j = j + 1;
            }
            let best = 0;
            let best_w = 0.0;
            let keys = dict_keys(votes);
            let kk = 0;
            while (kk < len(keys)) {
                if (votes[keys[kk]] > best_w) { best_w = votes[keys[kk]]; best = keys[kk]; }
                kk = kk + 1;
            }
            push(classes, best);
            i = i + 1;
        }
        return classes;
    }

    fn score(X, y) { return accuracy_score(self.predict_class(X), y); }
}

# ── HistGradientBoostingClassifier ──
class HistGradientBoostingClassifier {
    let n_estimators = 100;
    let learning_rate = 0.1;
    let max_depth = 5;
    let estimators = [];
    let init_pred = 0.0;

    fn init_hist_gradient_boosting(n_estimators, learning_rate, max_depth) {
        if (n_estimators != nullptr) { self.n_estimators = n_estimators; }
        if (learning_rate != nullptr) { self.learning_rate = learning_rate; }
        if (max_depth != nullptr) { self.max_depth = max_depth; }
        self.estimators = [];
        return 0;
    }

    fn fit(X, y) {
        let n = len(X);
        let d = len(X[0]);
        let pos = 0;
        let i = 0;
        while (i < n) { if (y[i] == 1) { pos = pos + 1; } i = i + 1; }
        let p = (pos * 1.0 + 1.0) / (n + 2.0);
        self.init_pred = math_log(p / (1.0 - p));
        let residuals = [];
        i = 0;
        while (i < n) { push(residuals, y[i] - p); i = i + 1; }
        let t = 0;
        while (t < self.n_estimators) {
            let tree = self.build_simple_tree(X, residuals, 0, self.max_depth);
            push(self.estimators, tree);
            i = 0;
            while (i < n) {
                let pred = self.predict_one(tree, X[i]);
                residuals[i] = residuals[i] - self.learning_rate * pred;
                i = i + 1;
            }
            t = t + 1;
        }
        return 0;
    }

    fn build_simple_tree(X, y, depth, max_depth) {
        let n = len(X);
        if (n == 0) { return {"leaf": 0.0}; }
        if (depth >= max_depth) {
            let avg = 0.0;
            let i = 0; while (i < n) { avg = avg + y[i]; i = i + 1; }
            return {"leaf": avg / n};
        }
        let d = len(X[0]);
        let best_feat = 0;
        let best_thresh = 0.0;
        let best_var = 1000000000.0;
        let feat = 0;
        while (feat < d) {
            let vals = hml_column_means([X])[feat];
            let left_y = [];
            let right_y = [];
            let i = 0;
            let thresh = 0.0;
            i = 0; while (i < n) { thresh = thresh + X[i][feat]; i = i + 1; }
            thresh = thresh / n;
            i = 0;
            while (i < n) {
                if (X[i][feat] <= thresh) { push(left_y, y[i]); }
                else { push(right_y, y[i]); }
                i = i + 1;
            }
            let v_left = self.compute_variance(left_y);
            let v_right = self.compute_variance(right_y);
            if (v_left + v_right < best_var) { best_var = v_left + v_right; best_feat = feat; best_thresh = thresh; }
            feat = feat + 1;
        }
        let left_X = [];
        let left_y = [];
        let right_X = [];
        let right_y = [];
        let i = 0;
        while (i < n) {
            if (X[i][best_feat] <= best_thresh) { push(left_X, X[i]); push(left_y, y[i]); }
            else { push(right_X, X[i]); push(right_y, y[i]); }
            i = i + 1;
        }
        return {
            "feature": best_feat,
            "threshold": best_thresh,
            "left": self.build_simple_tree(left_X, left_y, depth + 1, max_depth),
            "right": self.build_simple_tree(right_X, right_y, depth + 1, max_depth)
        };
    }

    fn compute_variance(vals) {
        let n = len(vals);
        if (n == 0) { return 0.0; }
        let m = 0.0;
        let i = 0; while (i < n) { m = m + vals[i]; i = i + 1; }
        m = m / n;
        let v = 0.0;
        i = 0; while (i < n) { let d = vals[i] - m; v = v + d * d; i = i + 1; }
        return v;
    }

    fn predict_one(tree, x) {
        if (tree["leaf"] != nullptr) { return tree["leaf"]; }
        if (x[tree["feature"]] <= tree["threshold"]) { return self.predict_one(tree["left"], x); }
        return self.predict_one(tree["right"], x);
    }

    fn predict_proba(X) {
        let n = len(X);
        let probs = [];
        let i = 0;
        while (i < n) {
            let logit = self.init_pred;
            let t = 0;
            while (t < len(self.estimators)) {
                logit = logit + self.learning_rate * self.predict_one(self.estimators[t], X[i]);
                t = t + 1;
            }
            push(probs, 1.0 / (1.0 + math_exp(-logit)));
            i = i + 1;
        }
        return probs;
    }

    fn predict(X) {
        let probs = self.predict_proba(X);
        let preds = [];
        let i = 0;
        while (i < len(probs)) {
            if (probs[i] >= 0.5) { push(preds, 1); }
            else { push(preds, 0); }
            i = i + 1;
        }
        return preds;
    }

    fn score(X, y) { return accuracy_score(self.predict(X), y); }
}

# ── HistGradientBoostingRegressor ──
class HistGradientBoostingRegressor {
    let n_estimators = 100;
    let learning_rate = 0.1;
    let max_depth = 5;
    let estimators = [];
    let init_pred = 0.0;

    fn init_hist_gradient_boosting_reg(n_estimators, learning_rate, max_depth) {
        if (n_estimators != nullptr) { self.n_estimators = n_estimators; }
        if (learning_rate != nullptr) { self.learning_rate = learning_rate; }
        if (max_depth != nullptr) { self.max_depth = max_depth; }
        self.estimators = [];
        return 0;
    }

    fn fit(X, y) {
        let n = len(X);
        let mean_y = 0.0;
        let i = 0;
        while (i < n) { mean_y = mean_y + y[i]; i = i + 1; }
        mean_y = mean_y / n;
        self.init_pred = mean_y;
        let residuals = [];
        i = 0;
        while (i < n) { push(residuals, y[i] - mean_y); i = i + 1; }
        let t = 0;
        while (t < self.n_estimators) {
            let best_feat = 0;
            let best_thresh = 0.0;
            let best_mse = 1000000000.0;
            let d = len(X[0]);
            let feat = 0;
            while (feat < d) {
                let thresh = 0.0;
                i = 0; while (i < n) { thresh = thresh + X[i][feat]; i = i + 1; }
                thresh = thresh / n;
                let left_res = [];
                let right_res = [];
                i = 0;
                while (i < n) {
                    if (X[i][feat] <= thresh) { push(left_res, residuals[i]); }
                    else { push(right_res, residuals[i]); }
                    i = i + 1;
                }
                let mse_left = 0.0;
                if (len(left_res) > 0) {
                    let m = 0.0;
                    let j = 0; while (j < len(left_res)) { m = m + left_res[j]; j = j + 1; }
                    m = m / len(left_res);
                    j = 0; while (j < len(left_res)) { let d = left_res[j] - m; mse_left = mse_left + d * d; j = j + 1; }
                }
                let mse_right = 0.0;
                if (len(right_res) > 0) {
                    let m = 0.0;
                    let j = 0; while (j < len(right_res)) { m = m + right_res[j]; j = j + 1; }
                    m = m / len(right_res);
                    j = 0; while (j < len(right_res)) { let d = right_res[j] - m; mse_right = mse_right + d * d; j = j + 1; }
                }
                if (mse_left + mse_right < best_mse) {
                    best_mse = mse_left + mse_right;
                    best_feat = feat;
                    best_thresh = thresh;
                }
                feat = feat + 1;
            }
            let tree = {"feature": best_feat, "threshold": best_thresh, "left_val": 0.0, "right_val": 0.0};
            let left_r = [];
            let right_r = [];
            i = 0;
            while (i < n) {
                if (X[i][best_feat] <= best_thresh) { push(left_r, residuals[i]); }
                else { push(right_r, residuals[i]); }
                i = i + 1;
            }
            if (len(left_r) > 0) {
                let s = 0.0;
                let j = 0; while (j < len(left_r)) { s = s + left_r[j]; j = j + 1; }
                tree["left_val"] = s / len(left_r);
            }
            if (len(right_r) > 0) {
                let s = 0.0;
                let j = 0; while (j < len(right_r)) { s = s + right_r[j]; j = j + 1; }
                tree["right_val"] = s / len(right_r);
            }
            push(self.estimators, tree);
            i = 0;
            while (i < n) {
                if (X[i][best_feat] <= best_thresh) { residuals[i] = residuals[i] - self.learning_rate * tree["left_val"]; }
                else { residuals[i] = residuals[i] - self.learning_rate * tree["right_val"]; }
                i = i + 1;
            }
            t = t + 1;
        }
        return 0;
    }

    fn predict(X) {
        let n = len(X);
        let preds = hml_vector_zeros(n);
        let i = 0;
        while (i < n) {
            let val = self.init_pred;
            let t = 0;
            while (t < len(self.estimators)) {
                if (X[i][self.estimators[t]["feature"]] <= self.estimators[t]["threshold"]) {
                    val = val + self.learning_rate * self.estimators[t]["left_val"];
                }
                else { val = val + self.learning_rate * self.estimators[t]["right_val"]; }
                t = t + 1;
            }
            preds[i] = val;
            i = i + 1;
        }
        return preds;
    }

    fn score(X, y) { return r2_score(y, self.predict(X)); }
}

# ═══════════════════════════════════════════════════════════════════════════
# SECTION 43: Dimensionality Reduction
# ═══════════════════════════════════════════════════════════════════════════

# ── TruncatedSVD ──
class TruncatedSVD {
    let n_components = 2;
    let n_iter = 5;
    let components = [];
    let explained_variance = [];
    let mean = [];

    fn init_truncated_svd(n_components, n_iter) {
        if (n_components != nullptr) { self.n_components = n_components; }
        if (n_iter != nullptr) { self.n_iter = n_iter; }
        self.components = [];
        return 0;
    }

    fn fit(X) {
        let n = len(X);
        let d = len(X[0]);
        let k = self.n_components;
        if (k > d) { k = d; }
        self.mean = hml_vector_zeros(d);
        let i = 0;
        while (i < n) {
            let j = 0;
            while (j < d) { self.mean[j] = self.mean[j] + X[i][j]; j = j + 1; }
            i = i + 1;
        }
        let j = 0;
        while (j < d) { self.mean[j] = self.mean[j] / n; j = j + 1; }
        let X_centered = [];
        i = 0;
        while (i < n) {
            let row = [];
            j = 0;
            while (j < d) { push(row, X[i][j] - self.mean[j]); j = j + 1; }
            push(X_centered, row);
            i = i + 1;
        }
        let comp = 0;
        while (comp < k) {
            let v = [];
            j = 0;
            while (j < d) {
                let r = hml_random();
                push(v, r - 0.5);
                j = j + 1;
            }
            let it = 0;
            while (it < self.n_iter) {
                let v_new = hml_vector_zeros(d);
                i = 0;
                while (i < n) {
                    let dot = 0.0;
                    j = 0; while (j < d) { dot = dot + X_centered[i][j] * v[j]; j = j + 1; }
                    j = 0; while (j < d) { v_new[j] = v_new[j] + dot * X_centered[i][j]; j = j + 1; }
                    i = i + 1;
                }
                let norm = 0.0;
                j = 0; while (j < d) { norm = norm + v_new[j] * v_new[j]; j = j + 1; }
                norm = math_sqrt(norm);
                if (norm > 0) {
                    j = 0; while (j < d) { v_new[j] = v_new[j] / norm; j = j + 1; }
                }
                v = v_new;
                it = it + 1;
            }
            push(self.components, v);
            let variance = 0.0;
            i = 0;
            while (i < n) {
                let dot = 0.0;
                j = 0; while (j < d) { dot = dot + X_centered[i][j] * v[j]; j = j + 1; }
                variance = variance + dot * dot;
                i = i + 1;
            }
            push(self.explained_variance, variance / n);
            i = 0;
            while (i < n) {
                let dot = 0.0;
                j = 0; while (j < d) { dot = dot + X_centered[i][j] * v[j]; j = j + 1; }
                j = 0; while (j < d) { X_centered[i][j] = X_centered[i][j] - dot * v[j]; j = j + 1; }
                i = i + 1;
            }
            comp = comp + 1;
        }
        return 0;
    }

    fn transform(X) {
        let n = len(X);
        let d = len(X[0]);
        let k = len(self.components);
        let result = [];
        let i = 0;
        while (i < n) {
            let proj = [];
            let comp = 0;
            while (comp < k) {
                let dot = 0.0;
                let j = 0;
                while (j < d) { dot = dot + X[i][j] * self.components[comp][j]; j = j + 1; }
                push(proj, dot);
                comp = comp + 1;
            }
            push(result, proj);
            i = i + 1;
        }
        return result;
    }

    fn fit_transform(X) {
        self.fit(X);
        return self.transform(X);
    }
}

# ── NMFDecomposition ──
class NMFDecomposition {
    let n_components = 2;
    let max_iter = 200;
    let W = [];
    let H = [];

    fn init_nmf(n_components, max_iter) {
        if (n_components != nullptr) { self.n_components = n_components; }
        if (max_iter != nullptr) { self.max_iter = max_iter; }
        self.W = [];
        self.H = [];
        return 0;
    }

    fn fit(X) {
        let n = len(X);
        let d = len(X[0]);
        let k = self.n_components;
        self.W = [];
        let i = 0;
        while (i < n) {
            let row = [];
            let j = 0;
            while (j < k) { push(row, hml_random()); j = j + 1; }
            push(self.W, row);
            i = i + 1;
        }
        self.H = [];
        i = 0;
        while (i < k) {
            let row = [];
            let j = 0;
            while (j < d) { push(row, hml_random()); j = j + 1; }
            push(self.H, row);
            i = i + 1;
        }
        let iter = 0;
        while (iter < self.max_iter) {
            let WH = [];
            i = 0;
            while (i < n) {
                let row = [];
                let j = 0;
                while (j < d) {
                    let val = 0.0;
                    let l = 0;
                    while (l < k) { val = val + self.W[i][l] * self.H[l][j]; l = l + 1; }
                    push(row, val);
                    j = j + 1;
                }
                push(WH, row);
                i = i + 1;
            }
            i = 0;
            while (i < n) {
                let j = 0;
                while (j < k) {
                    let num = 0.0;
                    let denom = 0.0;
                    let l = 0;
                    while (l < d) {
                        num = num + X[i][l] * self.H[j][l];
                        denom = denom + WH[i][l] * self.H[j][l];
                        l = l + 1;
                    }
                    if (denom > 0.000000001) { self.W[i][j] = self.W[i][j] * num / denom; }
                    j = j + 1;
                }
                i = i + 1;
            }
            WH = [];
            i = 0;
            while (i < n) {
                let row = [];
                let j = 0;
                while (j < d) {
                    let val = 0.0;
                    let l = 0;
                    while (l < k) { val = val + self.W[i][l] * self.H[l][j]; l = l + 1; }
                    push(row, val);
                    j = j + 1;
                }
                push(WH, row);
                i = i + 1;
            }
            let j = 0;
            while (j < k) {
                let l = 0;
                while (l < d) {
                    let num = 0.0;
                    let denom = 0.0;
                    i = 0;
                    while (i < n) {
                        num = num + self.W[i][j] * X[i][l];
                        denom = denom + self.W[i][j] * WH[i][l];
                        i = i + 1;
                    }
                    if (denom > 0.000000001) { self.H[j][l] = self.H[j][l] * num / denom; }
                    l = l + 1;
                }
                j = j + 1;
            }
            iter = iter + 1;
        }
        return 0;
    }

    fn transform(X) {
        let n = len(X);
        let k = len(self.H);
        let result = [];
        let i = 0;
        while (i < n) {
            let row = [];
            let j = 0;
            while (j < k) {
                let val = 0.0;
                let l = 0;
                while (l < len(X[0])) { val = val + X[i][l] * self.H[j][l]; l = l + 1; }
                push(row, val);
                j = j + 1;
            }
            push(result, row);
            i = i + 1;
        }
        return result;
    }

    fn fit_transform(X) {
        self.fit(X);
        return self.transform(X);
    }
}

# ── LatentDirichletAllocation ──
class LatentDirichletAllocation {
    let n_topics = 5;
    let max_iter = 10;
    let doc_topic = [];
    let topic_word = [];

    fn init_lda(n_topics, max_iter) {
        if (n_topics != nullptr) { self.n_topics = n_topics; }
        if (max_iter != nullptr) { self.max_iter = max_iter; }
        self.doc_topic = [];
        self.topic_word = [];
        return 0;
    }

    fn fit(X) {
        let n_docs = len(X);
        let n_words = 0;
        let i = 0;
        while (i < n_docs) {
            let j = 0;
            while (j < len(X[i])) { if (X[i][j] > n_words) { n_words = X[i][j]; } j = j + 1; }
            i = i + 1;
        }
        n_words = n_words + 1;
        let k = self.n_topics;
        self.doc_topic = [];
        i = 0;
        while (i < n_docs) {
            let row = [];
            let j = 0;
            while (j < k) { push(row, hml_random() + 0.1); j = j + 1; }
            push(self.doc_topic, row);
            i = i + 1;
        }
        self.topic_word = [];
        i = 0;
        while (i < k) {
            let row = [];
            let j = 0;
            while (j < n_words) { push(row, hml_random() + 0.1); j = j + 1; }
            push(self.topic_word, row);
            i = i + 1;
        }
        return 0;
    }

    fn transform(X) {
        let n_docs = len(X);
        let k = self.n_topics;
        let result = [];
        let i = 0;
        while (i < n_docs) {
            let topic_dist = [];
            let j = 0;
            while (j < k) {
                let score = self.doc_topic[i][j];
                let w = 0;
                while (w < len(X[i])) {
                    let word_id = X[i][w];
                    if (word_id < len(self.topic_word[j])) { score = score + self.topic_word[j][word_id]; }
                    w = w + 1;
                }
                push(topic_dist, score);
                j = j + 1;
            }
            let total = 0.0;
            j = 0; while (j < k) { total = total + topic_dist[j]; j = j + 1; }
            if (total > 0) { j = 0; while (j < k) { topic_dist[j] = topic_dist[j] / total; j = j + 1; } }
            push(result, topic_dist);
            i = i + 1;
        }
        return result;
    }

    fn fit_transform(X) {
        self.fit(X);
        return self.transform(X);
    }
}

# ── FastICA ──
class FastICA {
    let n_components = 2;
    let max_iter = 200;
    let components = [];
    let mean = [];

    fn init_fast_ica(n_components, max_iter) {
        if (n_components != nullptr) { self.n_components = n_components; }
        if (max_iter != nullptr) { self.max_iter = max_iter; }
        self.components = [];
        return 0;
    }

    fn fit(X) {
        let n = len(X);
        let d = len(X[0]);
        let k = self.n_components;
        if (k > d) { k = d; }
        self.mean = hml_vector_zeros(d);
        let i = 0;
        while (i < n) {
            let j = 0;
            while (j < d) { self.mean[j] = self.mean[j] + X[i][j]; j = j + 1; }
            i = i + 1;
        }
        let j = 0;
        while (j < d) { self.mean[j] = self.mean[j] / n; j = j + 1; }
        self.components = [];
        let comp = 0;
        while (comp < k) {
            let w = [];
            j = 0;
            while (j < d) {
                let r = hml_random();
                push(w, r - 0.5);
                j = j + 1;
            }
            let norm = 0.0;
            j = 0; while (j < d) { norm = norm + w[j] * w[j]; j = j + 1; }
            norm = math_sqrt(norm);
            if (norm > 0) { j = 0; while (j < d) { w[j] = w[j] / norm; j = j + 1; } }
            let iter = 0;
            while (iter < self.max_iter) {
                let w_new = hml_vector_zeros(d);
                i = 0;
                while (i < n) {
                    let dot = 0.0;
                    j = 0;
                    while (j < d) { dot = dot + (X[i][j] - self.mean[j]) * w[j]; j = j + 1; }
                    let g = math_tan(dot);
                    j = 0;
                    while (j < d) { w_new[j] = w_new[j] + (X[i][j] - self.mean[j]) * g; j = j + 1; }
                    i = i + 1;
                }
                let g_prime = 0.0;
                i = 0;
                while (i < n) {
                    let dot = 0.0;
                    j = 0;
                    while (j < d) { dot = dot + (X[i][j] - self.mean[j]) * w[j]; j = j + 1; }
                    let sec_sq = 1.0 / (math_cos(dot) * math_cos(dot) + 0.000000001);
                    g_prime = g_prime + sec_sq;
                    i = i + 1;
                }
                j = 0;
                while (j < d) { w_new[j] = (w_new[j] - g_prime * w[j]) / n; j = j + 1; }
                let c = 0;
                while (c < len(self.components)) {
                    let dot = 0.0;
                    j = 0; while (j < d) { dot = dot + w_new[j] * self.components[c][j]; j = j + 1; }
                    j = 0; while (j < d) { w_new[j] = w_new[j] - dot * self.components[c][j]; j = j + 1; }
                    c = c + 1;
                }
                norm = 0.0;
                j = 0; while (j < d) { norm = norm + w_new[j] * w_new[j]; j = j + 1; }
                norm = math_sqrt(norm);
                if (norm > 0) { j = 0; while (j < d) { w_new[j] = w_new[j] / norm; j = j + 1; } }
                w = w_new;
                iter = iter + 1;
            }
            push(self.components, w);
            comp = comp + 1;
        }
        return 0;
    }

    fn transform(X) {
        let n = len(X);
        let d = len(X[0]);
        let k = len(self.components);
        let result = [];
        let i = 0;
        while (i < n) {
            let row = [];
            let comp = 0;
            while (comp < k) {
                let dot = 0.0;
                let j = 0;
                while (j < d) { dot = dot + (X[i][j] - self.mean[j]) * self.components[comp][j]; j = j + 1; }
                push(row, dot);
                comp = comp + 1;
            }
            push(result, row);
            i = i + 1;
        }
        return result;
    }

    fn fit_transform(X) {
        self.fit(X);
        return self.transform(X);
    }
}

# ── Isomap ──
class Isomap {
    let n_components = 2;
    let n_neighbors = 5;
    let embedding = [];

    fn init_isomap(n_components, n_neighbors) {
        if (n_components != nullptr) { self.n_components = n_components; }
        if (n_neighbors != nullptr) { self.n_neighbors = n_neighbors; }
        self.embedding = [];
        return 0;
    }

    fn fit_transform(X) {
        let n = len(X);
        let d = len(X[0]);
        let result = [];
        let i = 0;
        while (i < n) {
            let row = [];
            let j = 0;
            while (j < self.n_components) { push(row, 0.0); j = j + 1; }
            let sum_sq = 0.0;
            j = 0;
            while (j < d) {
                let val = X[i][j];
                sum_sq = sum_sq + val * val;
                j = j + 1;
            }
            if (sum_sq > 0) {
                let scale = math_sqrt(sum_sq);
                j = 0;
                while (j < self.n_components and j < d) { row[j] = X[i][j] / scale; j = j + 1; }
            }
            push(result, row);
            i = i + 1;
        }
        self.embedding = result;
        return result;
    }

    fn transform(X) {
        return self.fit_transform(X);
    }
}

# ── MDS ──
class MDS {
    let n_components = 2;
    let max_iter = 300;
    let embedding = [];

    fn init_mds(n_components, max_iter) {
        if (n_components != nullptr) { self.n_components = n_components; }
        if (max_iter != nullptr) { self.max_iter = max_iter; }
        self.embedding = [];
        return 0;
    }

    fn fit_transform(X) {
        let n = len(X);
        let k = self.n_components;
        if (k > n) { k = n; }
        self.embedding = [];
        let i = 0;
        while (i < n) {
            let row = [];
            let j = 0;
            while (j < k) { push(row, hml_random() - 0.5); j = j + 1; }
            push(self.embedding, row);
            i = i + 1;
        }
        let iter = 0;
        while (iter < self.max_iter) {
            i = 0;
            while (i < n) {
                let j = 0;
                while (j < k) {
                    let grad = 0.0;
                    let m = 0;
                    while (m < n) {
                        if (m != i) {
                            let dist = 0.0;
                            let l = 0; while (l < k) { let d = self.embedding[i][l] - self.embedding[m][l]; dist = dist + d * d; l = l + 1; }
                            dist = math_sqrt(dist);
                            if (dist > 0.000000001) {
                                let target = 0.0;
                                l = 0; while (l < len(X[0])) { let d = X[i][l] - X[m][l]; target = target + d * d; l = l + 1; }
                                target = math_sqrt(target);
                                grad = grad + (dist - target) / dist * (self.embedding[i][j] - self.embedding[m][j]);
                            }
                        }
                        m = m + 1;
                    }
                    self.embedding[i][j] = self.embedding[i][j] - 0.01 * grad;
                    j = j + 1;
                }
                i = i + 1;
            }
            iter = iter + 1;
        }
        return self.embedding;
    }
}

# ── TSNE ──
class TSNE {
    let n_components = 2;
    let perplexity = 30.0;
    let max_iter = 1000;
    let learning_rate = 200.0;
    let embedding = [];

    fn init_tsne(n_components, perplexity, max_iter, learning_rate) {
        if (n_components != nullptr) { self.n_components = n_components; }
        if (perplexity != nullptr) { self.perplexity = perplexity; }
        if (max_iter != nullptr) { self.max_iter = max_iter; }
        if (learning_rate != nullptr) { self.learning_rate = learning_rate; }
        self.embedding = [];
        return 0;
    }

    fn fit_transform(X) {
        let n = len(X);
        let d = len(X[0]);
        let k = self.n_components;
        self.embedding = [];
        let i = 0;
        while (i < n) {
            let row = [];
            let j = 0;
            while (j < k) { push(row, hml_random() * 0.0001 - 0.00005); j = j + 1; }
            push(self.embedding, row);
            i = i + 1;
        }
        let iter = 0;
        while (iter < self.max_iter) {
            i = 0;
            while (i < n) {
                let j = 0;
                while (j < k) {
                    let grad = 0.0;
                    let m = 0;
                    while (m < n) {
                        if (m != i) {
                            let dist_sq = 0.0;
                            let l = 0;
                            while (l < k) { let d = self.embedding[i][l] - self.embedding[m][l]; dist_sq = dist_sq + d * d; l = l + 1; }
                            let num = self.embedding[i][j] - self.embedding[m][j];
                            let denom = dist_sq + 1.0;
                            grad = grad + num / denom;
                        }
                        m = m + 1;
                    }
                    self.embedding[i][j] = self.embedding[i][j] - self.learning_rate * grad;
                    j = j + 1;
                }
                i = i + 1;
            }
            iter = iter + 1;
        }
        return self.embedding;
    }
}

# ── KernelPCA ──
class KernelPCA {
    let n_components = 2;
    let kernel = "rbf";
    let gamma = 1.0;
    let alphas = [];
    let X_fit = [];

    fn init_kernel_pca(n_components, kernel, gamma) {
        if (n_components != nullptr) { self.n_components = n_components; }
        if (kernel != nullptr) { self.kernel = kernel; }
        if (gamma != nullptr) { self.gamma = gamma; }
        self.alphas = [];
        self.X_fit = [];
        return 0;
    }

    fn rbf_kernel(x1, x2) {
        let dist = 0.0;
        let j = 0;
        while (j < len(x1)) { let d = x1[j] - x2[j]; dist = dist + d * d; j = j + 1; }
        return math_exp(-self.gamma * dist);
    }

    fn linear_kernel(x1, x2) {
        let dot = 0.0;
        let j = 0;
        while (j < len(x1)) { dot = dot + x1[j] * x2[j]; j = j + 1; }
        return dot;
    }

    fn fit(X) {
        self.X_fit = X;
        let n = len(X);
        let k = self.n_components;
        if (k > n) { k = n; }
        let K = [];
        let i = 0;
        while (i < n) {
            let row = [];
            let j = 0;
            while (j < n) {
                if (self.kernel == "rbf") { push(row, self.rbf_kernel(X[i], X[j])); }
                else { push(row, self.linear_kernel(X[i], X[j])); }
                j = j + 1;
            }
            push(K, row);
            i = i + 1;
        }
        let one_n = 1.0 / n;
        i = 0;
        while (i < n) {
            let j = 0;
            while (j < n) {
                let row_mean = 0.0;
                let l = 0; while (l < n) { row_mean = row_mean + K[i][l]; l = l + 1; }
                row_mean = row_mean * one_n;
                let col_mean = 0.0;
                l = 0; while (l < n) { col_mean = col_mean + K[l][j]; l = l + 1; }
                col_mean = col_mean * one_n;
                let total_mean = 0.0;
                l = 0; while (l < n) { let m = 0; while (m < n) { total_mean = total_mean + K[l][m]; m = m + 1; } l = l + 1; }
                total_mean = total_mean * one_n * one_n;
                K[i][j] = K[i][j] - row_mean - col_mean + total_mean;
                j = j + 1;
            }
            i = i + 1;
        }
        let comp = 0;
        while (comp < k) {
            let alpha = [];
            i = 0;
            while (i < n) { push(alpha, hml_random() - 0.5); i = i + 1; }
            let it = 0;
            while (it < 20) {
                let alpha_new = hml_vector_zeros(n);
                i = 0;
                while (i < n) {
                    let j = 0;
                    while (j < n) { alpha_new[i] = alpha_new[i] + K[i][j] * alpha[j]; j = j + 1; }
                    i = i + 1;
                }
                let norm = 0.0;
                i = 0; while (i < n) { norm = norm + alpha_new[i] * alpha_new[i]; i = i + 1; }
                norm = math_sqrt(norm);
                if (norm > 0) { i = 0; while (i < n) { alpha_new[i] = alpha_new[i] / norm; i = i + 1; } }
                alpha = alpha_new;
                it = it + 1;
            }
            push(self.alphas, alpha);
            comp = comp + 1;
        }
        return 0;
    }

    fn transform(X) {
        let n = len(X);
        let n_train = len(self.X_fit);
        let k = len(self.alphas);
        let result = [];
        let i = 0;
        while (i < n) {
            let row = [];
            let comp = 0;
            while (comp < k) {
                let val = 0.0;
                let j = 0;
                while (j < n_train) {
                    let kv = 0.0;
                    if (self.kernel == "rbf") { kv = self.rbf_kernel(X[i], self.X_fit[j]); }
                    else { kv = self.linear_kernel(X[i], self.X_fit[j]); }
                    val = val + self.alphas[comp][j] * kv;
                    j = j + 1;
                }
                push(row, val);
                comp = comp + 1;
            }
            push(result, row);
            i = i + 1;
        }
        return result;
    }

    fn fit_transform(X) {
        self.fit(X);
        return self.transform(X);
    }
}

# ── SparsePCA ──
class SparsePCA {
    let n_components = 2;
    let alpha = 1.0;
    let max_iter = 100;
    let components = [];
    let mean = [];

    fn init_sparse_pca(n_components, alpha, max_iter) {
        if (n_components != nullptr) { self.n_components = n_components; }
        if (alpha != nullptr) { self.alpha = alpha; }
        if (max_iter != nullptr) { self.max_iter = max_iter; }
        self.components = [];
        return 0;
    }

    fn fit(X) {
        let n = len(X);
        let d = len(X[0]);
        let k = self.n_components;
        if (k > d) { k = d; }
        self.mean = hml_vector_zeros(d);
        let i = 0;
        while (i < n) {
            let j = 0;
            while (j < d) { self.mean[j] = self.mean[j] + X[i][j]; j = j + 1; }
            i = i + 1;
        }
        let j = 0;
        while (j < d) { self.mean[j] = self.mean[j] / n; j = j + 1; }
        let Xc = [];
        i = 0;
        while (i < n) {
            let row = [];
            j = 0;
            while (j < d) { push(row, X[i][j] - self.mean[j]); j = j + 1; }
            push(Xc, row);
            i = i + 1;
        }
        self.components = [];
        let comp = 0;
        while (comp < k) {
            let v = [];
            j = 0;
            while (j < d) { push(v, hml_random() - 0.5); j = j + 1; }
            let iter = 0;
            while (iter < self.max_iter) {
                let v_new = hml_vector_zeros(d);
                i = 0;
                while (i < n) {
                    let dot = 0.0;
                    j = 0; while (j < d) { dot = dot + Xc[i][j] * v[j]; j = j + 1; }
                    j = 0; while (j < d) { v_new[j] = v_new[j] + dot * Xc[i][j]; j = j + 1; }
                    i = i + 1;
                }
                j = 0;
                while (j < d) {
                    v_new[j] = v_new[j] / n;
                    if (v_new[j] > self.alpha) { v_new[j] = v_new[j] - self.alpha; }
                    else { if (v_new[j] < -self.alpha) { v_new[j] = v_new[j] + self.alpha; } else { v_new[j] = 0.0; } }
                    j = j + 1;
                }
                let norm = 0.0;
                j = 0; while (j < d) { norm = norm + v_new[j] * v_new[j]; j = j + 1; }
                norm = math_sqrt(norm);
                if (norm > 0) { j = 0; while (j < d) { v_new[j] = v_new[j] / norm; j = j + 1; } }
                v = v_new;
                iter = iter + 1;
            }
            push(self.components, v);
            i = 0;
            while (i < n) {
                let dot = 0.0;
                j = 0; while (j < d) { dot = dot + Xc[i][j] * v[j]; j = j + 1; }
                j = 0; while (j < d) { Xc[i][j] = Xc[i][j] - dot * v[j]; j = j + 1; }
                i = i + 1;
            }
            comp = comp + 1;
        }
        return 0;
    }

    fn transform(X) {
        let n = len(X);
        let d = len(X[0]);
        let k = len(self.components);
        let result = [];
        let i = 0;
        while (i < n) {
            let row = [];
            let comp = 0;
            while (comp < k) {
                let dot = 0.0;
                let j = 0;
                while (j < d) { dot = dot + (X[i][j] - self.mean[j]) * self.components[comp][j]; j = j + 1; }
                push(row, dot);
                comp = comp + 1;
            }
            push(result, row);
            i = i + 1;
        }
        return result;
    }

    fn fit_transform(X) {
        self.fit(X);
        return self.transform(X);
    }
}

# ── IncrementalPCA ──
class IncrementalPCA {
    let n_components = 2;
    let batch_size = 100;
    let components = [];
    let mean = [];
    let n_samples_seen = 0;

    fn init_incremental_pca(n_components, batch_size) {
        if (n_components != nullptr) { self.n_components = n_components; }
        if (batch_size != nullptr) { self.batch_size = batch_size; }
        self.components = [];
        self.mean = [];
        self.n_samples_seen = 0;
        return 0;
    }

    fn partial_fit(X) {
        let n = len(X);
        let d = len(X[0]);
        let k = self.n_components;
        if (k > d) { k = d; }
        if (len(self.mean) == 0) {
            self.mean = hml_vector_zeros(d);
            self.components = [];
            let i = 0;
            while (i < k) {
                let row = [];
                let j = 0;
                while (j < d) { push(row, hml_random() - 0.5); j = j + 1; }
                push(self.components, row);
                i = i + 1;
            }
        }
        let i = 0;
        while (i < n) {
            let j = 0;
            while (j < d) {
                self.mean[j] = (self.mean[j] * self.n_samples_seen + X[i][j]) / (self.n_samples_seen + 1);
                j = j + 1;
            }
            self.n_samples_seen = self.n_samples_seen + 1;
            i = i + 1;
        }
        return 0;
    }

    fn transform(X) {
        let n = len(X);
        let d = len(X[0]);
        let k = len(self.components);
        let result = [];
        let i = 0;
        while (i < n) {
            let row = [];
            let comp = 0;
            while (comp < k) {
                let dot = 0.0;
                let j = 0;
                while (j < d) { dot = dot + (X[i][j] - self.mean[j]) * self.components[comp][j]; j = j + 1; }
                push(row, dot);
                comp = comp + 1;
            }
            push(result, row);
            i = i + 1;
        }
        return result;
    }
}

