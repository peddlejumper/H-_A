# ── ReLUActivation ──
class ReLUActivation {
    fn init_relu_act() { return 0; }
    fn call(x) { return relu(x); }
    fn forward(x) { return relu(x); }
}

# ── LeakyReLUActivation ──
class LeakyReLUActivation {
    let alpha = 0.01;

    fn init_leaky_relu(alpha) {
        if (alpha == nullptr) { self.alpha = 0.01; }
        else { self.alpha = alpha; }
        return 0;
    }

    fn call(x) {
        if (x > 0) { return x; }
        return self.alpha * x;
    }

    fn forward(X) {
        let result = [];
        let i = 0;
        while (i < len(X)) {
            let row = [];
            let j = 0;
            while (j < len(X[i])) {
                if (X[i][j] > 0) { push(row, X[i][j]); }
                else { push(row, self.alpha * X[i][j]); }
                j = j + 1;
            }
            push(result, row);
            i = i + 1;
        }
        return result;
    }
}

# ── ELUActivation ──
class ELUActivation {
    let alpha = 1.0;

    fn init_elu(alpha) {
        if (alpha == nullptr) { self.alpha = 1.0; }
        else { self.alpha = alpha; }
        return 0;
    }

    fn call(x) {
        if (x > 0) { return x; }
        return self.alpha * (math_exp(x) - 1.0);
    }

    fn forward(X) {
        let result = [];
        let i = 0;
        while (i < len(X)) {
            let row = [];
            let j = 0;
            while (j < len(X[i])) {
                if (X[i][j] > 0) { push(row, X[i][j]); }
                else { push(row, self.alpha * (math_exp(X[i][j]) - 1.0)); }
                j = j + 1;
            }
            push(result, row);
            i = i + 1;
        }
        return result;
    }
}

# ── GELUActivation ──
class GELUActivation {
    fn init_gelu() { return 0; }

    fn call(x) {
        let cdf = 0.5 * (1.0 + tanh_act(math_sqrt(2.0 / 3.141592653589793) * (x + 0.044715 * x * x * x)));
        return x * cdf;
    }

    fn forward(X) {
        let result = [];
        let i = 0;
        while (i < len(X)) {
            let row = [];
            let j = 0;
            while (j < len(X[i])) {
                let x = X[i][j];
                let cdf = 0.5 * (1.0 + tanh_act(math_sqrt(2.0 / 3.141592653589793) * (x + 0.044715 * x * x * x)));
                push(row, x * cdf);
                j = j + 1;
            }
            push(result, row);
            i = i + 1;
        }
        return result;
    }
}

# ── SELUActivation ──
class SELUActivation {
    let alpha = 1.6732632423543772;
    let scale = 1.0507009873554805;

    fn init_selu() { return 0; }

    fn forward(X) {
        let result = [];
        let i = 0;
        while (i < len(X)) {
            let row = [];
            let j = 0;
            while (j < len(X[i])) {
                let x = X[i][j];
                if (x > 0) { push(row, self.scale * x); }
                else { push(row, self.scale * self.alpha * (math_exp(x) - 1.0)); }
                j = j + 1;
            }
            push(result, row);
            i = i + 1;
        }
        return result;
    }
}

# ── SigmoidActivation ──
class SigmoidActivation {
    fn init_sigmoid_act() { return 0; }
    fn call(x) { return sigmoid(x); }
    fn forward(X) {
        let result = [];
        let i = 0;
        while (i < len(X)) {
            let row = [];
            let j = 0;
            while (j < len(X[i])) {
                push(row, sigmoid(X[i][j]));
                j = j + 1;
            }
            push(result, row);
            i = i + 1;
        }
        return result;
    }
}

# ── TanhActivation ──
class TanhActivation {
    fn init_tanh_act() { return 0; }
    fn call(x) { return tanh_act(x); }
    fn forward(X) {
        let result = [];
        let i = 0;
        while (i < len(X)) {
            let row = [];
            let j = 0;
            while (j < len(X[i])) {
                push(row, tanh_act(X[i][j]));
                j = j + 1;
            }
            push(result, row);
