# ═══════════════════════════════════════════════════════════════════════════
# H#ML — H# Machine Learning Library v2.0
# ═══════════════════════════════════════════════════════════════════════════
# SECTION 1: Random Number Generation (LCG)
# ═══════════════════════════════════════════════════════════════════════════
let _hml_seed = 42;

fn hml_random() {
    let a = 1664525;
    let c = 1013904223;
    let m = 4294967296;
    let new_seed = (a * _hml_seed + c) % m;
    _hml_seed = new_seed;
    return new_seed * 1.0 / m;
}

fn hml_set_seed(s) {
    _hml_seed = s;
    return 0;
}

fn hml_randint(lo, hi) {
    let r = hml_random();
    return math_floor(lo + r * (hi - lo + 1));
}

fn hml_shuffle(arr) {
    let n = len(arr);
    let i = n - 1;
    while (i > 0) {
        let j = hml_randint(0, i);
        let tmp = arr[i];
        arr[i] = arr[j];
        arr[j] = tmp;
        i = i - 1;
    }
    return arr;
}

# ═══════════════════════════════════════════════════════════════════════════
# SECTION 2: Vector Operations
# ═══════════════════════════════════════════════════════════════════════════
fn hml_vector_add(a, b) {
    let result = [];
    let i = 0;
    while (i < len(a)) {
        push(result, a[i] + b[i]);
        i = i + 1;
    }
    return result;
}

fn hml_vector_sub(a, b) {
    let result = [];
    let i = 0;
    while (i < len(a)) {
        push(result, a[i] - b[i]);
        i = i + 1;
    }
    return result;
}

fn hml_vector_scale(a, s) {
    let result = [];
    let i = 0;
    while (i < len(a)) {
        push(result, a[i] * s);
        i = i + 1;
    }
    return result;
}

fn hml_vector_dot(a, b) {
    let result = 0.0;
    let i = 0;
    while (i < len(a)) {
        result = result + a[i] * b[i];
        i = i + 1;
    }
    return result;
}

fn hml_vector_norm(a) {
    let s = 0.0;
    let i = 0;
    while (i < len(a)) {
        s = s + a[i] * a[i];
        i = i + 1;
    }
    return math_sqrt(s);
}

fn hml_vector_mean(a) {
    if (len(a) == 0) { return 0.0; }
    let s = 0.0;
    let i = 0;
    while (i < len(a)) {
        s = s + a[i];
        i = i + 1;
    }
    return s * 1.0 / len(a);
}

fn hml_vector_argmax(a) {
    let best_i = 0;
    let best_v = a[0];
    let i = 1;
    while (i < len(a)) {
        if (a[i] > best_v) {
            best_v = a[i];
            best_i = i;
        }
        i = i + 1;
    }
    return best_i;
}

fn hml_vector_argmin(a) {
    let best_i = 0;
    let best_v = a[0];
    let i = 1;
    while (i < len(a)) {
        if (a[i] < best_v) {
            best_v = a[i];
            best_i = i;
        }
        i = i + 1;
    }
    return best_i;
}

fn hml_vector_zeros(n) {
    let result = [];
    let i = 0;
    while (i < n) {
        push(result, 0.0);
        i = i + 1;
    }
    return result;
}

fn hml_vector_ones(n) {
    let result = [];
    let i = 0;
    while (i < n) {
        push(result, 1.0);
        i = i + 1;
    }
    return result;
}

fn hml_vector_random(n) {
    let result = [];
    let i = 0;
    while (i < n) {
        push(result, hml_random());
        i = i + 1;
    }
    return result;
}

# ═══════════════════════════════════════════════════════════════════════════
# SECTION 3: Matrix Operations
# ═══════════════════════════════════════════════════════════════════════════
fn hml_matrix_shape(m) {
    if (len(m) == 0) { return [0, 0]; }
    return [len(m), len(m[0])];
}

fn hml_matrix_rows(m) { return len(m); }

fn hml_matrix_cols(m) {
    if (len(m) == 0) { return 0; }
    return len(m[0]);
}

fn hml_matrix_transpose(m) {
    let rows = hml_matrix_rows(m);
    let cols = hml_matrix_cols(m);
    let result = [];
    let j = 0;
    while (j < cols) {
        let col = [];
        let i = 0;
        while (i < rows) {
            push(col, m[i][j]);
            i = i + 1;
        }
        push(result, col);
        j = j + 1;
    }
    return result;
}

fn hml_matrix_multiply(a, b) {
    let a_rows = hml_matrix_rows(a);
    let a_cols = hml_matrix_cols(a);
    let b_cols = hml_matrix_cols(b);
    let result = [];
    let i = 0;
    while (i < a_rows) {
        let row = [];
        let j = 0;
        while (j < b_cols) {
            let s = 0.0;
            let k = 0;
            while (k < a_cols) {
                s = s + a[i][k] * b[k][j];
                k = k + 1;
            }
            push(row, s);
            j = j + 1;
        }
        push(result, row);
        i = i + 1;
    }
    return result;
}

fn hml_matrix_add(a, b) {
    let rows = hml_matrix_rows(a);
    let cols = hml_matrix_cols(a);
    let result = [];
    let i = 0;
    while (i < rows) {
        let row = [];
        let j = 0;
        while (j < cols) {
            push(row, a[i][j] + b[i][j]);
            j = j + 1;
        }
        push(result, row);
        i = i + 1;
    }
    return result;
}

fn hml_matrix_sub(a, b) {
    let rows = hml_matrix_rows(a);
    let cols = hml_matrix_cols(a);
    let result = [];
    let i = 0;
    while (i < rows) {
        let row = [];
        let j = 0;
        while (j < cols) {
            push(row, a[i][j] - b[i][j]);
            j = j + 1;
        }
        push(result, row);
        i = i + 1;
    }
    return result;
}

fn hml_matrix_scale(a, s) {
    let rows = hml_matrix_rows(a);
    let cols = hml_matrix_cols(a);
    let result = [];
    let i = 0;
    while (i < rows) {
        let row = [];
        let j = 0;
        while (j < cols) {
            push(row, a[i][j] * s);
            j = j + 1;
        }
        push(result, row);
        i = i + 1;
    }
    return result;
}

fn hml_matrix_row(m, i) { return m[i]; }

fn hml_matrix_col(m, j) {
    let result = [];
    let i = 0;
    while (i < len(m)) {
        push(result, m[i][j]);
        i = i + 1;
    }
    return result;
}

fn hml_matrix_zeros(rows, cols) {
    let result = [];
    let i = 0;
    while (i < rows) {
        let row = [];
        let j = 0;
        while (j < cols) {
            push(row, 0.0);
            j = j + 1;
        }
        push(result, row);
        i = i + 1;
    }
    return result;
}

fn hml_matrix_ones(rows, cols) {
    let result = [];
    let i = 0;
    while (i < rows) {
        let row = [];
        let j = 0;
        while (j < cols) {
            push(row, 1.0);
            j = j + 1;
        }
        push(result, row);
        i = i + 1;
    }
    return result;
}

fn hml_matrix_random(rows, cols) {
    let result = [];
    let i = 0;
    while (i < rows) {
        let row = [];
        let j = 0;
        while (j < cols) {
            push(row, hml_random() - 0.5);
            j = j + 1;
        }
        push(result, row);
        i = i + 1;
    }
    return result;
}

fn hml_matrix_from_vector(v) {
    let result = [];
    let i = 0;
    while (i < len(v)) {
        push(result, [v[i]]);
        i = i + 1;
    }
    return result;
}

fn hml_matrix_to_vector(m) {
    let result = [];
    let i = 0;
    while (i < len(m)) {
        push(result, m[i][0]);
        i = i + 1;
    }
    return result;
}

# ═══════════════════════════════════════════════════════════════════════════
# SECTION 4: Statistical Functions
# ═══════════════════════════════════════════════════════════════════════════
fn hml_mean(data) {
    if (len(data) == 0) { return 0.0; }
    let s = 0.0;
    let i = 0;
    while (i < len(data)) {
        s = s + data[i];
        i = i + 1;
    }
    return s * 1.0 / len(data);
}

fn hml_std(data) {
    let n = len(data);
    if (n < 2) { return 0.0; }
    let m = hml_mean(data);
    let s = 0.0;
    let i = 0;
    while (i < n) {
        let d = data[i] - m;
        s = s + d * d;
        i = i + 1;
    }
    return math_sqrt(s * 1.0 / (n - 1));
}

fn hml_var(data) {
    let s = hml_std(data);
    return s * s;
}

fn hml_column_means(X) {
    let n_rows = len(X);
    if (n_rows == 0) { return []; }
    let n_cols = len(X[0]);
    let means = [];
    let j = 0;
    while (j < n_cols) {
        let s = 0.0;
        let i = 0;
        while (i < n_rows) {
            s = s + X[i][j];
            i = i + 1;
        }
        push(means, s * 1.0 / n_rows);
        j = j + 1;
    }
    return means;
}

fn hml_column_stds(X) {
    let n_rows = len(X);
    if (n_rows < 2) { return []; }
    let n_cols = len(X[0]);
    let means = hml_column_means(X);
    let stds = [];
    let j = 0;
    while (j < n_cols) {
        let s = 0.0;
        let i = 0;
        while (i < n_rows) {
            let d = X[i][j] - means[j];
            s = s + d * d;
            i = i + 1;
        }
        push(stds, math_sqrt(s * 1.0 / (n_rows - 1)));
        j = j + 1;
    }
    return stds;
}

fn hml_unique(vals) {
    let result = [];
    let i = 0;
    while (i < len(vals)) {
        let v = vals[i];
        let found = false;
        let j = 0;
        while (j < len(result)) {
            if (result[j] == v) {
                found = true;
                break;
            }
            j = j + 1;
        }
        if (found == false) {
            push(result, v);
        }
        i = i + 1;
    }
    return result;
}

fn hml_value_counts(vals) {
    let result = {};
    let i = 0;
    while (i < len(vals)) {
        let v = vals[i];
        let key = v;
        let cnt = result[key];
        if (cnt == nullptr) {
            result[key] = 1;
        } else {
            result[key] = cnt + 1;
        }
        i = i + 1;
    }
    return result;
}

# ═══════════════════════════════════════════════════════════════════════════
# SECTION 5: Metrics
# ═══════════════════════════════════════════════════════════════════════════
fn accuracy_score(y_true, y_pred) {
    let correct = 0;
    let i = 0;
    while (i < len(y_true)) {
        if (y_true[i] == y_pred[i]) {
            correct = correct + 1;
        }
        i = i + 1;
    }
    return correct * 1.0 / len(y_true);
}

fn mse(y_true, y_pred) {
    let s = 0.0;
    let i = 0;
    while (i < len(y_true)) {
        let d = y_true[i] - y_pred[i];
        s = s + d * d;
        i = i + 1;
    }
    return s * 1.0 / len(y_true);
}

fn mae(y_true, y_pred) {
    let s = 0.0;
    let i = 0;
    while (i < len(y_true)) {
        let d = y_true[i] - y_pred[i];
        if (d < 0) { d = -d; }
        s = s + d;
        i = i + 1;
    }
    return s * 1.0 / len(y_true);
}

fn r2_score(y_true, y_pred) {
    let n = len(y_true);
    if (n == 0) { return 0.0; }
    let y_mean = hml_mean(y_true);
    let ss_res = 0.0;
    let ss_tot = 0.0;
    let i = 0;
    while (i < n) {
        let d_res = y_true[i] - y_pred[i];
        let d_tot = y_true[i] - y_mean;
        ss_res = ss_res + d_res * d_res;
        ss_tot = ss_tot + d_tot * d_tot;
        i = i + 1;
    }
    if (ss_tot == 0.0) { return 0.0; }
    return 1.0 - ss_res / ss_tot;
}

fn confusion_matrix(y_true, y_pred, n_classes) {
    let cm = hml_matrix_zeros(n_classes, n_classes);
    let i = 0;
    while (i < len(y_true)) {
        let row = y_true[i];
        let col = y_pred[i];
        cm[row][col] = cm[row][col] + 1;
        i = i + 1;
    }
    return cm;
}

# ═══════════════════════════════════════════════════════════════════════════

# ═══════════════════════════════════════════════════════════════════════════
# SECTION 6: Advanced Metrics
# ═══════════════════════════════════════════════════════════════════════════

fn precision_score(y_true, y_pred, pos_label) {
    let tp = 0;
    let fp = 0;
    let i = 0;
    while (i < len(y_true)) {
        if (y_pred[i] == pos_label) {
            if (y_true[i] == pos_label) {
                tp = tp + 1;
            } else {
                fp = fp + 1;
            }
        }
        i = i + 1;
    }
    if (tp + fp == 0) { return 0.0; }
    return tp * 1.0 / (tp + fp);
}

fn recall_score(y_true, y_pred, pos_label) {
    let tp = 0;
    let fn_ = 0;
    let i = 0;
    while (i < len(y_true)) {
        if (y_true[i] == pos_label) {
            if (y_pred[i] == pos_label) {
                tp = tp + 1;
            } else {
                fn_ = fn_ + 1;
            }
        }
        i = i + 1;
    }
    if (tp + fn_ == 0) { return 0.0; }
    return tp * 1.0 / (tp + fn_);
}

fn f1_score(y_true, y_pred, pos_label) {
    let p = precision_score(y_true, y_pred, pos_label);
    let r = recall_score(y_true, y_pred, pos_label);
    if (p + r == 0.0) { return 0.0; }
    return 2.0 * p * r / (p + r);
}

fn fbeta_score(y_true, y_pred, beta, pos_label) {
    let p = precision_score(y_true, y_pred, pos_label);
    let r = recall_score(y_true, y_pred, pos_label);
    let b2 = beta * beta;
    if (b2 * p + r == 0.0) { return 0.0; }
    return (1.0 + b2) * p * r / (b2 * p + r);
}

fn specificity_score(y_true, y_pred, pos_label) {
    let tn = 0;
    let fp = 0;
    let i = 0;
    while (i < len(y_true)) {
        if (y_true[i] != pos_label) {
            if (y_pred[i] != pos_label) {
                tn = tn + 1;
            } else {
                fp = fp + 1;
            }
        }
        i = i + 1;
    }
    if (tn + fp == 0) { return 0.0; }
    return tn * 1.0 / (tn + fp);
}

fn npv_score(y_true, y_pred, pos_label) {
    let tn = 0;
    let fn_ = 0;
    let i = 0;
    while (i < len(y_true)) {
        if (y_pred[i] != pos_label) {
            if (y_true[i] != pos_label) {
                tn = tn + 1;
            } else {
                fn_ = fn_ + 1;
            }
        }
        i = i + 1;
    }
    if (tn + fn_ == 0) { return 0.0; }
    return tn * 1.0 / (tn + fn_);
}

fn false_positive_rate(y_true, y_pred, pos_label) {
    let tn = 0;
    let fp = 0;
    let i = 0;
    while (i < len(y_true)) {
        if (y_true[i] != pos_label) {
            if (y_pred[i] == pos_label) {
                fp = fp + 1;
            } else {
                tn = tn + 1;
            }
        }
        i = i + 1;
    }
    if (fp + tn == 0) { return 0.0; }
    return fp * 1.0 / (fp + tn);
}

fn false_negative_rate(y_true, y_pred, pos_label) {
    let tp = 0;
    let fn_ = 0;
    let i = 0;
    while (i < len(y_true)) {
        if (y_true[i] == pos_label) {
            if (y_pred[i] == pos_label) {
                tp = tp + 1;
            } else {
                fn_ = fn_ + 1;
            }
        }
        i = i + 1;
    }
    if (tp + fn_ == 0) { return 0.0; }
    return fn_ * 1.0 / (tp + fn_);
}

fn matthews_corrcoef(y_true, y_pred) {
    let tp = 0;
    let tn = 0;
    let fp = 0;
    let fn_ = 0;
    let i = 0;
    while (i < len(y_true)) {
        if (y_true[i] == 1 and y_pred[i] == 1) {
            tp = tp + 1;
        }
        if (y_true[i] == 0 and y_pred[i] == 0) {
            tn = tn + 1;
        }
        if (y_true[i] == 0 and y_pred[i] == 1) {
            fp = fp + 1;
        }
        if (y_true[i] == 1 and y_pred[i] == 0) {
            fn_ = fn_ + 1;
        }
        i = i + 1;
    }
    let num = tp * tn - fp * fn_;
    let den = (tp + fp) * (tp + fn_) * (tn + fp) * (tn + fn_);
    if (den == 0) { return 0.0; }
    return num * 1.0 / math_sqrt(den);
}

fn cohen_kappa(y_true, y_pred) {
    let n = len(y_true);
    if (n == 0) { return 0.0; }
    let labels = hml_unique(y_true);
    let pred_labels = hml_unique(y_pred);
    let li = 0;
    while (li < len(pred_labels)) {
        let found = false;
        let lj = 0;
        while (lj < len(labels)) {
            if (labels[lj] == pred_labels[li]) { found = true; break; }
            lj = lj + 1;
        }
        if (found == false) { push(labels, pred_labels[li]); }
        li = li + 1;
    }
    let n_labels = len(labels);
    let cm = hml_matrix_zeros(n_labels, n_labels);
    let li2 = 0;
    while (li2 < len(labels)) {
        let lj2 = 0;
        while (lj2 < len(labels)) {
            cm[li2][lj2] = 0;
            lj2 = lj2 + 1;
        }
        li2 = li2 + 1;
    }
    let i = 0;
    while (i < n) {
        let row = 0;
        let col = 0;
        let rj = 0;
        while (rj < n_labels) {
            if (labels[rj] == y_true[i]) { row = rj; }
            if (labels[rj] == y_pred[i]) { col = rj; }
            rj = rj + 1;
        }
        cm[row][col] = cm[row][col] + 1;
        i = i + 1;
    }
    let po = 0.0;
    let pe = 0.0;
    let k = 0;
    while (k < n_labels) {
        po = po + cm[k][k];
        let row_sum = 0;
        let col_sum = 0;
        let j = 0;
        while (j < n_labels) {
            row_sum = row_sum + cm[k][j];
            col_sum = col_sum + cm[j][k];
            j = j + 1;
        }
        pe = pe + row_sum * col_sum;
        k = k + 1;
    }
    po = po * 1.0 / n;
    pe = pe * 1.0 / (n * n);
    if (pe == 1.0) { return 0.0; }
    return (po - pe) / (1.0 - pe);
}

fn log_loss(y_true, y_prob) {
    let n = len(y_true);
    if (n == 0) { return 0.0; }
    let eps = 0.0000000001;
    let s = 0.0;
    let i = 0;
    while (i < n) {
        let p = y_prob[i];
        if (p < eps) { p = eps; }
        if (p > 1.0 - eps) { p = 1.0 - eps; }
        if (y_true[i] == 1) {
            s = s + math_log(p);
        } else {
            s = s + math_log(1.0 - p);
        }
        i = i + 1;
    }
    return -s * 1.0 / n;
}

fn cross_entropy(y_true, y_prob) {
    return log_loss(y_true, y_prob);
}

fn hinge_loss(y_true, y_pred) {
    let n = len(y_true);
    if (n == 0) { return 0.0; }
    let s = 0.0;
    let i = 0;
    while (i < n) {
        let yt = y_true[i];
        if (yt == 0) { yt = -1; }
        let loss = 1.0 - yt * y_pred[i];
        if (loss < 0.0) { loss = 0.0; }
        s = s + loss;
        i = i + 1;
    }
    return s * 1.0 / n;
}

fn squared_hinge_loss(y_true, y_pred) {
    let n = len(y_true);
    if (n == 0) { return 0.0; }
    let s = 0.0;
    let i = 0;
    while (i < n) {
        let yt = y_true[i];
        if (yt == 0) { yt = -1; }
        let loss = 1.0 - yt * y_pred[i];
        if (loss < 0.0) { loss = 0.0; }
        s = s + loss * loss;
        i = i + 1;
    }
    return s * 1.0 / n;
}

fn huber_loss(y_true, y_pred, delta) {
    let n = len(y_true);
    if (n == 0) { return 0.0; }
    let s = 0.0;
    let i = 0;
    while (i < n) {
        let d = y_true[i] - y_pred[i];
        if (d < 0.0) { d = -d; }
        if (d <= delta) {
            s = s + 0.5 * d * d;
        } else {
            s = s + delta * (d - 0.5 * delta);
        }
        i = i + 1;
    }
    return s * 1.0 / n;
}

fn log_cosh_loss(y_true, y_pred) {
    let n = len(y_true);
    if (n == 0) { return 0.0; }
    let s = 0.0;
    let i = 0;
    while (i < n) {
        let d = y_true[i] - y_pred[i];
        s = s + math_log(math_cosh(d));
        i = i + 1;
    }
    return s * 1.0 / n;
}

fn mean_squared_log_error(y_true, y_pred) {
    let n = len(y_true);
    if (n == 0) { return 0.0; }
    let s = 0.0;
    let i = 0;
    while (i < n) {
        let d = math_log(y_true[i] + 1.0) - math_log(y_pred[i] + 1.0);
        s = s + d * d;
        i = i + 1;
    }
    return s * 1.0 / n;
}

fn mean_absolute_percentage_error(y_true, y_pred) {
    let n = len(y_true);
    if (n == 0) { return 0.0; }
    let s = 0.0;
    let i = 0;
    while (i < n) {
        if (y_true[i] == 0.0) {
            s = s + 0.0;
        } else {
            let d = y_true[i] - y_pred[i];
            if (d < 0.0) { d = -d; }
            s = s + d / y_true[i];
        }
        i = i + 1;
    }
    return s * 100.0 / n;
}

fn mean_percentage_error(y_true, y_pred) {
    let n = len(y_true);
    if (n == 0) { return 0.0; }
    let s = 0.0;
    let i = 0;
    while (i < n) {
        if (y_true[i] == 0.0) {
            s = s + 0.0;
        } else {
            s = s + (y_true[i] - y_pred[i]) / y_true[i];
        }
        i = i + 1;
    }
    return s * 100.0 / n;
}

fn explained_variance_score(y_true, y_pred) {
    let n = len(y_true);
    if (n == 0) { return 0.0; }
    let y_mean = hml_mean(y_true);
    let ss_res = 0.0;
    let ss_tot = 0.0;
    let i = 0;
    while (i < n) {
        let d_res = y_true[i] - y_pred[i];
        let d_tot = y_true[i] - y_mean;
        ss_res = ss_res + d_res * d_res;
        ss_tot = ss_tot + d_tot * d_tot;
        i = i + 1;
    }
    if (ss_tot == 0.0) { return 0.0; }
    let var_res = ss_res * 1.0 / n;
    let var_tot = ss_tot * 1.0 / n;
    return 1.0 - var_res / var_tot;
}

fn max_error(y_true, y_pred) {
    let n = len(y_true);
    if (n == 0) { return 0.0; }
    let mx = 0.0;
    let i = 0;
    while (i < n) {
        let d = y_true[i] - y_pred[i];
        if (d < 0.0) { d = -d; }
        if (d > mx) { mx = d; }
        i = i + 1;
    }
    return mx;
}

fn median_absolute_error(y_true, y_pred) {
    let n = len(y_true);
    if (n == 0) { return 0.0; }
    let errors = [];
    let i = 0;
    while (i < n) {
        let d = y_true[i] - y_pred[i];
        if (d < 0.0) { d = -d; }
        push(errors, d);
        i = i + 1;
    }
    let si = 0;
    while (si < n) {
        let min_idx = si;
        let j = si + 1;
        while (j < n) {
            if (errors[j] < errors[min_idx]) { min_idx = j; }
            j = j + 1;
        }
        let tmp = errors[si];
        errors[si] = errors[min_idx];
        errors[min_idx] = tmp;
        si = si + 1;
    }
    let mid = math_floor(n / 2);
    if (n % 2 == 0) {
        return (errors[mid - 1] + errors[mid]) / 2.0;
    }
    return errors[mid] * 1.0;
}

fn auc_roc(y_true, y_prob) {
    let n = len(y_true);
    if (n == 0) { return 0.0; }
    let pairs = [];
    let i = 0;
    while (i < n) {
        push(pairs, {"prob": y_prob[i], "label": y_true[i]});
        i = i + 1;
    }
    let si = 0;
    while (si < n) {
        let max_idx = si;
        let j = si + 1;
        while (j < n) {
            if (pairs[j]["prob"] > pairs[max_idx]["prob"]) { max_idx = j; }
            j = j + 1;
        }
        let tmp = pairs[si];
        pairs[si] = pairs[max_idx];
        pairs[max_idx] = tmp;
        si = si + 1;
    }
    let tpr = [];
    let fpr = [];
    let pos_count = 0;
    let neg_count = 0;
    let k = 0;
    while (k < n) {
        if (y_true[k] == 1) { pos_count = pos_count + 1; }
        if (y_true[k] == 0) { neg_count = neg_count + 1; }
        k = k + 1;
    }
    if (pos_count == 0 or neg_count == 0) { return 0.0; }
    let tp = 0;
    let fp = 0;
    push(tpr, 0.0);
    push(fpr, 0.0);
    k = 0;
    while (k < n) {
        if (pairs[k]["label"] == 1) {
            tp = tp + 1;
        } else {
            fp = fp + 1;
        }
        push(tpr, tp * 1.0 / pos_count);
        push(fpr, fp * 1.0 / neg_count);
        k = k + 1;
    }
    let auc = 0.0;
    k = 1;
    while (k < len(fpr)) {
        let width = fpr[k] - fpr[k - 1];
        if (width < 0.0) { width = -width; }
        auc = auc + width * (tpr[k] + tpr[k - 1]) / 2.0;
        k = k + 1;
    }
    return auc;
}

fn average_precision_score(y_true, y_prob) {
    let n = len(y_true);
    if (n == 0) { return 0.0; }
    let pairs = [];
    let i = 0;
    while (i < n) {
        push(pairs, {"prob": y_prob[i], "label": y_true[i]});
        i = i + 1;
    }
    let si = 0;
    while (si < n) {
        let max_idx = si;
        let j = si + 1;
        while (j < n) {
            if (pairs[j]["prob"] > pairs[max_idx]["prob"]) { max_idx = j; }
            j = j + 1;
        }
        let tmp = pairs[si];
        pairs[si] = pairs[max_idx];
        pairs[max_idx] = tmp;
        si = si + 1;
    }
    let ap = 0.0;
    let tp = 0;
    let total_pos = 0;
    let k = 0;
    while (k < n) {
        if (y_true[k] == 1) { total_pos = total_pos + 1; }
        k = k + 1;
    }
    if (total_pos == 0) { return 0.0; }
    let seen = 0;
    k = 0;
    while (k < n) {
        seen = seen + 1;
        if (pairs[k]["label"] == 1) {
            tp = tp + 1;
            ap = ap + tp * 1.0 / seen;
        }
        k = k + 1;
    }
    return ap * 1.0 / total_pos;
}

fn classification_report(y_true, y_pred, labels) {
    let result = {};
    let li = 0;
    while (li < len(labels)) {
        let lbl = labels[li];
        let tp = 0;
        let fp = 0;
        let fn_ = 0;
        let i = 0;
        while (i < len(y_true)) {
            if (y_true[i] == lbl and y_pred[i] == lbl) { tp = tp + 1; }
            if (y_true[i] != lbl and y_pred[i] == lbl) { fp = fp + 1; }
            if (y_true[i] == lbl and y_pred[i] != lbl) { fn_ = fn_ + 1; }
            i = i + 1;
        }
        let prec = 0.0;
        let rec = 0.0;
        let f1 = 0.0;
        if (tp + fp > 0) { prec = tp * 1.0 / (tp + fp); }
        if (tp + fn_ > 0) { rec = tp * 1.0 / (tp + fn_); }
        if (prec + rec > 0.0) { f1 = 2.0 * prec * rec / (prec + rec); }
        let support = 0;
        let j = 0;
        while (j < len(y_true)) {
            if (y_true[j] == lbl) { support = support + 1; }
            j = j + 1;
        }
        result[lbl] = {"precision": prec, "recall": rec, "f1": f1, "support": support};
        li = li + 1;
    }
    return result;
}

fn multilabel_confusion_matrix(y_true, y_pred, n_classes) {
    let result = [];
    let cls = 0;
    while (cls < n_classes) {
        let cm = hml_matrix_zeros(2, 2);
        let i = 0;
        while (i < len(y_true)) {
            if (y_true[i] == cls) {
                if (y_pred[i] == cls) {
                    cm[0][0] = cm[0][0] + 1;
                } else {
                    cm[0][1] = cm[0][1] + 1;
                }
            } else {
                if (y_pred[i] == cls) {
                    cm[1][0] = cm[1][0] + 1;
                } else {
                    cm[1][1] = cm[1][1] + 1;
                }
            }
            i = i + 1;
        }
        push(result, cm);
        cls = cls + 1;
    }
    return result;
}

fn hamming_loss(y_true, y_pred) {
    let n = len(y_true);
    if (n == 0) { return 0.0; }
    let wrong = 0;
    let i = 0;
    while (i < n) {
        if (y_true[i] != y_pred[i]) { wrong = wrong + 1; }
        i = i + 1;
    }
    return wrong * 1.0 / n;
}

fn jaccard_score(y_true, y_pred) {
    let intersection = 0;
    let u_set = 0;
    let i = 0;
    while (i < len(y_true)) {
        if (y_true[i] == 1 and y_pred[i] == 1) { intersection = intersection + 1; }
        if (y_true[i] == 1 or y_pred[i] == 1) { u_set = u_set + 1; }
        i = i + 1;
    }
    if (u_set == 0) { return 0.0; }
    return intersection * 1.0 / u_set;
}

fn zero_one_loss(y_true, y_pred) {
    let n = len(y_true);
    if (n == 0) { return 0.0; }
    let wrong = 0;
    let i = 0;
    while (i < n) {
        if (y_true[i] != y_pred[i]) { wrong = wrong + 1; }
        i = i + 1;
    }
    return wrong * 1.0 / n;
}

fn brier_score_loss(y_true, y_prob) {
    let n = len(y_true);
    if (n == 0) { return 0.0; }
    let s = 0.0;
    let i = 0;
    while (i < n) {
        let d = y_prob[i] - y_true[i];
        s = s + d * d;
        i = i + 1;
    }
    return s * 1.0 / n;
}

fn top_k_accuracy(y_true, y_prob, k) {
    let n = len(y_true);
    if (n == 0) { return 0.0; }
    let correct = 0;
    let i = 0;
    while (i < n) {
        let probs = y_prob[i];
        let indices = [];
        let m = 0;
        while (m < len(probs)) {
            push(indices, m);
            m = m + 1;
        }
        let sorted = false;
        let pass = 0;
        while (sorted == false) {
            sorted = true;
            let j = 0;
            while (j < len(probs) - 1) {
                if (probs[indices[j]] < probs[indices[j + 1]]) {
                    let tmp = indices[j];
                    indices[j] = indices[j + 1];
                    indices[j + 1] = tmp;
                    sorted = false;
                }
                j = j + 1;
            }
            pass = pass + 1;
        }
        let top_k = 0;
        while (top_k < k and top_k < len(indices)) {
            if (indices[top_k] == y_true[i]) {
                correct = correct + 1;
                break;
            }
            top_k = top_k + 1;
        }
        i = i + 1;
    }
    return correct * 1.0 / n;
}

fn balanced_accuracy_score(y_true, y_pred) {
    let labels = hml_unique(y_true);
    let pred_labels = hml_unique(y_pred);
    let li = 0;
    while (li < len(pred_labels)) {
        let found = false;
        let lj = 0;
        while (lj < len(labels)) {
            if (labels[lj] == pred_labels[li]) { found = true; break; }
            lj = lj + 1;
        }
        if (found == false) { push(labels, pred_labels[li]); }
        li = li + 1;
    }
    let n_labels = len(labels);
    let s = 0.0;
    let li2 = 0;
    while (li2 < n_labels) {
        let lbl = labels[li2];
        let tp = 0;
        let total = 0;
        let i = 0;
        while (i < len(y_true)) {
            if (y_true[i] == lbl) {
                total = total + 1;
                if (y_pred[i] == lbl) { tp = tp + 1; }
            }
            i = i + 1;
        }
        if (total > 0) { s = s + tp * 1.0 / total; }
        li2 = li2 + 1;
    }
    return s * 1.0 / n_labels;
}

fn precision_recall_curve(y_true, y_prob) {
    let n = len(y_true);
    if (n == 0) { return {"precision": [], "recall": [], "thresholds": []}; }
    let pairs = [];
    let i = 0;
    while (i < n) {
        push(pairs, {"prob": y_prob[i], "label": y_true[i]});
        i = i + 1;
    }
    let si = 0;
    while (si < n) {
        let max_idx = si;
        let j = si + 1;
        while (j < n) {
            if (pairs[j]["prob"] > pairs[max_idx]["prob"]) { max_idx = j; }
            j = j + 1;
        }
        let tmp = pairs[si];
        pairs[si] = pairs[max_idx];
        pairs[max_idx] = tmp;
        si = si + 1;
    }
    let precisions = [];
    let recalls = [];
    let thresholds = [];
    let total_pos = 0;
    let k = 0;
    while (k < n) {
        if (y_true[k] == 1) { total_pos = total_pos + 1; }
        k = k + 1;
    }
    if (total_pos == 0) { return {"precision": [], "recall": [], "thresholds": []}; }
    let tp = 0;
    let fp = 0;
    k = 0;
    while (k < n) {
        if (pairs[k]["label"] == 1) {
            tp = tp + 1;
        } else {
            fp = fp + 1;
        }
        let prec = 0.0;
        if (tp + fp > 0) { prec = tp * 1.0 / (tp + fp); }
        let rec = tp * 1.0 / total_pos;
        push(precisions, prec);
        push(recalls, rec);
        push(thresholds, pairs[k]["prob"]);
        k = k + 1;
    }
    return {"precision": precisions, "recall": recalls, "thresholds": thresholds};
}

fn roc_curve(y_true, y_prob) {
    let n = len(y_true);
    if (n == 0) { return {"fpr": [], "tpr": [], "thresholds": []}; }
    let pairs = [];
    let i = 0;
    while (i < n) {
        push(pairs, {"prob": y_prob[i], "label": y_true[i]});
        i = i + 1;
    }
    let si = 0;
    while (si < n) {
        let max_idx = si;
        let j = si + 1;
        while (j < n) {
            if (pairs[j]["prob"] > pairs[max_idx]["prob"]) { max_idx = j; }
            j = j + 1;
        }
        let tmp = pairs[si];
        pairs[si] = pairs[max_idx];
        pairs[max_idx] = tmp;
        si = si + 1;
    }
    let fprs = [];
    let tprs = [];
    let thresh_arr = [];
    let pos = 0;
    let neg = 0;
    let k = 0;
    while (k < n) {
        if (y_true[k] == 1) { pos = pos + 1; }
        if (y_true[k] == 0) { neg = neg + 1; }
        k = k + 1;
    }
    if (pos == 0 or neg == 0) { return {"fpr": [], "tpr": [], "thresholds": []}; }
    push(fprs, 0.0);
    push(tprs, 0.0);
    push(thresh_arr, 1.0);
    let tp = 0;
    let fp = 0;
    k = 0;
    while (k < n) {
        if (pairs[k]["label"] == 1) {
            tp = tp + 1;
        } else {
            fp = fp + 1;
        }
        push(fprs, fp * 1.0 / neg);
        push(tprs, tp * 1.0 / pos);
        push(thresh_arr, pairs[k]["prob"]);
        k = k + 1;
    }
    return {"fpr": fprs, "tpr": tprs, "thresholds": thresh_arr};
}

fn silhouette_score(X, labels) {
    let n = len(X);
    if (n == 0) { return 0.0; }
    let unique_labels = hml_unique(labels);
    let k = len(unique_labels);
    if (k < 2) { return 0.0; }
    let cluster_points = {};
    let li = 0;
    while (li < len(unique_labels)) {
        let lbl = unique_labels[li];
        cluster_points[lbl] = [];
        li = li + 1;
    }
    let i = 0;
    while (i < n) {
        let lbl = labels[i];
        push(cluster_points[lbl], i);
        i = i + 1;
    }
    let total_s = 0.0;
    i = 0;
    while (i < n) {
        let my_lbl = labels[i];
        let a = 0.0;
        let my_pts = cluster_points[my_lbl];
        let pj = 0;
        let ac = 0;
        while (pj < len(my_pts)) {
            let idx = my_pts[pj];
            if (idx != i) {
                let d = 0.0;
                let f = 0;
                while (f < len(X[i])) {
                    let diff = X[i][f] - X[idx][f];
                    d = d + diff * diff;
                    f = f + 1;
                }
                a = a + math_sqrt(d);
                ac = ac + 1;
            }
            pj = pj + 1;
        }
        if (ac > 0) { a = a * 1.0 / ac; }
        let b = 999999999.0;
        let lj = 0;
        while (lj < len(unique_labels)) {
            let other_lbl = unique_labels[lj];
            if (other_lbl != my_lbl) {
                let other_pts = cluster_points[other_lbl];
                let dist_sum = 0.0;
                let dc = 0;
                let pk = 0;
                while (pk < len(other_pts)) {
                    let idx = other_pts[pk];
                    let d = 0.0;
                    let f = 0;
                    while (f < len(X[i])) {
                        let diff = X[i][f] - X[idx][f];
                        d = d + diff * diff;
                        f = f + 1;
                    }
                    dist_sum = dist_sum + math_sqrt(d);
                    dc = dc + 1;
                    pk = pk + 1;
                }
                if (dc > 0) {
                    let avg = dist_sum * 1.0 / dc;
                    if (avg < b) { b = avg; }
                }
            }
            lj = lj + 1;
        }
        let s = 0.0;
        if (a < b) {
            s = 1.0 - a / b;
        } else {
            if (a > b) {
                s = b / a - 1.0;
            }
        }
        total_s = total_s + s;
        i = i + 1;
    }
    return total_s * 1.0 / n;
}

fn davies_bouldin_score(X, labels) {
    let n = len(X);
    if (n == 0) { return 0.0; }
    let unique_labels = hml_unique(labels);
    let k = len(unique_labels);
    if (k < 2) { return 0.0; }
    let centroids = [];
    let avg_dists = [];
    let li = 0;
    while (li < k) {
        let lbl = unique_labels[li];
        let cnt = 0;
        let sum = hml_vector_zeros(len(X[0]));
        let i = 0;
        while (i < n) {
            if (labels[i] == lbl) {
                cnt = cnt + 1;
                let f = 0;
                while (f < len(sum)) {
                    sum[f] = sum[f] + X[i][f];
                    f = f + 1;
                }
            }
            i = i + 1;
        }
        if (cnt > 0) {
            let f = 0;
            while (f < len(sum)) {
                sum[f] = sum[f] * 1.0 / cnt;
                f = f + 1;
            }
        }
        push(centroids, sum);
        let avg = 0.0;
        i = 0;
        while (i < n) {
            if (labels[i] == lbl) {
                let d = 0.0;
                let f = 0;
                while (f < len(sum)) {
                    let diff = X[i][f] - sum[f];
                    d = d + diff * diff;
                    f = f + 1;
                }
                avg = avg + math_sqrt(d);
            }
            i = i + 1;
        }
        if (cnt > 0) { avg = avg * 1.0 / cnt; }
        push(avg_dists, avg);
        li = li + 1;
    }
    let s = 0.0;
    let i = 0;
    while (i < k) {
        let mx = 0.0;
        let j = 0;
        while (j < k) {
            if (i != j) {
                let d = 0.0;
                let f = 0;
                while (f < len(centroids[i])) {
                    let diff = centroids[i][f] - centroids[j][f];
                    d = d + diff * diff;
                    f = f + 1;
                }
                d = math_sqrt(d);
                let r = 0.0;
                if (d > 0.0) { r = (avg_dists[i] + avg_dists[j]) / d; }
                if (r > mx) { mx = r; }
            }
            j = j + 1;
        }
        s = s + mx;
        i = i + 1;
    }
    return s * 1.0 / k;
}

fn calinski_harabasz_score(X, labels) {
    let n = len(X);
    if (n == 0) { return 0.0; }
    let n_features = len(X[0]);
    let unique_labels = hml_unique(labels);
    let k = len(unique_labels);
    if (k < 2) { return 0.0; }
    let overall_mean = hml_vector_zeros(n_features);
    let i = 0;
    while (i < n) {
        let f = 0;
        while (f < n_features) {
            overall_mean[f] = overall_mean[f] + X[i][f];
            f = f + 1;
        }
        i = i + 1;
    }
    let f = 0;
    while (f < n_features) {
        overall_mean[f] = overall_mean[f] * 1.0 / n;
        f = f + 1;
    }
    let ssb = 0.0;
    let ssw = 0.0;
    let li = 0;
    while (li < k) {
        let lbl = unique_labels[li];
        let cnt = 0;
        let cluster_mean = hml_vector_zeros(n_features);
        i = 0;
        while (i < n) {
            if (labels[i] == lbl) {
                cnt = cnt + 1;
                f = 0;
                while (f < n_features) {
                    cluster_mean[f] = cluster_mean[f] + X[i][f];
                    f = f + 1;
                }
            }
            i = i + 1;
        }
        if (cnt > 0) {
            f = 0;
            while (f < n_features) {
                cluster_mean[f] = cluster_mean[f] * 1.0 / cnt;
                f = f + 1;
            }
        }
        let b_dist = 0.0;
        f = 0;
        while (f < n_features) {
            let diff = cluster_mean[f] - overall_mean[f];
            b_dist = b_dist + diff * diff;
            f = f + 1;
        }
        ssb = ssb + cnt * b_dist;
        i = 0;
        while (i < n) {
            if (labels[i] == lbl) {
                f = 0;
                while (f < n_features) {
                    let diff = X[i][f] - cluster_mean[f];
                    ssw = ssw + diff * diff;
                    f = f + 1;
                }
            }
            i = i + 1;
        }
        li = li + 1;
    }
    if (ssw == 0.0) { return 0.0; }
    return (ssb * 1.0 / (k - 1)) / (ssw * 1.0 / (n - k));
}

fn adjusted_rand_score(labels_true, labels_pred) {
    let n = len(labels_true);
    if (n == 0) { return 0.0; }
    let true_unique = hml_unique(labels_true);
    let pred_unique = hml_unique(labels_pred);
    let nr = len(true_unique);
    let nc = len(pred_unique);
    let cm = hml_matrix_zeros(nr, nc);
    let i = 0;
    while (i < n) {
        let r = 0;
        let c = 0;
        let j = 0;
        while (j < nr) {
            if (true_unique[j] == labels_true[i]) { r = j; }
            j = j + 1;
        }
        j = 0;
        while (j < nc) {
            if (pred_unique[j] == labels_pred[i]) { c = j; }
            j = j + 1;
        }
        cm[r][c] = cm[r][c] + 1;
        i = i + 1;
    }
    let sum_a = 0;
    let sum_b = 0;
    let ri = 0;
    while (ri < nr) {
        let rsum = 0;
        let cj = 0;
        while (cj < nc) {
            rsum = rsum + cm[ri][cj];
            cj = cj + 1;
        }
        sum_a = sum_a + rsum * (rsum - 1) / 2;
        ri = ri + 1;
    }
    let cj = 0;
    while (cj < nc) {
        let csum = 0;
        ri = 0;
        while (ri < nr) {
            csum = csum + cm[ri][cj];
            ri = ri + 1;
        }
        sum_b = sum_b + csum * (csum - 1) / 2;
        cj = cj + 1;
    }
    let sum_nij = 0;
    ri = 0;
    while (ri < nr) {
        cj = 0;
        while (cj < nc) {
            let nij = cm[ri][cj];
            sum_nij = sum_nij + nij * (nij - 1) / 2;
            cj = cj + 1;
        }
        ri = ri + 1;
    }
    let total = n * (n - 1) / 2;
    let expected = sum_a * sum_b * 1.0 / total;
    let max_rand = (sum_a + sum_b) * 0.5;
    let den = max_rand - expected;
    if (den == 0.0) { return 0.0; }
    return (sum_nij - expected) / den;
}

fn normalized_mutual_info_score(labels_true, labels_pred) {
    let mi = mutual_info_score(labels_true, labels_pred);
    let n = len(labels_true);
    if (n == 0) { return 0.0; }
    let true_counts = hml_value_counts(labels_true);
    let pred_counts = hml_value_counts(labels_pred);
    let h_true = 0.0;
    let true_keys = dict_keys(true_counts);
    let i = 0;
    while (i < len(true_keys)) {
        let p = true_counts[true_keys[i]] * 1.0 / n;
        h_true = h_true - p * math_log(p);
        i = i + 1;
    }
    let h_pred = 0.0;
    let pred_keys = dict_keys(pred_counts);
    i = 0;
    while (i < len(pred_keys)) {
        let p = pred_counts[pred_keys[i]] * 1.0 / n;
        h_pred = h_pred - p * math_log(p);
        i = i + 1;
    }
    let den = h_true + h_pred;
    if (den == 0.0) { return 0.0; }
    return 2.0 * mi / den;
}

fn homogeneity_score(labels_true, labels_pred) {
    let n = len(labels_true);
    if (n == 0) { return 0.0; }
    let true_counts = hml_value_counts(labels_true);
    let true_keys = dict_keys(true_counts);
    let pred_keys = dict_keys(hml_value_counts(labels_pred));
    let h_true = 0.0;
    let i = 0;
    while (i < len(true_keys)) {
        let p = true_counts[true_keys[i]] * 1.0 / n;
        h_true = h_true - p * math_log(p);
        i = i + 1;
    }
    if (h_true == 0.0) { return 1.0; }
    let h_cond = 0.0;
    let pk = 0;
    while (pk < len(pred_keys)) {
        let pc = pred_keys[pk];
        let cluster_pts = [];
        let j = 0;
        while (j < n) {
            if (labels_pred[j] == pc) { push(cluster_pts, j); }
            j = j + 1;
        }
        let c_size = len(cluster_pts);
        let h = 0.0;
        let tk = 0;
        while (tk < len(true_keys)) {
            let tc = true_keys[tk];
            let cnt = 0;
            let cj = 0;
            while (cj < c_size) {
                if (labels_true[cluster_pts[cj]] == tc) { cnt = cnt + 1; }
                cj = cj + 1;
            }
            if (cnt > 0) {
                let p = cnt * 1.0 / c_size;
                h = h - p * math_log(p);
            }
            tk = tk + 1;
        }
        h_cond = h_cond + c_size * 1.0 / n * h;
        pk = pk + 1;
    }
    if (h_true == 0.0) { return 0.0; }
    return 1.0 - h_cond / h_true;
}

fn completeness_score(labels_true, labels_pred) {
    return homogeneity_score(labels_pred, labels_true);
}

fn v_measure_score(labels_true, labels_pred) {
    let h = homogeneity_score(labels_true, labels_pred);
    let c = completeness_score(labels_true, labels_pred);
    if (h + c == 0.0) { return 0.0; }
    return 2.0 * h * c / (h + c);
}

fn fowlkes_mallows_score(labels_true, labels_pred) {
    let n = len(labels_true);
    if (n == 0) { return 0.0; }
    let tp = 0;
    let i = 0;
    while (i < n) {
        let j = i + 1;
        while (j < n) {
            let same_true = (labels_true[i] == labels_true[j]);
            let same_pred = (labels_pred[i] == labels_pred[j]);
            if (same_true and same_pred) { tp = tp + 1; }
            j = j + 1;
        }
        i = i + 1;
    }
    let fp = 0;
    i = 0;
    while (i < n) {
        let j = i + 1;
        while (j < n) {
            let same_true = (labels_true[i] == labels_true[j]);
            let same_pred = (labels_pred[i] == labels_pred[j]);
            if (same_pred and same_true == false) { fp = fp + 1; }
            j = j + 1;
        }
        i = i + 1;
    }
    let fn_ = 0;
    i = 0;
    while (i < n) {
        let j = i + 1;
        while (j < n) {
            let same_true = (labels_true[i] == labels_true[j]);
            let same_pred = (labels_pred[i] == labels_pred[j]);
            if (same_true and same_pred == false) { fn_ = fn_ + 1; }
            j = j + 1;
        }
        i = i + 1;
    }
    let prec = 0.0;
    let rec = 0.0;
    if (tp + fp > 0) { prec = tp * 1.0 / (tp + fp); }
    if (tp + fn_ > 0) { rec = tp * 1.0 / (tp + fn_); }
    if (prec * rec == 0.0) { return 0.0; }
    return math_sqrt(prec * rec);
}

fn mutual_info_score(labels_true, labels_pred) {
    let n = len(labels_true);
    if (n == 0) { return 0.0; }
    let true_unique = hml_unique(labels_true);
    let pred_unique = hml_unique(labels_pred);
    let nr = len(true_unique);
    let nc = len(pred_unique);
    let cm = hml_matrix_zeros(nr, nc);
    let i = 0;
    while (i < n) {
        let r = 0;
        let c = 0;
        let j = 0;
        while (j < nr) {
            if (true_unique[j] == labels_true[i]) { r = j; }
            j = j + 1;
        }
        j = 0;
        while (j < nc) {
            if (pred_unique[j] == labels_pred[i]) { c = j; }
            j = j + 1;
        }
        cm[r][c] = cm[r][c] + 1;
        i = i + 1;
    }
    let mi = 0.0;
    let ri = 0;
    while (ri < nr) {
        let cj = 0;
        while (cj < nc) {
            let nij = cm[ri][cj];
            if (nij > 0) {
                let row_sum = 0;
                let ck = 0;
                while (ck < nc) {
                    row_sum = row_sum + cm[ri][ck];
                    ck = ck + 1;
                }
                let col_sum = 0;
                let rk = 0;
                while (rk < nr) {
                    col_sum = col_sum + cm[rk][cj];
                    rk = rk + 1;
                }
                mi = mi + nij * 1.0 / n * math_log(nij * n * 1.0 / (row_sum * col_sum));
            }
            cj = cj + 1;
        }
        ri = ri + 1;
    }
    return mi;
}

fn contingency_table(labels_true, labels_pred) {
    let true_unique = hml_unique(labels_true);
    let pred_unique = hml_unique(labels_pred);
    let nr = len(true_unique);
    let nc = len(pred_unique);
    let cm = hml_matrix_zeros(nr, nc);
    let i = 0;
    while (i < len(labels_true)) {
        let r = 0;
        let c = 0;
        let j = 0;
        while (j < nr) {
            if (true_unique[j] == labels_true[i]) { r = j; }
            j = j + 1;
        }
        j = 0;
        while (j < nc) {
            if (pred_unique[j] == labels_pred[i]) { c = j; }
            j = j + 1;
        }
        cm[r][c] = cm[r][c] + 1;
        i = i + 1;
    }
    return cm;
}

fn purity_score(labels_true, labels_pred) {
    let n = len(labels_true);
    if (n == 0) { return 0.0; }
    let pred_unique = hml_unique(labels_pred);
    let total = 0;
    let pk = 0;
    while (pk < len(pred_unique)) {
        let pc = pred_unique[pk];
        let counts = {};
        let i = 0;
        while (i < n) {
            if (labels_pred[i] == pc) {
                let lbl = labels_true[i];
                let cnt = counts[lbl];
                if (cnt == nullptr) {
                    counts[lbl] = 1;
                } else {
                    counts[lbl] = cnt + 1;
                }
            }
            i = i + 1;
        }
        let mx = 0;
        let keys = dict_keys(counts);
        let ki = 0;
        while (ki < len(keys)) {
            if (counts[keys[ki]] > mx) { mx = counts[keys[ki]]; }
            ki = ki + 1;
        }
        total = total + mx;
        pk = pk + 1;
    }
    return total * 1.0 / n;
}

fn cluster_accuracy(labels_true, labels_pred) {
    let n = len(labels_true);
    if (n == 0) { return 0.0; }
    let true_unique = hml_unique(labels_true);
    let pred_unique = hml_unique(labels_pred);
    let nr = len(true_unique);
    let nc = len(pred_unique);
    let cm = hml_matrix_zeros(nr, nc);
    let i = 0;
    while (i < n) {
        let r = 0;
        let c = 0;
        let j = 0;
        while (j < nr) {
            if (true_unique[j] == labels_true[i]) { r = j; }
            j = j + 1;
        }
        j = 0;
        while (j < nc) {
            if (pred_unique[j] == labels_pred[i]) { c = j; }
            j = j + 1;
        }
        cm[r][c] = cm[r][c] + 1;
        i = i + 1;
    }
    let assigned = [];
    let nc2 = nc;
    let cj = 0;
    while (cj < nc2) {
        push(assigned, false);
        cj = cj + 1;
    }
    let total = 0;
    let ri = 0;
    while (ri < nr) {
        let mx = 0;
        let best = -1;
        cj = 0;
        while (cj < nc2) {
            if (assigned[cj] == false and cm[ri][cj] > mx) {
                mx = cm[ri][cj];
                best = cj;
            }
            cj = cj + 1;
        }
        if (best >= 0) {
            assigned[best] = true;
            total = total + mx;
        }
        ri = ri + 1;
    }
    return total * 1.0 / n;
}

# ═══════════════════════════════════════════════════════════════════════════
# SECTION 7: Loss Functions
# ═══════════════════════════════════════════════════════════════════════════

fn binary_crossentropy(y_true, y_pred) {
    let n = len(y_true);
    if (n == 0) { return 0.0; }
    let eps = 0.0000001;
    let s = 0.0;
    let i = 0;
    while (i < n) {
        let p = y_pred[i];
        if (p < eps) { p = eps; }
        if (p > 1.0 - eps) { p = 1.0 - eps; }
        s = s + y_true[i] * math_log(p) + (1.0 - y_true[i]) * math_log(1.0 - p);
        i = i + 1;
    }
    return -s * 1.0 / n;
}

fn categorical_crossentropy(y_true, y_pred) {
    let n = len(y_true);
    if (n == 0) { return 0.0; }
    let eps = 0.0000001;
    let s = 0.0;
    let i = 0;
    while (i < n) {
        let n_classes = len(y_true[i]);
        let j = 0;
        while (j < n_classes) {
            let p = y_pred[i][j];
            if (p < eps) { p = eps; }
            if (p > 1.0 - eps) { p = 1.0 - eps; }
            s = s + y_true[i][j] * math_log(p);
            j = j + 1;
        }
        i = i + 1;
    }
    return -s * 1.0 / n;
}

fn sparse_categorical_crossentropy(y_true, y_pred) {
    let n = len(y_true);
    if (n == 0) { return 0.0; }
    let eps = 0.0000001;
    let s = 0.0;
    let i = 0;
    while (i < n) {
        let p = y_pred[i][y_true[i]];
        if (p < eps) { p = eps; }
        s = s + math_log(p);
        i = i + 1;
    }
    return -s * 1.0 / n;
}

fn mean_squared_error_loss(y_true, y_pred) {
    return mse(y_true, y_pred);
}

fn mean_absolute_error_loss(y_true, y_pred) {
    return mae(y_true, y_pred);
}

fn mean_absolute_percentage_error_loss(y_true, y_pred) {
    return mean_absolute_percentage_error(y_true, y_pred);
}

fn hinge_loss_fn(y_true, y_pred) {
    let n = len(y_true);
    if (n == 0) { return 0.0; }
    let s = 0.0;
    let i = 0;
    while (i < n) {
        let yt = y_true[i];
        if (yt == 0) { yt = -1.0; }
        let loss = 1.0 - yt * y_pred[i];
        if (loss < 0.0) { loss = 0.0; }
        s = s + loss;
        i = i + 1;
    }
    return s * 1.0 / n;
}

fn squared_hinge_loss_fn(y_true, y_pred) {
    let n = len(y_true);
    if (n == 0) { return 0.0; }
    let s = 0.0;
    let i = 0;
    while (i < n) {
        let yt = y_true[i];
        if (yt == 0) { yt = -1.0; }
        let loss = 1.0 - yt * y_pred[i];
        if (loss < 0.0) { loss = 0.0; }
        s = s + loss * loss;
        i = i + 1;
    }
    return s * 1.0 / n;
}

fn huber_loss_fn(y_true, y_pred, delta) {
    return huber_loss(y_true, y_pred, delta);
}

fn log_cosh_loss_fn(y_true, y_pred) {
    return log_cosh_loss(y_true, y_pred);
}

fn poisson_loss(y_true, y_pred) {
    let n = len(y_true);
    if (n == 0) { return 0.0; }
    let eps = 0.0000001;
    let s = 0.0;
    let i = 0;
    while (i < n) {
        let p = y_pred[i];
        if (p < eps) { p = eps; }
        s = s + p - y_true[i] * math_log(p);
        i = i + 1;
    }
    return s * 1.0 / n;
}

fn kl_divergence(y_true, y_pred) {
    let n = len(y_true);
    if (n == 0) { return 0.0; }
    let eps = 0.0000001;
    let s = 0.0;
    let i = 0;
    while (i < n) {
        let p = y_true[i];
        if (p < eps) { p = eps; }
        let q = y_pred[i];
        if (q < eps) { q = eps; }
        s = s + p * math_log(p / q);
        i = i + 1;
    }
    return s;
}

fn cosine_proximity_loss(y_true, y_pred) {
    let n = len(y_true);
    if (n == 0) { return 0.0; }
    let dot = 0.0;
    let norm_a = 0.0;
    let norm_b = 0.0;
    let i = 0;
    while (i < n) {
        dot = dot + y_true[i] * y_pred[i];
        norm_a = norm_a + y_true[i] * y_true[i];
        norm_b = norm_b + y_pred[i] * y_pred[i];
        i = i + 1;
    }
    norm_a = math_sqrt(norm_a);
    norm_b = math_sqrt(norm_b);
    let den = norm_a * norm_b;
    if (den == 0.0) { return 0.0; }
    return -dot / den;
}

fn binary_focal_loss(y_true, y_pred, gamma, alpha) {
    let n = len(y_true);
    if (n == 0) { return 0.0; }
    let eps = 0.0000001;
    let s = 0.0;
    let i = 0;
    while (i < n) {
        let p = y_pred[i];
        if (p < eps) { p = eps; }
        if (p > 1.0 - eps) { p = 1.0 - eps; }
        let pt = 0.0;
        if (y_true[i] == 1) {
            pt = p;
        } else {
            pt = 1.0 - p;
        }
        let fl = -alpha * math_pow(1.0 - pt, gamma) * math_log(pt);
        s = s + fl;
        i = i + 1;
    }
    return s * 1.0 / n;
}

fn categorical_focal_loss(y_true, y_pred, gamma, alpha) {
    let n = len(y_true);
    if (n == 0) { return 0.0; }
    let eps = 0.0000001;
    let s = 0.0;
    let i = 0;
    while (i < n) {
        let n_classes = len(y_true[i]);
        let j = 0;
        while (j < n_classes) {
            let p = y_pred[i][j];
            if (p < eps) { p = eps; }
            if (p > 1.0 - eps) { p = 1.0 - eps; }
            let fl = -alpha * math_pow(1.0 - p, gamma) * math_log(p);
            s = s + y_true[i][j] * fl;
            j = j + 1;
        }
        i = i + 1;
    }
    return s * 1.0 / n;
}

fn softmax_crossentropy(logits, labels) {
    let n = len(logits);
    if (n == 0) { return 0.0; }
    let eps = 0.0000001;
    let s = 0.0;
    let i = 0;
    while (i < n) {
        let n_classes = len(logits[i]);
        let mx = logits[i][0];
        let j = 1;
        while (j < n_classes) {
            if (logits[i][j] > mx) { mx = logits[i][j]; }
            j = j + 1;
        }
        let sum_exp = 0.0;
        j = 0;
        while (j < n_classes) {
            sum_exp = sum_exp + math_exp(logits[i][j] - mx);
            j = j + 1;
        }
        let log_sum = math_log(sum_exp);
        let target = labels[i];
        let z = logits[i][target] - mx - log_sum;
        s = s + z;
        i = i + 1;
    }
    return -s * 1.0 / n;
}

fn sigmoid_crossentropy(logits, labels) {
    let n = len(logits);
    if (n == 0) { return 0.0; }
    let s = 0.0;
    let i = 0;
    while (i < n) {
        let z = logits[i];
        let loss = 0.0;
        if (z >= 0.0) {
            loss = z - z * labels[i] + math_log(1.0 + math_exp(-z));
        } else {
            loss = -z * labels[i] + math_log(1.0 + math_exp(z));
        }
        s = s + loss;
        i = i + 1;
    }
    return s * 1.0 / n;
}

fn weighted_binary_crossentropy(y_true, y_pred, pos_weight) {
    let n = len(y_true);
    if (n == 0) { return 0.0; }
    let eps = 0.0000001;
    let s = 0.0;
    let i = 0;
    while (i < n) {
        let p = y_pred[i];
        if (p < eps) { p = eps; }
        if (p > 1.0 - eps) { p = 1.0 - eps; }
        s = s + pos_weight * y_true[i] * math_log(p) + (1.0 - y_true[i]) * math_log(1.0 - p);
        i = i + 1;
    }
    return -s * 1.0 / n;
}

fn contrastive_loss(y1, y2, label, margin) {
    let n = len(y1);
    if (n == 0) { return 0.0; }
    let s = 0.0;
    let i = 0;
    while (i < n) {
        let d = 0.0;
        let j = 0;
        while (j < len(y1[i])) {
            let diff = y1[i][j] - y2[i][j];
            d = d + diff * diff;
            j = j + 1;
        }
        if (label[i] == 1) {
            s = s + d;
        } else {
            let loss = margin - d;
            if (loss < 0.0) { loss = 0.0; }
            s = s + loss;
        }
        i = i + 1;
    }
    return s * 0.5 / n;
}

fn triplet_loss(anchor, positive, negative, margin) {
    let n = len(anchor);
    if (n == 0) { return 0.0; }
    let s = 0.0;
    let i = 0;
    while (i < n) {
        let d_pos = 0.0;
        let d_neg = 0.0;
        let j = 0;
        while (j < len(anchor[i])) {
            let diff_pos = anchor[i][j] - positive[i][j];
            let diff_neg = anchor[i][j] - negative[i][j];
            d_pos = d_pos + diff_pos * diff_pos;
            d_neg = d_neg + diff_neg * diff_neg;
            j = j + 1;
        }
        let loss = d_pos - d_neg + margin;
        if (loss < 0.0) { loss = 0.0; }
        s = s + loss;
        i = i + 1;
    }
    return s * 1.0 / n;
}

fn dice_loss(y_true, y_pred) {
    let n = len(y_true);
    if (n == 0) { return 0.0; }
    let eps = 0.0000001;
    let intersection = 0.0;
    let sum_a = 0.0;
    let sum_b = 0.0;
    let i = 0;
    while (i < n) {
        intersection = intersection + y_true[i] * y_pred[i];
        sum_a = sum_a + y_true[i] * y_true[i];
        sum_b = sum_b + y_pred[i] * y_pred[i];
        i = i + 1;
    }
    let dice = 2.0 * intersection / (sum_a + sum_b + eps);
    return 1.0 - dice;
}

fn tversky_loss(y_true, y_pred, alpha, beta) {
    let n = len(y_true);
    if (n == 0) { return 0.0; }
    let eps = 0.0000001;
    let tp = 0.0;
    let fp = 0.0;
    let fn_ = 0.0;
    let i = 0;
    while (i < n) {
        tp = tp + y_true[i] * y_pred[i];
        fp = fp + (1.0 - y_true[i]) * y_pred[i];
        fn_ = fn_ + y_true[i] * (1.0 - y_pred[i]);
        i = i + 1;
    }
    let tversky = tp / (tp + alpha * fp + beta * fn_ + eps);
    return 1.0 - tversky;
}

fn jaccard_loss(y_true, y_pred) {
    let n = len(y_true);
    if (n == 0) { return 0.0; }
    let eps = 0.0000001;
    let intersection = 0.0;
    let u_set = 0.0;
    let i = 0;
    while (i < n) {
        intersection = intersection + y_true[i] * y_pred[i];
        if (y_true[i] > 0.0 or y_pred[i] > 0.0) { u_set = u_set + 1.0; }
        i = i + 1;
    }
    u_set = u_set + eps;
    return 1.0 - intersection / u_set;
}

fn lovasz_hinge_loss(y_true, y_pred) {
    let n = len(y_true);
    if (n == 0) { return 0.0; }
    let s = 0.0;
    let i = 0;
    while (i < n) {
        let yt = y_true[i];
        if (yt == 0) { yt = -1.0; }
        let loss = 1.0 - yt * y_pred[i];
        if (loss < 0.0) { loss = 0.0; }
        s = s + loss;
        i = i + 1;
    }
    return s * 1.0 / n;
}

fn pinball_loss(y_true, y_pred, tau) {
    let n = len(y_true);
    if (n == 0) { return 0.0; }
    let s = 0.0;
    let i = 0;
    while (i < n) {
        let d = y_true[i] - y_pred[i];
        if (d >= 0.0) {
            s = s + tau * d;
        } else {
            s = s + (tau - 1.0) * d;
        }
        i = i + 1;
    }
    return s * 1.0 / n;
}

fn wing_loss(y_true, y_pred, w, eps) {
    let n = len(y_true);
    if (n == 0) { return 0.0; }
    let s = 0.0;
    let c = w * (1.0 - math_log(1.0 + w / eps));
    let i = 0;
    while (i < n) {
        let d = y_true[i] - y_pred[i];
        if (d < 0.0) { d = -d; }
        if (d < w) {
            s = s + w * math_log(1.0 + d / eps);
        } else {
            s = s + d - c;
        }
        i = i + 1;
    }
    return s * 1.0 / n;
}

fn smooth_l1_loss(y_true, y_pred) {
    let n = len(y_true);
    if (n == 0) { return 0.0; }
    let s = 0.0;
    let i = 0;
    while (i < n) {
        let d = y_true[i] - y_pred[i];
        if (d < 0.0) { d = -d; }
        if (d < 1.0) {
            s = s + 0.5 * d * d;
        } else {
            s = s + d - 0.5;
        }
        i = i + 1;
    }
    return s * 1.0 / n;
}

fn cauchy_loss(y_true, y_pred, c) {
    let n = len(y_true);
    if (n == 0) { return 0.0; }
    let s = 0.0;
    let i = 0;
    while (i < n) {
        let d = y_true[i] - y_pred[i];
        s = s + c * c * 0.5 * math_log(1.0 + (d * d) / (c * c));
        i = i + 1;
    }
    return s * 1.0 / n;
}

fn geman_mcclure_loss(y_true, y_pred, c) {
    let n = len(y_true);
    if (n == 0) { return 0.0; }
    let s = 0.0;
    let i = 0;
    while (i < n) {
        let d = y_true[i] - y_pred[i];
        s = s + (d * d) / (d * d + c * c);
        i = i + 1;
    }
    return s * 1.0 / n;
}

fn charbonnier_loss(y_true, y_pred, eps) {
    let n = len(y_true);
    if (n == 0) { return 0.0; }
    let s = 0.0;
    let i = 0;
    while (i < n) {
        let d = y_true[i] - y_pred[i];
        s = s + math_sqrt(d * d + eps * eps);
        i = i + 1;
    }
    return s * 1.0 / n;
}

# ═══════════════════════════════════════════════════════════════════════════
# SECTION 8: Activation Functions
# ═══════════════════════════════════════════════════════════════════════════

fn sigmoid(x) {
    return 1.0 / (1.0 + math_exp(-x));
}

fn sigmoid_derivative(x) {
    let s = sigmoid(x);
    return s * (1.0 - s);
}

fn tanh_act(x) {
    return math_tanh(x);
}

fn tanh_derivative(x) {
    let t = math_tanh(x);
    return 1.0 - t * t;
}

fn relu(x) {
    if (x > 0.0) { return x; }
    return 0.0;
}

fn relu_derivative(x) {
    if (x > 0.0) { return 1.0; }
    return 0.0;
}

fn leaky_relu(x, alpha) {
    if (x > 0.0) { return x; }
    return alpha * x;
}

fn leaky_relu_derivative(x, alpha) {
    if (x > 0.0) { return 1.0; }
    return alpha;
}

fn elu(x, alpha) {
    if (x > 0.0) { return x; }
    return alpha * (math_exp(x) - 1.0);
}

fn elu_derivative(x, alpha) {
    if (x > 0.0) { return 1.0; }
    return alpha * math_exp(x);
}

fn _selu_alpha() { return 1.6732632423543772848170429916717; }
fn _selu_scale() { return 1.0507009873554804934193349852946; }

fn selu(x) {
    let alpha = _selu_alpha();
    let scale = _selu_scale();
    if (x > 0.0) { return scale * x; }
    return scale * alpha * (math_exp(x) - 1.0);
}

fn selu_derivative(x) {
    let alpha = _selu_alpha();
    let scale = _selu_scale();
    if (x > 0.0) { return scale; }
    return scale * alpha * math_exp(x);
}

fn softmax(x_arr) {
    let n = len(x_arr);
    if (n == 0) { return []; }
    let mx = x_arr[0];
    let i = 1;
    while (i < n) {
        if (x_arr[i] > mx) { mx = x_arr[i]; }
        i = i + 1;
    }
    let exps = [];
    let sum = 0.0;
    i = 0;
    while (i < n) {
        let e = math_exp(x_arr[i] - mx);
        push(exps, e);
        sum = sum + e;
        i = i + 1;
    }
    let result = [];
    i = 0;
    while (i < n) {
        push(result, exps[i] / sum);
        i = i + 1;
    }
    return result;
}

fn softmax_derivative(x_arr, index) {
    let sm = softmax(x_arr);
    let s_i = sm[index];
    let result = [];
    let i = 0;
    while (i < len(sm)) {
        if (i == index) {
            push(result, s_i * (1.0 - s_i));
        } else {
            push(result, -s_i * sm[i]);
        }
        i = i + 1;
    }
    return result;
}

fn softplus(x) {
    return math_log(1.0 + math_exp(x));
}

fn softplus_derivative(x) {
    return 1.0 / (1.0 + math_exp(-x));
}

fn softsign(x) {
    return x / (1.0 + math_fabs(x));
}

fn softsign_derivative(x) {
    let d = 1.0 + math_fabs(x);
    return 1.0 / (d * d);
}

fn swish(x) {
    return x * sigmoid(x);
}

fn swish_derivative(x) {
    let s = sigmoid(x);
    return s + x * s * (1.0 - s);
}

fn hard_sigmoid(x) {
    if (x <= -2.5) { return 0.0; }
    if (x >= 2.5) { return 1.0; }
    return 0.2 * x + 0.5;
}

fn hard_sigmoid_derivative(x) {
    if (x <= -2.5 or x >= 2.5) { return 0.0; }
    return 0.2;
}

fn hard_swish(x) {
    if (x <= -3.0) { return 0.0; }
    if (x >= 3.0) { return x; }
    return x * (x + 3.0) / 6.0;
}

fn hard_swish_derivative(x) {
    if (x <= -3.0) { return 0.0; }
    if (x >= 3.0) { return 1.0; }
    return (2.0 * x + 3.0) / 6.0;
}

fn gelu(x) {
    return 0.5 * x * (1.0 + math_erf(x / math_sqrt(2.0)));
}

fn gelu_derivative(x) {
    let sqrt2 = math_sqrt(2.0);
    let term1 = 0.5 * (1.0 + math_erf(x / sqrt2));
    let term2 = x * math_exp(-x * x / 2.0) / math_sqrt(2.0 * 3.141592653589793);
    return term1 + term2;
}

fn gelu_approx(x) {
    return 0.5 * x * (1.0 + math_tanh(math_sqrt(2.0 / 3.141592653589793) * (x + 0.044715 * x * x * x)));
}

fn gelu_approx_derivative(x) {
    let pi = 3.141592653589793;
    let sqrt_2_pi = math_sqrt(2.0 / pi);
    let inner = x + 0.044715 * x * x * x;
    let t = math_tanh(sqrt_2_pi * inner);
    let sech2 = 1.0 - t * t;
    let d_inner = 1.0 + 0.044715 * 3.0 * x * x;
    return 0.5 * (1.0 + t) + 0.5 * x * sech2 * sqrt_2_pi * d_inner;
}

fn linear_act(x) {
    return x;
}

fn linear_derivative(x) {
    return 1.0;
}

fn exponential_act(x) {
    return math_exp(x);
}

fn exponential_derivative(x) {
    return math_exp(x);
}

fn mish(x) {
    return x * math_tanh(softplus(x));
}

fn mish_derivative(x) {
    let sp = softplus(x);
    let t = math_tanh(sp);
    let s = sigmoid(x);
    return t + x * s * (1.0 - t * t);
}

fn thresholded_relu(x, theta) {
    if (x > theta) { return x; }
    return 0.0;
}

fn thresholded_relu_derivative(x, theta) {
    if (x > theta) { return 1.0; }
    return 0.0;
}

fn prelu(x, alpha) {
    if (x > 0.0) { return x; }
    return alpha * x;
}

fn prelu_derivative(x, alpha, grad) {
    if (x > 0.0) { return 1.0; }
    return alpha;
}

fn log_softmax(x_arr) {
    let n = len(x_arr);
    if (n == 0) { return []; }
    let mx = x_arr[0];
    let i = 1;
    while (i < n) {
        if (x_arr[i] > mx) { mx = x_arr[i]; }
        i = i + 1;
    }
    let sum = 0.0;
    i = 0;
    while (i < n) {
        sum = sum + math_exp(x_arr[i] - mx);
        i = i + 1;
    }
    let log_sum = math_log(sum);
    let result = [];
    i = 0;
    while (i < n) {
        push(result, x_arr[i] - mx - log_sum);
        i = i + 1;
    }
    return result;
}

fn identity_act(x) {
    return x;
}

fn identity_derivative(x) {
    return 1.0;
}

fn bent_identity(x) {
    return (math_sqrt(x * x + 1.0) - 1.0) / 2.0 + x;
}

fn bent_identity_derivative(x) {
    return x / (2.0 * math_sqrt(x * x + 1.0)) + 1.0;
}

fn soft_clip(x, clip_val) {
    if (x > clip_val) { return clip_val; }
    if (x < -clip_val) { return -clip_val; }
    return x;
}

fn soft_clip_derivative(x, clip_val) {
    if (x > clip_val or x < -clip_val) { return 0.0; }
    return 1.0;
}

fn sin_act(x) {
    return math_sin(x);
}

fn sin_derivative(x) {
    return math_cos(x);
}

fn gaussian_act(x) {
    return math_exp(-x * x);
}

fn gaussian_derivative(x) {
    return -2.0 * x * math_exp(-x * x);
}

fn tanh_shrink(x) {
    return x - math_tanh(x);
}

fn tanh_shrink_derivative(x) {
    let t = math_tanh(x);
    return 1.0 - (1.0 - t * t);
}

fn soft_shrink(x, lambda_val) {
    if (x > lambda_val) { return x - lambda_val; }
    if (x < -lambda_val) { return x + lambda_val; }
    return 0.0;
}

fn soft_shrink_derivative(x, lambda_val) {
    if (x > lambda_val or x < -lambda_val) { return 1.0; }
    return 0.0;
}

fn hard_shrink(x, lambda_val) {
    if (x > lambda_val or x < -lambda_val) { return x; }
    return 0.0;
}

fn hard_shrink_derivative(x, lambda_val) {
    if (x > lambda_val or x < -lambda_val) { return 1.0; }
    return 0.0;
}

fn hard_tanh(x) {
    if (x < -1.0) { return -1.0; }
    if (x > 1.0) { return 1.0; }
    return x;
}

fn hard_tanh_derivative(x) {
    if (x >= -1.0 and x <= 1.0) { return 1.0; }
    return 0.0;
}

# ═══════════════════════════════════════════════════════════════════════════
# SECTION 9: Distance Metrics
# ═══════════════════════════════════════════════════════════════════════════

fn euclidean_distance(a, b) {
    let s = 0.0;
    let i = 0;
    while (i < len(a)) {
        let d = a[i] - b[i];
        s = s + d * d;
        i = i + 1;
    }
    return math_sqrt(s);
}

fn squared_euclidean(a, b) {
    let s = 0.0;
    let i = 0;
    while (i < len(a)) {
        let d = a[i] - b[i];
        s = s + d * d;
        i = i + 1;
    }
    return s;
}

fn manhattan_distance(a, b) {
    let s = 0.0;
    let i = 0;
    while (i < len(a)) {
        let d = a[i] - b[i];
        if (d < 0.0) { d = -d; }
        s = s + d;
        i = i + 1;
    }
    return s;
}

fn chebyshev_distance(a, b) {
    let mx = 0.0;
    let i = 0;
    while (i < len(a)) {
        let d = a[i] - b[i];
        if (d < 0.0) { d = -d; }
        if (d > mx) { mx = d; }
        i = i + 1;
    }
    return mx;
}

fn minkowski_distance(a, b, p) {
    let s = 0.0;
    let i = 0;
    while (i < len(a)) {
        let d = a[i] - b[i];
        if (d < 0.0) { d = -d; }
        s = s + math_pow(d, p);
        i = i + 1;
    }
    return math_pow(s, 1.0 / p);
}

fn cosine_similarity_fn(a, b) {
    let dot = 0.0;
    let norm_a = 0.0;
    let norm_b = 0.0;
    let i = 0;
    while (i < len(a)) {
        dot = dot + a[i] * b[i];
        norm_a = norm_a + a[i] * a[i];
        norm_b = norm_b + b[i] * b[i];
        i = i + 1;
    }
    norm_a = math_sqrt(norm_a);
    norm_b = math_sqrt(norm_b);
    let den = norm_a * norm_b;
    if (den == 0.0) { return 0.0; }
    return dot / den;
}

fn cosine_distance(a, b) {
    return 1.0 - cosine_similarity_fn(a, b);
}

fn hamming_distance(a, b) {
    let s = 0;
    let i = 0;
    while (i < len(a)) {
        if (a[i] != b[i]) { s = s + 1; }
        i = i + 1;
    }
    return s;
}

fn canberra_distance(a, b) {
    let s = 0.0;
    let i = 0;
    while (i < len(a)) {
        let num = a[i] - b[i];
        if (num < 0.0) { num = -num; }
        let den = math_fabs(a[i]) + math_fabs(b[i]);
        if (den > 0.0) { s = s + num / den; }
        i = i + 1;
    }
    return s;
}

fn braycurtis_distance(a, b) {
    let num = 0.0;
    let den = 0.0;
    let i = 0;
    while (i < len(a)) {
        let d = a[i] - b[i];
        if (d < 0.0) { d = -d; }
        num = num + d;
        den = den + math_fabs(a[i]) + math_fabs(b[i]);
        i = i + 1;
    }
    if (den == 0.0) { return 0.0; }
    return num / den;
}

fn jaccard_similarity(a, b) {
    let intersection = 0;
    let u_set = 0;
    let i = 0;
    while (i < len(a)) {
        if (a[i] == 1 and b[i] == 1) { intersection = intersection + 1; }
        if (a[i] == 1 or b[i] == 1) { u_set = u_set + 1; }
        i = i + 1;
    }
    if (u_set == 0) { return 0.0; }
    return intersection * 1.0 / u_set;
}

fn jaccard_distance(a, b) {
    return 1.0 - jaccard_similarity(a, b);
}

fn dice_similarity(a, b) {
    let intersection = 0;
    let sum_a = 0;
    let sum_b = 0;
    let i = 0;
    while (i < len(a)) {
        if (a[i] == 1 and b[i] == 1) { intersection = intersection + 1; }
        if (a[i] == 1) { sum_a = sum_a + 1; }
        if (b[i] == 1) { sum_b = sum_b + 1; }
        i = i + 1;
    }
    if (sum_a + sum_b == 0) { return 0.0; }
    return 2.0 * intersection * 1.0 / (sum_a + sum_b);
}

fn pearson_correlation(a, b) {
    let n = len(a);
    if (n == 0) { return 0.0; }
    let sum_a = 0.0;
    let sum_b = 0.0;
    let i = 0;
    while (i < n) {
        sum_a = sum_a + a[i];
        sum_b = sum_b + b[i];
        i = i + 1;
    }
    let mean_a = sum_a * 1.0 / n;
    let mean_b = sum_b * 1.0 / n;
    let cov = 0.0;
    let var_a = 0.0;
    let var_b = 0.0;
    i = 0;
    while (i < n) {
        let da = a[i] - mean_a;
        let db = b[i] - mean_b;
        cov = cov + da * db;
        var_a = var_a + da * da;
        var_b = var_b + db * db;
        i = i + 1;
    }
    let den = math_sqrt(var_a * var_b);
    if (den == 0.0) { return 0.0; }
    return cov / den;
}

fn _rank_array(arr) {
    let n = len(arr);
    let indices = [];
    let i = 0;
    while (i < n) {
        push(indices, i);
        i = i + 1;
    }
    let si = 0;
    while (si < n) {
        let min_idx = si;
        let j = si + 1;
        while (j < n) {
            if (arr[indices[j]] < arr[indices[min_idx]]) { min_idx = j; }
            j = j + 1;
        }
        let tmp = indices[si];
        indices[si] = indices[min_idx];
        indices[min_idx] = tmp;
        si = si + 1;
    }
    let ranks = [];
    i = 0;
    while (i < n) {
        push(ranks, 0.0);
        i = i + 1;
    }
    i = 0;
    while (i < n) {
        let idx = indices[i];
        ranks[idx] = i + 1.0;
        i = i + 1;
    }
    return ranks;
}

fn spearman_correlation(a, b) {
    let n = len(a);
    if (n == 0) { return 0.0; }
    let ranks_a = _rank_array(a);
    let ranks_b = _rank_array(b);
    let sum_d = 0.0;
    let i = 0;
    while (i < n) {
        let d = ranks_a[i] - ranks_b[i];
        sum_d = sum_d + d * d;
        i = i + 1;
    }
    return 1.0 - 6.0 * sum_d / (n * (n * n - 1.0));
}

fn mahalanobis_distance(x, mean, inv_cov) {
    let n = len(x);
    let diff = [];
    let i = 0;
    while (i < n) {
        push(diff, x[i] - mean[i]);
        i = i + 1;
    }
    let left = [];
    i = 0;
    while (i < n) {
        let s = 0.0;
        let j = 0;
        while (j < n) {
            s = s + diff[j] * inv_cov[j][i];
            j = j + 1;
        }
        push(left, s);
        i = i + 1;
    }
    let result = 0.0;
    i = 0;
    while (i < n) {
        result = result + left[i] * diff[i];
        i = i + 1;
    }
    return math_sqrt(result);
}

fn hellinger_distance(p, q) {
    let n = len(p);
    if (n == 0) { return 0.0; }
    let s = 0.0;
    let i = 0;
    while (i < n) {
        let d = math_sqrt(p[i]) - math_sqrt(q[i]);
        s = s + d * d;
        i = i + 1;
    }
    return math_sqrt(0.5 * s);
}

fn bhattacharyya_distance(p, q) {
    let n = len(p);
    if (n == 0) { return 0.0; }
    let bc = 0.0;
    let i = 0;
    while (i < n) {
        bc = bc + math_sqrt(p[i] * q[i]);
        i = i + 1;
    }
    if (bc <= 0.0) { return 0.0; }
    return -math_log(bc);
}

fn kl_divergence_distance(p, q) {
    let n = len(p);
    if (n == 0) { return 0.0; }
    let eps = 0.0000001;
    let s = 0.0;
    let i = 0;
    while (i < n) {
        let pi = p[i];
        if (pi < eps) { pi = eps; }
        let qi = q[i];
        if (qi < eps) { qi = eps; }
        s = s + pi * math_log(pi / qi);
        i = i + 1;
    }
    return s;
}

fn js_divergence(p, q) {
    let n = len(p);
    if (n == 0) { return 0.0; }
    let m = [];
    let i = 0;
    while (i < n) {
        push(m, 0.5 * (p[i] + q[i]));
        i = i + 1;
    }
    return 0.5 * kl_divergence_distance(p, m) + 0.5 * kl_divergence_distance(q, m);
}

fn wasserstein_distance_1d(p, q) {
    let n = len(p);
    if (n == 0) { return 0.0; }
    let sorted_p = [];
    let sorted_q = [];
    let i = 0;
    while (i < n) {
        push(sorted_p, p[i]);
        push(sorted_q, q[i]);
        i = i + 1;
    }
    let si = 0;
    while (si < n) {
        let min_idx = si;
        let j = si + 1;
        while (j < n) {
            if (sorted_p[j] < sorted_p[min_idx]) { min_idx = j; }
            j = j + 1;
        }
        let tmp = sorted_p[si];
        sorted_p[si] = sorted_p[min_idx];
        sorted_p[min_idx] = tmp;
        si = si + 1;
    }
    si = 0;
    while (si < n) {
        let min_idx = si;
        let j = si + 1;
        while (j < n) {
            if (sorted_q[j] < sorted_q[min_idx]) { min_idx = j; }
            j = j + 1;
        }
        let tmp = sorted_q[si];
        sorted_q[si] = sorted_q[min_idx];
        sorted_q[min_idx] = tmp;
        si = si + 1;
    }
    let s = 0.0;
    i = 0;
    while (i < n) {
        let d = sorted_p[i] - sorted_q[i];
        if (d < 0.0) { d = -d; }
        s = s + d;
        i = i + 1;
    }
    return s * 1.0 / n;
}

fn earth_mover_distance_1d(p, q) {
    return wasserstein_distance_1d(p, q);
}

fn haversine_distance(lat1, lon1, lat2, lon2) {
    let r = 6371.0;
    let dlat = (lat2 - lat1) * 3.141592653589793 / 180.0;
    let dlon = (lon2 - lon1) * 3.141592653589793 / 180.0;
    let a = math_sin(dlat / 2.0) * math_sin(dlat / 2.0) + math_cos(lat1 * 3.141592653589793 / 180.0) * math_cos(lat2 * 3.141592653589793 / 180.0) * math_sin(dlon / 2.0) * math_sin(dlon / 2.0);
    let c = 2.0 * math_atan2(math_sqrt(a), math_sqrt(1.0 - a));
    return r * c;
}

fn levenshtein_distance(s1, s2) {
    let n1 = len(s1);
    let n2 = len(s2);
    if (n1 == 0) { return n2; }
    if (n2 == 0) { return n1; }
    let prev = [];
    let i = 0;
    while (i <= n2) {
        push(prev, i);
        i = i + 1;
    }
    let r = 1;
    while (r <= n1) {
        let curr = [];
        push(curr, r);
        let c = 1;
        while (c <= n2) {
            let cost = 1;
            let ch1 = substring(s1, r - 1, 1);
            let ch2 = substring(s2, c - 1, 1);
            if (ch1 == ch2) { cost = 0; }
            let mn = prev[c] + 1;
            if (curr[c - 1] + 1 < mn) { mn = curr[c - 1] + 1; }
            if (prev[c - 1] + cost < mn) { mn = prev[c - 1] + cost; }
            push(curr, mn);
            c = c + 1;
        }
        prev = curr;
        r = r + 1;
    }
    return prev[n2];
}

fn damerau_levenshtein(s1, s2) {
    let n1 = len(s1);
    let n2 = len(s2);
    if (n1 == 0) { return n2; }
    if (n2 == 0) { return n1; }
    let d = [];
    let i = 0;
    while (i <= n1) {
        let row = [];
        let j = 0;
        while (j <= n2) {
            push(row, 0);
            j = j + 1;
        }
        push(d, row);
        i = i + 1;
    }
    i = 0;
    while (i <= n1) {
        d[i][0] = i;
        i = i + 1;
    }
    let j = 0;
    while (j <= n2) {
        d[0][j] = j;
        j = j + 1;
    }
    i = 1;
    while (i <= n1) {
        j = 1;
        while (j <= n2) {
            let cost = 1;
            let ch1 = substring(s1, i - 1, 1);
            let ch2 = substring(s2, j - 1, 1);
            if (ch1 == ch2) { cost = 0; }
            let mn = d[i - 1][j] + 1;
            if (d[i][j - 1] + 1 < mn) { mn = d[i][j - 1] + 1; }
            if (d[i - 1][j - 1] + cost < mn) { mn = d[i - 1][j - 1] + cost; }
            if (i > 1 and j > 1) {
                let ch1b = substring(s1, i - 2, 1);
                let ch2b = substring(s2, j - 2, 1);
                if (ch1 == ch2b and ch2 == ch1b) {
                    if (d[i - 2][j - 2] + cost < mn) { mn = d[i - 2][j - 2] + cost; }
                }
            }
            d[i][j] = mn;
            j = j + 1;
        }
        i = i + 1;
    }
    return d[n1][n2];
}

fn pairwise_distances(X, metric) {
    let n = len(X);
    if (n == 0) { return []; }
    let result = [];
    let i = 0;
    while (i < n) {
        let row = [];
        let j = 0;
        while (j < n) {
            let d = 0.0;
            if (metric == "euclidean") {
                d = euclidean_distance(X[i], X[j]);
            }
            if (metric == "manhattan") {
                d = manhattan_distance(X[i], X[j]);
            }
            if (metric == "cosine") {
                d = cosine_distance(X[i], X[j]);
            }
            if (metric == "chebyshev") {
                d = chebyshev_distance(X[i], X[j]);
            }
            push(row, d);
            j = j + 1;
        }
        push(result, row);
        i = i + 1;
    }
    return result;
}

fn pairwise_euclidean(X) {
    return pairwise_distances(X, "euclidean");
}

fn pairwise_cosine(X) {
    return pairwise_distances(X, "cosine");
}

fn pairwise_manhattan(X) {
    return pairwise_distances(X, "manhattan");
}

# ═══════════════════════════════════════════════════════════════════════════
# SECTION 10: Kernel Functions
# ═══════════════════════════════════════════════════════════════════════════

fn linear_kernel(x, y) {
    let s = 0.0;
    let i = 0;
    while (i < len(x)) {
        s = s + x[i] * y[i];
        i = i + 1;
    }
    return s;
}

fn polynomial_kernel(x, y, degree, coef0) {
    let dot = linear_kernel(x, y);
    return math_pow(dot + coef0, degree);
}

fn rbf_kernel(x, y, gamma) {
    let s = 0.0;
    let i = 0;
    while (i < len(x)) {
        let d = x[i] - y[i];
        s = s + d * d;
        i = i + 1;
    }
    return math_exp(-gamma * s);
}

fn sigmoid_kernel(x, y, gamma, coef0) {
    let dot = linear_kernel(x, y);
    return math_tanh(gamma * dot + coef0);
}

fn laplacian_kernel(x, y, gamma) {
    let s = 0.0;
    let i = 0;
    while (i < len(x)) {
        let d = x[i] - y[i];
        if (d < 0.0) { d = -d; }
        s = s + d;
        i = i + 1;
    }
    return math_exp(-gamma * s);
}

fn chi2_kernel(x, y) {
    let s = 0.0;
    let i = 0;
    while (i < len(x)) {
        let den = x[i] + y[i];
        if (den > 0.0) {
            let d = x[i] - y[i];
            s = s + d * d / den;
        }
        i = i + 1;
    }
    return s;
}

fn exponential_kernel(x, y, gamma) {
    let s = 0.0;
    let i = 0;
    while (i < len(x)) {
        let d = x[i] - y[i];
        s = s + d * d;
        i = i + 1;
    }
    let dist = math_sqrt(s);
    return math_exp(-gamma * dist);
}

fn anova_kernel(x, y, gamma, degree) {
    let n = len(x);
    let s = 0.0;
    let i = 0;
    while (i < n) {
        let d = x[i] - y[i];
        s = s + math_exp(-gamma * d * d);
        i = i + 1;
    }
    return math_pow(s, degree);
}

fn cauchy_kernel(x, y, gamma) {
    let s = 0.0;
    let i = 0;
    while (i < len(x)) {
        let d = x[i] - y[i];
        s = s + d * d;
        i = i + 1;
    }
    return 1.0 / (1.0 + gamma * s);
}

fn histogram_intersection_kernel(x, y) {
    let s = 0.0;
    let i = 0;
    while (i < len(x)) {
        if (x[i] < y[i]) {
            s = s + x[i];
        } else {
            s = s + y[i];
        }
        i = i + 1;
    }
    return s;
}

fn generalized_histogram_kernel(x, y, beta) {
    let s = 0.0;
    let i = 0;
    while (i < len(x)) {
        let mn = x[i];
        if (y[i] < mn) { mn = y[i]; }
        let mx = x[i];
        if (y[i] > mx) { mx = y[i]; }
        s = s + math_pow(mn, beta) * math_pow(mx, beta);
        i = i + 1;
    }
    return s;
}

fn multiquadric_kernel(x, y, gamma) {
    let s = 0.0;
    let i = 0;
    while (i < len(x)) {
        let d = x[i] - y[i];
        s = s + d * d;
        i = i + 1;
    }
    return math_sqrt(s + gamma * gamma);
}

fn inverse_multiquadric_kernel(x, y, gamma) {
    let s = 0.0;
    let i = 0;
    while (i < len(x)) {
        let d = x[i] - y[i];
        s = s + d * d;
        i = i + 1;
    }
    return 1.0 / math_sqrt(s + gamma * gamma);
}

fn power_kernel(x, y, degree) {
    let s = 0.0;
    let i = 0;
    while (i < len(x)) {
        let d = x[i] - y[i];
        s = s + d * d;
        i = i + 1;
    }
    return -math_pow(math_sqrt(s), degree);
}

fn log_kernel(x, y, degree) {
    let s = 0.0;
    let i = 0;
    while (i < len(x)) {
        let d = x[i] - y[i];
        s = s + d * d;
        i = i + 1;
    }
    return -math_log(math_pow(s, degree / 2.0) + 1.0);
}

fn spherical_kernel(x, y, sigma) {
    let s = 0.0;
    let i = 0;
    while (i < len(x)) {
        let d = x[i] - y[i];
        s = s + d * d;
        i = i + 1;
    }
    let dist = math_sqrt(s);
    if (dist > sigma) { return 0.0; }
    let r = dist / sigma;
    return 1.0 - 1.5 * r + 0.5 * r * r * r;
}

fn circular_kernel(x, y, sigma) {
    let s = 0.0;
    let i = 0;
    while (i < len(x)) {
        let d = x[i] - y[i];
        s = s + d * d;
        i = i + 1;
    }
    let dist = math_sqrt(s);
    if (dist > sigma) { return 0.0; }
    let r = dist / sigma;
    return 2.0 / 3.141592653589793 * (math_acos(-r) - r * math_sqrt(1.0 - r * r));
}

fn triangular_kernel(x, y, sigma) {
    let s = 0.0;
    let i = 0;
    while (i < len(x)) {
        let d = x[i] - y[i];
        s = s + d * d;
        i = i + 1;
    }
    let dist = math_sqrt(s);
    if (dist > sigma) { return 0.0; }
    return 1.0 - dist / sigma;
}

fn epanechnikov_kernel(x, y, sigma) {
    let s = 0.0;
    let i = 0;
    while (i < len(x)) {
        let d = x[i] - y[i];
        s = s + d * d;
        i = i + 1;
    }
    let dist = math_sqrt(s);
    if (dist > sigma) { return 0.0; }
    let r = dist / sigma;
    return 0.75 * (1.0 - r * r);
}

fn gram_matrix(X, kernel_fn) {
    let n = len(X);
    if (n == 0) { return []; }
    let result = [];
    let i = 0;
    while (i < n) {
        let row = [];
        let j = 0;
        while (j < n) {
            let kv = kernel_fn(X[i], X[j]);
            push(row, kv);
            j = j + 1;
        }
        push(result, row);
        i = i + 1;
    }
    return result;
}

# SECTION 6: Preprocessing
# ═══════════════════════════════════════════════════════════════════════════
fn train_test_split(X, y, test_ratio) {
    let n = len(X);
    let indices = [];
    let i = 0;
    while (i < n) {
        push(indices, i);
        i = i + 1;
    }
    let shuffled = hml_shuffle(indices);
    let test_size = math_floor(n * test_ratio);
    if (test_size < 1) { test_size = 1; }
    let X_train = [];
    let X_test = [];
    let y_train = [];
    let y_test = [];
    i = 0;
    while (i < n) {
        let idx = shuffled[i];
        if (i < test_size) {
            push(X_test, X[idx]);
            if (y != nullptr) {
                push(y_test, y[idx]);
            }
        } else {
            push(X_train, X[idx]);
            if (y != nullptr) {
                push(y_train, y[idx]);
            }
        }
        i = i + 1;
    }
    return {"X_train": X_train, "X_test": X_test, "y_train": y_train, "y_test": y_test};
}

# ═══════════════════════════════════════════════════════════════════════════
# StandardScaler — 标准化 (z-score)
# ═══════════════════════════════════════════════════════════════════════════
class StandardScaler {
    let means = [];
    let stds = [];
    let fitted = false;

    fn init_scaler() {
        self.means = [];
        self.stds = [];
        self.fitted = false;
        return 0;
    }

    fn fit(X) {
        self.means = hml_column_means(X);
        self.stds = hml_column_stds(X);
        self.fitted = true;
        return 0;
    }

    fn transform(X) {
        let result = [];
        let i = 0;
        while (i < len(X)) {
            let row = [];
            let j = 0;
            while (j < len(X[i])) {
                let s = self.stds[j];
                if (s == 0.0) { s = 1.0; }
                push(row, (X[i][j] - self.means[j]) / s);
                j = j + 1;
            }
            push(result, row);
            i = i + 1;
        }
        return result;
    }

    fn fit_transform(X) {
        self.fit(X);
        return self.transform(X);
    }

    fn inverse_transform(X) {
        let result = [];
        let i = 0;
        while (i < len(X)) {
            let row = [];
            let j = 0;
            while (j < len(X[i])) {
                push(row, X[i][j] * self.stds[j] + self.means[j]);
                j = j + 1;
            }
            push(result, row);
            i = i + 1;
        }
        return result;
    }
}

# ═══════════════════════════════════════════════════════════════════════════
# MinMaxScaler — 归一化 [0, 1]
# ═══════════════════════════════════════════════════════════════════════════
class MinMaxScaler {
    let mins = [];
    let maxs = [];
    let fitted = false;

    fn init_mmscaler() {
        self.mins = [];
        self.maxs = [];
        self.fitted = false;
        return 0;
    }

    fn fit(X) {
        let n_cols = len(X[0]);
        let n_rows = len(X);
        self.mins = [];
        self.maxs = [];
        let j = 0;
        while (j < n_cols) {
            let mn = X[0][j];
            let mx = X[0][j];
            let i = 1;
            while (i < n_rows) {
                if (X[i][j] < mn) { mn = X[i][j]; }
                if (X[i][j] > mx) { mx = X[i][j]; }
                i = i + 1;
            }
            push(self.mins, mn);
            push(self.maxs, mx);
            j = j + 1;
        }
        self.fitted = true;
        return 0;
    }

    fn transform(X) {
        let result = [];
        let i = 0;
        while (i < len(X)) {
            let row = [];
            let j = 0;
            while (j < len(X[i])) {
                let rng = self.maxs[j] - self.mins[j];
                if (rng == 0.0) { rng = 1.0; }
                push(row, (X[i][j] - self.mins[j]) / rng);
                j = j + 1;
            }
            push(result, row);
            i = i + 1;
        }
        return result;
    }

    fn fit_transform(X) {
        self.fit(X);
        return self.transform(X);
    }
}

# ═══════════════════════════════════════════════════════════════════════════
# LabelEncoder — 标签编码
# ═══════════════════════════════════════════════════════════════════════════
class LabelEncoder {
    let classes = [];
    let class_to_idx = {};
    let fitted = false;

    fn init_encoder() {
        self.classes = [];
        self.class_to_idx = {};
        self.fitted = false;
        return 0;
    }

    fn fit(y) {
        self.classes = hml_unique(y);
        self.class_to_idx = {};
        let i = 0;
        while (i < len(self.classes)) {
            self.class_to_idx[self.classes[i]] = i;
            i = i + 1;
        }
        self.fitted = true;
        return 0;
    }

    fn transform(y) {
        let result = [];
        let i = 0;
        while (i < len(y)) {
            push(result, self.class_to_idx[y[i]]);
            i = i + 1;
        }
        return result;
    }

    fn fit_transform(y) {
        self.fit(y);
        return self.transform(y);
    }

    fn inverse_transform(encoded) {
        let result = [];
        let i = 0;
        while (i < len(encoded)) {
            push(result, self.classes[encoded[i]]);
            i = i + 1;
        }
        return result;
    }
}

# ═══════════════════════════════════════════════════════════════════════════
# SECTION 7: Linear Regression (Gradient Descent)
# ═══════════════════════════════════════════════════════════════════════════
class LinearRegression {
    let weights = [];
    let bias = 0.0;
    let lr = 0.01;
    let epochs = 1000;
    let fitted = false;

    fn init_linear(lr, epochs) {
        self.weights = [];
        self.bias = 0.0;
        self.lr = lr;
        if (epochs == nullptr) { self.epochs = 1000; }
        self.fitted = false;
        return 0;
    }

    fn fit(X, y) {
        let n = len(X);
        let n_features = len(X[0]);
        self.weights = hml_vector_zeros(n_features);
        self.bias = 0.0;
        let epoch = 0;
        while (epoch < self.epochs) {
            let dw = hml_vector_zeros(n_features);
            let db = 0.0;
            let i = 0;
            while (i < n) {
                let y_pred = self.bias;
                let j = 0;
                while (j < n_features) {
                    y_pred = y_pred + self.weights[j] * X[i][j];
                    j = j + 1;
                }
                let error = y_pred - y[i];
                j = 0;
                while (j < n_features) {
                    dw[j] = dw[j] + error * X[i][j];
                    j = j + 1;
                }
                db = db + error;
                i = i + 1;
            }
            let j = 0;
            while (j < n_features) {
                self.weights[j] = self.weights[j] - self.lr * dw[j] / n;
                j = j + 1;
            }
            self.bias = self.bias - self.lr * db / n;
            epoch = epoch + 1;
        }
        self.fitted = true;
        return 0;
    }

    fn predict(X) {
        let result = [];
        let i = 0;
        while (i < len(X)) {
            let pred = self.bias;
            let j = 0;
            while (j < len(self.weights)) {
                pred = pred + self.weights[j] * X[i][j];
                j = j + 1;
            }
            push(result, pred);
            i = i + 1;
        }
        return result;
    }

    fn score(X, y) {
        let y_pred = self.predict(X);
        return r2_score(y, y_pred);
    }
}

# ═══════════════════════════════════════════════════════════════════════════
# SECTION 8: Logistic Regression
# ═══════════════════════════════════════════════════════════════════════════
class LogisticRegression {
    let weights = [];
    let bias = 0.0;
    let lr = 0.1;
    let epochs = 1000;
    let fitted = false;

    fn init_logistic(lr, epochs) {
        self.weights = [];
        self.bias = 0.0;
        self.lr = lr;
        if (epochs == nullptr) { self.epochs = 1000; }
        self.fitted = false;
        return 0;
    }

    fn _sigmoid(z) {
        return 1.0 / (1.0 + math_exp(-z));
    }

    fn fit(X, y) {
        let n = len(X);
        let n_features = len(X[0]);
        self.weights = hml_vector_zeros(n_features);
        self.bias = 0.0;
        let epoch = 0;
        while (epoch < self.epochs) {
            let dw = hml_vector_zeros(n_features);
            let db = 0.0;
            let i = 0;
            while (i < n) {
                let z = self.bias;
                let j = 0;
                while (j < n_features) {
                    z = z + self.weights[j] * X[i][j];
                    j = j + 1;
                }
                let y_pred = self._sigmoid(z);
                let error = y_pred - y[i];
                j = 0;
                while (j < n_features) {
                    dw[j] = dw[j] + error * X[i][j];
                    j = j + 1;
                }
                db = db + error;
                i = i + 1;
            }
            let j = 0;
            while (j < n_features) {
                self.weights[j] = self.weights[j] - self.lr * dw[j] / n;
                j = j + 1;
            }
            self.bias = self.bias - self.lr * db / n;
            epoch = epoch + 1;
        }
        self.fitted = true;
        return 0;
    }

    fn predict_proba(X) {
        let result = [];
        let i = 0;
        while (i < len(X)) {
            let z = self.bias;
            let j = 0;
            while (j < len(self.weights)) {
                z = z + self.weights[j] * X[i][j];
                j = j + 1;
            }
            push(result, self._sigmoid(z));
            i = i + 1;
        }
        return result;
    }

    fn predict(X) {
        let probas = self.predict_proba(X);
        let result = [];
        let i = 0;
        while (i < len(probas)) {
            if (probas[i] >= 0.5) {
                push(result, 1);
            } else {
                push(result, 0);
            }
            i = i + 1;
        }
        return result;
    }

    fn score(X, y) {
        let y_pred = self.predict(X);
        return accuracy_score(y, y_pred);
    }
}

# ═══════════════════════════════════════════════════════════════════════════
# SECTION 9: KNN Classifier
# ═══════════════════════════════════════════════════════════════════════════
class KNNClassifier {
    let k = 3;
    let X_train = [];
    let y_train = [];
    let fitted = false;

    fn init_knn(k) {
        self.k = k;
        self.X_train = [];
        self.y_train = [];
        self.fitted = false;
        return 0;
    }

    fn fit(X, y) {
        self.X_train = X;
        self.y_train = y;
        self.fitted = true;
        return 0;
    }

    fn _distance(a, b) {
        let s = 0.0;
        let i = 0;
        while (i < len(a)) {
            let d = a[i] - b[i];
            s = s + d * d;
            i = i + 1;
        }
        return math_sqrt(s);
    }

    fn predict(X) {
        let result = [];
        let i = 0;
        while (i < len(X)) {
            let dists = [];
            let j = 0;
            while (j < len(self.X_train)) {
                let d = self._distance(X[i], self.X_train[j]);
                push(dists, {"dist": d, "label": self.y_train[j]});
                j = j + 1;
            }
            # Sort by distance (selection sort first k)
            let ki = 0;
            while (ki < self.k and ki < len(dists)) {
                let min_idx = ki;
                let jj = ki + 1;
                while (jj < len(dists)) {
                    if (dists[jj]["dist"] < dists[min_idx]["dist"]) {
                        min_idx = jj;
                    }
                    jj = jj + 1;
                }
                let tmp = dists[ki];
                dists[ki] = dists[min_idx];
                dists[min_idx] = tmp;
                ki = ki + 1;
            }
            # Vote
            let votes = {};
            j = 0;
            while (j < self.k and j < len(dists)) {
                let lbl = dists[j]["label"];
                let cnt = votes[lbl];
                if (cnt == nullptr) {
                    votes[lbl] = 1;
                } else {
                    votes[lbl] = cnt + 1;
                }
                j = j + 1;
            }
            let best_label = 0;
            let best_count = 0;
            let vote_keys = dict_keys(votes);
            j = 0;
            while (j < len(vote_keys)) {
                let lbl = vote_keys[j];
                let cnt = votes[lbl];
                if (cnt > best_count) {
                    best_count = cnt;
                    best_label = lbl;
                }
                j = j + 1;
            }
            push(result, best_label);
            i = i + 1;
        }
        return result;
    }

    fn score(X, y) {
        let y_pred = self.predict(X);
        return accuracy_score(y, y_pred);
    }
}

# ═══════════════════════════════════════════════════════════════════════════
# SECTION 10: K-Means Clustering
# ═══════════════════════════════════════════════════════════════════════════
class KMeans {
    let k = 3;
    let max_iters = 100;
    let centroids = [];
    let fitted = false;

    fn init_kmeans(k, max_iters) {
        self.k = k;
        if (max_iters == nullptr) { self.max_iters = 100; }
        self.centroids = [];
        self.fitted = false;
        return 0;
    }

    fn _distance(a, b) {
        let s = 0.0;
        let i = 0;
        while (i < len(a)) {
            let d = a[i] - b[i];
            s = s + d * d;
            i = i + 1;
        }
        return math_sqrt(s);
    }

    fn fit(X) {
        let n = len(X);
        let n_features = len(X[0]);
        # Initialize centroids randomly from data points
        self.centroids = [];
        let used = [];
        let ci = 0;
        while (ci < self.k and ci < n) {
            let idx = hml_randint(0, n - 1);
            let dup = false;
            let uj = 0;
            while (uj < len(used)) {
                if (used[uj] == idx) { dup = true; break; }
                uj = uj + 1;
            }
            if (dup) { continue; }
            push(used, idx);
            push(self.centroids, X[idx]);
            ci = ci + 1;
        }
        let iter = 0;
        while (iter < self.max_iters) {
            # Assign clusters
            let labels = [];
            let i = 0;
            while (i < n) {
                let min_dist = self._distance(X[i], self.centroids[0]);
                let best = 0;
                let j = 1;
                while (j < self.k) {
                    let d = self._distance(X[i], self.centroids[j]);
                    if (d < min_dist) {
                        min_dist = d;
                        best = j;
                    }
                    j = j + 1;
                }
                push(labels, best);
                i = i + 1;
            }
            # Update centroids
            let new_centroids = [];
            let j = 0;
            while (j < self.k) {
                let sum_vec = hml_vector_zeros(n_features);
                let count = 0;
                i = 0;
                while (i < n) {
                    if (labels[i] == j) {
                        count = count + 1;
                        let f = 0;
                        while (f < n_features) {
                            sum_vec[f] = sum_vec[f] + X[i][f];
                            f = f + 1;
                        }
                    }
                    i = i + 1;
                }
                if (count > 0) {
                    let f = 0;
                    while (f < n_features) {
                        sum_vec[f] = sum_vec[f] * 1.0 / count;
                        f = f + 1;
                    }
                    push(new_centroids, sum_vec);
                } else {
                    push(new_centroids, self.centroids[j]);
                }
                j = j + 1;
            }
            self.centroids = new_centroids;
            iter = iter + 1;
        }
        self.fitted = true;
        return 0;
    }

    fn predict(X) {
        let result = [];
        let i = 0;
        while (i < len(X)) {
            let min_dist = self._distance(X[i], self.centroids[0]);
            let best = 0;
            let j = 1;
            while (j < self.k) {
                let d = self._distance(X[i], self.centroids[j]);
                if (d < min_dist) {
                    min_dist = d;
                    best = j;
                }
                j = j + 1;
            }
            push(result, best);
            i = i + 1;
        }
        return result;
    }

    fn get_centroids() {
        return self.centroids;
    }
}

# ═══════════════════════════════════════════════════════════════════════════
# SECTION 11: Decision Tree Classifier
# ═══════════════════════════════════════════════════════════════════════════
class DecisionTreeClassifier {
    let max_depth = 10;
    let min_samples_split = 2;
    let tree = nullptr;
    let fitted = false;

    fn init_dtree(max_depth, min_samples_split) {
        self.max_depth = max_depth;
        if (min_samples_split == nullptr) { self.min_samples_split = 2; }
        self.tree = nullptr;
        self.fitted = false;
        return 0;
    }

    fn _gini(y) {
        let n = len(y);
        if (n == 0) { return 0.0; }
        let counts = hml_value_counts(y);
        let gini = 1.0;
        let keys = dict_keys(counts);
        let i = 0;
        while (i < len(keys)) {
            let p = counts[keys[i]] * 1.0 / n;
            gini = gini - p * p;
            i = i + 1;
        }
        return gini;
    }

    fn _split(X, y, feature_idx, threshold) {
        let left_X = [];
        let left_y = [];
        let right_X = [];
        let right_y = [];
        let i = 0;
        while (i < len(X)) {
            if (X[i][feature_idx] <= threshold) {
                push(left_X, X[i]);
                push(left_y, y[i]);
            } else {
                push(right_X, X[i]);
                push(right_y, y[i]);
            }
            i = i + 1;
        }
        return {"left_X": left_X, "left_y": left_y, "right_X": right_X, "right_y": right_y};
    }

    fn _best_split(X, y) {
        let n = len(y);
        let best_gini = 1.0;
        let best_feature = -1;
        let best_threshold = 0.0;
        let n_features = len(X[0]);
        let j = 0;
        while (j < n_features) {
            let vals = [];
            let i = 0;
            while (i < n) {
                push(vals, X[i][j]);
                i = i + 1;
            }
            let unique_vals = hml_unique(vals);
            let k = 0;
            while (k < len(unique_vals)) {
                let threshold = unique_vals[k];
                let split_data = self._split(X, y, j, threshold);
                let left_n = len(split_data["left_y"]);
                let right_n = len(split_data["right_y"]);
                if (left_n == 0 or right_n == 0) {
                    k = k + 1;
                    continue;
                }
                let gini = (left_n * 1.0 / n) * self._gini(split_data["left_y"]) + (right_n * 1.0 / n) * self._gini(split_data["right_y"]);
                if (gini < best_gini) {
                    best_gini = gini;
                    best_feature = j;
                    best_threshold = threshold;
                }
                k = k + 1;
            }
            j = j + 1;
        }
        return {"feature": best_feature, "threshold": best_threshold};
    }

    fn _majority(y) {
        let counts = hml_value_counts(y);
        let best = y[0];
        let best_cnt = 0;
        let keys = dict_keys(counts);
        let i = 0;
        while (i < len(keys)) {
            let cnt = counts[keys[i]];
            if (cnt > best_cnt) {
                best_cnt = cnt;
                best = keys[i];
            }
            i = i + 1;
        }
        return best;
    }

    fn _build_tree(X, y, depth) {
        let n = len(y);
        if (depth >= self.max_depth or n < self.min_samples_split) {
            return {"_leaf": true, "value": self._majority(y)};
        }
        let unique_y = hml_unique(y);
        if (len(unique_y) == 1) {
            return {"_leaf": true, "value": y[0]};
        }
        let split = self._best_split(X, y);
        if (split["feature"] < 0) {
            return {"_leaf": true, "value": self._majority(y)};
        }
        let split_data = self._split(X, y, split["feature"], split["threshold"]);
        let left = self._build_tree(split_data["left_X"], split_data["left_y"], depth + 1);
        let right = self._build_tree(split_data["right_X"], split_data["right_y"], depth + 1);
        return {"_leaf": false, "feature": split["feature"], "threshold": split["threshold"], "left": left, "right": right};
    }

    fn fit(X, y) {
        self.tree = self._build_tree(X, y, 0);
        self.fitted = true;
        return 0;
    }

    fn _predict_one(node, x) {
        if (node["_leaf"] == true) { return node["value"]; }
        if (x[node["feature"]] <= node["threshold"]) {
            return self._predict_one(node["left"], x);
        }
        return self._predict_one(node["right"], x);
    }

    fn predict(X) {
        let result = [];
        let i = 0;
        while (i < len(X)) {
            push(result, self._predict_one(self.tree, X[i]));
            i = i + 1;
        }
        return result;
    }

    fn score(X, y) {
        let y_pred = self.predict(X);
        return accuracy_score(y, y_pred);
    }
}

# ═══════════════════════════════════════════════════════════════════════════
# SECTION 12: MLP Neural Network (1 hidden layer)
# ═══════════════════════════════════════════════════════════════════════════
class MLPClassifier {
    let W1 = [];
    let b1 = [];
    let W2 = [];
    let b2 = [];
    let hidden_size = 10;
    let lr = 0.1;
    let epochs = 500;
    let fitted = false;

    fn init_mlp(hidden_size, lr, epochs) {
        self.hidden_size = hidden_size;
        if (lr == nullptr) { self.lr = 0.1; }
        if (epochs == nullptr) { self.epochs = 500; }
        self.W1 = [];
        self.b1 = [];
        self.W2 = [];
        self.b2 = [];
        self.fitted = false;
        return 0;
    }

    fn _sigmoid(z) {
        return 1.0 / (1.0 + math_exp(-z));
    }

    fn _relu(z) {
        if (z > 0.0) { return z; }
        return 0.0;
    }

    fn _relu_deriv(z) {
        if (z > 0.0) { return 1.0; }
        return 0.0;
    }

    fn fit(X, y) {
        let n = len(X);
        let n_features = len(X[0]);
        let h = self.hidden_size;
        # Initialize weights
        self.W1 = hml_matrix_random(h, n_features);
        self.b1 = hml_vector_zeros(h);
        self.W2 = hml_matrix_random(1, h);
        self.b2 = [0.0];
        let epoch = 0;
        while (epoch < self.epochs) {
            let total_loss = 0.0;
            let i = 0;
            while (i < n) {
                let x = X[i];
                let target = y[i] * 1.0;
                # Forward pass
                let z1 = [];
                let j = 0;
                while (j < h) {
                    let s = self.b1[j];
                    let k = 0;
                    while (k < n_features) {
                        s = s + self.W1[j][k] * x[k];
                        k = k + 1;
                    }
                    push(z1, s);
                    j = j + 1;
                }
                let a1 = [];
                j = 0;
                while (j < h) {
                    push(a1, self._relu(z1[j]));
                    j = j + 1;
                }
                let z2 = self.b2[0];
                j = 0;
                while (j < h) {
                    z2 = z2 + self.W2[0][j] * a1[j];
                    j = j + 1;
                }
                let y_pred = self._sigmoid(z2);
                # Loss
                let eps = 0.000001;
                let l = target * math_log(y_pred + eps) + (1.0 - target) * math_log(1.0 - y_pred + eps);
                total_loss = total_loss - l;
                # Backward pass
                let d_z2 = y_pred - target;
                let d_W2 = [];
                j = 0;
                while (j < h) {
                    push(d_W2, d_z2 * a1[j]);
                    j = j + 1;
                }
                let d_b2 = d_z2;
                let d_a1 = [];
                j = 0;
                while (j < h) {
                    push(d_a1, d_z2 * self.W2[0][j]);
                    j = j + 1;
                }
                let d_z1 = [];
                j = 0;
                while (j < h) {
                    push(d_z1, d_a1[j] * self._relu_deriv(z1[j]));
                    j = j + 1;
                }
                let d_W1 = hml_matrix_zeros(h, n_features);
                let d_b1 = hml_vector_zeros(h);
                j = 0;
                while (j < h) {
                    d_b1[j] = d_z1[j];
                    let k = 0;
                    while (k < n_features) {
                        d_W1[j][k] = d_z1[j] * x[k];
                        k = k + 1;
                    }
                    j = j + 1;
                }
                # Update weights
                j = 0;
                while (j < h) {
                    self.W2[0][j] = self.W2[0][j] - self.lr * d_W2[j];
                    self.b1[j] = self.b1[j] - self.lr * d_b1[j];
                    let k = 0;
                    while (k < n_features) {
                        self.W1[j][k] = self.W1[j][k] - self.lr * d_W1[j][k];
                        k = k + 1;
                    }
                    j = j + 1;
                }
                self.b2[0] = self.b2[0] - self.lr * d_b2;
                i = i + 1;
            }
            epoch = epoch + 1;
        }
        self.fitted = true;
        return 0;
    }

    fn predict_proba(X) {
        let n_features = len(X[0]);
        let h = self.hidden_size;
        let result = [];
        let i = 0;
        while (i < len(X)) {
            let x = X[i];
            let z1 = [];
            let j = 0;
            while (j < h) {
                let s = self.b1[j];
                let k = 0;
                while (k < n_features) {
                    s = s + self.W1[j][k] * x[k];
                    k = k + 1;
                }
                push(z1, s);
                j = j + 1;
            }
            let a1 = [];
            j = 0;
            while (j < h) {
                push(a1, self._relu(z1[j]));
                j = j + 1;
            }
            let z2 = self.b2[0];
            j = 0;
            while (j < h) {
                z2 = z2 + self.W2[0][j] * a1[j];
                j = j + 1;
            }
            push(result, self._sigmoid(z2));
            i = i + 1;
        }
        return result;
    }

    fn predict(X) {
        let probas = self.predict_proba(X);
        let result = [];
        let i = 0;
        while (i < len(probas)) {
            if (probas[i] >= 0.5) {
                push(result, 1);
            } else {
                push(result, 0);
            }
            i = i + 1;
        }
        return result;
    }

    fn score(X, y) {
        let y_pred = self.predict(X);
        return accuracy_score(y, y_pred);
    }
}

# ═══════════════════════════════════════════════════════════════════════════

# SECTION 11: Probability Distributions
# ═══════════════════════════════════════════════════════════════════════════

# ── Normal Distribution ──

fn normal_pdf(x, mu, sigma) {
    let coeff = 1.0 / (sigma * math_sqrt(2.0 * 3.141592653589793));
    let z = (x - mu) / sigma;
    return coeff * math_exp(-0.5 * z * z);
}

fn normal_cdf(x, mu, sigma) {
    let z = (x - mu) / sigma;
    return 0.5 * (1.0 + math_erf(z / math_sqrt(2.0)));
}

fn normal_ppf(p, mu, sigma) {
    if (p <= 0.0) { return mu - 10.0 * sigma; }
    if (p >= 1.0) { return mu + 10.0 * sigma; }
    let q = p - 0.5;
    let r = 0.0;
    if (math_fabs(q) <= 0.425) {
        r = 0.180625 - q * q;
        let num = (((((((2509.0809287301227 * r + 33430.57558358813) * r + 67265.7709270087) * r + 45921.95393154987) * r + 13731.69376550946) * r + 1971.5909503065513) * r + 133.14166789178438) * r + 3.3871328727963665);
        let den = (((((((5226.495278852854 * r + 28729.085735721943) * r + 39307.89580009271) * r + 21213.794301586597) * r + 5394.196021424751) * r + 687.1870074920579) * r + 42.31333070160091) * r + 1.0);
        q = q * num / den;
    } else {
        r = 0.0;
        if (q < 0.0) { r = p; }
        else { r = 1.0 - p; }
        if (r <= 0.0) { r = 0.0000001; }
        r = math_sqrt(-math_log(r));
        if (r <= 5.0) {
            r = r - 1.6;
            let num = (((((((0.0007745450142783414 * r + 0.022723844989269184) * r + 0.2417807251774506) * r + 1.2704582524523684) * r + 3.6478483247632045) * r + 5.769497221460691) * r + 4.630337846156546) * r + 1.4234371107496835);
            let den = (((((((0.0000000010507501 * r + 0.0005475938084995345) * r + 0.015198666563616457) * r + 0.14810397642748008) * r + 0.6897673349851) * r + 1.6763848301838038) * r + 2.053191626637759) * r + 1.0);
            r = num / den;
        } else {
            r = r - 5.0;
            let num = (((((((0.0000002010334399 * r + 0.0000271155556874) * r + 0.0012426609473880784) * r + 0.026532189526576124) * r + 0.29656057182850487) * r + 1.7848265399172913) * r + 5.463784911164114) * r + 6.657904643501103);
            let den = (((((((0.0000000000000020443 * r + 0.0000001421511758) * r + 0.0000184631831751) * r + 0.0007868691311456133) * r + 0.014875361290850615) * r + 0.1369298809227358) * r + 0.599832206555888) * r + 1.0);
            r = num / den;
        }
        if (q < 0.0) { r = -r; }
    }
    return mu + r * sigma;
}

fn standard_normal_pdf(x) {
    return normal_pdf(x, 0.0, 1.0);
}

fn standard_normal_cdf(x) {
    return normal_cdf(x, 0.0, 1.0);
}

# ── Uniform Distribution ──

fn uniform_pdf(x, a, b) {
    if (x < a or x > b) { return 0.0; }
    return 1.0 / (b - a);
}

fn uniform_cdf(x, a, b) {
    if (x < a) { return 0.0; }
    if (x > b) { return 1.0; }
    return (x - a) / (b - a);
}

# ── Exponential Distribution ──

fn exponential_pdf(x, rate) {
    if (x < 0.0) { return 0.0; }
    return rate * math_exp(-rate * x);
}

fn exponential_cdf(x, rate) {
    if (x < 0.0) { return 0.0; }
    return 1.0 - math_exp(-rate * x);
}

# ── Gamma Distribution ──

fn gamma_pdf(x, shape, rate) {
    if (x <= 0.0) { return 0.0; }
    let log_pdf = (shape - 1.0) * math_log(x) - rate * x + shape * math_log(rate) - math_lgamma(shape);
    return math_exp(log_pdf);
}

fn gamma_log_pdf(x, shape, rate) {
    if (x <= 0.0) { return -1000000.0; }
    return (shape - 1.0) * math_log(x) - rate * x + shape * math_log(rate) - math_lgamma(shape);
}

# ── Beta Distribution ──

fn beta_pdf(x, a, b) {
    if (x <= 0.0 or x >= 1.0) { return 0.0; }
    let log_pdf = (a - 1.0) * math_log(x) + (b - 1.0) * math_log(1.0 - x) - math_lbeta(a, b);
    return math_exp(log_pdf);
}

fn beta_log_pdf(x, a, b) {
    if (x <= 0.0 or x >= 1.0) { return -1000000.0; }
    return (a - 1.0) * math_log(x) + (b - 1.0) * math_log(1.0 - x) - math_lbeta(a, b);
}

# ── Binomial Distribution ──

fn _hml_binom_coeff(n, k) {
    if (k < 0 or k > n) { return 0.0; }
    if (k == 0 or k == n) { return 1.0; }
    let kk = k;
    if (kk > n - kk) { kk = n - kk; }
    let result = 1.0;
    let i = 0;
    while (i < kk) {
        result = result * (n - i) * 1.0 / (i + 1.0);
        i = i + 1;
    }
    return result;
}

fn binomial_pmf(k, n, p) {
    if (k < 0 or k > n) { return 0.0; }
    if (p == 0.0) {
        if (k == 0) { return 1.0; }
        return 0.0;
    }
    if (p == 1.0) {
        if (k == n) { return 1.0; }
        return 0.0;
    }
    return _hml_binom_coeff(n, k) * math_pow(p, k) * math_pow(1.0 - p, n - k);
}

fn binomial_log_pmf(k, n, p) {
    if (k < 0 or k > n) { return -1000000.0; }
    if (p == 0.0) {
        if (k == 0) { return 0.0; }
        return -1000000.0;
    }
    if (p == 1.0) {
        if (k == n) { return 0.0; }
        return -1000000.0;
    }
    let log_comb = math_lgamma(n + 1) - math_lgamma(k + 1) - math_lgamma(n - k + 1);
    return log_comb + k * math_log(p) + (n - k) * math_log(1.0 - p);
}

# ── Poisson Distribution ──

fn poisson_pmf_body(k, rate) {
    if (k < 0) { return 0.0; }
    let log_pmf = k * math_log(rate) - rate - math_lgamma(k + 1);
    return math_exp(log_pmf);
}

fn poisson_pmf(k, rate) {
    return poisson_pmf_body(k, rate);
}

fn poisson_log_pmf(k, rate) {
    if (k < 0) { return -1000000.0; }
    return k * math_log(rate) - rate - math_lgamma(k + 1);
}

# ── Geometric Distribution ──

fn geometric_pmf(k, p) {
    if (k < 1) { return 0.0; }
    return p * math_pow(1.0 - p, k - 1);
}

# ── Negative Binomial Distribution ──

fn negative_binomial_pmf(k, r, p) {
    if (k < 0) { return 0.0; }
    let log_pmf = math_lgamma(k + r) - math_lgamma(k + 1) - math_lgamma(r) + r * math_log(p) + k * math_log(1.0 - p);
    return math_exp(log_pmf);
}

# ── Hypergeometric Distribution ──

fn hypergeometric_pmf(k, N, K, n) {
    if (k < 0 or k > K or k > n) { return 0.0; }
    if (n - k > N - K) { return 0.0; }
    let log_num = math_lgamma(K + 1) - math_lgamma(k + 1) - math_lgamma(K - k + 1);
    let log_den = math_lgamma(N - K + 1) - math_lgamma(n - k + 1) - math_lgamma(N - K - n + k + 1);
    let log_total = math_lgamma(N + 1) - math_lgamma(n + 1) - math_lgamma(N - n + 1);
    return math_exp(log_num + log_den - log_total);
}

# ── Bernoulli Distribution ──

fn bernoulli_pmf(k, p) {
    if (k == 1) { return p; }
    if (k == 0) { return 1.0 - p; }
    return 0.0;
}

# ── Categorical Distribution ──

fn categorical_pmf(k, probs) {
    if (k < 0 or k >= len(probs)) { return 0.0; }
    return probs[k];
}

# ── Multinomial Distribution (log) ──

fn multinomial_pmf(counts, n, probs) {
    let k = len(counts);
    let log_pmf = math_lgamma(n + 1);
    let i = 0;
    while (i < k) {
        log_pmf = log_pmf - math_lgamma(counts[i] + 1);
        if (counts[i] > 0) {
            log_pmf = log_pmf + counts[i] * math_log(probs[i]);
        }
        i = i + 1;
    }
    return math_exp(log_pmf);
}

# ── Cauchy Distribution ──

fn cauchy_pdf(x, location, scale) {
    let z = (x - location) / scale;
    return 1.0 / (3.141592653589793 * scale * (1.0 + z * z));
}

fn cauchy_cdf(x, location, scale) {
    return 0.5 + math_atan((x - location) / scale) / 3.141592653589793;
}

# ── Laplace Distribution ──

fn laplace_pdf(x, mu, b) {
    return math_exp(-math_fabs(x - mu) / b) / (2.0 * b);
}

fn laplace_cdf(x, mu, b) {
    if (x < mu) {
        return 0.5 * math_exp((x - mu) / b);
    }
    return 1.0 - 0.5 * math_exp(-(x - mu) / b);
}

# ── Lognormal Distribution ──

fn lognormal_pdf(x, mu, sigma) {
    if (x <= 0.0) { return 0.0; }
    let coeff = 1.0 / (x * sigma * math_sqrt(2.0 * 3.141592653589793));
    let z = (math_log(x) - mu) / sigma;
    return coeff * math_exp(-0.5 * z * z);
}

fn lognormal_cdf(x, mu, sigma) {
    if (x <= 0.0) { return 0.0; }
    return normal_cdf(math_log(x), mu, sigma);
}

# ── Chi-Squared Distribution ──

fn _reg_lower_inc_gamma(s, x) {
    if (x < 0.0) { return 0.0; }
    if (x == 0.0) { return 0.0; }
    let result = 0.0;
    let term = 1.0 / s;
    let n = 0;
    while (n < 200) {
        result = result + term;
        n = n + 1;
        term = term * x / (s + n);
        if (term < 0.0000000000001) { break; }
    }
    return result * math_exp(s * math_log(x) - x - math_lgamma(s));
}

fn chi2_pdf(x, df) {
    if (x <= 0.0) { return 0.0; }
    let k = df / 2.0;
    let log_pdf = (k - 1.0) * math_log(x) - x / 2.0 - k * math_log(2.0) - math_lgamma(k);
    return math_exp(log_pdf);
}

fn chi2_cdf(x, df) {
    if (x <= 0.0) { return 0.0; }
    return _reg_lower_inc_gamma(df / 2.0, x / 2.0);
}

# ── Student's t-Distribution ──

fn _reg_inc_beta_cont_frac(a, b, x) {
    let max_iter = 200;
    let eps = 0.0000000001;
    let d = 1.0;
    let i = 0;
    let c = 1.0;
    let f = 1.0;
    while (i < max_iter) {
        let m = i / 2;
        let num = 0.0;
        if (i == 0) {
            num = 1.0;
        } else {
            let even = i - int(i / 2) * 2;
            if (even == 0) {
                num = m * (b - m) * x / ((a + 2.0 * m - 1.0) * (a + 2.0 * m));
            } else {
                num = -(a + m) * (a + b + m) * x / ((a + 2.0 * m) * (a + 2.0 * m + 1.0));
            }
        }
        d = 1.0 + num * d;
        if (math_fabs(d) < 0.0000000000001) { d = 0.0000000000001; }
        d = 1.0 / d;
        c = 1.0 + num / c;
        if (math_fabs(c) < 0.0000000000001) { c = 0.0000000000001; }
        f = f * c * d;
        if (math_fabs(c * d - 1.0) < eps) { break; }
        i = i + 1;
    }
    return f;
}

fn _reg_inc_beta(a, b, x) {
    if (x <= 0.0) { return 0.0; }
    if (x >= 1.0) { return 1.0; }
    let log_beta = math_lgamma(a) + math_lgamma(b) - math_lgamma(a + b);
    let prefix = math_exp(a * math_log(x) + b * math_log(1.0 - x) - log_beta) / a;
    let cf = _reg_inc_beta_cont_frac(a, b, x);
    return prefix * cf;
}

fn student_t_pdf(x, df) {
    let log_num = math_lgamma((df + 1.0) / 2.0);
    let log_den = math_lgamma(df / 2.0);
    let coeff = math_exp(log_num - log_den) / (math_sqrt(df * 3.141592653589793));
    return coeff * math_pow(1.0 + x * x / df, -(df + 1.0) / 2.0);
}

fn student_t_cdf(x, df) {
    let xt = df / (x * x + df);
    let ib = _reg_inc_beta(df / 2.0, 0.5, xt);
    if (x > 0.0) {
        return 1.0 - 0.5 * ib;
    }
    return 0.5 * ib;
}

# ── F-Distribution ──

fn f_pdf(x, df1, df2) {
    if (x <= 0.0) { return 0.0; }
    let log_num = (df1 / 2.0) * math_log(df1 * 1.0 / df2) + (df1 / 2.0 - 1.0) * math_log(x);
    let log_den = math_lgamma(df1 / 2.0) + math_lgamma(df2 / 2.0) - math_lgamma((df1 + df2) / 2.0);
    let log_pow = -(df1 + df2) / 2.0 * math_log(1.0 + df1 * x / df2);
    return math_exp(log_num + log_den + log_pow);
}

# ── Weibull Distribution ──

fn weibull_pdf(x, shape, scale) {
    if (x < 0.0) { return 0.0; }
    if (x == 0.0) {
        if (shape == 1.0) { return 1.0 / scale; }
        if (shape > 1.0) { return 0.0; }
        return 1000000.0;
    }
    return (shape / scale) * math_pow(x / scale, shape - 1.0) * math_exp(-math_pow(x / scale, shape));
}

fn weibull_cdf(x, shape, scale) {
    if (x <= 0.0) { return 0.0; }
    return 1.0 - math_exp(-math_pow(x / scale, shape));
}

# ── Pareto Distribution ──

fn pareto_pdf(x, shape, scale) {
    if (x < scale) { return 0.0; }
    return shape * math_pow(scale, shape) / math_pow(x, shape + 1.0);
}

# ── Gumbel Distribution ──

fn gumbel_pdf(x, mu, beta) {
    let z = (x - mu) / beta;
    return math_exp(-z - math_exp(-z)) / beta;
}

# ── Rayleigh Distribution ──

fn rayleigh_pdf(x, sigma) {
    if (x < 0.0) { return 0.0; }
    return (x / (sigma * sigma)) * math_exp(-x * x / (2.0 * sigma * sigma));
}

# ── Triangular Distribution ──

fn triangular_pdf(x, a, b, c) {
    if (x < a or x > b) { return 0.0; }
    if (x < c) {
        return 2.0 * (x - a) / ((b - a) * (c - a));
    }
    if (x > c) {
        return 2.0 * (b - x) / ((b - a) * (b - c));
    }
    return 2.0 / (b - a);
}

# ═══════════════════════════════════════════════════════════════════════════
# SECTION 12: Statistical Tests
# ═══════════════════════════════════════════════════════════════════════════

# ── Helper: sort array in place ──

fn _hml_sort(arr) {
    let n = len(arr);
    let i = 0;
    while (i < n - 1) {
        let j = 0;
        while (j < n - i - 1) {
            if (arr[j] > arr[j + 1]) {
                let tmp = arr[j];
                arr[j] = arr[j + 1];
                arr[j + 1] = tmp;
            }
            j = j + 1;
        }
        i = i + 1;
    }
    return arr;
}

# ── Helper: compute ranks of data ──

fn _hml_rank(data) {
    let n = len(data);
    let indexed = [];
    let i = 0;
    while (i < n) {
        push(indexed, {"val": data[i], "idx": i});
        i = i + 1;
    }
    i = 0;
    while (i < n - 1) {
        let j = 0;
        while (j < n - i - 1) {
            if (indexed[j]["val"] > indexed[j + 1]["val"]) {
                let tmp = indexed[j];
                indexed[j] = indexed[j + 1];
                indexed[j + 1] = tmp;
            }
            j = j + 1;
        }
        i = i + 1;
    }
    let ranks = [];
    i = 0;
    while (i < n) { push(ranks, 0.0); i = i + 1; }
    i = 0;
    while (i < n) {
        let j = i;
        while (j < n and indexed[j]["val"] == indexed[i]["val"]) { j = j + 1; }
        let avg_rank = (i + j + 1) * 0.5;
        let k = i;
        while (k < j) {
            ranks[indexed[k]["idx"]] = avg_rank;
            k = k + 1;
        }
        i = j;
    }
    return ranks;
}

# ── Z-Test (one-sample) ──

fn z_test(data, mu, sigma) {
    let n = len(data);
    if (n == 0) { return {"z_stat": 0.0, "p_value": 1.0}; }
    let sample_mean = hml_mean(data);
    let se = sigma / math_sqrt(n);
    let z_stat = (sample_mean - mu) / se;
    let p_value = 2.0 * (1.0 - normal_cdf(math_fabs(z_stat), 0.0, 1.0));
    return {"z_stat": z_stat, "p_value": p_value};
}

# ── One-Sample T-Test ──

fn t_test_1samp(data, mu) {
    let n = len(data);
    if (n < 2) { return {"t_stat": 0.0, "p_value": 1.0}; }
    let sample_mean = hml_mean(data);
    let sample_std = hml_std(data);
    let se = sample_std / math_sqrt(n);
    let t_stat = (sample_mean - mu) / se;
    let df = n - 1;
    let p_value = 2.0 * (1.0 - student_t_cdf(math_fabs(t_stat), df));
    return {"t_stat": t_stat, "p_value": p_value, "df": df};
}

# ── Independent Two-Sample T-Test (equal variance) ──

fn t_test_ind(data1, data2) {
    let n1 = len(data1);
    let n2 = len(data2);
    if (n1 < 2 or n2 < 2) { return {"t_stat": 0.0, "p_value": 1.0}; }
    let m1 = hml_mean(data1);
    let m2 = hml_mean(data2);
    let v1 = hml_var(data1) * (n1 - 1) / n1;
    let v2 = hml_var(data2) * (n2 - 1) / n2;
    let sp = math_sqrt(((n1 - 1) * v1 + (n2 - 1) * v2) / (n1 + n2 - 2));
    let se = sp * math_sqrt(1.0 / n1 + 1.0 / n2);
    let t_stat = (m1 - m2) / se;
    let df = n1 + n2 - 2;
    let p_value = 2.0 * (1.0 - student_t_cdf(math_fabs(t_stat), df));
    return {"t_stat": t_stat, "p_value": p_value, "df": df};
}

# ── Paired T-Test ──

fn t_test_paired(data1, data2) {
    let n = len(data1);
    if (n < 2) { return {"t_stat": 0.0, "p_value": 1.0}; }
    let diffs = [];
    let i = 0;
    while (i < n) {
        push(diffs, data1[i] - data2[i]);
        i = i + 1;
    }
    return t_test_1samp(diffs, 0.0);
}

# ── Welch's T-Test ──

fn welch_t_test(data1, data2) {
    let n1 = len(data1);
    let n2 = len(data2);
    if (n1 < 2 or n2 < 2) { return {"t_stat": 0.0, "p_value": 1.0}; }
    let m1 = hml_mean(data1);
    let m2 = hml_mean(data2);
    let v1 = hml_var(data1) * (n1 - 1) / n1;
    let v2 = hml_var(data2) * (n2 - 1) / n2;
    let se = math_sqrt(v1 / n1 + v2 / n2);
    let t_stat = (m1 - m2) / se;
    let num = (v1 / n1 + v2 / n2) * (v1 / n1 + v2 / n2);
    let den = (v1 / n1) * (v1 / n1) / (n1 - 1) + (v2 / n2) * (v2 / n2) / (n2 - 1);
    let df = num / den;
    let p_value = 2.0 * (1.0 - student_t_cdf(math_fabs(t_stat), df));
    return {"t_stat": t_stat, "p_value": p_value, "df": df};
}

# ── Pearson Chi-Squared Test ──

fn chi2_test(observed, expected) {
    let n = len(observed);
    let chi2 = 0.0;
    let i = 0;
    while (i < n) {
        if (expected[i] > 0.0) {
            let diff = observed[i] - expected[i];
            chi2 = chi2 + diff * diff / expected[i];
        }
        i = i + 1;
    }
    let df = n - 1;
    let p_value = 1.0 - chi2_cdf(chi2, df);
    return {"chi2": chi2, "p_value": p_value, "df": df};
}

# ── Chi-Squared Test of Independence ──

fn chi2_independence(contingency_table) {
    let n_rows = len(contingency_table);
    if (n_rows == 0) { return {"chi2": 0.0, "p_value": 1.0, "df": 0}; }
    let n_cols = len(contingency_table[0]);
    let row_sums = [];
    let col_sums = [];
    let total = 0.0;
    let i = 0;
    while (i < n_rows) { push(row_sums, 0.0); i = i + 1; }
    i = 0;
    while (i < n_cols) { push(col_sums, 0.0); i = i + 1; }
    i = 0;
    while (i < n_rows) {
        let j = 0;
        while (j < n_cols) {
            row_sums[i] = row_sums[i] + contingency_table[i][j];
            col_sums[j] = col_sums[j] + contingency_table[i][j];
            total = total + contingency_table[i][j];
            j = j + 1;
        }
        i = i + 1;
    }
    let chi2 = 0.0;
    i = 0;
    while (i < n_rows) {
        let j = 0;
        while (j < n_cols) {
            let expected = row_sums[i] * col_sums[j] / total;
            if (expected > 0.0) {
                let diff = contingency_table[i][j] - expected;
                chi2 = chi2 + diff * diff / expected;
            }
            j = j + 1;
        }
        i = i + 1;
    }
    let df = (n_rows - 1) * (n_cols - 1);
    let p_value = 1.0 - chi2_cdf(chi2, df);
    return {"chi2": chi2, "p_value": p_value, "df": df};
}

# ── F-Test for Equal Variances ──

fn f_test(data1, data2) {
    let n1 = len(data1);
    let n2 = len(data2);
    if (n1 < 2 or n2 < 2) { return {"f_stat": 1.0, "p_value": 1.0}; }
    let v1 = hml_var(data1);
    let v2 = hml_var(data2);
    let f_stat = 0.0;
    if (v1 > v2) {
        f_stat = v1 / v2;
    } else {
        f_stat = v2 / v1;
    }
    let p_value = 2.0 * (1.0 - chi2_cdf(f_stat, n1 - 1));
    return {"f_stat": f_stat, "p_value": p_value};
}

# ── One-Way ANOVA ──

fn one_way_anova(groups) {
    let k = len(groups);
    if (k < 2) { return {"f_stat": 0.0, "p_value": 1.0}; }
    let all_data = [];
    let group_means = [];
    let group_ns = [];
    let i = 0;
    while (i < k) {
        push(group_means, hml_mean(groups[i]));
        push(group_ns, len(groups[i]));
        let j = 0;
        while (j < len(groups[i])) {
            push(all_data, groups[i][j]);
            j = j + 1;
        }
        i = i + 1;
    }
    let grand_mean = hml_mean(all_data);
    let ss_between = 0.0;
    let ss_within = 0.0;
    i = 0;
    while (i < k) {
        ss_between = ss_between + group_ns[i] * (group_means[i] - grand_mean) * (group_means[i] - grand_mean);
        let j = 0;
        while (j < group_ns[i]) {
            ss_within = ss_within + (groups[i][j] - group_means[i]) * (groups[i][j] - group_means[i]);
            j = j + 1;
        }
        i = i + 1;
    }
    let df_between = k - 1;
    let df_within = len(all_data) - k;
    if (df_within == 0) { return {"f_stat": 0.0, "p_value": 1.0}; }
    let ms_between = ss_between / df_between;
    let ms_within = ss_within / df_within;
    let f_stat = ms_between / ms_within;
    let p_value = 1.0 - chi2_cdf(f_stat, df_between);
    return {"f_stat": f_stat, "p_value": p_value, "df_between": df_between, "df_within": df_within};
}

# ── Kruskal-Wallis Test ──

fn kruskal_wallis(groups) {
    let k = len(groups);
    let all_data = [];
    let group_labels = [];
    let i = 0;
    while (i < k) {
        let j = 0;
        while (j < len(groups[i])) {
            push(all_data, groups[i][j]);
            push(group_labels, i);
            j = j + 1;
        }
        i = i + 1;
    }
    let N = len(all_data);
    let ranks = _hml_rank(all_data);
    let group_rank_sums = [];
    let group_ns = [];
    i = 0;
    while (i < k) { push(group_rank_sums, 0.0); push(group_ns, 0); i = i + 1; }
    i = 0;
    while (i < N) {
        group_rank_sums[group_labels[i]] = group_rank_sums[group_labels[i]] + ranks[i];
        group_ns[group_labels[i]] = group_ns[group_labels[i]] + 1;
        i = i + 1;
    }
    let H = 0.0;
    i = 0;
    while (i < k) {
        if (group_ns[i] > 0) {
            H = H + group_rank_sums[i] * group_rank_sums[i] / group_ns[i];
        }
        i = i + 1;
    }
    H = 12.0 / (N * (N + 1)) * H - 3.0 * (N + 1);
    let p_value = 1.0 - chi2_cdf(H, k - 1);
    return {"H_stat": H, "p_value": p_value};
}

# ── Mann-Whitney U Test ──

fn mann_whitney_u(data1, data2) {
    let n1 = len(data1);
    let n2 = len(data2);
    let combined = [];
    let i = 0;
    while (i < n1) { push(combined, data1[i]); i = i + 1; }
    i = 0;
    while (i < n2) { push(combined, data2[i]); i = i + 1; }
    let ranks = _hml_rank(combined);
    let r1 = 0.0;
    i = 0;
    while (i < n1) { r1 = r1 + ranks[i]; i = i + 1; }
    let u1 = r1 - n1 * (n1 + 1) / 2.0;
    let u2 = n1 * n2 - u1;
    let u = u1;
    if (u2 < u1) { u = u2; }
    let mu = n1 * n2 / 2.0;
    let sigma = math_sqrt(n1 * n2 * (n1 + n2 + 1) / 12.0);
    let z = (u - mu) / sigma;
    let p_value = 2.0 * (1.0 - normal_cdf(math_fabs(z), 0.0, 1.0));
    return {"u_stat": u, "z_stat": z, "p_value": p_value};
}

# ── Wilcoxon Signed-Rank Test ──

fn wilcoxon_signed_rank(data1, data2) {
    let n = len(data1);
    let diffs = [];
    let i = 0;
    while (i < n) {
        let d = data1[i] - data2[i];
        if (d != 0.0) { push(diffs, d); }
        i = i + 1;
    }
    let m = len(diffs);
    if (m == 0) { return {"W_stat": 0.0, "p_value": 1.0}; }
    let abs_diffs = [];
    i = 0;
    while (i < m) {
        let a = diffs[i];
        if (a < 0.0) { a = -a; }
        push(abs_diffs, a);
        i = i + 1;
    }
    let ranks = _hml_rank(abs_diffs);
    let W = 0.0;
    i = 0;
    while (i < m) {
        if (diffs[i] > 0.0) { W = W + ranks[i]; }
        i = i + 1;
    }
    let mu = m * (m + 1) / 4.0;
    let sigma = math_sqrt(m * (m + 1) * (2 * m + 1) / 24.0);
    let z = (W - mu) / sigma;
    let p_value = 2.0 * (1.0 - normal_cdf(math_fabs(z), 0.0, 1.0));
    return {"W_stat": W, "z_stat": z, "p_value": p_value};
}

# ── Friedman Test ──

fn friedman_test(groups) {
    let k = len(groups);
    let n = len(groups[0]);
    let ranks_matrix = [];
    let i = 0;
    while (i < n) {
        let row = [];
        let j = 0;
        while (j < k) {
            push(row, {"val": groups[j][i], "col": j});
            j = j + 1;
        }
        let a = 0;
        while (a < k - 1) {
            let b = 0;
            while (b < k - a - 1) {
                if (row[b]["val"] > row[b + 1]["val"]) {
                    let tmp = row[b];
                    row[b] = row[b + 1];
                    row[b + 1] = tmp;
                }
                b = b + 1;
            }
            a = a + 1;
        }
        j = 0;
        while (j < k) {
            let start = j;
            while (start < k and row[start]["val"] == row[j]["val"]) { start = start + 1; }
            let avg_rank = (j + start + 1) * 0.5;
            let t = j;
            while (t < start) {
                row[t]["rank"] = avg_rank;
                t = t + 1;
            }
            j = start;
        }
        push(ranks_matrix, row);
        i = i + 1;
    }
    let col_rank_sums = [];
    i = 0;
    while (i < k) { push(col_rank_sums, 0.0); i = i + 1; }
    i = 0;
    while (i < n) {
        let j = 0;
        while (j < k) {
            let c = ranks_matrix[i][j]["col"];
            col_rank_sums[c] = col_rank_sums[c] + ranks_matrix[i][j]["rank"];
            j = j + 1;
        }
        i = i + 1;
    }
    let Q = 0.0;
    i = 0;
    while (i < k) {
        Q = Q + col_rank_sums[i] * col_rank_sums[i];
        i = i + 1;
    }
    Q = 12.0 * Q / (n * k * (k + 1)) - 3.0 * n * (k + 1);
    let p_value = 1.0 - chi2_cdf(Q, k - 1);
    return {"Q_stat": Q, "p_value": p_value};
}

# ── Kolmogorov-Smirnov Test (one-sample) ──

fn ks_test(data, cdf_fn) {
    let n = len(data);
    let sorted = [];
    let i = 0;
    while (i < n) { push(sorted, data[i]); i = i + 1; }
    _hml_sort(sorted);
    let D = 0.0;
    i = 0;
    while (i < n) {
        let ecdf = (i + 1) * 1.0 / n;
        let theoretical = cdf_fn(sorted[i]);
        let d1 = math_fabs(ecdf - theoretical);
        if (d1 > D) { D = d1; }
        if (i > 0) {
            let d2 = math_fabs(i * 1.0 / n - theoretical);
            if (d2 > D) { D = d2; }
        }
        i = i + 1;
    }
    let lambda = (math_sqrt(n) + 0.12 + 0.11 / math_sqrt(n)) * D;
    let p_value = 2.0 * math_exp(-2.0 * lambda * lambda);
    if (p_value > 1.0) { p_value = 1.0; }
    return {"D_stat": D, "p_value": p_value};
}

# ── Two-Sample KS Test ──

fn ks_test_2samp(data1, data2) {
    let n1 = len(data1);
    let n2 = len(data2);
    let s1 = [];
    let s2 = [];
    let i = 0;
    while (i < n1) { push(s1, data1[i]); i = i + 1; }
    i = 0;
    while (i < n2) { push(s2, data2[i]); i = i + 1; }
    _hml_sort(s1);
    _hml_sort(s2);
    let D = 0.0;
    let i1 = 0;
    let i2 = 0;
    while (i1 < n1 and i2 < n2) {
        let d = 0.0;
        if (s1[i1] <= s2[i2]) {
            d = math_fabs((i1 + 1) * 1.0 / n1 - i2 * 1.0 / n2);
            i1 = i1 + 1;
        } else {
            d = math_fabs(i1 * 1.0 / n1 - (i2 + 1) * 1.0 / n2);
            i2 = i2 + 1;
        }
        if (d > D) { D = d; }
    }
    let ne = n1 * n2 * 1.0 / (n1 + n2);
    let lambda = (math_sqrt(ne) + 0.12 + 0.11 / math_sqrt(ne)) * D;
    let p_value = 2.0 * math_exp(-2.0 * lambda * lambda);
    if (p_value > 1.0) { p_value = 1.0; }
    return {"D_stat": D, "p_value": p_value};
}

# ── Shapiro-Wilk Test (approximate) ──

fn shapiro_wilk_test(data) {
    let n = len(data);
    if (n < 3) { return {"W_stat": 1.0, "p_value": 1.0}; }
    let sorted = [];
    let i = 0;
    while (i < n) { push(sorted, data[i]); i = i + 1; }
    _hml_sort(sorted);
    let m = hml_mean(data);
    let ss = 0.0;
    i = 0;
    while (i < n) {
        let d = data[i] - m;
        ss = ss + d * d;
        i = i + 1;
    }
    let b = 0.0;
    let half = n / 2;
    i = 0;
    while (i < half) {
        let coeff = -0.682 * math_exp(-0.5 * ((i + 1.0 - 0.375) / (n + 0.25)) * ((i + 1.0 - 0.375) / (n + 0.25)));
        b = b + coeff * (sorted[n - 1 - i] - sorted[i]);
        i = i + 1;
    }
    let W = b * b / ss;
    if (W > 1.0) { W = 1.0; }
    let p_value = 1.0 - normal_cdf(W, 0.95, 0.05);
    return {"W_stat": W, "p_value": p_value};
}

# ── Anderson-Darling Test ──

fn anderson_darling_test(data) {
    let n = len(data);
    let sorted = [];
    let i = 0;
    while (i < n) { push(sorted, data[i]); i = i + 1; }
    _hml_sort(sorted);
    let m = hml_mean(data);
    let s = hml_std(data);
    let A2 = -n * 1.0;
    i = 0;
    while (i < n) {
        let z1 = (sorted[i] - m) / s;
        let z2 = (sorted[n - 1 - i] - m) / s;
        let c1 = normal_cdf(z1, 0.0, 1.0);
        let c2 = normal_cdf(z2, 0.0, 1.0);
        let term = (2.0 * i + 1.0) * (math_log(c1 + 0.0000001) + math_log(1.0 - c2 + 0.0000001));
        A2 = A2 - term / n;
        i = i + 1;
    }
    let A2_star = A2 * (1.0 + 0.75 / n + 2.25 / (n * n));
    let p_value = 0.0;
    if (A2_star < 0.2) { p_value = 1.0 - math_exp(-13.436 + 101.14 * A2_star - 223.73 * A2_star * A2_star); }
    if (A2_star >= 0.2 and A2_star < 0.34) { p_value = 1.0 - math_exp(-8.318 + 42.796 * A2_star - 59.938 * A2_star * A2_star); }
    if (A2_star >= 0.34 and A2_star < 0.6) { p_value = math_exp(0.9177 - 4.279 * A2_star - 1.38 * A2_star * A2_star); }
    if (A2_star >= 0.6) { p_value = math_exp(1.2937 - 5.709 * A2_star + 0.0186 * A2_star * A2_star); }
    if (p_value > 1.0) { p_value = 1.0; }
    if (p_value < 0.0) { p_value = 0.0; }
    return {"A2_stat": A2_star, "p_value": p_value};
}

# ── Jarque-Bera Test ──

fn jarque_bera_test(data) {
    let n = len(data);
    if (n < 3) { return {"JB_stat": 0.0, "p_value": 1.0}; }
    let m = hml_mean(data);
    let m2 = 0.0;
    let m3 = 0.0;
    let m4 = 0.0;
    let i = 0;
    while (i < n) {
        let d = data[i] - m;
        m2 = m2 + d * d;
        m3 = m3 + d * d * d;
        m4 = m4 + d * d * d * d;
        i = i + 1;
    }
    m2 = m2 / n;
    m3 = m3 / n;
    m4 = m4 / n;
    let skew = m3 / math_pow(m2, 1.5);
    let kurt = m4 / (m2 * m2) - 3.0;
    let JB = n * (skew * skew / 6.0 + kurt * kurt / 24.0);
    let p_value = 1.0 - chi2_cdf(JB, 2.0);
    return {"JB_stat": JB, "skewness": skew, "kurtosis": kurt, "p_value": p_value};
}

# ── Durbin-Watson Test ──

fn durbin_watson(residuals) {
    let n = len(residuals);
    if (n < 2) { return {"DW_stat": 2.0}; }
    let num = 0.0;
    let den = 0.0;
    let i = 0;
    while (i < n) {
        den = den + residuals[i] * residuals[i];
        if (i > 0) {
            let d = residuals[i] - residuals[i - 1];
            num = num + d * d;
        }
        i = i + 1;
    }
    if (den == 0.0) { return {"DW_stat": 2.0}; }
    let DW = num / den;
    return {"DW_stat": DW};
}

# ── Breusch-Pagan Test ──

fn breusch_pagan_test(residuals, X) {
    let n = len(residuals);
    if (n < 2) { return {"BP_stat": 0.0, "p_value": 1.0}; }
    let rss = 0.0;
    let i = 0;
    while (i < n) {
        rss = rss + residuals[i] * residuals[i];
        i = i + 1;
    }
    let sigma2 = rss / n;
    let g = [];
    i = 0;
    while (i < n) {
        push(g, residuals[i] * residuals[i] / sigma2 - 1.0);
        i = i + 1;
    }
    let g_mean = hml_mean(g);
    let ssg = 0.0;
    i = 0;
    while (i < n) {
        ssg = ssg + (g[i] - g_mean) * (g[i] - g_mean);
        i = i + 1;
    }
    let BP = ssg / 2.0;
    let df = len(X[0]);
    let p_value = 1.0 - chi2_cdf(BP, df);
    return {"BP_stat": BP, "p_value": p_value, "df": df};
}

# ── Levene Test ──

fn levene_test(groups) {
    let k = len(groups);
    let all_data = [];
    let i = 0;
    while (i < k) {
        let med = hml_mean(groups[i]);
        let j = 0;
        while (j < len(groups[i])) {
            let z = groups[i][j] - med;
            if (z < 0.0) { z = -z; }
            push(all_data, {"val": z, "group": i});
            j = j + 1;
        }
        i = i + 1;
    }
    let N = len(all_data);
    let grand_mean = 0.0;
    i = 0;
    while (i < N) { grand_mean = grand_mean + all_data[i]["val"]; i = i + 1; }
    grand_mean = grand_mean / N;
    let ss_between = 0.0;
    let ss_within = 0.0;
    let group_means = [];
    let group_ns = [];
    i = 0;
    while (i < k) { push(group_means, 0.0); push(group_ns, 0); i = i + 1; }
    i = 0;
    while (i < N) {
        let g = all_data[i]["group"];
        group_means[g] = group_means[g] + all_data[i]["val"];
        group_ns[g] = group_ns[g] + 1;
        i = i + 1;
    }
    i = 0;
    while (i < k) {
        if (group_ns[i] > 0) { group_means[i] = group_means[i] / group_ns[i]; }
        i = i + 1;
    }
    i = 0;
    while (i < k) {
        ss_between = ss_between + group_ns[i] * (group_means[i] - grand_mean) * (group_means[i] - grand_mean);
        i = i + 1;
    }
    i = 0;
    while (i < N) {
        let g = all_data[i]["group"];
        let d = all_data[i]["val"] - group_means[g];
        ss_within = ss_within + d * d;
        i = i + 1;
    }
    let df_between = k - 1;
    let df_within = N - k;
    let ms_between = ss_between / df_between;
    let ms_within = ss_within / df_within;
    let W = ms_between / ms_within;
    let p_value = 1.0 - chi2_cdf(W, df_between);
    return {"W_stat": W, "p_value": p_value};
}

# ── Bartlett Test ──

fn bartlett_test(groups) {
    let k = len(groups);
    let N = 0;
    let i = 0;
    while (i < k) { N = N + len(groups[i]); i = i + 1; }
    let pooled_var = 0.0;
    i = 0;
    while (i < k) {
        let ni = len(groups[i]);
        if (ni > 1) { pooled_var = pooled_var + (ni - 1) * hml_var(groups[i]); }
        i = i + 1;
    }
    pooled_var = pooled_var / (N - k);
    let numerator = (N - k) * math_log(pooled_var);
    i = 0;
    while (i < k) {
        let ni = len(groups[i]);
        if (ni > 1) { numerator = numerator - (ni - 1) * math_log(hml_var(groups[i])); }
        i = i + 1;
    }
    let correction = 0.0;
    i = 0;
    while (i < k) {
        let ni = len(groups[i]);
        if (ni > 1) { correction = correction + 1.0 / (ni - 1); }
        i = i + 1;
    }
    correction = 1.0 + (correction - 1.0 / (N - k)) / (3.0 * (k - 1));
    let T = numerator / correction;
    let p_value = 1.0 - chi2_cdf(T, k - 1);
    return {"T_stat": T, "p_value": p_value};
}

# ── McNemar Test ──

fn mcnemar_test(table) {
    let b = table[0][1];
    let c = table[1][0];
    let chi2 = (b - c) * (b - c) / (b + c + 0.0000001);
    let p_value = 1.0 - chi2_cdf(chi2, 1.0);
    return {"chi2": chi2, "p_value": p_value};
}

# ── Cochran's Q Test ──

fn cochran_q_test(data) {
    let n = len(data);
    let k = len(data[0]);
    let col_sums = [];
    let j = 0;
    while (j < k) { push(col_sums, 0.0); j = j + 1; }
    let row_sums = [];
    let i = 0;
    while (i < n) {
        let rs = 0.0;
        j = 0;
        while (j < k) {
            col_sums[j] = col_sums[j] + data[i][j];
            rs = rs + data[i][j];
            j = j + 1;
        }
        push(row_sums, rs);
        i = i + 1;
    }
    let total = 0.0;
    j = 0;
    while (j < k) { total = total + col_sums[j]; j = j + 1; }
    let mean = total / k;
    let num = 0.0;
    j = 0;
    while (j < k) {
        num = num + (col_sums[j] - mean) * (col_sums[j] - mean);
        j = j + 1;
    }
    num = num * k * (k - 1);
    let den = 0.0;
    i = 0;
    while (i < n) { den = den + row_sums[i] * (k - row_sums[i]); i = i + 1; }
    let Q = 0.0;
    if (den > 0.0) { Q = num / den; }
    let p_value = 1.0 - chi2_cdf(Q, k - 1);
    return {"Q_stat": Q, "p_value": p_value};
}

# ── Fisher's Exact Test ──

fn fisher_exact_test(a, b, c, d) {
    let n = a + b + c + d;
    let log_p = math_lgamma(a + b + 1) - math_lgamma(a + 1) - math_lgamma(b + 1);
    log_p = log_p + math_lgamma(c + d + 1) - math_lgamma(c + 1) - math_lgamma(d + 1);
    log_p = log_p + math_lgamma(a + c + 1) - math_lgamma(n + 1);
    log_p = log_p + math_lgamma(b + d + 1);
    let p_value = math_exp(log_p);
    if (p_value > 1.0) { p_value = 1.0; }
    return {"p_value": p_value};
}

# ── Spearman Rank Correlation ──

fn spearman_rank_correlation(x, y) {
    let n = len(x);
    if (n < 3) { return {"rho": 0.0, "p_value": 1.0}; }
    let rx = _hml_rank(x);
    let ry = _hml_rank(y);
    let sum_d2 = 0.0;
    let i = 0;
    while (i < n) {
        let d = rx[i] - ry[i];
        sum_d2 = sum_d2 + d * d;
        i = i + 1;
    }
    let rho = 1.0 - 6.0 * sum_d2 / (n * (n * n - 1));
    let t_stat = rho * math_sqrt((n - 2) * 1.0 / (1.0 - rho * rho + 0.0000001));
    let p_value = 2.0 * (1.0 - student_t_cdf(math_fabs(t_stat), n - 2));
    return {"rho": rho, "p_value": p_value};
}

# ── Kendall's Tau ──

fn kendall_tau(x, y) {
    let n = len(x);
    if (n < 2) { return {"tau": 0.0, "p_value": 1.0}; }
    let concordant = 0;
    let discordant = 0;
    let i = 0;
    while (i < n) {
        let j = i + 1;
        while (j < n) {
            let dx = x[i] - x[j];
            let dy = y[i] - y[j];
            if (dx * dy > 0.0) { concordant = concordant + 1; }
            if (dx * dy < 0.0) { discordant = discordant + 1; }
            j = j + 1;
        }
        i = i + 1;
    }
    let total = n * (n - 1) / 2;
    let tau = (concordant - discordant) * 1.0 / total;
    let z = tau * math_sqrt(9.0 * n * (n - 1) / (2.0 * (2 * n + 5)));
    let p_value = 2.0 * (1.0 - normal_cdf(math_fabs(z), 0.0, 1.0));
    return {"tau": tau, "p_value": p_value};
}

# ── Pearson Correlation Test ──

fn pearson_correlation_test(x, y) {
    let n = len(x);
    if (n < 3) { return {"r": 0.0, "p_value": 1.0}; }
    let mx = hml_mean(x);
    let my = hml_mean(y);
    let sxy = 0.0;
    let sx2 = 0.0;
    let sy2 = 0.0;
    let i = 0;
    while (i < n) {
        let dx = x[i] - mx;
        let dy = y[i] - my;
        sxy = sxy + dx * dy;
        sx2 = sx2 + dx * dx;
        sy2 = sy2 + dy * dy;
        i = i + 1;
    }
    let r = 0.0;
    if (sx2 > 0.0 and sy2 > 0.0) {
        r = sxy / math_sqrt(sx2 * sy2);
    }
    let t_stat = r * math_sqrt((n - 2) * 1.0 / (1.0 - r * r + 0.0000001));
    let p_value = 2.0 * (1.0 - student_t_cdf(math_fabs(t_stat), n - 2));
    return {"r": r, "p_value": p_value};
}

# ── Point-Biserial Correlation ──

fn point_biserial_correlation(x, y) {
    let n = len(x);
    let n0 = 0;
    let n1 = 0;
    let sum0 = 0.0;
    let sum1 = 0.0;
    let i = 0;
    while (i < n) {
        if (y[i] == 0) {
            n0 = n0 + 1;
            sum0 = sum0 + x[i];
        } else {
            n1 = n1 + 1;
            sum1 = sum1 + x[i];
        }
        i = i + 1;
    }
    if (n0 == 0 or n1 == 0) { return 0.0; }
    let m0 = sum0 / n0;
    let m1 = sum1 / n1;
    let total_std = hml_std(x);
    let rpb = (m1 - m0) * math_sqrt(n0 * n1 * 1.0 / (n * n)) / total_std;
    return rpb;
}

# ── Cramér's V ──

fn cramers_v(contingency_table) {
    let result = chi2_independence(contingency_table);
    let chi2 = result["chi2"];
    let n = 0.0;
    let i = 0;
    while (i < len(contingency_table)) {
        let j = 0;
        while (j < len(contingency_table[i])) {
            n = n + contingency_table[i][j];
            j = j + 1;
        }
        i = i + 1;
    }
    let r = len(contingency_table);
    let c = len(contingency_table[0]);
    let min_rc = r;
    if (c < r) { min_rc = c; }
    let denom = n * (min_rc - 1);
    if (denom == 0.0) { return 0.0; }
    return math_sqrt(chi2 / denom);
}

# ═══════════════════════════════════════════════════════════════════════════
# SECTION 13: Advanced Feature Engineering
# ═══════════════════════════════════════════════════════════════════════════

# ── Polynomial Features ──

fn polynomial_features(X, degree) {
    let n = len(X);
    let n_features = len(X[0]);
    let result = [];
    let i = 0;
    while (i < n) {
        let row = [1.0];
        let d = 1;
        while (d <= degree) {
            let j = 0;
            while (j < n_features) {
                push(row, math_pow(X[i][j], d));
                j = j + 1;
            }
            d = d + 1;
        }
        push(result, row);
        i = i + 1;
    }
    return result;
}

# ── Interaction Features ──

fn interaction_features(X) {
    let n = len(X);
    let n_features = len(X[0]);
    let result = [];
    let i = 0;
    while (i < n) {
        let row = [];
        let j = 0;
        while (j < n_features) {
            push(row, X[i][j]);
            j = j + 1;
        }
        j = 0;
        while (j < n_features) {
            let k = j + 1;
            while (k < n_features) {
                push(row, X[i][j] * X[i][k]);
                k = k + 1;
            }
            j = j + 1;
        }
        push(result, row);
        i = i + 1;
    }
    return result;
}

# ── One-Hot Encode ──

fn one_hot_encode(categorical_data) {
    let unique_vals = hml_unique(categorical_data);
    let n = len(categorical_data);
    let m = len(unique_vals);
    let encoded = [];
    let i = 0;
    while (i < n) {
        let row = [];
        let j = 0;
        while (j < m) { push(row, 0.0); j = j + 1; }
        let val = categorical_data[i];
        let found_idx = -1;
        j = 0;
        while (j < m) {
            if (unique_vals[j] == val) { found_idx = j; break; }
            j = j + 1;
        }
        if (found_idx >= 0) { row[found_idx] = 1.0; }
        push(encoded, row);
        i = i + 1;
    }
    return {"encoded": encoded, "categories": unique_vals};
}

# ── One-Hot Decode ──

fn one_hot_decode(encoded, categories) {
    let result = [];
    let i = 0;
    while (i < len(encoded)) {
        let best = 0;
        let best_val = encoded[i][0];
        let j = 1;
        while (j < len(encoded[i])) {
            if (encoded[i][j] > best_val) {
                best_val = encoded[i][j];
                best = j;
            }
            j = j + 1;
        }
        push(result, categories[best]);
        i = i + 1;
    }
    return result;
}

# ── Binarize ──

fn binarize(X, threshold) {
    let result = [];
    let i = 0;
    while (i < len(X)) {
        let row = [];
        let j = 0;
        while (j < len(X[i])) {
            if (X[i][j] > threshold) { push(row, 1.0); }
            else { push(row, 0.0); }
            j = j + 1;
        }
        push(result, row);
        i = i + 1;
    }
    return result;
}

# ── Quantile Transform ──

fn quantile_transform(X, n_quantiles) {
    let n = len(X);
    let n_features = len(X[0]);
    let result = [];
    let i = 0;
    while (i < n) { push(result, []); i = i + 1; }
    let j = 0;
    while (j < n_features) {
        let col = [];
        i = 0;
        while (i < n) { push(col, X[i][j]); i = i + 1; }
        let sorted = [];
        i = 0;
        while (i < n) { push(sorted, col[i]); i = i + 1; }
        _hml_sort(sorted);
        i = 0;
        while (i < n) {
            let rank = 0;
            let k = 0;
            while (k < n) {
                if (sorted[k] <= col[i]) { rank = rank + 1; }
                k = k + 1;
            }
            let q = (rank - 1.0) / (n - 1.0);
            push(result[i], q);
            i = i + 1;
        }
        j = j + 1;
    }
    return result;
}

# ── Power Transform (Yeo-Johnson) ──

fn power_transform(X, method) {
    let n = len(X);
    let n_features = len(X[0]);
    let result = [];
    let i = 0;
    while (i < n) {
        let row = [];
        let j = 0;
        while (j < n_features) {
            let val = X[i][j];
            if (method == "box-cox") {
                if (val > 0.0) {
                    push(row, math_log(val));
                } else {
                    push(row, val);
                }
            } else {
                if (val >= 0.0) {
                    push(row, math_log(val + 1.0));
                } else {
                    push(row, -math_log(-val + 1.0));
                }
            }
            j = j + 1;
        }
        push(result, row);
        i = i + 1;
    }
    return result;
}

# ── KBins Discretizer ──

fn kbins_discretizer(X, n_bins, strategy) {
    let n = len(X);
    let n_features = len(X[0]);
    let result = [];
    let i = 0;
    while (i < n) { push(result, []); i = i + 1; }
    let j = 0;
    while (j < n_features) {
        let col = [];
        i = 0;
        while (i < n) { push(col, X[i][j]); i = i + 1; }
        let mn = col[0];
        let mx = col[0];
        i = 1;
        while (i < n) {
            if (col[i] < mn) { mn = col[i]; }
            if (col[i] > mx) { mx = col[i]; }
            i = i + 1;
        }
        let bin_width = (mx - mn) / n_bins;
        if (bin_width == 0.0) { bin_width = 1.0; }
        i = 0;
        while (i < n) {
            let b = math_floor((col[i] - mn) / bin_width);
            if (b >= n_bins) { b = n_bins - 1; }
            push(result[i], b * 1.0);
            i = i + 1;
        }
        j = j + 1;
    }
    return result;
}

# ── Feature Scale (minmax, standard, robust, maxabs) ──

fn feature_scale(X, method) {
    let n = len(X);
    let n_features = len(X[0]);
    let result = [];
    let i = 0;
    while (i < n) { push(result, []); i = i + 1; }
    let j = 0;
    while (j < n_features) {
        let col = [];
        i = 0;
        while (i < n) { push(col, X[i][j]); i = i + 1; }
        if (method == "minmax") {
            let mn = col[0];
            let mx = col[0];
            i = 1;
            while (i < n) { if (col[i] < mn) { mn = col[i]; } if (col[i] > mx) { mx = col[i]; } i = i + 1; }
            let rng = mx - mn;
            if (rng == 0.0) { rng = 1.0; }
            i = 0;
            while (i < n) { push(result[i], (col[i] - mn) / rng); i = i + 1; }
        }
        if (method == "standard") {
            let m = hml_mean(col);
            let s = hml_std(col);
            if (s == 0.0) { s = 1.0; }
            i = 0;
            while (i < n) { push(result[i], (col[i] - m) / s); i = i + 1; }
        }
        if (method == "robust") {
            let sorted = [];
            i = 0;
            while (i < n) { push(sorted, col[i]); i = i + 1; }
            _hml_sort(sorted);
            let q1 = sorted[n / 4];
            let q3 = sorted[3 * n / 4];
            let med = sorted[n / 2];
            let iqr = q3 - q1;
            if (iqr == 0.0) { iqr = 1.0; }
            i = 0;
            while (i < n) { push(result[i], (col[i] - med) / iqr); i = i + 1; }
        }
        if (method == "maxabs") {
            let mx = col[0];
            if (mx < 0.0) { mx = -mx; }
            i = 1;
            while (i < n) { let a = col[i]; if (a < 0.0) { a = -a; } if (a > mx) { mx = a; } i = i + 1; }
            if (mx == 0.0) { mx = 1.0; }
            i = 0;
            while (i < n) { push(result[i], col[i] / mx); i = i + 1; }
        }
        j = j + 1;
    }
    return result;
}

# ── MaxAbs Scale ──

fn maxabs_scale(X) {
    return feature_scale(X, "maxabs");
}

# ── Robust Scale ──

fn robust_scale(X) {
    return feature_scale(X, "robust");
}

# ── L1 Normalization ──

fn l1_normalize(X) {
    let result = [];
    let i = 0;
    while (i < len(X)) {
        let s = 0.0;
        let j = 0;
        while (j < len(X[i])) { s = s + math_fabs(X[i][j]); j = j + 1; }
        if (s == 0.0) { s = 1.0; }
        let row = [];
        j = 0;
        while (j < len(X[i])) { push(row, X[i][j] / s); j = j + 1; }
        push(result, row);
        i = i + 1;
    }
    return result;
}

# ── L2 Normalization ──

fn l2_normalize(X) {
    let result = [];
    let i = 0;
    while (i < len(X)) {
        let s = 0.0;
        let j = 0;
        while (j < len(X[i])) { s = s + X[i][j] * X[i][j]; j = j + 1; }
        s = math_sqrt(s);
        if (s == 0.0) { s = 1.0; }
        let row = [];
        j = 0;
        while (j < len(X[i])) { push(row, X[i][j] / s); j = j + 1; }
        push(result, row);
        i = i + 1;
    }
    return result;
}

# ── Unit Vector Normalize ──

fn unit_vector_normalize(X) {
    return l2_normalize(X);
}

# ── Feature Hasher ──

fn feature_hasher(data, n_features) {
    let result = [];
    let i = 0;
    while (i < len(data)) {
        let row = [];
        let j = 0;
        while (j < n_features) { push(row, 0.0); j = j + 1; }
        let k = 0;
        while (k < len(data[i])) {
            let h = 0;
            let s = data[i][k];
            let ci = 0;
            while (ci < len(s)) {
                h = (h * 31 + s[ci]) % n_features;
                ci = ci + 1;
            }
            if (h < 0) { h = h + n_features; }
            row[h] = row[h] + 1.0;
            k = k + 1;
        }
        push(result, row);
        i = i + 1;
    }
    return result;
}

# ── Count Vectorizer ──

fn count_vectorizer(docs) {
    let vocab = {};
    let doc_token_counts = [];
    let i = 0;
    while (i < len(docs)) {
        let tokens = docs[i];
        let counts = {};
        let j = 0;
        while (j < len(tokens)) {
            let tok = tokens[j];
            let cnt = vocab[tok];
            if (cnt == nullptr) { vocab[tok] = 1; }
            let c = counts[tok];
            if (c == nullptr) { counts[tok] = 1; }
            else { counts[tok] = c + 1; }
            j = j + 1;
        }
        push(doc_token_counts, counts);
        i = i + 1;
    }
    let vocab_keys = dict_keys(vocab);
    let n_vocab = len(vocab_keys);
    let result = [];
    i = 0;
    while (i < len(docs)) {
        let row = [];
        let j = 0;
        while (j < n_vocab) { push(row, 0.0); j = j + 1; }
        let counts = doc_token_counts[i];
        j = 0;
        while (j < n_vocab) {
            let tok = vocab_keys[j];
            let c = counts[tok];
            if (c != nullptr) { row[j] = c * 1.0; }
            j = j + 1;
        }
        push(result, row);
        i = i + 1;
    }
    return result;
}

# ── TF-IDF Vectorizer ──

fn tfidf_transform(X) {
    let n_docs = len(X);
    let n_features = len(X[0]);
    let df = [];
    let j = 0;
    while (j < n_features) { push(df, 0.0); j = j + 1; }
    let i = 0;
    while (i < n_docs) {
        j = 0;
        while (j < n_features) {
            if (X[i][j] > 0.0) { df[j] = df[j] + 1.0; }
            j = j + 1;
        }
        i = i + 1;
    }
    let result = [];
    i = 0;
    while (i < n_docs) {
        let row = [];
        j = 0;
        while (j < n_features) {
            let tf = X[i][j];
            let idf = math_log((n_docs + 1.0) / (df[j] + 1.0)) + 1.0;
            push(row, tf * idf);
            j = j + 1;
        }
        push(result, row);
        i = i + 1;
    }
    return result;
}

fn tfidf_vectorizer(docs) {
    let counts = count_vectorizer(docs);
    return tfidf_transform(counts);
}

# ── Add Noise ──

fn add_noise(X, noise_level) {
    let result = [];
    let i = 0;
    while (i < len(X)) {
        let row = [];
        let j = 0;
        while (j < len(X[i])) {
            let noise = (hml_random() - 0.5) * 2.0 * noise_level;
            push(row, X[i][j] + noise);
            j = j + 1;
        }
        push(result, row);
        i = i + 1;
    }
    return result;
}

# ── Drop Low Variance ──

fn drop_low_variance(X, threshold) {
    let n = len(X);
    let n_features = len(X[0]);
    let keep = [];
    let j = 0;
    while (j < n_features) {
        let col = [];
        let i = 0;
        while (i < n) { push(col, X[i][j]); i = i + 1; }
        let m = hml_mean(col);
        let var = 0.0;
        i = 0;
        while (i < n) { let d = col[i] - m; var = var + d * d; i = i + 1; }
        var = var / n;
        if (var > threshold) { push(keep, j); }
        j = j + 1;
    }
    let result = [];
    let i = 0;
    while (i < n) {
        let row = [];
        let k = 0;
        while (k < len(keep)) { push(row, X[i][keep[k]]); k = k + 1; }
        push(result, row);
        i = i + 1;
    }
    return result;
}

# ── Drop High Correlation ──

fn drop_high_correlation(X, threshold) {
    let n = len(X);
    let n_features = len(X[0]);
    let to_drop = [];
    let j = 0;
    while (j < n_features) { push(to_drop, false); j = j + 1; }
    let i = 0;
    while (i < n_features) {
        if (to_drop[i]) { i = i + 1; continue; }
        let j = i + 1;
        while (j < n_features) {
            if (to_drop[j]) { j = j + 1; continue; }
            let col_i = [];
            let col_j = [];
            let k = 0;
            while (k < n) { push(col_i, X[k][i]); push(col_j, X[k][j]); k = k + 1; }
            let r = pearson_correlation_test(col_i, col_j)["r"];
            if (math_fabs(r) > threshold) { to_drop[j] = true; }
            j = j + 1;
        }
        i = i + 1;
    }
    let keep = [];
    i = 0;
    while (i < n_features) { if (not to_drop[i]) { push(keep, i); } i = i + 1; }
    let result = [];
    i = 0;
    while (i < n) {
        let row = [];
        let k = 0;
        while (k < len(keep)) { push(row, X[i][keep[k]]); k = k + 1; }
        push(result, row);
        i = i + 1;
    }
    return result;
}

# ── Select K Best ──

fn select_k_best(X, y, k, score_fn) {
    let n_features = len(X[0]);
    let scores = [];
    let indices = [];
    let j = 0;
    while (j < n_features) {
        let col = [];
        let i = 0;
        while (i < len(X)) { push(col, X[i][j]); i = i + 1; }
        push(scores, score_fn(col, y));
        push(indices, j);
        j = j + 1;
    }
    let i = 0;
    while (i < n_features - 1) {
        let jj = 0;
        while (jj < n_features - i - 1) {
            if (scores[jj] < scores[jj + 1]) {
                let tmp = scores[jj]; scores[jj] = scores[jj + 1]; scores[jj + 1] = tmp;
                let tmp2 = indices[jj]; indices[jj] = indices[jj + 1]; indices[jj + 1] = tmp2;
            }
            jj = jj + 1;
        }
        i = i + 1;
    }
    let top_k = [];
    i = 0;
    while (i < k and i < n_features) { push(top_k, indices[i]); i = i + 1; }
    let result = [];
    i = 0;
    while (i < len(X)) {
        let row = [];
        let t = 0;
        while (t < len(top_k)) { push(row, X[i][top_k[t]]); t = t + 1; }
        push(result, row);
        i = i + 1;
    }
    return result;
}

# ── Select Percentile ──

fn select_percentile(X, y, percentile, score_fn) {
    let n_features = len(X[0]);
    let k = math_floor(n_features * percentile / 100.0);
    if (k < 1) { k = 1; }
    return select_k_best(X, y, k, score_fn);
}

# ── Mutual Information (Classification) ──

fn mutual_info_classif(X, y) {
    let n_features = len(X[0]);
    let n = len(X);
    let scores = [];
    let j = 0;
    while (j < n_features) {
        let col = [];
        let i = 0;
        while (i < n) { push(col, X[i][j]); i = i + 1; }
        let mi = 0.0;
        let n_bins = 10;
        let col_min = col[0];
        let col_max = col[0];
        i = 1;
        while (i < n) { if (col[i] < col_min) { col_min = col[i]; } if (col[i] > col_max) { col_max = col[i]; } i = i + 1; }
        let bin_w = (col_max - col_min) / n_bins;
        if (bin_w == 0.0) { bin_w = 1.0; }
        let y_classes = hml_unique(y);
        let n_classes = len(y_classes);
        let joint = [];
        i = 0;
        while (i < n_bins) { let row = []; let k = 0; while (k < n_classes) { push(row, 0.0); k = k + 1; } push(joint, row); i = i + 1; }
        i = 0;
        while (i < n) {
            let b = math_floor((col[i] - col_min) / bin_w);
            if (b >= n_bins) { b = n_bins - 1; }
            if (b < 0) { b = 0; }
            let y_idx = 0;
            let k = 0;
            while (k < n_classes) {
                if (y_classes[k] == y[i]) { y_idx = k; break; }
                k = k + 1;
            }
            joint[b][y_idx] = joint[b][y_idx] + 1.0;
            i = i + 1;
        }
        i = 0;
        while (i < n_bins) {
            let k = 0;
            while (k < n_classes) {
                joint[i][k] = joint[i][k] / n;
                if (joint[i][k] > 0.0) {
                    let px = 0.0;
                    let k2 = 0;
                    while (k2 < n_classes) { px = px + joint[i][k2]; k2 = k2 + 1; }
                    let py = 0.0;
                    let i2 = 0;
                    while (i2 < n_bins) { py = py + joint[i2][k]; i2 = i2 + 1; }
                    mi = mi + joint[i][k] * math_log(joint[i][k] / (px * py + 0.0000001));
                }
                k = k + 1;
            }
            i = i + 1;
        }
        push(scores, mi);
        j = j + 1;
    }
    return scores;
}

# ── Mutual Information (Regression) ──

fn mutual_info_regression(X, y) {
    let n_features = len(X[0]);
    let n = len(X);
    let scores = [];
    let j = 0;
    while (j < n_features) {
        let col = [];
        let i = 0;
        while (i < n) { push(col, X[i][j]); i = i + 1; }
        let n_bins = 10;
        let col_min = col[0];
        let col_max = col[0];
        i = 1;
        while (i < n) { if (col[i] < col_min) { col_min = col[i]; } if (col[i] > col_max) { col_max = col[i]; } i = i + 1; }
        let bin_w = (col_max - col_min) / n_bins;
        if (bin_w == 0.0) { bin_w = 1.0; }
        let y_min = y[0];
        let y_max = y[0];
        i = 1;
        while (i < n) { if (y[i] < y_min) { y_min = y[i]; } if (y[i] > y_max) { y_max = y[i]; } i = i + 1; }
        let y_bin_w = (y_max - y_min) / n_bins;
        if (y_bin_w == 0.0) { y_bin_w = 1.0; }
        let joint = [];
        i = 0;
        while (i < n_bins) { let row = []; let k = 0; while (k < n_bins) { push(row, 0.0); k = k + 1; } push(joint, row); i = i + 1; }
        i = 0;
        while (i < n) {
            let bx = math_floor((col[i] - col_min) / bin_w);
            if (bx >= n_bins) { bx = n_bins - 1; }
            if (bx < 0) { bx = 0; }
            let by = math_floor((y[i] - y_min) / y_bin_w);
            if (by >= n_bins) { by = n_bins - 1; }
            if (by < 0) { by = 0; }
            joint[bx][by] = joint[bx][by] + 1.0;
            i = i + 1;
        }
        let mi = 0.0;
        i = 0;
        while (i < n_bins) {
            let k = 0;
            while (k < n_bins) {
                joint[i][k] = joint[i][k] / n;
                if (joint[i][k] > 0.0) {
                    let px = 0.0;
                    let k2 = 0;
                    while (k2 < n_bins) { px = px + joint[i][k2]; k2 = k2 + 1; }
                    let py = 0.0;
                    let i2 = 0;
                    while (i2 < n_bins) { py = py + joint[i2][k]; i2 = i2 + 1; }
                    mi = mi + joint[i][k] * math_log(joint[i][k] / (px * py + 0.0000001));
                }
                k = k + 1;
            }
            i = i + 1;
        }
        push(scores, mi);
        j = j + 1;
    }
    return scores;
}

# ── Chi2 Feature Selection ──

fn chi2_feature_selection(X, y) {
    let n_features = len(X[0]);
    let n = len(X);
    let scores = [];
    let j = 0;
    while (j < n_features) {
        let col = [];
        let i = 0;
        while (i < n) { push(col, X[i][j]); i = i + 1; }
        let y_classes = hml_unique(y);
        let n_classes = len(y_classes);
        let chi2 = 0.0;
        let observed = [];
        let total = 0.0;
        i = 0;
        while (i < n_classes) { push(observed, 0.0); i = i + 1; }
        let overall = 0.0;
        i = 0;
        while (i < n) {
            observed[y[i]] = observed[y[i]] + col[i];
            overall = overall + col[i];
            total = total + col[i];
            i = i + 1;
        }
        let class_counts = [];
        i = 0;
        while (i < n_classes) { push(class_counts, 0.0); i = i + 1; }
        i = 0;
        while (i < n) { class_counts[y[i]] = class_counts[y[i]] + 1.0; i = i + 1; }
        let class_total = 0.0;
        i = 0;
        while (i < n_classes) { class_total = class_total + class_counts[i]; i = i + 1; }
        i = 0;
        while (i < n_classes) {
            let expected = observed[i] * class_counts[i] / class_total;
            if (expected > 0.0) {
                let diff = observed[i] - expected;
                chi2 = chi2 + diff * diff / expected;
            }
            i = i + 1;
        }
        push(scores, chi2);
        j = j + 1;
    }
    return scores;
}

# ── F-Classif (ANOVA F-value for classification) ──

fn f_classif(X, y) {
    let n_features = len(X[0]);
    let n = len(X);
    let y_classes = hml_unique(y);
    let scores = [];
    let j = 0;
    while (j < n_features) {
        let col = [];
        let i = 0;
        while (i < n) { push(col, X[i][j]); i = i + 1; }
        let groups = [];
        let c = 0;
        while (c < len(y_classes)) { push(groups, []); c = c + 1; }
        i = 0;
        while (i < n) {
            let c = 0;
            while (c < len(y_classes)) { if (y_classes[c] == y[i]) { push(groups[c], col[i]); break; } c = c + 1; }
            i = i + 1;
        }
        let result = one_way_anova(groups);
        push(scores, result["f_stat"]);
        j = j + 1;
    }
    return scores;
}

# ── F-Regression ──

fn f_regression(X, y) {
    let n_features = len(X[0]);
    let n = len(X);
    let scores = [];
    let j = 0;
    while (j < n_features) {
        let col = [];
        let i = 0;
        while (i < n) { push(col, X[i][j]); i = i + 1; }
        let r = pearson_correlation_test(col, y)["r"];
        let f = r * r / (1.0 - r * r + 0.0000001) * (n - 2);
        push(scores, f);
        j = j + 1;
    }
    return scores;
}

# ── RFE Ranking ──

fn rfe_ranking(X, y, estimator) {
    let n_features = len(X[0]);
    let active = [];
    let j = 0;
    while (j < n_features) { push(active, j); j = j + 1; }
    let rankings = [];
    j = 0;
    while (j < n_features) { push(rankings, 0); j = j + 1; }
    let n_active = n_features;
    while (n_active > 0) {
        let X_subset = [];
        let i = 0;
        while (i < len(X)) {
            let row = [];
            let a = 0;
            while (a < len(active)) { push(row, X[i][active[a]]); a = a + 1; }
            push(X_subset, row);
            i = i + 1;
        }
        estimator.fit(X_subset, y);
        let weights = estimator.weights;
        let min_idx = 0;
        let min_val = math_fabs(weights[0]);
        let a = 1;
        while (a < len(weights)) {
            if (math_fabs(weights[a]) < min_val) { min_val = math_fabs(weights[a]); min_idx = a; }
            a = a + 1;
        }
        rankings[active[min_idx]] = n_active;
        let new_active = [];
        a = 0;
        while (a < len(active)) { if (a != min_idx) { push(new_active, active[a]); } a = a + 1; }
        active = new_active;
        n_active = n_active - 1;
    }
    return rankings;
}

# ── Sequential Forward Selection ──

fn sequential_forward_selection(X, y, estimator, k) {
    let n_features = len(X[0]);
    let selected = [];
    let remaining = [];
    let j = 0;
    while (j < n_features) { push(remaining, j); j = j + 1; }
    while (len(selected) < k and len(remaining) > 0) {
        let best_score = -1000000.0;
        let best_feature = -1;
        let r = 0;
        while (r < len(remaining)) {
            let candidate = [];
            let s = 0;
            while (s < len(selected)) { push(candidate, selected[s]); s = s + 1; }
            push(candidate, remaining[r]);
            let X_subset = [];
            let i = 0;
            while (i < len(X)) {
                let row = [];
                let c = 0;
                while (c < len(candidate)) { push(row, X[i][candidate[c]]); c = c + 1; }
                push(X_subset, row);
                i = i + 1;
            }
            estimator.fit(X_subset, y);
            let score = estimator.score(X_subset, y);
            if (score > best_score) { best_score = score; best_feature = r; }
            r = r + 1;
        }
        if (best_feature >= 0) {
            push(selected, remaining[best_feature]);
            let new_remaining = [];
            r = 0;
            while (r < len(remaining)) { if (r != best_feature) { push(new_remaining, remaining[r]); } r = r + 1; }
            remaining = new_remaining;
        }
    }
    return selected;
}

# ── Sequential Backward Selection ──

fn sequential_backward_selection(X, y, estimator, k) {
    let n_features = len(X[0]);
    let selected = [];
    let j = 0;
    while (j < n_features) { push(selected, j); j = j + 1; }
    while (len(selected) > k) {
        let best_score = -1000000.0;
        let best_to_remove = -1;
        let r = 0;
        while (r < len(selected)) {
            let candidate = [];
            let s = 0;
            while (s < len(selected)) { if (s != r) { push(candidate, selected[s]); } s = s + 1; }
            let X_subset = [];
            let i = 0;
            while (i < len(X)) {
                let row = [];
                let c = 0;
                while (c < len(candidate)) { push(row, X[i][candidate[c]]); c = c + 1; }
                push(X_subset, row);
                i = i + 1;
            }
            estimator.fit(X_subset, y);
            let score = estimator.score(X_subset, y);
            if (score > best_score) { best_score = score; best_to_remove = r; }
            r = r + 1;
        }
        if (best_to_remove >= 0) {
            let new_selected = [];
            r = 0;
            while (r < len(selected)) { if (r != best_to_remove) { push(new_selected, selected[r]); } r = r + 1; }
            selected = new_selected;
        }
    }
    return selected;
}

# ── Target Encoding ──

fn target_encode(X, y, categorical_cols) {
    let n = len(X);
    let result = [];
    let i = 0;
    while (i < n) {
        let row = [];
        let j = 0;
        while (j < len(X[i])) { push(row, X[i][j]); j = j + 1; }
        push(result, row);
        i = i + 1;
    }
    let c = 0;
    while (c < len(categorical_cols)) {
        let col_idx = categorical_cols[c];
        let encodings = {};
        let counts = {};
        let sums = {};
        let i = 0;
        while (i < n) {
            let key = X[i][col_idx];
            let cnt = counts[key];
            if (cnt == nullptr) { counts[key] = 0; sums[key] = 0.0; }
            counts[key] = counts[key] + 1;
            sums[key] = sums[key] + y[i];
            i = i + 1;
        }
        let global_mean = hml_mean(y);
        let keys = dict_keys(counts);
        let k = 0;
        while (k < len(keys)) {
            let key = keys[k];
            encodings[key] = sums[key] / counts[key];
            k = k + 1;
        }
        i = 0;
        while (i < n) {
            result[i][col_idx] = encodings[X[i][col_idx]];
            i = i + 1;
        }
        c = c + 1;
    }
    return result;
}

# ── Frequency Encoding ──

fn frequency_encode(X, categorical_cols) {
    let n = len(X);
    let result = [];
    let i = 0;
    while (i < n) {
        let row = [];
        let j = 0;
        while (j < len(X[i])) { push(row, X[i][j]); j = j + 1; }
        push(result, row);
        i = i + 1;
    }
    let c = 0;
    while (c < len(categorical_cols)) {
        let col_idx = categorical_cols[c];
        let freqs = {};
        let i = 0;
        while (i < n) {
            let key = X[i][col_idx];
            let cnt = freqs[key];
            if (cnt == nullptr) { freqs[key] = 0; }
            freqs[key] = freqs[key] + 1;
            i = i + 1;
        }
        i = 0;
        while (i < n) {
            result[i][col_idx] = freqs[X[i][col_idx]] * 1.0 / n;
            i = i + 1;
        }
        c = c + 1;
    }
    return result;
}

# ── Ordinal Encoding ──

fn ordinal_encode(categorical_data) {
    let unique_vals = hml_unique(categorical_data);
    let mapping = {};
    let i = 0;
    while (i < len(unique_vals)) { mapping[unique_vals[i]] = i; i = i + 1; }
    let result = [];
    i = 0;
    while (i < len(categorical_data)) { push(result, mapping[categorical_data[i]]); i = i + 1; }
    return result;
}

# ── Count Encoding ──

fn count_encode(X, categorical_cols) {
    let n = len(X);
    let result = [];
    let i = 0;
    while (i < n) {
        let row = [];
        let j = 0;
        while (j < len(X[i])) { push(row, X[i][j]); j = j + 1; }
        push(result, row);
        i = i + 1;
    }
    let c = 0;
    while (c < len(categorical_cols)) {
        let col_idx = categorical_cols[c];
        let counts = {};
        let i = 0;
        while (i < n) {
            let key = X[i][col_idx];
            let cnt = counts[key];
            if (cnt == nullptr) { counts[key] = 0; }
            counts[key] = counts[key] + 1;
            i = i + 1;
        }
        i = 0;
        while (i < n) {
            result[i][col_idx] = counts[X[i][col_idx]] * 1.0;
            i = i + 1;
        }
        c = c + 1;
    }
    return result;
}

# ── Binary Encoding ──

fn binary_encode(X, categorical_cols) {
    let n = len(X);
    let result = [];
    let i = 0;
    while (i < n) {
        let row = [];
        let j = 0;
        while (j < len(X[i])) { push(row, X[i][j]); j = j + 1; }
        push(result, row);
        i = i + 1;
    }
    let c = 0;
    while (c < len(categorical_cols)) {
        let col_idx = categorical_cols[c];
        let unique_vals = [];
        i = 0;
        while (i < n) {
            let found = false;
            let k = 0;
            while (k < len(unique_vals)) { if (unique_vals[k] == X[i][col_idx]) { found = true; break; } k = k + 1; }
            if (not found) { push(unique_vals, X[i][col_idx]); }
            i = i + 1;
        }
        let mapping = {};
        let k = 0;
        while (k < len(unique_vals)) { mapping[unique_vals[k]] = k; k = k + 1; }
        let n_bits = 1;
        let max_val = len(unique_vals);
        while (max_val > 0) { n_bits = n_bits + 1; max_val = max_val / 2; }
        i = 0;
        while (i < n) {
            let code = mapping[X[i][col_idx]];
            let bit = 0;
            while (bit < n_bits) {
                let bit_val = code - int(code / 2) * 2;
                push(result[i], bit_val * 1.0);
                code = code / 2;
                bit = bit + 1;
            }
            i = i + 1;
        }
        c = c + 1;
    }
    return result;
}

# ── Hash Encoding ──

fn hash_encode(X, categorical_cols, n_components) {
    let n = len(X);
    let result = [];
    let i = 0;
    while (i < n) {
        let row = [];
        let j = 0;
        while (j < len(X[i])) { push(row, X[i][j]); j = j + 1; }
        push(result, row);
        i = i + 1;
    }
    let c = 0;
    while (c < len(categorical_cols)) {
        let col_idx = categorical_cols[c];
        i = 0;
        while (i < n) {
            let val = X[i][col_idx];
            let h = 0;
            let ci = 0;
            while (ci < len(val)) {
                h = (h * 31 + val[ci]) % n_components;
                ci = ci + 1;
            }
            if (h < 0) { h = h + n_components; }
            push(result[i], h * 1.0);
            i = i + 1;
        }
        c = c + 1;
    }
    return result;
}

# ── Leave-One-Out Target Encoding ──

fn leave_one_out_encode(X, y, categorical_cols) {
    let n = len(X);
    let result = [];
    let i = 0;
    while (i < n) {
        let row = [];
        let j = 0;
        while (j < len(X[i])) { push(row, X[i][j]); j = j + 1; }
        push(result, row);
        i = i + 1;
    }
    let c = 0;
    while (c < len(categorical_cols)) {
        let col_idx = categorical_cols[c];
        let sums = {};
        let counts = {};
        i = 0;
        while (i < n) {
            let key = X[i][col_idx];
            let cnt = counts[key];
            if (cnt == nullptr) { counts[key] = 0; sums[key] = 0.0; }
            counts[key] = counts[key] + 1;
            sums[key] = sums[key] + y[i];
            i = i + 1;
        }
        i = 0;
        while (i < n) {
            let key = X[i][col_idx];
            let total_sum = sums[key];
            let total_cnt = counts[key];
            let loo_sum = total_sum - y[i];
            let loo_cnt = total_cnt - 1;
            if (loo_cnt > 0) {
                result[i][col_idx] = loo_sum / loo_cnt;
            } else {
                result[i][col_idx] = hml_mean(y);
            }
            i = i + 1;
        }
        c = c + 1;
    }
    return result;
}

# ── CatBoost Encoding ──

fn catboost_encode(X, y, categorical_cols) {
    let n = len(X);
    let result = [];
    let i = 0;
    while (i < n) {
        let row = [];
        let j = 0;
        while (j < len(X[i])) { push(row, X[i][j]); j = j + 1; }
        push(result, row);
        i = i + 1;
    }
    let perm = [];
    i = 0;
    while (i < n) { push(perm, i); i = i + 1; }
    hml_shuffle(perm);
    let c = 0;
    while (c < len(categorical_cols)) {
        let col_idx = categorical_cols[c];
        let sums = {};
        let counts = {};
        let prior = hml_mean(y);
        i = 0;
        while (i < n) {
            let idx = perm[i];
            let key = X[idx][col_idx];
            let cnt = counts[key];
            if (cnt == nullptr) { counts[key] = 0; sums[key] = 0.0; }
            let smoothed = prior;
            if (counts[key] > 0) {
                smoothed = (sums[key] + prior) / (counts[key] + 1);
            }
            result[idx][col_idx] = smoothed;
            counts[key] = counts[key] + 1;
            sums[key] = sums[key] + y[idx];
            i = i + 1;
        }
        c = c + 1;
    }
    return result;
}

# ── Weight of Evidence Encoding ──

fn weight_of_evidence_encode(X, y, categorical_cols) {
    let n = len(X);
    let result = [];
    let i = 0;
    while (i < n) {
        let row = [];
        let j = 0;
        while (j < len(X[i])) { push(row, X[i][j]); j = j + 1; }
        push(result, row);
        i = i + 1;
    }
    let total_pos = 0.0;
    let total_neg = 0.0;
    i = 0;
    while (i < n) {
        if (y[i] == 1) { total_pos = total_pos + 1.0; }
        else { total_neg = total_neg + 1.0; }
        i = i + 1;
    }
    let c = 0;
    while (c < len(categorical_cols)) {
        let col_idx = categorical_cols[c];
        let pos_counts = {};
        let neg_counts = {};
        i = 0;
        while (i < n) {
            let key = X[i][col_idx];
            if (pos_counts[key] == nullptr) { pos_counts[key] = 0.0; neg_counts[key] = 0.0; }
            if (y[i] == 1) { pos_counts[key] = pos_counts[key] + 1.0; }
            else { neg_counts[key] = neg_counts[key] + 1.0; }
            i = i + 1;
        }
        let woes = {};
        let keys = dict_keys(pos_counts);
        let k = 0;
        while (k < len(keys)) {
            let key = keys[k];
            let pos_rate = (pos_counts[key] + 0.5) / total_pos;
            let neg_rate = (neg_counts[key] + 0.5) / total_neg;
            woes[key] = math_log(pos_rate / neg_rate);
            k = k + 1;
        }
        i = 0;
        while (i < n) {
            result[i][col_idx] = woes[X[i][col_idx]];
            i = i + 1;
        }
        c = c + 1;
    }
    return result;
}

# ═══════════════════════════════════════════════════════════════════════════
# SECTION 14: Optimizers and Schedulers
# ═══════════════════════════════════════════════════════════════════════════

# ── SGD Optimizer ──

class SGDOptimizer {
    let lr = 0.01;
    let momentum = 0.0;
    let nesterov = false;
    let weight_decay = 0.0;
    let velocity = [];

    fn init_sgd(lr, momentum, nesterov, weight_decay) {
        self.lr = lr;
        self.momentum = momentum;
        if (nesterov == nullptr) { self.nesterov = false; }
        if (weight_decay == nullptr) { self.weight_decay = 0.0; }
        self.velocity = [];
        return 0;
    }

    fn update(params, grads) {
        if (len(self.velocity) == 0) {
            let i = 0;
            while (i < len(params)) { push(self.velocity, []); i = i + 1; }
            i = 0;
            while (i < len(params)) {
                let j = 0;
                while (j < len(params[i])) { push(self.velocity[i], 0.0); j = j + 1; }
                i = i + 1;
            }
        }
        let i = 0;
        while (i < len(params)) {
            let j = 0;
            while (j < len(params[i])) {
                let g = grads[i][j] + self.weight_decay * params[i][j];
                if (self.momentum > 0.0) {
                    self.velocity[i][j] = self.momentum * self.velocity[i][j] + self.lr * g;
                    if (self.nesterov) {
                        params[i][j] = params[i][j] - self.momentum * self.velocity[i][j] - self.lr * g;
                    } else {
                        params[i][j] = params[i][j] - self.velocity[i][j];
                    }
                } else {
                    params[i][j] = params[i][j] - self.lr * g;
                }
                j = j + 1;
            }
            i = i + 1;
        }
        return params;
    }
}

# ── Momentum Optimizer ──

class MomentumOptimizer {
    let lr = 0.01;
    let momentum = 0.9;
    let velocity = [];

    fn init_momentum(lr, momentum) {
        self.lr = lr;
        self.momentum = momentum;
        self.velocity = [];
        return 0;
    }

    fn update(params, grads) {
        if (len(self.velocity) == 0) {
            let i = 0;
            while (i < len(params)) { push(self.velocity, []); i = i + 1; }
            i = 0;
            while (i < len(params)) {
                let j = 0;
                while (j < len(params[i])) { push(self.velocity[i], 0.0); j = j + 1; }
                i = i + 1;
            }
        }
        let i = 0;
        while (i < len(params)) {
            let j = 0;
            while (j < len(params[i])) {
                self.velocity[i][j] = self.momentum * self.velocity[i][j] + self.lr * grads[i][j];
                params[i][j] = params[i][j] - self.velocity[i][j];
                j = j + 1;
            }
            i = i + 1;
        }
        return params;
    }
}

# ── NAG Optimizer (Nesterov Accelerated Gradient) ──

class NAGOptimizer {
    let lr = 0.01;
    let momentum = 0.9;
    let velocity = [];

    fn init_nag(lr, momentum) {
        self.lr = lr;
        self.momentum = momentum;
        self.velocity = [];
        return 0;
    }

    fn update(params, grads) {
        if (len(self.velocity) == 0) {
            let i = 0;
            while (i < len(params)) { push(self.velocity, []); i = i + 1; }
            i = 0;
            while (i < len(params)) {
                let j = 0;
                while (j < len(params[i])) { push(self.velocity[i], 0.0); j = j + 1; }
                i = i + 1;
            }
        }
        let i = 0;
        while (i < len(params)) {
            let j = 0;
            while (j < len(params[i])) {
                let prev_v = self.velocity[i][j];
                self.velocity[i][j] = self.momentum * self.velocity[i][j] + self.lr * grads[i][j];
                params[i][j] = params[i][j] + self.momentum * prev_v - (1.0 + self.momentum) * self.velocity[i][j];
                j = j + 1;
            }
            i = i + 1;
        }
        return params;
    }
}

# ── Adagrad Optimizer ──

class AdagradOptimizer {
    let lr = 0.01;
    let eps = 0.00000001;
    let cache = [];

    fn init_adagrad(lr, eps) {
        self.lr = lr;
        if (eps == nullptr) { self.eps = 0.00000001; }
        self.cache = [];
        return 0;
    }

    fn update(params, grads) {
        if (len(self.cache) == 0) {
            let i = 0;
            while (i < len(params)) { push(self.cache, []); i = i + 1; }
            i = 0;
            while (i < len(params)) {
                let j = 0;
                while (j < len(params[i])) { push(self.cache[i], 0.0); j = j + 1; }
                i = i + 1;
            }
        }
        let i = 0;
        while (i < len(params)) {
            let j = 0;
            while (j < len(params[i])) {
                self.cache[i][j] = self.cache[i][j] + grads[i][j] * grads[i][j];
                params[i][j] = params[i][j] - self.lr * grads[i][j] / (math_sqrt(self.cache[i][j]) + self.eps);
                j = j + 1;
            }
            i = i + 1;
        }
        return params;
    }
}

# ── RMSprop Optimizer ──

class RMSpropOptimizer {
    let lr = 0.001;
    let rho = 0.9;
    let eps = 0.00000001;
    let cache = [];

    fn init_rmsprop(lr, rho, eps) {
        self.lr = lr;
        self.rho = rho;
        if (eps == nullptr) { self.eps = 0.00000001; }
        self.cache = [];
        return 0;
    }

    fn update(params, grads) {
        if (len(self.cache) == 0) {
            let i = 0;
            while (i < len(params)) { push(self.cache, []); i = i + 1; }
            i = 0;
            while (i < len(params)) {
                let j = 0;
                while (j < len(params[i])) { push(self.cache[i], 0.0); j = j + 1; }
                i = i + 1;
            }
        }
        let i = 0;
        while (i < len(params)) {
            let j = 0;
            while (j < len(params[i])) {
                self.cache[i][j] = self.rho * self.cache[i][j] + (1.0 - self.rho) * grads[i][j] * grads[i][j];
                params[i][j] = params[i][j] - self.lr * grads[i][j] / (math_sqrt(self.cache[i][j]) + self.eps);
                j = j + 1;
            }
            i = i + 1;
        }
        return params;
    }
}

# ── Adadelta Optimizer ──

class AdadeltaOptimizer {
    let rho = 0.95;
    let eps = 0.00000001;
    let cache = [];
    let delta = [];

    fn init_adadelta(rho, eps) {
        self.rho = rho;
        if (eps == nullptr) { self.eps = 0.00000001; }
        self.cache = [];
        self.delta = [];
        return 0;
    }

    fn update(params, grads) {
        if (len(self.cache) == 0) {
            let i = 0;
            while (i < len(params)) { push(self.cache, []); push(self.delta, []); i = i + 1; }
            i = 0;
            while (i < len(params)) {
                let j = 0;
                while (j < len(params[i])) { push(self.cache[i], 0.0); push(self.delta[i], 0.0); j = j + 1; }
                i = i + 1;
            }
        }
        let i = 0;
        while (i < len(params)) {
            let j = 0;
            while (j < len(params[i])) {
                self.cache[i][j] = self.rho * self.cache[i][j] + (1.0 - self.rho) * grads[i][j] * grads[i][j];
                let update = -math_sqrt(self.delta[i][j] + self.eps) / math_sqrt(self.cache[i][j] + self.eps) * grads[i][j];
                self.delta[i][j] = self.rho * self.delta[i][j] + (1.0 - self.rho) * update * update;
                params[i][j] = params[i][j] + update;
                j = j + 1;
            }
            i = i + 1;
        }
        return params;
    }
}

# ── Adam Optimizer ──

class AdamOptimizer {
    let lr = 0.001;
    let beta1 = 0.9;
    let beta2 = 0.999;
    let eps = 0.00000001;
    let m = [];
    let v = [];
    let t = 0;

    fn init_adam(lr, beta1, beta2, eps) {
        self.lr = lr;
        self.beta1 = beta1;
        self.beta2 = beta2;
        if (eps == nullptr) { self.eps = 0.00000001; }
        self.m = [];
        self.v = [];
        self.t = 0;
        return 0;
    }

    fn update(params, grads) {
        self.t = self.t + 1;
        if (len(self.m) == 0) {
            let i = 0;
            while (i < len(params)) { push(self.m, []); push(self.v, []); i = i + 1; }
            i = 0;
            while (i < len(params)) {
                let j = 0;
                while (j < len(params[i])) { push(self.m[i], 0.0); push(self.v[i], 0.0); j = j + 1; }
                i = i + 1;
            }
        }
        let i = 0;
        while (i < len(params)) {
            let j = 0;
            while (j < len(params[i])) {
                self.m[i][j] = self.beta1 * self.m[i][j] + (1.0 - self.beta1) * grads[i][j];
                self.v[i][j] = self.beta2 * self.v[i][j] + (1.0 - self.beta2) * grads[i][j] * grads[i][j];
                let m_hat = self.m[i][j] / (1.0 - math_pow(self.beta1, self.t));
                let v_hat = self.v[i][j] / (1.0 - math_pow(self.beta2, self.t));
                params[i][j] = params[i][j] - self.lr * m_hat / (math_sqrt(v_hat) + self.eps);
                j = j + 1;
            }
            i = i + 1;
        }
        return params;
    }
}

# ── Lookahead Optimizer ──

class LookaheadOptimizer {
    let base_optimizer = nullptr;
    let k = 5;
    let alpha = 0.5;
    let slow_params = [];
    let step_counter = 0;

    fn init_lookahead(base_optimizer, k, alpha) {
        self.base_optimizer = base_optimizer;
        self.k = k;
        self.alpha = alpha;
        self.slow_params = [];
        self.step_counter = 0;
        return 0;
    }

    fn update(params, grads) {
        self.step_counter = self.step_counter + 1;
        if (len(self.slow_params) == 0) {
            let i = 0;
            while (i < len(params)) {
                let row = [];
                let j = 0;
                while (j < len(params[i])) { push(row, params[i][j]); j = j + 1; }
                push(self.slow_params, row);
                i = i + 1;
            }
        }
        params = self.base_optimizer.update(params, grads);
        if (self.step_counter >= self.k) {
            let i = 0;
            while (i < len(params)) {
                let j = 0;
                while (j < len(params[i])) {
                    self.slow_params[i][j] = self.slow_params[i][j] + self.alpha * (params[i][j] - self.slow_params[i][j]);
                    params[i][j] = self.slow_params[i][j];
                    j = j + 1;
                }
                i = i + 1;
            }
            self.step_counter = 0;
        }
        return params;
    }
}

# ── LAMB Optimizer ──

class LAMBOptimizer {
    let lr = 0.001;
    let beta1 = 0.9;
    let beta2 = 0.999;
    let eps = 0.00000001;
    let m = [];
    let v = [];
    let t = 0;

    fn init_lamb(lr, beta1, beta2, eps) {
        self.lr = lr;
        self.beta1 = beta1;
        self.beta2 = beta2;
        if (eps == nullptr) { self.eps = 0.00000001; }
        self.m = [];
        self.v = [];
        self.t = 0;
        return 0;
    }

    fn update(params, grads) {
        self.t = self.t + 1;
        if (len(self.m) == 0) {
            let i = 0;
            while (i < len(params)) { push(self.m, []); push(self.v, []); i = i + 1; }
            i = 0;
            while (i < len(params)) {
                let j = 0;
                while (j < len(params[i])) { push(self.m[i], 0.0); push(self.v[i], 0.0); j = j + 1; }
                i = i + 1;
            }
        }
        let i = 0;
        while (i < len(params)) {
            let j = 0;
            while (j < len(params[i])) {
                self.m[i][j] = self.beta1 * self.m[i][j] + (1.0 - self.beta1) * grads[i][j];
                self.v[i][j] = self.beta2 * self.v[i][j] + (1.0 - self.beta2) * grads[i][j] * grads[i][j];
                let m_hat = self.m[i][j] / (1.0 - math_pow(self.beta1, self.t));
                let v_hat = self.v[i][j] / (1.0 - math_pow(self.beta2, self.t));
                let update = m_hat / (math_sqrt(v_hat) + self.eps);
                let w_norm = math_fabs(params[i][j]);
                let u_norm = math_fabs(update);
                let ratio = 1.0;
                if (w_norm > 0.0 and u_norm > 0.0) { ratio = w_norm / u_norm; }
                if (ratio > 10.0) { ratio = 10.0; }
                params[i][j] = params[i][j] - self.lr * ratio * update;
                j = j + 1;
            }
            i = i + 1;
        }
        return params;
    }
}

# ═══════════════════════════════════════════════════════════════════════════
# SECTION 14b: Learning Rate Schedulers
# ═══════════════════════════════════════════════════════════════════════════

# ── Step Decay ──

fn lr_step_decay(initial_lr, epoch, drop_rate, epochs_drop) {
    return initial_lr * math_pow(drop_rate, math_floor(epoch * 1.0 / epochs_drop));
}

# ── Exponential Decay ──

fn lr_exponential_decay(initial_lr, epoch, decay_rate) {
    return initial_lr * math_exp(-decay_rate * epoch);
}

# ── Cosine Decay ──

fn lr_cosine_decay(initial_lr, epoch, total_epochs) {
    return initial_lr * 0.5 * (1.0 + math_cos(epoch * 3.141592653589793 / total_epochs));
}

# ── Cosine Restart ──

fn lr_cosine_restart(initial_lr, epoch, T_0, T_mult) {
    let cycle = 0;
    let current_epoch = epoch;
    let total = 0;
    let T_cur = T_0;
    while (current_epoch >= T_cur) {
        current_epoch = current_epoch - T_cur;
        cycle = cycle + 1;
        total = total + T_cur;
        T_cur = T_0 * math_pow(T_mult, cycle);
    }
    return initial_lr * 0.5 * (1.0 + math_cos(current_epoch * 3.141592653589793 / T_cur));
}

# ── Linear Decay ──

fn lr_linear_decay(initial_lr, epoch, total_epochs) {
    return initial_lr * (1.0 - epoch * 1.0 / total_epochs);
}

# ── Inverse Time Decay ──

fn lr_inverse_time_decay(initial_lr, epoch, decay_rate) {
    return initial_lr / (1.0 + decay_rate * epoch);
}

# ── Polynomial Decay ──

fn lr_polynomial_decay(initial_lr, epoch, total_epochs, power) {
    return initial_lr * math_pow(1.0 - epoch * 1.0 / total_epochs, power);
}

# ── Cyclic LR ──

fn lr_cyclic(initial_lr, max_lr, epoch, step_size, mode) {
    let cycle = math_floor(epoch * 1.0 / (2.0 * step_size));
    let x = math_fabs(epoch * 1.0 / step_size - 2.0 * cycle - 1.0);
    let ratio = x;
    if (mode == "triangular2") {
        ratio = x / math_pow(2.0, cycle);
    }
    if (mode == "exp_range") {
        ratio = x * math_pow(0.999, epoch);
    }
    return initial_lr + (max_lr - initial_lr) * (1.0 - ratio);
}

# ── One Cycle LR ──

fn lr_one_cycle(initial_lr, max_lr, epoch, total_epochs) {
    let mid = total_epochs / 2;
    if (epoch < mid) {
        return initial_lr + (max_lr - initial_lr) * (epoch * 1.0 / mid);
    }
    return initial_lr + (max_lr - initial_lr) * (1.0 - (epoch - mid) * 1.0 / (total_epochs - mid));
}

# ── Warmup LR ──

fn lr_warmup(initial_lr, epoch, warmup_epochs) {
    if (epoch < warmup_epochs) {
        return initial_lr * (epoch + 1) * 1.0 / warmup_epochs;
    }
    return initial_lr;
}

# ── Reduce on Plateau ──

fn lr_reduce_on_plateau(lr, metric, patience, factor, min_lr, best_metric_ptr) {
    let best_metric = best_metric_ptr[0];
    let patience_count = best_metric_ptr[1];
    if (metric < best_metric) {
        best_metric_ptr[0] = metric;
        best_metric_ptr[1] = 0;
    } else {
        best_metric_ptr[1] = patience_count + 1;
    }
    if (best_metric_ptr[1] >= patience) {
        let new_lr = lr * factor;
        if (new_lr < min_lr) { new_lr = min_lr; }
        best_metric_ptr[1] = 0;
        return new_lr;
    }
    return lr;
}

# ═══════════════════════════════════════════════════════════════════════════
# SECTION 14c: Regularization
# ═══════════════════════════════════════════════════════════════════════════

# ── L1 Regularization ──

fn l1_regularization(weights, lambda_val) {
    let loss = 0.0;
    let i = 0;
    while (i < len(weights)) {
        let j = 0;
        while (j < len(weights[i])) {
            loss = loss + math_fabs(weights[i][j]);
            j = j + 1;
        }
        i = i + 1;
    }
    return lambda_val * loss;
}

# ── L2 Regularization ──

fn l2_regularization(weights, lambda_val) {
    let loss = 0.0;
    let i = 0;
    while (i < len(weights)) {
        let j = 0;
        while (j < len(weights[i])) {
            loss = loss + weights[i][j] * weights[i][j];
            j = j + 1;
        }
        i = i + 1;
    }
    return 0.5 * lambda_val * loss;
}

# ── Elastic Net ──

fn elastic_net(weights, l1_ratio, lambda_val) {
    let l1_loss = l1_regularization(weights, lambda_val);
    let l2_loss = l2_regularization(weights, lambda_val);
    return l1_ratio * l1_loss + (1.0 - l1_ratio) * l2_loss;
}

# ── L1 Gradient ──

fn l1_gradient(weight, lambda_val) {
    if (weight > 0.0) { return lambda_val; }
    if (weight < 0.0) { return -lambda_val; }
    return 0.0;
}

# ── L2 Gradient ──

fn l2_gradient(weight, lambda_val) {
    return lambda_val * weight;
}

# ── Elastic Net Gradient ──

fn elastic_net_gradient(weight, l1_ratio, lambda_val) {
    return l1_ratio * l1_gradient(weight, lambda_val) + (1.0 - l1_ratio) * l2_gradient(weight, lambda_val);
}

