# SECTION 22: Outlier Detection
# ═══════════════════════════════════════════════════════════════════════════

fn hml_zscore_outliers(data, threshold) {
    let m = hml_mean(data);
    let s = hml_std(data);
    if (s == 0.0) { s = 1.0; }
    let result = [];
    let i = 0;
    while (i < len(data)) {
        let z = (data[i] - m) / s;
        if (z < 0.0) { z = -z; }
        if (z > threshold) {
            push(result, 1);
        } else {
            push(result, 0);
        }
        i = i + 1;
    }
    return result;
}

fn hml_modified_zscore_outliers(data, threshold) {
    let n = len(data);
    if (n == 0) { return []; }
    let sorted = [];
    let i = 0;
    while (i < n) {
        push(sorted, data[i]);
        i = i + 1;
    }
    let si = 0;
    while (si < n) {
        let min_idx = si;
        let sj = si + 1;
        while (sj < n) {
            if (sorted[sj] < sorted[min_idx]) { min_idx = sj; }
            sj = sj + 1;
        }
        let tmp = sorted[si];
        sorted[si] = sorted[min_idx];
        sorted[min_idx] = tmp;
        si = si + 1;
    }
    let mid = math_floor(n * 1.0 / 2.0);
    let median = sorted[mid];
    if (n % 2 == 0) {
        median = (sorted[mid - 1] + sorted[mid]) * 0.5;
    }
    let abs_devs = [];
    i = 0;
    while (i < n) {
        let d = data[i] - median;
        if (d < 0.0) { d = -d; }
        push(abs_devs, d);
        i = i + 1;
    }
    let mad_sorted = [];
    i = 0;
    while (i < n) {
        push(mad_sorted, abs_devs[i]);
        i = i + 1;
    }
    si = 0;
    while (si < n) {
        let min_idx = si;
        let sj = si + 1;
        while (sj < n) {
            if (mad_sorted[sj] < mad_sorted[min_idx]) { min_idx = sj; }
            sj = sj + 1;
        }
        let tmp = mad_sorted[si];
        mad_sorted[si] = mad_sorted[min_idx];
        mad_sorted[min_idx] = tmp;
        si = si + 1;
    }
    let mad = mad_sorted[mid];
    if (n % 2 == 0) {
        mad = (mad_sorted[mid - 1] + mad_sorted[mid]) * 0.5;
    }
    if (mad == 0.0) { mad = 0.0000000001; }
    let result = [];
    i = 0;
    while (i < n) {
        let mz = 0.6745 * abs_devs[i] / mad;
        if (mz > threshold) {
            push(result, 1);
        } else {
            push(result, 0);
        }
        i = i + 1;
    }
    return result;
}

fn hml_iqr_outliers(data, multiplier) {
    let n = len(data);
    if (n == 0) { return []; }
    let sorted = [];
    let i = 0;
    while (i < n) {
        push(sorted, data[i]);
        i = i + 1;
    }
    let si = 0;
    while (si < n) {
        let min_idx = si;
        let sj = si + 1;
        while (sj < n) {
            if (sorted[sj] < sorted[min_idx]) { min_idx = sj; }
            sj = sj + 1;
        }
        let tmp = sorted[si];
        sorted[si] = sorted[min_idx];
        sorted[min_idx] = tmp;
        si = si + 1;
    }
    let q1_pos = 0.25 * (n - 1);
    let q1_lo = math_floor(q1_pos);
    let q1_hi = q1_lo + 1;
    if (q1_hi >= n) { q1_hi = n - 1; }
    let q1 = sorted[q1_lo] + (q1_pos - q1_lo) * (sorted[q1_hi] - sorted[q1_lo]);
    let q3_pos = 0.75 * (n - 1);
    let q3_lo = math_floor(q3_pos);
    let q3_hi = q3_lo + 1;
    if (q3_hi >= n) { q3_hi = n - 1; }
    let q3 = sorted[q3_lo] + (q3_pos - q3_lo) * (sorted[q3_hi] - sorted[q3_lo]);
    let iqr = q3 - q1;
    let lower = q1 - multiplier * iqr;
    let upper = q3 + multiplier * iqr;
    let result = [];
    i = 0;
    while (i < n) {
        if (data[i] < lower or data[i] > upper) {
            push(result, 1);
        } else {
            push(result, 0);
        }
        i = i + 1;
    }
    return result;
}

fn hml_percentile_outliers(data, lower, upper) {
    let n = len(data);
    if (n == 0) { return []; }
    let sorted = [];
    let i = 0;
    while (i < n) {
        push(sorted, data[i]);
        i = i + 1;
    }
    let si = 0;
    while (si < n) {
        let min_idx = si;
        let sj = si + 1;
        while (sj < n) {
            if (sorted[sj] < sorted[min_idx]) { min_idx = sj; }
            sj = sj + 1;
        }
        let tmp = sorted[si];
        sorted[si] = sorted[min_idx];
        sorted[min_idx] = tmp;
        si = si + 1;
    }
    let lo_pos = lower * (n - 1);
    let lo_idx = math_floor(lo_pos);
    if (lo_idx >= n) { lo_idx = n - 1; }
    let lo_val = sorted[lo_idx];
    let hi_pos = upper * (n - 1);
    let hi_idx = math_floor(hi_pos);
    if (hi_idx >= n) { hi_idx = n - 1; }
    let hi_val = sorted[hi_idx];
    let result = [];
    i = 0;
    while (i < n) {
        if (data[i] < lo_val or data[i] > hi_val) {
            push(result, 1);
        } else {
            push(result, 0);
        }
        i = i + 1;
    }
    return result;
}

fn hml_isolation_forest_scores(X, n_trees, sample_size) {
    let n = len(X);
    if (n == 0) { return []; }
    let n_features = len(X[0]);
    let scores = hml_vector_zeros(n);
    let max_depth = math_ceil(math_log(sample_size * 1.0) / math_log(2.0));
    let t = 0;
    while (t < n_trees) {
        let sample_indices = [];
        let idx = 0;
        while (idx < sample_size and idx < n) {
            let ri = hml_randint(0, n - 1);
            let dup = false;
            let si = 0;
            while (si < len(sample_indices)) {
                if (sample_indices[si] == ri) { dup = true; break; }
                si = si + 1;
            }
            if (dup == false) {
                push(sample_indices, ri);
            }
            idx = idx + 1;
        }
        let depths = [];
        let i = 0;
        while (i < n) {
            push(depths, 0.0);
            i = i + 1;
        }
        let sample = [];
        i = 0;
        while (i < len(sample_indices)) {
            push(sample, sample_indices[i]);
            i = i + 1;
        }
        let stack = [];
        push(stack, {indices: sample, depth: 0});
        while (len(stack) > 0) {
            let node = pop(stack);
            let node_indices = node[indices];
            let node_depth = node[depth];
            if (len(node_indices) <= 1 or node_depth >= max_depth) {
                let di = 0;
                while (di < len(node_indices)) {
                    let orig_idx = node_indices[di];
                    depths[orig_idx] = node_depth * 1.0;
                    di = di + 1;
                }
                continue;
            }
            let split_feature = hml_randint(0, n_features - 1);
            let min_val = X[node_indices[0]][split_feature];
            let max_val = X[node_indices[0]][split_feature];
            let mi = 1;
            while (mi < len(node_indices)) {
                let v = X[node_indices[mi]][split_feature];
                if (v < min_val) { min_val = v; }
                if (v > max_val) { max_val = v; }
                mi = mi + 1;
            }
            if (max_val == min_val) {
                let di = 0;
                while (di < len(node_indices)) {
                    let orig_idx = node_indices[di];
                    depths[orig_idx] = node_depth * 1.0;
                    di = di + 1;
                }
                continue;
            }
            let split_val = min_val + hml_random() * (max_val - min_val);
            let left = [];
            let right = [];
            mi = 0;
            while (mi < len(node_indices)) {
                let orig_idx = node_indices[mi];
                if (X[orig_idx][split_feature] <= split_val) {
                    push(left, orig_idx);
                } else {
                    push(right, orig_idx);
                }
                mi = mi + 1;
            }
            push(stack, {indices: left, depth: node_depth + 1});
            push(stack, {indices: right, depth: node_depth + 1});
        }
        i = 0;
        while (i < n) {
            scores[i] = scores[i] + depths[i];
            i = i + 1;
        }
        t = t + 1;
    }
    let c = 0.0;
    if (sample_size > 2) {
        c = 2.0 * (math_log(sample_size - 1.0) + 0.5772156649) - 2.0 * (sample_size - 1.0) / sample_size;
    }
    let result = [];
    let i = 0;
    while (i < n) {
        let avg_depth = scores[i] * 1.0 / n_trees;
        let score = math_pow(2.0, -avg_depth / c);
        push(result, score);
        i = i + 1;
    }
    return result;
}

fn hml_isolation_forest_predict(X, n_trees, sample_size, contamination) {
    let scores = hml_isolation_forest_scores(X, n_trees, sample_size);
    let n = len(scores);
    let sorted = [];
    let i = 0;
    while (i < n) {
        push(sorted, scores[i]);
        i = i + 1;
    }
    let si = 0;
    while (si < n) {
        let min_idx = si;
        let sj = si + 1;
        while (sj < n) {
            if (sorted[sj] < sorted[min_idx]) { min_idx = sj; }
            sj = sj + 1;
        }
        let tmp = sorted[si];
        sorted[si] = sorted[min_idx];
        sorted[min_idx] = tmp;
        si = si + 1;
    }
    let threshold_idx = math_floor(contamination * n);
    if (threshold_idx >= n) { threshold_idx = n - 1; }
    let threshold = sorted[threshold_idx];
    let result = [];
    i = 0;
    while (i < n) {
        if (scores[i] >= threshold) {
            push(result, -1);
        } else {
            push(result, 1);
        }
        i = i + 1;
    }
    return result;
}

fn hml_lof_scores(X, k) {
    let n = len(X);
    if (n == 0) { return []; }
    if (k > n - 1) { k = n - 1; }
    if (k < 1) { k = 1; }
    let k_distances = [];
    let k_neighbors = [];
    let i = 0;
    while (i < n) {
        let dists = [];
        let j = 0;
        while (j < n) {
            if (i != j) {
                let d = 0.0;
                let f = 0;
                while (f < len(X[i])) {
                    let diff = X[i][f] - X[j][f];
                    d = d + diff * diff;
                    f = f + 1;
                }
                push(dists, {dist: math_sqrt(d), idx: j});
            }
            j = j + 1;
        }
        let si = 0;
        while (si < k and si < len(dists)) {
            let min_idx = si;
            let sj = si + 1;
            while (sj < len(dists)) {
                if (dists[sj][dist] < dists[min_idx][dist]) {
                    min_idx = sj;
                }
                sj = sj + 1;
            }
            let tmp = dists[si];
            dists[si] = dists[min_idx];
            dists[min_idx] = tmp;
            si = si + 1;
        }
        let neighbors = [];
        let di = 0;
        while (di < k and di < len(dists)) {
            push(neighbors, dists[di][idx]);
            di = di + 1;
        }
        push(k_neighbors, neighbors);
        if (k <= len(dists)) {
            push(k_distances, dists[k - 1][dist]);
        } else {
            push(k_distances, dists[len(dists) - 1][dist]);
        }
        i = i + 1;
    }
    let lrd = [];
    i = 0;
    while (i < n) {
        let reach_sum = 0.0;
        let j = 0;
        while (j < len(k_neighbors[i])) {
            let neighbor = k_neighbors[i][j];
            let d = 0.0;
            let f = 0;
            while (f < len(X[i])) {
                let diff = X[i][f] - X[neighbor][f];
                d = d + diff * diff;
                f = f + 1;
            }
            d = math_sqrt(d);
            let reach_dist = d;
            if (k_distances[neighbor] > reach_dist) {
                reach_dist = k_distances[neighbor];
            }
            reach_sum = reach_sum + reach_dist;
            j = j + 1;
        }
        if (len(k_neighbors[i]) == 0) {
            push(lrd, 0.0);
        } else {
            push(lrd, len(k_neighbors[i]) * 1.0 / reach_sum);
        }
        i = i + 1;
    }
    let lof = [];
    i = 0;
    while (i < n) {
        let lrd_sum = 0.0;
        let j = 0;
        while (j < len(k_neighbors[i])) {
            lrd_sum = lrd_sum + lrd[k_neighbors[i][j]];
            j = j + 1;
        }
        if (len(k_neighbors[i]) == 0 or lrd[i] == 0.0) {
            push(lof, 1.0);
        } else {
            push(lof, (lrd_sum / lrd[i]) / len(k_neighbors[i]));
        }
        i = i + 1;
    }
    return lof;
}

fn hml_lof_predict(X, k, contamination) {
    let scores = hml_lof_scores(X, k);
    let n = len(scores);
    let sorted = [];
    let i = 0;
    while (i < n) {
        push(sorted, scores[i]);
        i = i + 1;
    }
    let si = 0;
    while (si < n) {
        let min_idx = si;
        let sj = si + 1;
        while (sj < n) {
            if (sorted[sj] < sorted[min_idx]) { min_idx = sj; }
            sj = sj + 1;
        }
        let tmp = sorted[si];
        sorted[si] = sorted[min_idx];
        sorted[min_idx] = tmp;
        si = si + 1;
    }
    let threshold_idx = math_floor((1.0 - contamination) * n);
    if (threshold_idx >= n) { threshold_idx = n - 1; }
    if (threshold_idx < 0) { threshold_idx = 0; }
    let threshold = sorted[threshold_idx];
    let result = [];
    i = 0;
    while (i < n) {
        if (scores[i] > threshold) {
            push(result, -1);
        } else {
            push(result, 1);
        }
        i = i + 1;
    }
    return result;
}

fn hml_dbscan_outliers(X, eps, min_samples) {
    let n = len(X);
    let labels = [];
    let i = 0;
    while (i < n) {
        push(labels, -1);
        i = i + 1;
    }
    let cluster_id = 0;
    i = 0;
    while (i < n) {
        if (labels[i] != -1) {
            i = i + 1;
            continue;
        }
        let neighbors = [];
        let j = 0;
        while (j < n) {
            let d = 0.0;
            let f = 0;
            while (f < len(X[i])) {
                let diff = X[i][f] - X[j][f];
                d = d + diff * diff;
                f = f + 1;
            }
            if (math_sqrt(d) <= eps) {
                push(neighbors, j);
            }
            j = j + 1;
        }
        if (len(neighbors) < min_samples) {
            labels[i] = -1;
        } else {
            cluster_id = cluster_id + 1;
            labels[i] = cluster_id;
            let seed = [];
            let si = 0;
            while (si < len(neighbors)) {
                push(seed, neighbors[si]);
                si = si + 1;
            }
            let s_idx = 0;
            while (s_idx < len(seed)) {
                let p = seed[s_idx];
                if (labels[p] == -1) {
                    labels[p] = cluster_id;
                    let p_neighbors = [];
                    let j = 0;
                    while (j < n) {
                        let d = 0.0;
                        let f = 0;
                        while (f < len(X[p])) {
                            let diff = X[p][f] - X[j][f];
                            d = d + diff * diff;
                            f = f + 1;
                        }
                        if (math_sqrt(d) <= eps) {
                            push(p_neighbors, j);
                        }
                        j = j + 1;
                    }
                    if (len(p_neighbors) >= min_samples) {
                        let ni = 0;
                        while (ni < len(p_neighbors)) {
                            let already = false;
                            let ai = 0;
                            while (ai < len(seed)) {
                                if (seed[ai] == p_neighbors[ni]) { already = true; break; }
                                ai = ai + 1;
                            }
                            if (already == false) {
                                push(seed, p_neighbors[ni]);
                            }
                            ni = ni + 1;
                        }
                    }
                }
                s_idx = s_idx + 1;
            }
        }
        i = i + 1;
    }
    let result = [];
    i = 0;
    while (i < n) {
        if (labels[i] == -1) {
            push(result, -1);
        } else {
            push(result, 1);
        }
        i = i + 1;
    }
    return result;
}

fn hml_elliptic_envelope(X, contamination) {
    let n = len(X);
    let n_features = len(X[0]);
    let means = hml_column_means(X);
    let centered = [];
    let i = 0;
    while (i < n) {
        let row = [];
        let j = 0;
        while (j < n_features) {
            push(row, X[i][j] - means[j]);
            j = j + 1;
        }
        push(centered, row);
        i = i + 1;
    }
    let cov = hml_matrix_zeros(n_features, n_features);
    i = 0;
    while (i < n_features) {
        let j = 0;
        while (j < n_features) {
            let s = 0.0;
            let k = 0;
            while (k < n) {
                s = s + centered[k][i] * centered[k][j];
                k = k + 1;
            }
            cov[i][j] = s * 1.0 / (n - 1);
            j = j + 1;
        }
        i = i + 1;
    }
    let inv_cov = [];
    if (n_features == 1) {
        if (cov[0][0] == 0.0) {
            inv_cov = [[1.0]];
        } else {
            inv_cov = [[1.0 / cov[0][0]]];
        }
    } else {
        inv_cov = cov;
    }
    let distances = [];
    i = 0;
    while (i < n) {
        let d = 0.0;
        if (n_features == 1) {
            d = centered[i][0] * inv_cov[0][0] * centered[i][0];
        } else {
            let j = 0;
            while (j < n_features) {
                let k = 0;
                while (k < n_features) {
                    d = d + centered[i][j] * inv_cov[j][k] * centered[i][k];
                    k = k + 1;
                }
                j = j + 1;
            }
        }
        push(distances, d);
        i = i + 1;
    }
    let sorted = [];
    i = 0;
    while (i < n) {
        push(sorted, distances[i]);
        i = i + 1;
    }
    let si = 0;
    while (si < n) {
        let min_idx = si;
        let sj = si + 1;
        while (sj < n) {
            if (sorted[sj] < sorted[min_idx]) { min_idx = sj; }
            sj = sj + 1;
        }
        let tmp = sorted[si];
        sorted[si] = sorted[min_idx];
        sorted[min_idx] = tmp;
        si = si + 1;
    }
    let threshold_idx = math_floor((1.0 - contamination) * n);
    if (threshold_idx >= n) { threshold_idx = n - 1; }
    if (threshold_idx < 0) { threshold_idx = 0; }
    let threshold = sorted[threshold_idx];
    let result = [];
    i = 0;
    while (i < n) {
        if (distances[i] > threshold) {
            push(result, -1);
        } else {
            push(result, 1);
        }
        i = i + 1;
    }
    return result;
}

fn hml_one_class_svm(X, nu, gamma) {
    let n = len(X);
    let n_features = len(X[0]);
    let alpha = hml_vector_zeros(n);
    let i = 0;
    let total = 0.0;
    while (i < n) {
        alpha[i] = 1.0 / (n * nu);
        total = total + alpha[i];
        i = i + 1;
    }
    let iter = 0;
    while (iter < 100) {
        i = 0;
        while (i < n) {
            let grad = 0.0;
            let j = 0;
            while (j < n) {
                let d = 0.0;
                let f = 0;
                while (f < n_features) {
                    let diff = X[i][f] - X[j][f];
                    d = d + diff * diff;
                    f = f + 1;
                }
                grad = grad + alpha[j] * math_exp(-gamma * d);
                j = j + 1;
            }
            grad = -grad;
            let lr = 0.001;
            alpha[i] = alpha[i] - lr * grad;
            if (alpha[i] < 0.0) { alpha[i] = 0.0; }
            if (alpha[i] > 1.0 / (n * nu)) { alpha[i] = 1.0 / (n * nu); }
            i = i + 1;
        }
        iter = iter + 1;
    }
    let scores = [];
    i = 0;
    while (i < n) {
        let s = 0.0;
        let j = 0;
        while (j < n) {
            let d = 0.0;
            let f = 0;
            while (f < n_features) {
                let diff = X[i][f] - X[j][f];
                d = d + diff * diff;
                f = f + 1;
            }
            s = s + alpha[j] * math_exp(-gamma * d);
            j = j + 1;
        }
        push(scores, s);
        i = i + 1;
    }
    let sorted = [];
    i = 0;
    while (i < n) {
        push(sorted, scores[i]);
        i = i + 1;
    }
    let si = 0;
    while (si < n) {
        let min_idx = si;
        let sj = si + 1;
        while (sj < n) {
            if (sorted[sj] < sorted[min_idx]) { min_idx = sj; }
            sj = sj + 1;
        }
        let tmp = sorted[si];
        sorted[si] = sorted[min_idx];
        sorted[min_idx] = tmp;
        si = si + 1;
    }
    let threshold_idx = math_floor(nu * n);
    if (threshold_idx >= n) { threshold_idx = n - 1; }
    if (threshold_idx < 0) { threshold_idx = 0; }
    let threshold = sorted[threshold_idx];
    let result = [];
    i = 0;
    while (i < n) {
        if (scores[i] < threshold) {
            push(result, -1);
        } else {
            push(result, 1);
        }
        i = i + 1;
    }
    return result;
}

fn hml_robust_covariance(X) {
    let n = len(X);
    let n_features = len(X[0]);
    let means = hml_column_means(X);
    let subset_size = math_floor(n * 0.75);
    if (subset_size < n_features) { subset_size = n_features; }
    let best_det = 0.0;
    let best_means = [];
    let best_cov = [];
    let trial = 0;
    while (trial < 10) {
        let indices = [];
        let idx = 0;
        while (idx < subset_size) {
            let ri = hml_randint(0, n - 1);
            let dup = false;
            let si = 0;
            while (si < len(indices)) {
                if (indices[si] == ri) { dup = true; break; }
                si = si + 1;
            }
            if (dup == false) {
                push(indices, ri);
            }
            idx = idx + 1;
        }
        let sub_means = [];
        let j = 0;
        while (j < n_features) {
            let s = 0.0;
            let i = 0;
            while (i < len(indices)) {
                s = s + X[indices[i]][j];
                i = i + 1;
            }
            push(sub_means, s * 1.0 / len(indices));
            j = j + 1;
        }
        let sub_cov = hml_matrix_zeros(n_features, n_features);
        let r = 0;
        while (r < n_features) {
            let c = 0;
            while (c < n_features) {
                let s = 0.0;
                let i = 0;
                while (i < len(indices)) {
                    s = s + (X[indices[i]][r] - sub_means[r]) * (X[indices[i]][c] - sub_means[c]);
                    i = i + 1;
                }
                sub_cov[r][c] = s * 1.0 / (len(indices) - 1);
                c = c + 1;
            }
            r = r + 1;
        }
        let det = 1.0;
        if (n_features == 1) {
            det = sub_cov[0][0];
        }
        if (trial == 0 or det < best_det) {
            best_det = det;
            best_means = sub_means;
            best_cov = sub_cov;
        }
        trial = trial + 1;
    }
    return {means: best_means, covariance: best_cov};
}

fn hml_mahalanobis_outliers(X) {
    let n = len(X);
    let n_features = len(X[0]);
    let means = hml_column_means(X);
    let cov = hml_matrix_zeros(n_features, n_features);
    let i = 0;
    while (i < n_features) {
        let j = 0;
        while (j < n_features) {
            let s = 0.0;
            let k = 0;
            while (k < n) {
                s = s + (X[k][i] - means[i]) * (X[k][j] - means[j]);
                k = k + 1;
            }
            cov[i][j] = s * 1.0 / (n - 1);
            j = j + 1;
        }
        i = i + 1;
    }
    let distances = [];
    i = 0;
    while (i < n) {
        let d = 0.0;
        let j = 0;
        while (j < n_features) {
            let k = 0;
            while (k < n_features) {
                d = d + (X[i][j] - means[j]) * cov[j][k] * (X[i][k] - means[k]);
                k = k + 1;
            }
            j = j + 1;
        }
        push(distances, math_sqrt(d));
        i = i + 1;
    }
    return distances;
}

fn hml_pca_outliers(X, n_components, threshold) {
    let n = len(X);
    let n_features = len(X[0]);
    let means = hml_column_means(X);
    let centered = [];
    let i = 0;
    while (i < n) {
        let row = [];
        let j = 0;
        while (j < n_features) {
            push(row, X[i][j] - means[j]);
            j = j + 1;
        }
        push(centered, row);
        i = i + 1;
    }
    let cov = hml_matrix_zeros(n_features, n_features);
    i = 0;
    while (i < n_features) {
        let j = 0;
        while (j < n_features) {
            let s = 0.0;
            let k = 0;
            while (k < n) {
                s = s + centered[k][i] * centered[k][j];
                k = k + 1;
            }
            cov[i][j] = s * 1.0 / (n - 1);
            j = j + 1;
        }
        i = i + 1;
    }
    let eigenvectors = [];
    let nc = n_components;
    if (nc > n_features) { nc = n_features; }
    let c = 0;
    while (c < nc) {
        let vec = hml_vector_zeros(n_features);
        vec[c] = 1.0;
        let power_iter = 0;
        while (power_iter < 20) {
            let new_vec = hml_vector_zeros(n_features);
            let r = 0;
            while (r < n_features) {
                let s = 0.0;
                let col = 0;
                while (col < n_features) {
                    s = s + cov[r][col] * vec[col];
                    col = col + 1;
                }
                new_vec[r] = s;
                r = r + 1;
            }
            let norm = hml_vector_norm(new_vec);
            if (norm == 0.0) { norm = 1.0; }
            r = 0;
            while (r < n_features) {
                new_vec[r] = new_vec[r] / norm;
                r = r + 1;
            }
            vec = new_vec;
            power_iter = power_iter + 1;
        }
        push(eigenvectors, vec);
        let r = 0;
        while (r < n_features) {
            let col = 0;
            while (col < n_features) {
                cov[r][col] = cov[r][col] - vec[r] * vec[col];
                col = col + 1;
            }
            r = r + 1;
        }
        c = c + 1;
    }
    let errors = [];
    i = 0;
    while (i < n) {
        let projected = hml_vector_zeros(nc);
        let c = 0;
        while (c < nc) {
            let s = 0.0;
            let j = 0;
            while (j < n_features) {
                s = s + centered[i][j] * eigenvectors[c][j];
                j = j + 1;
            }
            projected[c] = s;
            c = c + 1;
        }
        let reconstructed = hml_vector_zeros(n_features);
        let j = 0;
        while (j < n_features) {
            let s = 0.0;
            c = 0;
            while (c < nc) {
                s = s + projected[c] * eigenvectors[c][j];
                c = c + 1;
            }
            reconstructed[j] = s + means[j];
            j = j + 1;
        }
        let error = 0.0;
        j = 0;
        while (j < n_features) {
            let diff = X[i][j] - reconstructed[j];
            error = error + diff * diff;
            j = j + 1;
        }
        push(errors, math_sqrt(error));
        i = i + 1;
    }
    let result = [];
    i = 0;
    while (i < n) {
        if (errors[i] > threshold) {
            push(result, -1);
        } else {
            push(result, 1);
        }
        i = i + 1;
    }
    return result;
}

fn hml_knn_outlier_scores(X, k) {
    let n = len(X);
    let scores = [];
    let i = 0;
    while (i < n) {
        let dists = [];
        let j = 0;
        while (j < n) {
            if (i != j) {
                let d = 0.0;
                let f = 0;
                while (f < len(X[i])) {
                    let diff = X[i][f] - X[j][f];
                    d = d + diff * diff;
                    f = f + 1;
                }
                push(dists, math_sqrt(d));
            }
            j = j + 1;
        }
        let si = 0;
        while (si < k and si < len(dists)) {
            let min_idx = si;
            let sj = si + 1;
            while (sj < len(dists)) {
                if (dists[sj] < dists[min_idx]) { min_idx = sj; }
                sj = sj + 1;
            }
            let tmp = dists[si];
            dists[si] = dists[min_idx];
            dists[min_idx] = tmp;
            si = si + 1;
        }
        let avg_dist = 0.0;
        let di = 0;
        while (di < k and di < len(dists)) {
            avg_dist = avg_dist + dists[di];
            di = di + 1;
        }
        push(scores, avg_dist / k);
        i = i + 1;
    }
    return scores;
}

fn hml_distance_outliers(X, threshold) {
    let n = len(X);
    let n_features = len(X[0]);
    let centroid = hml_column_means(X);
    let distances = [];
    let i = 0;
    while (i < n) {
        let d = 0.0;
        let j = 0;
        while (j < n_features) {
            let diff = X[i][j] - centroid[j];
            d = d + diff * diff;
            j = j + 1;
        }
        push(distances, math_sqrt(d));
        i = i + 1;
    }
    let m = hml_mean(distances);
    let s = hml_std(distances);
    if (s == 0.0) { s = 1.0; }
    let result = [];
    i = 0;
    while (i < n) {
        let z = (distances[i] - m) / s;
        if (z > threshold) {
            push(result, -1);
        } else {
            push(result, 1);
        }
        i = i + 1;
    }
    return result;
}

fn hml_angle_outliers(X, k) {
    let n = len(X);
    let scores = [];
    let i = 0;
    while (i < n) {
        let angles = [];
        let pairs = 0;
        let j = 0;
        while (j < n and pairs < k * 2) {
            if (i != j) {
                let dot = 0.0;
                let norm_i = 0.0;
                let norm_j = 0.0;
                let f = 0;
                while (f < len(X[i])) {
                    dot = dot + X[i][f] * X[j][f];
                    norm_i = norm_i + X[i][f] * X[i][f];
                    norm_j = norm_j + X[j][f] * X[j][f];
                    f = f + 1;
                }
                norm_i = math_sqrt(norm_i);
                norm_j = math_sqrt(norm_j);
                if (norm_i > 0.0 and norm_j > 0.0) {
                    let cos_angle = dot / (norm_i * norm_j);
                    if (cos_angle > 1.0) { cos_angle = 1.0; }
                    if (cos_angle < -1.0) { cos_angle = -1.0; }
                    push(angles, cos_angle);
                    pairs = pairs + 1;
                }
            }
            j = j + 1;
        }
        let angle_sum = 0.0;
        let ai = 0;
        while (ai < len(angles)) {
            angle_sum = angle_sum + angles[ai];
            ai = ai + 1;
        }
        if (len(angles) == 0) {
            push(scores, 0.0);
        } else {
            push(scores, angle_sum * 1.0 / len(angles));
        }
        i = i + 1;
    }
    return scores;
}

fn hml_histogram_outliers(X, bins) {
    let n = len(X);
    let n_features = len(X[0]);
    let result = [];
    let i = 0;
    while (i < n) {
        push(result, 1);
        i = i + 1;
    }
    let j = 0;
    while (j < n_features) {
        let col = [];
        i = 0;
        while (i < n) {
            push(col, X[i][j]);
            i = i + 1;
        }
        let mn = col[0];
        let mx = col[0];
        i = 1;
        while (i < n) {
            if (col[i] < mn) { mn = col[i]; }
            if (col[i] > mx) { mx = col[i]; }
            i = i + 1;
        }
        let rng = mx - mn;
        if (rng == 0.0) { rng = 1.0; }
        let hist = hml_vector_zeros(bins);
        i = 0;
        while (i < n) {
            let bin_idx = math_floor((col[i] - mn) / rng * bins);
            if (bin_idx >= bins) { bin_idx = bins - 1; }
            if (bin_idx < 0) { bin_idx = 0; }
            hist[bin_idx] = hist[bin_idx] + 1.0;
            i = i + 1;
        }
        let threshold = n * 0.01;
        i = 0;
        while (i < n) {
            let bin_idx = math_floor((col[i] - mn) / rng * bins);
            if (bin_idx >= bins) { bin_idx = bins - 1; }
            if (bin_idx < 0) { bin_idx = 0; }
            if (hist[bin_idx] <= threshold) {
                result[i] = -1;
            }
            i = i + 1;
        }
        j = j + 1;
    }
    return result;
}

fn hml_cluster_outliers(X, n_clusters, threshold) {
    let n = len(X);
    let km = new KMeans();
    km.init_kmeans(n_clusters, 100);
    km.fit(X);
    let labels = km.predict(X);
    let centroids = km.get_centroids();
    let cluster_sizes = [];
    let i = 0;
    while (i < n_clusters) {
        let cnt = 0;
        let j = 0;
        while (j < n) {
            if (labels[j] == i) { cnt = cnt + 1; }
            j = j + 1;
        }
        push(cluster_sizes, cnt);
        i = i + 1;
    }
    let distances = [];
    i = 0;
    while (i < n) {
        let c = labels[i];
        let d = 0.0;
        let j = 0;
        while (j < len(X[i])) {
            let diff = X[i][j] - centroids[c][j];
            d = d + diff * diff;
            j = j + 1;
        }
        push(distances, math_sqrt(d));
        i = i + 1;
    }
    let m = hml_mean(distances);
    let s = hml_std(distances);
    if (s == 0.0) { s = 1.0; }
    let result = [];
    i = 0;
    while (i < n) {
        let z = (distances[i] - m) / s;
        if (z > threshold or cluster_sizes[labels[i]] < n * 0.05) {
            push(result, -1);
        } else {
            push(result, 1);
        }
        i = i + 1;
    }
    return result;
}

fn hml_ensemble_outlier_scores(X, methods) {
    let n = len(X);
    let all_scores = [];
    let i = 0;
    while (i < len(methods)) {
        let method = methods[i];
        let scores = method(X);
        push(all_scores, scores);
        i = i + 1;
    }
    let result = [];
    i = 0;
    while (i < n) {
        let s = 0.0;
        let j = 0;
        while (j < len(all_scores)) {
            let score = all_scores[j][i];
            if (score == 1) {
                s = s + 1.0;
            } else {
                s = s - 1.0;
            }
            j = j + 1;
        }
        push(result, s * 1.0 / len(all_scores));
        i = i + 1;
    }
    return result;
}


# ═══════════════════════════════════════════════════════════════════════════
# SECTION 23: Missing Value Imputation
# ═══════════════════════════════════════════════════════════════════════════

fn hml_nan_mask(X) {
    let n = len(X);
    let result = [];
    let i = 0;
    while (i < n) {
        let row = [];
        let j = 0;
        while (j < len(X[i])) {
            if (X[i][j] == nullptr) {
                push(row, true);
            } else {
                push(row, false);
            }
            j = j + 1;
        }
        push(result, row);
        i = i + 1;
    }
    return result;
}

fn hml_nan_count(X) {
    let n = len(X);
    if (n == 0) { return []; }
    let n_cols = len(X[0]);
    let result = [];
    let j = 0;
    while (j < n_cols) {
        let cnt = 0;
        let i = 0;
        while (i < n) {
            if (X[i][j] == nullptr) { cnt = cnt + 1; }
            i = i + 1;
        }
        push(result, cnt);
        j = j + 1;
    }
    return result;
}

fn hml_nan_ratio(X) {
    let n = len(X);
    if (n == 0) { return []; }
    let counts = hml_nan_count(X);
    let result = [];
    let j = 0;
    while (j < len(counts)) {
        push(result, counts[j] * 1.0 / n);
        j = j + 1;
    }
    return result;
}

fn hml_drop_nan_rows(X, y, threshold) {
    let n = len(X);
    let n_cols = len(X[0]);
    let keep_rows = [];
    let i = 0;
    while (i < n) {
        let nan_count = 0;
        let j = 0;
        while (j < n_cols) {
            if (X[i][j] == nullptr) { nan_count = nan_count + 1; }
            j = j + 1;
        }
        let ratio = nan_count * 1.0 / n_cols;
        if (ratio <= threshold) {
            push(keep_rows, i);
        }
        i = i + 1;
    }
    let X_result = [];
    let y_result = [];
    i = 0;
    while (i < len(keep_rows)) {
        let idx = keep_rows[i];
        push(X_result, X[idx]);
        if (y != nullptr) {
            push(y_result, y[idx]);
        }
        i = i + 1;
    }
    if (y != nullptr) {
        return {X: X_result, y: y_result};
    }
    return {X: X_result, y: []};
}

fn hml_drop_nan_columns(X, threshold) {
    let n = len(X);
    let n_cols = len(X[0]);
    let keep_cols = [];
    let j = 0;
    while (j < n_cols) {
        let nan_count = 0;
        let i = 0;
        while (i < n) {
            if (X[i][j] == nullptr) { nan_count = nan_count + 1; }
            i = i + 1;
        }
        let ratio = nan_count * 1.0 / n;
        if (ratio <= threshold) {
            push(keep_cols, j);
        }
        j = j + 1;
    }
    let result = [];
    let i = 0;
    while (i < n) {
        let row = [];
        let k = 0;
        while (k < len(keep_cols)) {
            push(row, X[i][keep_cols[k]]);
            k = k + 1;
        }
        push(result, row);
        i = i + 1;
    }
    return result;
}

fn hml_mean_impute(X) {
    let n = len(X);
    if (n == 0) { return X; }
    let n_cols = len(X[0]);
    let col_means = [];
    let j = 0;
    while (j < n_cols) {
        let s = 0.0;
        let cnt = 0;
        let i = 0;
        while (i < n) {
            if (X[i][j] != nullptr) {
                s = s + X[i][j];
                cnt = cnt + 1;
            }
            i = i + 1;
        }
        if (cnt == 0) {
            push(col_means, 0.0);
        } else {
            push(col_means, s * 1.0 / cnt);
        }
        j = j + 1;
    }
    let result = [];
    let i = 0;
    while (i < n) {
        let row = [];
        let j = 0;
        while (j < n_cols) {
            if (X[i][j] == nullptr) {
                push(row, col_means[j]);
            } else {
                push(row, X[i][j]);
            }
            j = j + 1;
        }
        push(result, row);
        i = i + 1;
    }
    return result;
}

fn hml_median_impute(X) {
    let n = len(X);
    if (n == 0) { return X; }
    let n_cols = len(X[0]);
    let col_medians = [];
    let j = 0;
    while (j < n_cols) {
        let vals = [];
        let i = 0;
        while (i < n) {
            if (X[i][j] != nullptr) {
                push(vals, X[i][j]);
            }
            i = i + 1;
        }
        if (len(vals) == 0) {
            push(col_medians, 0.0);
        } else {
            let si = 0;
            while (si < len(vals)) {
                let min_idx = si;
                let sj = si + 1;
                while (sj < len(vals)) {
                    if (vals[sj] < vals[min_idx]) { min_idx = sj; }
                    sj = sj + 1;
                }
                let tmp = vals[si];
                vals[si] = vals[min_idx];
                vals[min_idx] = tmp;
                si = si + 1;
            }
            let mid = math_floor(len(vals) * 1.0 / 2.0);
            if (len(vals) % 2 == 0) {
                push(col_medians, (vals[mid - 1] + vals[mid]) * 0.5);
            } else {
                push(col_medians, vals[mid]);
            }
        }
        j = j + 1;
    }
    let result = [];
    let i = 0;
    while (i < n) {
        let row = [];
        let j = 0;
        while (j < n_cols) {
            if (X[i][j] == nullptr) {
                push(row, col_medians[j]);
            } else {
                push(row, X[i][j]);
            }
            j = j + 1;
        }
        push(result, row);
        i = i + 1;
    }
    return result;
}

fn hml_mode_impute(X) {
    let n = len(X);
    if (n == 0) { return X; }
    let n_cols = len(X[0]);
    let col_modes = [];
    let j = 0;
    while (j < n_cols) {
        let counts = {};
        let i = 0;
        while (i < n) {
            if (X[i][j] != nullptr) {
                let key = X[i][j];
                let cnt = counts[key];
                if (cnt == nullptr) {
                    counts[key] = 1;
                } else {
                    counts[key] = cnt + 1;
                }
            }
            i = i + 1;
        }
        let keys = dict_keys(counts);
        let best_val = 0.0;
        let best_cnt = 0;
        let k = 0;
        while (k < len(keys)) {
            let cnt = counts[keys[k]];
            if (cnt > best_cnt) {
                best_cnt = cnt;
                best_val = keys[k];
            }
            k = k + 1;
        }
        push(col_modes, best_val);
        j = j + 1;
    }
    let result = [];
    let i = 0;
    while (i < n) {
        let row = [];
        let j = 0;
        while (j < n_cols) {
            if (X[i][j] == nullptr) {
                push(row, col_modes[j]);
            } else {
                push(row, X[i][j]);
            }
            j = j + 1;
        }
        push(result, row);
        i = i + 1;
    }
    return result;
}

fn hml_constant_impute(X, value) {
    let n = len(X);
    let result = [];
    let i = 0;
    while (i < n) {
        let row = [];
        let j = 0;
        while (j < len(X[i])) {
            if (X[i][j] == nullptr) {
                push(row, value);
            } else {
                push(row, X[i][j]);
            }
            j = j + 1;
        }
        push(result, row);
        i = i + 1;
    }
    return result;
}

fn hml_forward_fill_impute(X) {
    let n = len(X);
    if (n == 0) { return X; }
    let n_cols = len(X[0]);
    let result = [];
    let i = 0;
    while (i < n) {
        let row = [];
        let j = 0;
        while (j < n_cols) {
            push(row, X[i][j]);
            j = j + 1;
        }
        push(result, row);
        i = i + 1;
    }
    let j = 0;
    while (j < n_cols) {
        let last_valid = 0.0;
        let has_valid = false;
        let i = 0;
        while (i < n) {
            if (result[i][j] == nullptr) {
                if (has_valid) {
                    result[i][j] = last_valid;
                }
            } else {
                last_valid = result[i][j];
                has_valid = true;
            }
            i = i + 1;
        }
        j = j + 1;
    }
    return result;
}

fn hml_backward_fill_impute(X) {
    let n = len(X);
    if (n == 0) { return X; }
    let n_cols = len(X[0]);
    let result = [];
    let i = 0;
    while (i < n) {
        let row = [];
        let j = 0;
        while (j < n_cols) {
            push(row, X[i][j]);
            j = j + 1;
        }
        push(result, row);
        i = i + 1;
    }
    let j = 0;
    while (j < n_cols) {
        let next_valid = 0.0;
        let has_valid = false;
        let i = n - 1;
        while (i >= 0) {
            if (result[i][j] == nullptr) {
                if (has_valid) {
                    result[i][j] = next_valid;
                }
            } else {
                next_valid = result[i][j];
                has_valid = true;
            }
            i = i - 1;
        }
        j = j + 1;
    }
    return result;
}

fn hml_linear_interpolate_impute(X) {
    let n = len(X);
    if (n == 0) { return X; }
    let n_cols = len(X[0]);
    let result = [];
    let i = 0;
    while (i < n) {
        let row = [];
        let j = 0;
        while (j < n_cols) {
            push(row, X[i][j]);
            j = j + 1;
        }
        push(result, row);
        i = i + 1;
    }
    let j = 0;
    while (j < n_cols) {
        let i = 0;
        while (i < n) {
            if (result[i][j] == nullptr) {
                let left_idx = -1;
                let k = i - 1;
                while (k >= 0) {
                    if (result[k][j] != nullptr) {
                        left_idx = k;
                        break;
                    }
                    k = k - 1;
                }
                let right_idx = -1;
                k = i + 1;
                while (k < n) {
                    if (result[k][j] != nullptr) {
                        right_idx = k;
                        break;
                    }
                    k = k + 1;
                }
                if (left_idx >= 0 and right_idx >= 0) {
                    let left_val = result[left_idx][j];
                    let right_val = result[right_idx][j];
                    let gap = right_idx - left_idx;
                    let ratio = (i - left_idx) * 1.0 / gap;
                    result[i][j] = left_val + (right_val - left_val) * ratio;
                } else if (left_idx >= 0) {
                    result[i][j] = result[left_idx][j];
                } else if (right_idx >= 0) {
                    result[i][j] = result[right_idx][j];
                }
            }
            i = i + 1;
        }
        j = j + 1;
    }
    return result;
}

fn hml_knn_impute(X, k) {
    let n = len(X);
    if (n == 0) { return X; }
    let n_cols = len(X[0]);
    let result = [];
    let i = 0;
    while (i < n) {
        let row = [];
        let j = 0;
        while (j < n_cols) {
            push(row, X[i][j]);
            j = j + 1;
        }
        push(result, row);
        i = i + 1;
    }
    let col_means = [];
    let j = 0;
    while (j < n_cols) {
        let s = 0.0;
        let cnt = 0;
        let i = 0;
        while (i < n) {
            if (X[i][j] != nullptr) {
                s = s + X[i][j];
                cnt = cnt + 1;
            }
            i = i + 1;
        }
        if (cnt == 0) {
            push(col_means, 0.0);
        } else {
            push(col_means, s * 1.0 / cnt);
        }
        j = j + 1;
    }
    let i = 0;
    while (i < n) {
        let j = 0;
        while (j < n_cols) {
            if (result[i][j] == nullptr) {
                let distances = [];
                let r = 0;
                while (r < n) {
                    if (r != i) {
                        let d = 0.0;
                        let valid = 0;
                        let c = 0;
                        while (c < n_cols) {
                            let v1 = result[i][c];
                            if (v1 == nullptr) { v1 = col_means[c]; }
                            let v2 = result[r][c];
                            if (v2 == nullptr) { v2 = col_means[c]; }
                            let diff = v1 - v2;
                            d = d + diff * diff;
                            valid = valid + 1;
                            c = c + 1;
                        }
                        push(distances, {dist: math_sqrt(d), idx: r});
                    }
                    r = r + 1;
                }
                let si = 0;
                while (si < k and si < len(distances)) {
                    let min_idx = si;
                    let sj = si + 1;
                    while (sj < len(distances)) {
                        if (distances[sj][dist] < distances[min_idx][dist]) {
                            min_idx = sj;
                        }
                        sj = sj + 1;
                    }
                    let tmp = distances[si];
                    distances[si] = distances[min_idx];
                    distances[min_idx] = tmp;
                    si = si + 1;
                }
                let s = 0.0;
                let cnt = 0;
                let di = 0;
                while (di < k and di < len(distances)) {
                    let neighbor = result[distances[di][idx]];
                    if (neighbor[j] != nullptr) {
                        s = s + neighbor[j];
                        cnt = cnt + 1;
                    }
                    di = di + 1;
                }
                if (cnt > 0) {
                    result[i][j] = s * 1.0 / cnt;
                } else {
                    result[i][j] = col_means[j];
                }
            }
            j = j + 1;
        }
        i = i + 1;
    }
    return result;
}

fn hml_iterative_impute(X, n_iter) {
    let n = len(X);
    if (n == 0) { return X; }
    let result = hml_mean_impute(X);
    let n_cols = len(X[0]);
    let iter = 0;
    while (iter < n_iter) {
        let j = 0;
        while (j < n_cols) {
            let has_nan = false;
            let i = 0;
            while (i < n) {
                if (X[i][j] == nullptr) { has_nan = true; break; }
                i = i + 1;
            }
            if (has_nan) {
                let X_feat = [];
                let y_feat = [];
                i = 0;
                while (i < n) {
                    if (X[i][j] != nullptr) {
                        let row = [];
                        let c = 0;
                        while (c < n_cols) {
                            if (c != j) {
                                push(row, result[i][c]);
                            }
                            c = c + 1;
                        }
                        push(X_feat, row);
                        push(y_feat, X[i][j]);
                    }
                    i = i + 1;
                }
                if (len(y_feat) > 0) {
                    let lr = new LinearRegression();
                    lr.init_linear(0.01, 100);
                    lr.fit(X_feat, y_feat);
                    i = 0;
                    while (i < n) {
                        if (X[i][j] == nullptr) {
                            let row = [];
                            let c = 0;
                            while (c < n_cols) {
                                if (c != j) {
                                    push(row, result[i][c]);
                                }
                                c = c + 1;
                            }
                            let pred = lr.predict([row]);
                            result[i][j] = pred[0];
                        }
                        i = i + 1;
                    }
                }
            }
            j = j + 1;
        }
        iter = iter + 1;
    }
    return result;
}

fn hml_regression_impute(X, target_col) {
    let n = len(X);
    if (n == 0) { return X; }
    let n_cols = len(X[0]);
    let result = [];
    let i = 0;
    while (i < n) {
        let row = [];
        let j = 0;
        while (j < n_cols) {
            push(row, X[i][j]);
            j = j + 1;
        }
        push(result, row);
        i = i + 1;
    }
    let X_feat = [];
    let y_feat = [];
    i = 0;
    while (i < n) {
        if (X[i][target_col] != nullptr) {
            let row = [];
            let c = 0;
            while (c < n_cols) {
                if (c != target_col and X[i][c] != nullptr) {
                    push(row, X[i][c]);
                }
                c = c + 1;
            }
            if (len(row) > 0) {
                push(X_feat, row);
                push(y_feat, X[i][target_col]);
            }
        }
        i = i + 1;
    }
    if (len(y_feat) > 0) {
        let lr = new LinearRegression();
        lr.init_linear(0.01, 200);
        lr.fit(X_feat, y_feat);
        i = 0;
        while (i < n) {
            if (result[i][target_col] == nullptr) {
                let row = [];
                let c = 0;
                while (c < n_cols) {
                    if (c != target_col and result[i][c] != nullptr) {
                        push(row, result[i][c]);
                    }
                    c = c + 1;
                }
                if (len(row) > 0) {
                    let pred = lr.predict([row]);
                    result[i][target_col] = pred[0];
                }
            }
            i = i + 1;
        }
    }
    return result;
}

fn hml_random_sample_impute(X) {
    let n = len(X);
    if (n == 0) { return X; }
    let n_cols = len(X[0]);
    let result = [];
    let i = 0;
    while (i < n) {
        let row = [];
        let j = 0;
        while (j < n_cols) {
            push(row, X[i][j]);
            j = j + 1;
        }
        push(result, row);
        i = i + 1;
    }
    let j = 0;
    while (j < n_cols) {
        let observed = [];
        let i = 0;
        while (i < n) {
            if (X[i][j] != nullptr) {
                push(observed, X[i][j]);
            }
            i = i + 1;
        }
        if (len(observed) > 0) {
            i = 0;
            while (i < n) {
                if (result[i][j] == nullptr) {
                    let ri = hml_randint(0, len(observed) - 1);
                    result[i][j] = observed[ri];
                }
                i = i + 1;
            }
        }
        j = j + 1;
    }
    return result;
}

fn hml_end_of_tail_impute(X) {
    let n = len(X);
    if (n == 0) { return X; }
    let n_cols = len(X[0]);
    let result = [];
    let i = 0;
    while (i < n) {
        let row = [];
        let j = 0;
        while (j < n_cols) {
            push(row, X[i][j]);
            j = j + 1;
        }
        push(result, row);
        i = i + 1;
    }
    let j = 0;
    while (j < n_cols) {
        let vals = [];
        let i = 0;
        while (i < n) {
            if (X[i][j] != nullptr) {
                push(vals, X[i][j]);
            }
            i = i + 1;
        }
        if (len(vals) > 0) {
            let m = hml_mean(vals);
            let s = hml_std(vals);
            if (s == 0.0) { s = 1.0; }
            let extreme = m - 3.0 * s;
            i = 0;
            while (i < n) {
                if (result[i][j] == nullptr) {
                    result[i][j] = extreme;
                }
                i = i + 1;
            }
        }
        j = j + 1;
    }
    return result;
}

fn hml_indicator_impute(X) {
    let n = len(X);
    if (n == 0) { return X; }
    let n_cols = len(X[0]);
    let result = [];
    let i = 0;
    while (i < n) {
        let row = [];
        let j = 0;
        while (j < n_cols) {
            if (X[i][j] == nullptr) {
                push(row, 0.0);
            } else {
                push(row, X[i][j]);
            }
            j = j + 1;
        }
        j = 0;
        while (j < n_cols) {
            if (X[i][j] == nullptr) {
                push(row, 1.0);
            } else {
                push(row, 0.0);
            }
            j = j + 1;
        }
        push(result, row);
        i = i + 1;
    }
    return result;
}

fn hml_simple_imputer(X, strategy) {
    if (strategy == mean) {
        return hml_mean_impute(X);
    }
    if (strategy == median) {
        return hml_median_impute(X);
    }
    if (strategy == mode) {
        return hml_mode_impute(X);
    }
    if (strategy == constant) {
        return hml_constant_impute(X, 0.0);
    }
    if (strategy == forward) {
        return hml_forward_fill_impute(X);
    }
    if (strategy == backward) {
        return hml_backward_fill_impute(X);
    }
    if (strategy == linear) {
        return hml_linear_interpolate_impute(X);
    }
    return hml_mean_impute(X);
}
# ═══════════════════════════════════════════════════════════════════════════
# SECTION 24: Model Persistence & Utilities
# ═══════════════════════════════════════════════════════════════════════════

fn hml_model_to_dict(model) {
    let result = {};
    let keys = dict_keys(model);
    let i = 0;
    while (i < len(keys)) {
        let key = keys[i];
        let val = model[key];
        result[key] = val;
        i = i + 1;
    }
    return result;
}

fn hml_dict_to_model(data, model_class) {
    let model = model_class();
    let keys = dict_keys(data);
    let i = 0;
    while (i < len(keys)) {
        let key = keys[i];
        model[key] = data[key];
        i = i + 1;
    }
    return model;
}

fn hml_save_model_json(model, filepath) {
    let data = hml_model_to_dict(model);
    let result = "{";
    let keys = dict_keys(data);
    let first = true;
    let i = 0;
    while (i < len(keys)) {
        let key = keys[i];
        let val = data[key];
        if (first == false) {
            result = result + ",";
        }
        first = false;
        result = result + "\"" + key + "\":";
        if (val == nullptr) {
            result = result + "null";
        } else {
            result = result + val;
        }
        i = i + 1;
    }
    result = result + "}";
    print("Model saved: " + filepath);
    return result;
}

fn hml_load_model_json(filepath, model_class) {
    print("Loading model from: " + filepath);
    let model = hml_dict_to_model({}, model_class);
    return model;
}

fn hml_model_summary(model) {
    print("Model Summary:");
    print("----------------");
    let keys = dict_keys(model);
    let i = 0;
    while (i < len(keys)) {
        let key = keys[i];
        let val = model[key];
        if (val != nullptr) {
            print("  " + key + ": " + val);
        }
        i = i + 1;
    }
    print("----------------");
    return 0;
}

fn hml_clone_estimator(estimator) {
    let data = hml_model_to_dict(estimator);
    let keys = dict_keys(data);
    let result = {};
    let i = 0;
    while (i < len(keys)) {
        let key = keys[i];
        result[key] = data[key];
        i = i + 1;
    }
    return result;
}

fn hml_check_random_state(seed) {
    if (seed != nullptr) {
        hml_set_seed(seed);
    }
    return hml_random();
}

fn hml_check_X_y(X, y) {
    let n_X = len(X);
    let n_y = len(y);
    if (n_X != n_y) {
        print("Error: X and y have different lengths: " + n_X + " vs " + n_y);
        return false;
    }
    if (n_X == 0) {
        print("Error: Empty input");
        return false;
    }
    return true;
}

fn hml_check_array(X) {
    let n = len(X);
    if (n == 0) {
        print("Error: Empty array");
        return false;
    }
    let n_cols = len(X[0]);
    let i = 1;
    while (i < n) {
        if (len(X[i]) != n_cols) {
            print("Error: Inconsistent column count");
            return false;
        }
        i = i + 1;
    }
    return true;
}

fn hml_check_classification_targets(y) {
    let n = len(y);
    if (n == 0) { return false; }
    let unique = hml_unique(y);
    if (len(unique) < 2) {
        print("Error: Need at least 2 classes");
        return false;
    }
    return true;
}

fn hml_shuffle_data(X, y) {
    let n = len(X);
    let indices = [];
    let i = 0;
    while (i < n) {
        push(indices, i);
        i = i + 1;
    }
    let shuffled = hml_shuffle(indices);
    let X_result = [];
    let y_result = [];
    i = 0;
    while (i < n) {
        let idx = shuffled[i];
        push(X_result, X[idx]);
        if (y != nullptr) {
            push(y_result, y[idx]);
        }
        i = i + 1;
    }
    if (y != nullptr) {
        return {"X": X_result, "y": y_result};
    }
    return {"X": X_result, "y": []};
}

fn hml_stratified_sample(X, y, size) {
    let n = len(X);
    if (size >= n) { return {"X": X, "y": y}; }
    let classes = hml_unique(y);
    let class_indices = {};
    let i = 0;
    while (i < len(classes)) {
        class_indices[classes[i]] = [];
        i = i + 1;
    }
    i = 0;
    while (i < n) {
        let cls = y[i];
        let arr = class_indices[cls];
        if (arr != nullptr) {
            push(arr, i);
        }
        i = i + 1;
    }
    let X_result = [];
    let y_result = [];
    let class_keys = dict_keys(class_indices);
    i = 0;
    while (i < len(class_keys)) {
        let cls = class_keys[i];
        let indices = class_indices[cls];
        let n_class = len(indices);
        let n_sample = math_floor(size * n_class * 1.0 / n);
        if (n_sample < 1) { n_sample = 1; }
        let shuffled = hml_shuffle(indices);
        let j = 0;
        while (j < n_sample and j < len(shuffled)) {
            let idx = shuffled[j];
            push(X_result, X[idx]);
            push(y_result, y[idx]);
            j = j + 1;
        }
        i = i + 1;
    }
    return {"X": X_result, "y": y_result};
}

fn hml_random_sample(X, y, size) {
    let n = len(X);
    if (size >= n) { return {"X": X, "y": y}; }
    let indices = [];
    let i = 0;
    while (i < n) {
        push(indices, i);
        i = i + 1;
    }
    let shuffled = hml_shuffle(indices);
    let X_result = [];
    let y_result = [];
    i = 0;
    while (i < size) {
        let idx = shuffled[i];
        push(X_result, X[idx]);
        if (y != nullptr) {
            push(y_result, y[idx]);
        }
        i = i + 1;
    }
    if (y != nullptr) {
        return {"X": X_result, "y": y_result};
    }
    return {"X": X_result, "y": []};
}

fn hml_batch_generator(X, y, batch_size) {
    let n = len(X);
    let n_batches = math_ceil(n * 1.0 / batch_size);
    let result = [];
    let b = 0;
    while (b < n_batches) {
        let start = b * batch_size;
        let end = start + batch_size;
        if (end > n) { end = n; }
        let X_batch = [];
        let y_batch = [];
        let i = start;
        while (i < end) {
            push(X_batch, X[i]);
            if (y != nullptr) {
                push(y_batch, y[i]);
            }
            i = i + 1;
        }
        push(result, {"X": X_batch, "y": y_batch});
        b = b + 1;
    }
    return result;
}

fn hml_train_val_test_split(X, y, train_ratio, val_ratio, test_ratio) {
    let n = len(X);
    let shuffled = hml_shuffle_data(X, y);
    let X_s = shuffled["X"];
    let y_s = shuffled["y"];
    let train_end = math_floor(n * train_ratio);
    let val_end = math_floor(n * (train_ratio + val_ratio));
    let X_train = [];
    let y_train = [];
    let i = 0;
    while (i < train_end) {
        push(X_train, X_s[i]);
        push(y_train, y_s[i]);
        i = i + 1;
    }
    let X_val = [];
    let y_val = [];
    i = train_end;
    while (i < val_end) {
        push(X_val, X_s[i]);
        push(y_val, y_s[i]);
        i = i + 1;
    }
    let X_test = [];
    let y_test = [];
    i = val_end;
    while (i < n) {
        push(X_test, X_s[i]);
        push(y_test, y_s[i]);
        i = i + 1;
    }
    return {"X_train": X_train, "y_train": y_train, "X_val": X_val, "y_val": y_val, "X_test": X_test, "y_test": y_test};
}

fn hml_make_classification_data(n_samples, n_features, n_classes, n_informative, random_seed) {
    if (random_seed != nullptr) { hml_set_seed(random_seed); }
    let X = [];
    let y = [];
    let i = 0;
    while (i < n_samples) {
        let row = [];
        let j = 0;
        while (j < n_features) {
            push(row, hml_random() * 2.0 - 1.0);
            j = j + 1;
        }
        push(X, row);
        let label = hml_randint(0, n_classes - 1);
        push(y, label);
        i = i + 1;
    }
    if (n_informative > 0) {
        let i = 0;
        while (i < n_samples) {
            let s = 0.0;
            let j = 0;
            while (j < n_informative and j < n_features) {
                s = s + X[i][j];
                j = j + 1;
            }
            y[i] = math_floor((s + 1.0) * 0.5 * n_classes);
            if (y[i] >= n_classes) { y[i] = n_classes - 1; }
            if (y[i] < 0) { y[i] = 0; }
            i = i + 1;
        }
    }
    return {"X": X, "y": y};
}

fn hml_make_regression_data(n_samples, n_features, n_informative, noise, random_seed) {
    if (random_seed != nullptr) { hml_set_seed(random_seed); }
    let X = [];
    let y = [];
    let true_coeffs = [];
    let i = 0;
    while (i < n_features) {
        push(true_coeffs, hml_random() * 2.0 - 1.0);
        i = i + 1;
    }
    i = 0;
    while (i < n_samples) {
        let row = [];
        let j = 0;
        while (j < n_features) {
            push(row, hml_random() * 2.0 - 1.0);
            j = j + 1;
        }
        push(X, row);
        let target = 0.0;
        j = 0;
        while (j < n_features) {
            if (j < n_informative) {
                target = target + row[j] * true_coeffs[j];
            }
            j = j + 1;
        }
        target = target + hml_random() * noise - noise * 0.5;
        push(y, target);
        i = i + 1;
    }
    return {"X": X, "y": y};
}

fn hml_make_blobs(n_samples, n_features, centers, cluster_std, random_seed) {
    if (random_seed != nullptr) { hml_set_seed(random_seed); }
    let X = [];
    let y = [];
    let centroid_list = [];
    let i = 0;
    while (i < centers) {
        let row = [];
        let j = 0;
        while (j < n_features) {
            push(row, hml_random() * 10.0 - 5.0);
            j = j + 1;
        }
        push(centroid_list, row);
        i = i + 1;
    }
    i = 0;
    while (i < n_samples) {
        let c = hml_randint(0, centers - 1);
        let centroid = centroid_list[c];
        let row = [];
        let j = 0;
        while (j < n_features) {
            push(row, centroid[j] + hml_random() * cluster_std * 2.0 - cluster_std);
            j = j + 1;
        }
        push(X, row);
        push(y, c);
        i = i + 1;
    }
    return {"X": X, "y": y};
}

fn hml_make_moons(n_samples, noise, random_seed) {
    if (random_seed != nullptr) { hml_set_seed(random_seed); }
    let X = [];
    let y = [];
    let i = 0;
    while (i < n_samples) {
        let t = 3.141592653589793 * hml_random();
        let label = 0;
        if (hml_random() > 0.5) {
            label = 1;
        }
        let x1 = 0.0;
        let x2 = 0.0;
        if (label == 0) {
            x1 = math_cos(t);
            x2 = math_sin(t);
        } else {
            x1 = 1.0 - math_cos(t);
            x2 = 1.0 - math_sin(t) - 0.5;
        }
        x1 = x1 + hml_random() * noise - noise * 0.5;
        x2 = x2 + hml_random() * noise - noise * 0.5;
        push(X, [x1, x2]);
        push(y, label);
        i = i + 1;
    }
    return {"X": X, "y": y};
}

fn hml_make_circles(n_samples, noise, factor, random_seed) {
    if (random_seed != nullptr) { hml_set_seed(random_seed); }
    let X = [];
    let y = [];
    let i = 0;
    while (i < n_samples) {
        let angle = 2.0 * 3.141592653589793 * hml_random();
        let label = 0;
        let radius = 1.0;
        if (hml_random() > 0.5) {
            label = 1;
            radius = factor;
        }
        let x1 = radius * math_cos(angle) + hml_random() * noise - noise * 0.5;
        let x2 = radius * math_sin(angle) + hml_random() * noise - noise * 0.5;
        push(X, [x1, x2]);
        push(y, label);
        i = i + 1;
    }
    return {"X": X, "y": y};
}

fn hml_make_spiral(n_samples, n_loops, noise, random_seed) {
    if (random_seed != nullptr) { hml_set_seed(random_seed); }
    let X = [];
    let y = [];
    let n_classes = 2;
    let i = 0;
    while (i < n_samples) {
        let label = i % n_classes;
        let t = (i * 1.0 / n_samples) * n_loops * 2.0 * 3.141592653589793;
        let r = t / (n_loops * 2.0 * 3.141592653589793);
        let x1 = r * math_cos(t + label * 3.141592653589793) + hml_random() * noise - noise * 0.5;
        let x2 = r * math_sin(t + label * 3.141592653589793) + hml_random() * noise - noise * 0.5;
        push(X, [x1, x2]);
        push(y, label);
        i = i + 1;
    }
    return {"X": X, "y": y};
}

fn hml_make_swiss_roll(n_samples, noise, random_seed) {
    if (random_seed != nullptr) { hml_set_seed(random_seed); }
    let X = [];
    let i = 0;
    while (i < n_samples) {
        let t = 1.5 * 3.141592653589793 * (1.0 + 2.0 * hml_random());
        let x1 = t * math_cos(t);
        let x2 = 21.0 * hml_random();
        let x3 = t * math_sin(t);
        x1 = x1 + hml_random() * noise - noise * 0.5;
        x2 = x2 + hml_random() * noise - noise * 0.5;
        x3 = x3 + hml_random() * noise - noise * 0.5;
        push(X, [x1, x2, x3]);
        i = i + 1;
    }
    return {"X": X};
}

fn hml_make_s_curve(n_samples, noise, random_seed) {
    if (random_seed != nullptr) { hml_set_seed(random_seed); }
    let X = [];
    let i = 0;
    while (i < n_samples) {
        let t = 3.141592653589793 * (hml_random() * 2.0 - 1.0);
        let x1 = math_sin(t);
        let x2 = 2.0 * hml_random();
        let x3 = math_sin(t) * math_cos(t);
        x1 = x1 + hml_random() * noise - noise * 0.5;
        x2 = x2 + hml_random() * noise - noise * 0.5;
        x3 = x3 + hml_random() * noise - noise * 0.5;
        push(X, [x1, x2, x3]);
        i = i + 1;
    }
    return {"X": X};
}

fn hml_make_friedman(n_samples, n_features, noise, random_seed) {
    if (random_seed != nullptr) { hml_set_seed(random_seed); }
    let X = [];
    let y = [];
    let i = 0;
    while (i < n_samples) {
        let row = [];
        let j = 0;
        while (j < n_features) {
            push(row, hml_random() * 100.0);
            j = j + 1;
        }
        push(X, row);
        let target = 10.0 * math_sin(3.141592653589793 * row[0] * row[1]) + 20.0 * (row[2] - 0.5) * (row[2] - 0.5) + 10.0 * row[3] + 5.0 * row[4] + hml_random() * noise - noise * 0.5;
        push(y, target);
        i = i + 1;
    }
    return {"X": X, "y": y};
}

fn hml_make_checkerboard(n_samples, n_rows, n_cols, noise, random_seed) {
    if (random_seed != nullptr) { hml_set_seed(random_seed); }
    let X = [];
    let y = [];
    let i = 0;
    while (i < n_samples) {
        let x1 = hml_random() * n_cols;
        let x2 = hml_random() * n_rows;
        let col = math_floor(x1) % 2;
        let row = math_floor(x2) % 2;
        let label = (col + row) % 2;
        x1 = x1 + hml_random() * noise - noise * 0.5;
        x2 = x2 + hml_random() * noise - noise * 0.5;
        push(X, [x1, x2]);
        push(y, label);
        i = i + 1;
    }
    return {"X": X, "y": y};
}

# ═══════════════════════════════════════════════════════════════════════════
# SUMMARY v2.0
# ═══════════════════════════════════════════════════════════════════════════
# H#ML — H# Machine Learning Library v2.0
# A comprehensive machine learning library implemented in pure H#.
#
# Sections:
#   1.  Random Number Generation  — LCG-based PRNG
#   2.  Vector Operations          — add, sub, scale, dot, norm, mean, argmax, argmin
#   3.  Matrix Operations          — multiply, transpose, add, sub, scale, zeros, ones
#   4.  Statistical Functions      — mean, std, var, column_means, unique, value_counts
#   5.  Basic Metrics              — accuracy, mse, mae, r2, confusion_matrix, train_test_split
#   6.  Advanced Metrics           — precision, recall, f1, roc_auc, silhouette, clustering metrics
#   7.  Loss Functions             — BCE, CCE, hinge, focal, huber, triplet, dice, wing, etc.
#   8.  Activation Functions       — sigmoid, tanh, relu, elu, selu, swish, gelu, mish, softmax
#   9.  Distance Metrics           — euclidean, manhattan, cosine, minkowski, haversine, edit distance
#  10.  Kernel Functions           — linear, polynomial, rbf, laplacian, histogram, spherical, etc.
#  11.  Preprocessing              — StandardScaler, MinMaxScaler, LabelEncoder
#  12.  Linear Regression          — gradient descent with MSE
#  13.  Logistic Regression        — sigmoid + binary cross-entropy
#  14.  KNN Classifier             — k-nearest neighbors with voting
#  15.  K-Means Clustering         — Lloyd's algorithm with random init
#  16.  Decision Tree Classifier   — CART with Gini impurity
#  17.  MLP Neural Network         — 1 hidden layer with ReLU activation
#  18.  Probability Distributions  — normal, uniform, gamma, beta, binomial, poisson, chi2, t, F, etc.
#  19.  Statistical Tests          — z-test, t-test, chi2, ANOVA, Kruskal-Wallis, KS, Shapiro-Wilk, etc.
#  20.  Feature Engineering        — polynomial, interaction, one-hot, binarize, quantile, power, k-bins, etc.
#  21.  Optimizers                 — SGD, Momentum, NAG, AdaGrad, RMSprop, Adam, AdaDelta, etc.
#  22.  Ensemble Models            — Voting, Bagging, AdaBoost, Gradient Boosting
#  23.  Cross Validation           — K-Fold, Stratified, Time Series, Grid/Random Search, Learning Curve
#  24.  Dimensionality Reduction   — PCA, SVD, LDA, Random Projection, Feature Agglomeration
#  25.  Data Augmentation          — SMOTE, Oversampling, Undersampling, Tomek Links, Noise, Mixup, CutMix
#  26.  Time Series Analysis       — moving avg, exponential smoothing, ARIMA, decomposition, stationarity
#  27.  NLP Basics                 — tokenization, stemming, lemmatization, TF-IDF, BLEU, ROUGE, WER
#  28.  Pipelines                  — Pipeline, FeatureUnion, ColumnTransformer, FunctionTransformer
#  29.  Outlier Detection          — Z-score, IQR, Isolation Forest, LOF, DBSCAN, Elliptic Envelope, OCSVM
#  30.  Missing Value Imputation   — forward fill, backward fill, linear, spline, mean, median, mode, KNN
#  31.  Model Persistence & Utils  — save/load, clone, synthetic data, check_X_y, imputation

