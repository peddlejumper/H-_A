        }
        return result;
    }
}

# ── SoftmaxActivation ──
class SoftmaxActivation {
    fn init_softmax_act() { return 0; }
    fn call(x) { return softmax(x); }
    fn forward(X) {
        let result = [];
        let i = 0;
        while (i < len(X)) {
            push(result, softmax(X[i]));
