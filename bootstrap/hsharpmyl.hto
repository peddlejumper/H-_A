fn hml_xavier_init(fan_in, fan_out) {
    let limit = math_sqrt(6.0 / (fan_in + fan_out));
    let result = [];
    let i = 0;
    while (i < fan_in) {
        let row = [];
        let j = 0;
        while (j < fan_out) {
            push(row, (hml_random() - 0.5) * 2.0 * limit);
            j = j + 1;
        }
        push(result, row);
        i = i + 1;
    }
    return result;
}

fn hml_he_init(fan_in) {
    let std = math_sqrt(2.0 / fan_in);
    let result = hml_vector_zeros(fan_in);
    let i = 0;
    while (i < fan_in) {
        result[i] = (hml_random() - 0.5) * 2.0 * std * math_sqrt(3.0);
        i = i + 1;
    }
    return result;
}

fn hml_uniform_init(rows, cols, scale) {
    let result = [];
    let i = 0;
    while (i < rows) {
        let row = [];
        let j = 0;
        while (j < cols) {
            push(row, (hml_random() - 0.5) * 2.0 * scale);
            j = j + 1;
        }
        push(result, row);
        i = i + 1;
    }
    return result;
}

fn hml_dropout_forward(X, rate, training) {
    if (not training) { return X; }
    let result = [];
    let mask_rows = [];
    let i = 0;
    while (i < len(X)) {
        let row = [];
        let mask_row = [];
        let j = 0;
        while (j < len(X[0])) {
            if (hml_random() > rate) {
                push(row, X[i][j] / (1.0 - rate));
                push(mask_row, 1.0);
            } else {
                push(row, 0.0);
                push(mask_row, 0.0);
            }
            j = j + 1;
        }
        push(result, row);
        push(mask_rows, mask_row);
        i = i + 1;
    }
    return {"output": result, "mask": mask_rows};
}

fn hml_dropout_backward(dout, mask) {
    let result = [];
    let i = 0;
    while (i < len(dout)) {
        let row = [];
        let j = 0;
        while (j < len(dout[0])) {
            push(row, dout[i][j] * mask[i][j]);
            j = j + 1;
        }
        push(result, row);
        i = i + 1;
    }
    return result;
}

fn hml_batch_norm_forward(X, gamma, beta, eps) {
    let n = len(X);
    let d = len(X[0]);
    let mean = hml_vector_zeros(d);
    let var = hml_vector_zeros(d);
    let j = 0;
    while (j < d) {
        let s = 0.0;
        let i = 0;
        while (i < n) {
            s = s + X[i][j];
            i = i + 1;
        }
        mean[j] = s * 1.0 / n;
        j = j + 1;
    }
    j = 0;
    while (j < d) {
        let s = 0.0;
        let i = 0;
        while (i < n) {
            let diff = X[i][j] - mean[j];
            s = s + diff * diff;
            i = i + 1;
        }
        var[j] = s * 1.0 / n;
        j = j + 1;
    }
    let out = [];
    let i = 0;
    while (i < n) {
        let row = [];
        let j = 0;
        while (j < d) {
            let x_hat = (X[i][j] - mean[j]) / math_sqrt(var[j] + eps);
            push(row, gamma[j] * x_hat + beta[j]);
            j = j + 1;
        }
        push(out, row);
        i = i + 1;
    }
    return {"output": out, "mean": mean, "var": var};
}

fn hml_batch_norm_backward(dout, X, gamma, eps) {
    let n = len(X);
    let d = len(X[0]);
    let mean = hml_vector_zeros(d);
    let var = hml_vector_zeros(d);
    let j = 0;
    while (j < d) {
        let s = 0.0;
        let i = 0;
        while (i < n) { s = s + X[i][j]; i = i + 1; }
        mean[j] = s * 1.0 / n;
        j = j + 1;
    }
    j = 0;
    while (j < d) {
        let s = 0.0;
        let i = 0;
        while (i < n) {
            let diff = X[i][j] - mean[j];
            s = s + diff * diff;
            i = i + 1;
        }
        var[j] = s * 1.0 / n;
        j = j + 1;
    }
    let dx = hml_matrix_zeros(n, d);
    let dgamma = hml_vector_zeros(d);
    let dbeta = hml_vector_zeros(d);
    j = 0;
    while (j < d) {
        let inv_std = 1.0 / math_sqrt(var[j] + eps);
        let dgamma_j = 0.0;
        let dbeta_j = 0.0;
        let i = 0;
        while (i < n) {
            let x_hat = (X[i][j] - mean[j]) * inv_std;
            dgamma_j = dgamma_j + dout[i][j] * x_hat;
            dbeta_j = dbeta_j + dout[i][j];
            i = i + 1;
        }
        dgamma[j] = dgamma_j;
        dbeta[j] = dbeta_j;
        j = j + 1;
    }
    j = 0;
    while (j < d) {
        let inv_std = 1.0 / math_sqrt(var[j] + eps);
        let i = 0;
        while (i < n) {
            let x_hat = (X[i][j] - mean[j]) * inv_std;
            let dx_hat = dout[i][j] * gamma[j];
            dx[i][j] = (1.0 / n) * inv_std * (n * dx_hat - dx_hat - x_hat * (dx_hat * x_hat) * (1.0 / n));
            i = i + 1;
        }
        j = j + 1;
    }
    return {"dx": dx, "dgamma": dgamma, "dbeta": dbeta};
}

fn hml_layer_norm_forward(X, gamma, beta, eps) {
    let n = len(X);
    let d = len(X[0]);
    let out = [];
    let i = 0;
    while (i < n) {
        let s = 0.0;
        let j = 0;
        while (j < d) { s = s + X[i][j]; j = j + 1; }
        let mean_i = s * 1.0 / d;
        s = 0.0;
        j = 0;
        while (j < d) {
            let diff = X[i][j] - mean_i;
            s = s + diff * diff;
            j = j + 1;
        }
        let var_i = s * 1.0 / d;
        let row = [];
        j = 0;
        while (j < d) {
            let x_hat = (X[i][j] - mean_i) / math_sqrt(var_i + eps);
            push(row, gamma[j] * x_hat + beta[j]);
            j = j + 1;
        }
        push(out, row);
        i = i + 1;
    }
    return out;
}

fn hml_conv1d(input, kernel, stride) {
    let in_len = len(input);
    let k_len = len(kernel);
    let out_len = math_floor((in_len - k_len) * 1.0 / stride) + 1;
    let result = [];
    let i = 0;
    while (i < out_len) {
        let s = 0.0;
        let j = 0;
        while (j < k_len) {
            s = s + input[i * stride + j] * kernel[j];
            j = j + 1;
        }
        push(result, s);
        i = i + 1;
    }
    return result;
}

fn hml_conv2d(input, kernel, stride) {
    let in_h = len(input);
    let in_w = len(input[0]);
    let k_h = len(kernel);
    let k_w = len(kernel[0]);
    let out_h = math_floor((in_h - k_h) * 1.0 / stride) + 1;
    let out_w = math_floor((in_w - k_w) * 1.0 / stride) + 1;
    let result = [];
    let i = 0;
    while (i < out_h) {
        let row = [];
        let j = 0;
        while (j < out_w) {
            let s = 0.0;
            let ki = 0;
            while (ki < k_h) {
                let kj = 0;
                while (kj < k_w) {
                    s = s + input[i * stride + ki][j * stride + kj] * kernel[ki][kj];
                    kj = kj + 1;
                }
                ki = ki + 1;
            }
            push(row, s);
            j = j + 1;
        }
        push(result, row);
        i = i + 1;
    }
    return result;
}

fn hml_max_pool1d(input, pool_size, stride) {
    let in_len = len(input);
    let out_len = math_floor((in_len - pool_size) * 1.0 / stride) + 1;
    let result = [];
    let i = 0;
    while (i < out_len) {
        let mx = input[i * stride];
        let j = 1;
        while (j < pool_size) {
            let idx = i * stride + j;
            if (idx < in_len and input[idx] > mx) { mx = input[idx]; }
            j = j + 1;
        }
        push(result, mx);
        i = i + 1;
    }
    return result;
}

fn hml_max_pool2d(input, pool_size, stride) {
    let in_h = len(input);
    let in_w = len(input[0]);
    let out_h = math_floor((in_h - pool_size) * 1.0 / stride) + 1;
    let out_w = math_floor((in_w - pool_size) * 1.0 / stride) + 1;
    let result = [];
    let i = 0;
    while (i < out_h) {
        let row = [];
        let j = 0;
        while (j < out_w) {
            let mx = input[i * stride][j * stride];
            let ki = 0;
            while (ki < pool_size) {
                let kj = 0;
                while (kj < pool_size) {
                    let ii = i * stride + ki;
                    let jj = j * stride + kj;
                    if (ii < in_h and jj < in_w and input[ii][jj] > mx) {
                        mx = input[ii][jj];
                    }
                    kj = kj + 1;
                }
                ki = ki + 1;
            }
            push(row, mx);
            j = j + 1;
        }
        push(result, row);
        i = i + 1;
    }
    return result;
}

fn hml_avg_pool2d(input, pool_size, stride) {
    let in_h = len(input);
    let in_w = len(input[0]);
    let out_h = math_floor((in_h - pool_size) * 1.0 / stride) + 1;
    let out_w = math_floor((in_w - pool_size) * 1.0 / stride) + 1;
    let result = [];
    let i = 0;
    while (i < out_h) {
        let row = [];
        let j = 0;
        while (j < out_w) {
            let s = 0.0;
            let cnt = 0;
            let ki = 0;
            while (ki < pool_size) {
                let kj = 0;
                while (kj < pool_size) {
                    let ii = i * stride + ki;
                    let jj = j * stride + kj;
                    if (ii < in_h and jj < in_w) {
                        s = s + input[ii][jj];
                        cnt = cnt + 1;
                    }
                    kj = kj + 1;
                }
                ki = ki + 1;
            }
            if (cnt > 0) {
                push(row, s * 1.0 / cnt);
            } else {
                push(row, 0.0);
            }
            j = j + 1;
        }
        push(result, row);
        i = i + 1;
    }
    return result;
}

fn hml_flatten(X) {
    let result = [];
    let i = 0;
    while (i < len(X)) {
        let j = 0;
        while (j < len(X[i])) {
            push(result, X[i][j]);
            j = j + 1;
        }
        i = i + 1;
    }
    return result;
}

fn hml_im2col(image, kernel_h, kernel_w, stride) {
    let in_h = len(image);
    let in_w = len(image[0]);
    let out_h = math_floor((in_h - kernel_h) * 1.0 / stride) + 1;
    let out_w = math_floor((in_w - kernel_w) * 1.0 / stride) + 1;
    let cols = [];
    let i = 0;
    while (i < out_h) {
        let j = 0;
        while (j < out_w) {
            let patch = [];
            let ki = 0;
            while (ki < kernel_h) {
                let kj = 0;
                while (kj < kernel_w) {
                    push(patch, image[i * stride + ki][j * stride + kj]);
                    kj = kj + 1;
                }
                ki = ki + 1;
            }
            push(cols, patch);
            j = j + 1;
        }
        i = i + 1;
    }
    return cols;
}

fn hml_col2im(cols, output_shape) {
    let out_h = output_shape[0];
    let out_w = output_shape[1];
    let img = hml_matrix_zeros(out_h, out_w);
    let idx = 0;
    let i = 0;
    while (i < out_h) {
        let j = 0;
        while (j < out_w) {
            img[i][j] = cols[idx];
            idx = idx + 1;
            j = j + 1;
        }
        i = i + 1;
    }
    return img;
}

fn hml_pad_image(image, pad_h, pad_w) {
    let in_h = len(image);
    let in_w = len(image[0]);
    let out_h = in_h + 2 * pad_h;
    let out_w = in_w + 2 * pad_w;
    let result = hml_matrix_zeros(out_h, out_w);
    let i = 0;
    while (i < in_h) {
        let j = 0;
        while (j < in_w) {
            result[i + pad_h][j + pad_w] = image[i][j];
            j = j + 1;
        }
        i = i + 1;
    }
    return result;
}

fn hml_rnn_cell(x, h_prev, Wxh, Whh, bh) {
    let h_next = hml_vector_zeros(len(Whh));
    let i = 0;
    while (i < len(Whh)) {
        let s = bh[i];
        let j = 0;
        while (j < len(x)) {
            s = s + Wxh[i][j] * x[j];
            j = j + 1;
        }
        j = 0;
        while (j < len(h_prev)) {
            s = s + Whh[i][j] * h_prev[j];
            j = j + 1;
        }
        h_next[i] = s / (1.0 + math_fabs(s));
        i = i + 1;
    }
    return h_next;
}

fn hml_gru_cell(x, h_prev, Wxz, Whz, Wxr, Whr, Wxh, Whh) {
    let d = len(Whz);
    let z = hml_vector_zeros(d);
    let r = hml_vector_zeros(d);
    let h_tilde = hml_vector_zeros(d);
    let h_next = hml_vector_zeros(d);
    let i = 0;
    while (i < d) {
        let sz = 0.0;
        let sr = 0.0;
        let sh = 0.0;
        let j = 0;
        while (j < len(x)) {
            sz = sz + Wxz[i][j] * x[j];
            sr = sr + Wxr[i][j] * x[j];
            sh = sh + Wxh[i][j] * x[j];
            j = j + 1;
        }
        j = 0;
        while (j < d) {
            sz = sz + Whz[i][j] * h_prev[j];
            sr = sr + Whr[i][j] * h_prev[j];
            j = j + 1;
        }
        z[i] = 1.0 / (1.0 + math_exp(-sz));
        r[i] = 1.0 / (1.0 + math_exp(-sr));
        j = 0;
        while (j < d) {
            sh = sh + Whh[i][j] * (r[i] * h_prev[j]);
            j = j + 1;
        }
        h_tilde[i] = sh / (1.0 + math_fabs(sh));
        h_next[i] = (1.0 - z[i]) * h_prev[i] + z[i] * h_tilde[i];
        i = i + 1;
    }
    return h_next;
}

fn hml_lstm_cell(x, h_prev, c_prev, Wf, Wi, Wc, Wo) {
    let d = len(Wf);
    let f = hml_vector_zeros(d);
    let i_gate = hml_vector_zeros(d);
    let c_tilde = hml_vector_zeros(d);
    let o = hml_vector_zeros(d);
    let c_next = hml_vector_zeros(d);
    let h_next = hml_vector_zeros(d);
    let k = 0;
    while (k < d) {
        let sf = 0.0;
        let si = 0.0;
        let sc = 0.0;
        let so = 0.0;
        let j = 0;
        while (j < len(x)) {
            sf = sf + Wf[k][j] * x[j];
            si = si + Wi[k][j] * x[j];
            sc = sc + Wc[k][j] * x[j];
            so = so + Wo[k][j] * x[j];
            j = j + 1;
        }
        j = 0;
        let d_h = len(Wf[0]) - len(x);
        while (j < len(h_prev)) {
            sf = sf + Wf[k][len(x) + j] * h_prev[j];
            si = si + Wi[k][len(x) + j] * h_prev[j];
            sc = sc + Wc[k][len(x) + j] * h_prev[j];
            so = so + Wo[k][len(x) + j] * h_prev[j];
            j = j + 1;
        }
        f[k] = 1.0 / (1.0 + math_exp(-sf));
        i_gate[k] = 1.0 / (1.0 + math_exp(-si));
        c_tilde[k] = sc / (1.0 + math_fabs(sc));
        o[k] = 1.0 / (1.0 + math_exp(-so));
        c_next[k] = f[k] * c_prev[k] + i_gate[k] * c_tilde[k];
        h_next[k] = o[k] * (c_next[k] / (1.0 + math_fabs(c_next[k])));
        k = k + 1;
    }
    return {"h": h_next, "c": c_next};
}

fn hml_embedding_lookup(embeddings, indices) {
    let result = [];
    let i = 0;
    while (i < len(indices)) {
        let idx = indices[i];
        let emb = [];
        let j = 0;
        while (j < len(embeddings[idx])) {
            push(emb, embeddings[idx][j]);
            j = j + 1;
        }
        push(result, emb);
        i = i + 1;
    }
    return result;
}

fn hml_positional_encoding(seq_len, d_model) {
    let pe = hml_matrix_zeros(seq_len, d_model);
    let pos = 0;
    while (pos < seq_len) {
        let j = 0;
        while (j < d_model) {
            let div = math_pow(10000.0, (2.0 * math_floor(j * 1.0 / 2)) * 1.0 / d_model);
            let angle = pos * 1.0 / div;
            if (j % 2 == 0) {
                pe[pos][j] = math_sin(angle);
            } else {
                pe[pos][j] = math_cos(angle);
            }
            j = j + 1;
        }
        pos = pos + 1;
    }
    return pe;
}

fn hml_scaled_dot_product_attention(Q, K, V, mask) {
    let d_k = len(K[0]);
    let n_q = len(Q);
    let n_kv = len(K);
    let attn = hml_matrix_zeros(n_q, n_kv);
    let i = 0;
    while (i < n_q) {
        let j = 0;
        while (j < n_kv) {
            let s = 0.0;
            let d = 0;
            while (d < d_k) {
                s = s + Q[i][d] * K[j][d];
                d = d + 1;
            }
            attn[i][j] = s / math_sqrt(d_k * 1.0);
            j = j + 1;
        }
        i = i + 1;
    }
    if (mask != nullptr) {
        i = 0;
        while (i < n_q) {
            let j = 0;
            while (j < n_kv) {
                if (mask[i][j] == 0) { attn[i][j] = -1000000000; }
                j = j + 1;
            }
            i = i + 1;
        }
    }
    i = 0;
    while (i < n_q) {
        let mx = attn[i][0];
        let j = 1;
        while (j < n_kv) {
            if (attn[i][j] > mx) { mx = attn[i][j]; }
            j = j + 1;
        }
        let sum = 0.0;
        j = 0;
        while (j < n_kv) {
            attn[i][j] = math_exp(attn[i][j] - mx);
            sum = sum + attn[i][j];
            j = j + 1;
        }
        j = 0;
        while (j < n_kv) {
            attn[i][j] = attn[i][j] / sum;
            j = j + 1;
        }
        i = i + 1;
    }
    let output = hml_matrix_zeros(n_q, len(V[0]));
    i = 0;
    while (i < n_q) {
        let j = 0;
        while (j < len(V[0])) {
            let s = 0.0;
            let k = 0;
            while (k < n_kv) {
                s = s + attn[i][k] * V[k][j];
                k = k + 1;
            }
            output[i][j] = s;
            j = j + 1;
        }
        i = i + 1;
    }
    return {"output": output, "attention": attn};
}

fn hml_multi_head_attention_split(Q, K, V, n_heads) {
    let d_model = len(Q[0]);
    let d_k = math_floor(d_model * 1.0 / n_heads);
    let Q_heads = [];
    let K_heads = [];
    let V_heads = [];
    let h = 0;
    while (h < n_heads) {
        let Qh = [];
        let i = 0;
        while (i < len(Q)) {
            let row = [];
            let j = h * d_k;
            while (j < (h + 1) * d_k) {
                push(row, Q[i][j]);
                j = j + 1;
            }
            push(Qh, row);
            i = i + 1;
        }
        push(Q_heads, Qh);
        let Kh = [];
        i = 0;
        while (i < len(K)) {
            let row = [];
            let j = h * d_k;
            while (j < (h + 1) * d_k) {
                push(row, K[i][j]);
                j = j + 1;
            }
            push(Kh, row);
            i = i + 1;
        }
        push(K_heads, Kh);
        let Vh = [];
        i = 0;
        while (i < len(V)) {
            let row = [];
            let j = h * d_k;
            while (j < (h + 1) * d_k) {
                push(row, V[i][j]);
                j = j + 1;
            }
            push(Vh, row);
            i = i + 1;
        }
        push(V_heads, Vh);
        h = h + 1;
    }
    return {"Q_heads": Q_heads, "K_heads": K_heads, "V_heads": V_heads};
}

fn hml_multi_head_attention_concat(heads) {
    let n_heads = len(heads);
    let n_seq = len(heads[0]);
    let d_head = len(heads[0][0]);
    let result = [];
    let i = 0;
    while (i < n_seq) {
        let row = [];
        let h = 0;
        while (h < n_heads) {
            let j = 0;
            while (j < d_head) {
                push(row, heads[h][i][j]);
                j = j + 1;
            }
            h = h + 1;
        }
        push(result, row);
        i = i + 1;
    }
    return result;
}
# ═══════════════════════════════════════════════════════════════════════════
# SECTION 26: Reinforcement Learning
# ═══════════════════════════════════════════════════════════════════════════

fn hml_epsilon_greedy(q_values, epsilon) {
    if (hml_random() < epsilon) {
        return hml_randint(0, len(q_values) - 1);
    }
    return hml_vector_argmax(q_values);
}

fn hml_softmax_policy(q_values, temperature) {
    let n = len(q_values);
    let probs = hml_vector_zeros(n);
    let mx = q_values[0];
    let i = 1;
    while (i < n) {
        if (q_values[i] > mx) { mx = q_values[i]; }
        i = i + 1;
    }
    let sum = 0.0;
    i = 0;
    while (i < n) {
        probs[i] = math_exp((q_values[i] - mx) / temperature);
        sum = sum + probs[i];
        i = i + 1;
    }
    i = 0;
    while (i < n) {
        probs[i] = probs[i] / sum;
        i = i + 1;
    }
    let r = hml_random();
    let cum = 0.0;
    i = 0;
    while (i < n) {
        cum = cum + probs[i];
        if (r <= cum) { return i; }
        i = i + 1;
    }
    return n - 1;
}

fn hml_q_learning_update(Q, state, action, reward, next_state, alpha, gamma) {
    let n_actions = len(Q[0]);
    let best_next = Q[next_state][0];
    let a = 1;
    while (a < n_actions) {
        if (Q[next_state][a] > best_next) { best_next = Q[next_state][a]; }
        a = a + 1;
    }
    Q[state][action] = Q[state][action] + alpha * (reward + gamma * best_next - Q[state][action]);
    return Q;
}

fn hml_sarsa_update(Q, state, action, reward, next_state, next_action, alpha, gamma) {
    let td_target = reward + gamma * Q[next_state][next_action];
    Q[state][action] = Q[state][action] + alpha * (td_target - Q[state][action]);
    return Q;
}

fn hml_td0_value_update(V, state, reward, next_state, alpha, gamma) {
    let td_target = reward + gamma * V[next_state];
    V[state] = V[state] + alpha * (td_target - V[state]);
    return V;
}

fn hml_td_lambda_update(V, state, reward, next_state, alpha, gamma, lambda_val) {
    let td_error = reward + gamma * V[next_state] - V[state];
    V[state] = V[state] + alpha * td_error;
    return V;
}

fn hml_monte_carlo_value_update(V, episode, gamma) {
    let i = 0;
    while (i < len(episode)) {
        let state = episode[i]["state"];
        let G = 0.0;
        let discount = 1.0;
        let t = i;
        while (t < len(episode)) {
            G = G + discount * episode[t]["reward"];
            discount = discount * gamma;
            t = t + 1;
        }
        V[state] = V[state] + (G - V[state]) * 1.0 / (i + 1);
        i = i + 1;
    }
    return V;
}

fn hml_policy_evaluation(P, R, gamma, theta) {
    let n_states = len(P);
    let n_actions = len(P[0]);
    let V = hml_vector_zeros(n_states);
    let delta = theta + 1.0;
    while (delta > theta) {
        delta = 0.0;
        let s = 0;
        while (s < n_states) {
            let v = V[s];
            let new_v = 0.0;
            let a = 0;
            while (a < n_actions) {
                let prob = 1.0 / n_actions;
                new_v = new_v + prob * (R[s][a] + gamma * P[s][a] * V[s]);
                a = a + 1;
            }
            V[s] = new_v;
            let d = math_fabs(v - V[s]);
            if (d > delta) { delta = d; }
            s = s + 1;
        }
    }
    return V;
}

fn hml_policy_iteration(P, R, gamma, max_iter) {
    let n_states = len(P);
    let n_actions = len(P[0]);
    let V = hml_vector_zeros(n_states);
    let policy = hml_vector_zeros(n_states);
    let iter = 0;
    while (iter < max_iter) {
        let s = 0;
        while (s < n_states) {
            let best_val = -1000000000;
            let best_a = 0;
            let a = 0;
            while (a < n_actions) {
                let val = R[s][a] + gamma * P[s][a] * V[s];
                if (val > best_val) { best_val = val; best_a = a; }
                a = a + 1;
            }
            policy[s] = best_a;
            V[s] = best_val;
            s = s + 1;
        }
        iter = iter + 1;
    }
    return {"V": V, "policy": policy};
}

fn hml_value_iteration(P, R, gamma, theta, max_iter) {
    let n_states = len(P);
    let n_actions = len(P[0]);
    let V = hml_vector_zeros(n_states);
    let policy = hml_vector_zeros(n_states);
    let iter = 0;
    while (iter < max_iter) {
        let delta = 0.0;
        let s = 0;
        while (s < n_states) {
            let v = V[s];
            let best_val = -1000000000;
            let best_a = 0;
            let a = 0;
            while (a < n_actions) {
                let val = R[s][a] + gamma * P[s][a] * V[s];
                if (val > best_val) { best_val = val; best_a = a; }
                a = a + 1;
            }
            V[s] = best_val;
            policy[s] = best_a;
            let d = math_fabs(v - V[s]);
            if (d > delta) { delta = d; }
            s = s + 1;
        }
        if (delta < theta) { break; }
        iter = iter + 1;
    }
    return {"V": V, "policy": policy};
}

fn hml_replay_buffer_create(capacity) {
    return {"capacity": capacity, "buffer": [], "size": 0, "next_idx": 0};
}

fn hml_replay_buffer_push(buffer, experience) {
    if (buffer["size"] < buffer["capacity"]) {
        push(buffer["buffer"], experience);
        buffer["size"] = buffer["size"] + 1;
    } else {
        buffer["buffer"][buffer["next_idx"]] = experience;
    }
    buffer["next_idx"] = (buffer["next_idx"] + 1) % buffer["capacity"];
    return buffer;
}

fn hml_replay_buffer_sample(buffer, batch_size) {
    let batch = [];
    let i = 0;
    while (i < batch_size) {
        let idx = hml_randint(0, buffer["size"] - 1);
        push(batch, buffer["buffer"][idx]);
        i = i + 1;
    }
    return batch;
}

fn hml_dqn_target_update(online_Q, target_Q) {
    let i = 0;
    while (i < len(online_Q)) {
        let j = 0;
        while (j < len(online_Q[0])) {
            target_Q[i][j] = online_Q[i][j];
            j = j + 1;
        }
        i = i + 1;
    }
    return target_Q;
}

fn hml_reinforce_policy_gradient(states, actions, rewards, policy_net, gamma) {
    let T = len(rewards);
    let returns = hml_vector_zeros(T);
    let G = 0.0;
    let t = T - 1;
    while (t >= 0) {
        G = rewards[t] + gamma * G;
        returns[t] = G;
        t = t - 1;
    }
    let grad = hml_matrix_zeros(len(policy_net), len(policy_net[0]));
    t = 0;
    while (t < T) {
        let s = states[t];
        let a = actions[t];
        let Gt = returns[t];
        let j = 0;
        while (j < len(policy_net[0])) {
            if (j == a) {
                grad[s][j] = grad[s][j] + Gt * (1.0 - policy_net[s][j]);
            } else {
                grad[s][j] = grad[s][j] - Gt * policy_net[s][j];
            }
            j = j + 1;
        }
        t = t + 1;
    }
    return grad;
}

fn hml_actor_critic_update(actor, critic, state, action, reward, next_state, alpha, gamma) {
    let td_error = reward + gamma * critic[next_state] - critic[state];
    critic[state] = critic[state] + alpha * td_error;
    let n_actions = len(actor[0]);
    let a = 0;
    while (a < n_actions) {
        if (a == action) {
            actor[state][a] = actor[state][a] + alpha * td_error * (1.0 - actor[state][a]);
        } else {
            actor[state][a] = actor[state][a] - alpha * td_error * actor[state][a];
        }
        a = a + 1;
    }
    return {"actor": actor, "critic": critic};
}

fn hml_advantage_gae(rewards, values, gamma, lambda_val) {
    let T = len(rewards);
    let advantages = hml_vector_zeros(T);
    let gae = 0.0;
    let t = T - 1;
    while (t >= 0) {
        let next_val = 0.0;
        if (t < T - 1) { next_val = values[t + 1]; }
        let delta = rewards[t] + gamma * next_val - values[t];
        gae = delta + gamma * lambda_val * gae;
        advantages[t] = gae;
        t = t - 1;
    }
    return advantages;
}

fn hml_ppo_clip_loss(ratio, advantage, epsilon_clip) {
    let clipped = ratio;
    if (ratio < 1.0 - epsilon_clip) { clipped = 1.0 - epsilon_clip; }
    if (ratio > 1.0 + epsilon_clip) { clipped = 1.0 + epsilon_clip; }
    let unclipped = ratio * advantage;
    let clipped_val = clipped * advantage;
    if (unclipped < clipped_val) { return unclipped; }
    return clipped_val;
}

fn hml_entropy_bonus(probs) {
    let entropy = 0.0;
    let i = 0;
    while (i < len(probs)) {
        if (probs[i] > 0.000000000000001) {
            entropy = entropy - probs[i] * math_log(probs[i]);
        }
        i = i + 1;
    }
    return entropy;
}

fn hml_reward_discount(rewards, gamma) {
    let n = len(rewards);
    let discounted = hml_vector_zeros(n);
    let running = 0.0;
    let i = n - 1;
    while (i >= 0) {
        running = rewards[i] + gamma * running;
        discounted[i] = running;
        i = i - 1;
    }
    return discounted;
}

fn hml_multi_armed_bandit_ucb(means, counts, total) {
    let n = len(means);
    let ucb = hml_vector_zeros(n);
    let i = 0;
    while (i < n) {
        if (counts[i] == 0) { return i; }
        ucb[i] = means[i] + math_sqrt(2.0 * math_log(total) / counts[i]);
        i = i + 1;
    }
    return hml_vector_argmax(ucb);
}

fn hml_multi_armed_bandit_thompson(successes, failures) {
    let n = len(successes);
    let samples = hml_vector_zeros(n);
    let i = 0;
    while (i < n) {
        let alpha_i = successes[i] + 1.0;
        let beta_i = failures[i] + 1.0;
        samples[i] = hml_beta_distribution_sample(alpha_i, beta_i);
        i = i + 1;
    }
    return hml_vector_argmax(samples);
}

fn hml_mdp_transition_matrix(states, actions, next_states) {
    let n_states = 0;
    let i = 0;
    while (i < len(states)) {
        if (states[i] > n_states) { n_states = states[i]; }
        if (next_states[i] > n_states) { n_states = next_states[i]; }
        i = i + 1;
    }
    n_states = n_states + 1;
    let n_actions = 0;
    i = 0;
    while (i < len(actions)) {
        if (actions[i] > n_actions) { n_actions = actions[i]; }
        i = i + 1;
    }
    n_actions = n_actions + 1;
    let P = [];
    let a = 0;
    while (a < n_actions) {
        let row = [];
        let s = 0;
        while (s < n_states) {
            push(row, hml_vector_zeros(n_states));
            s = s + 1;
        }
        push(P, row);
        a = a + 1;
    }
    let counts = [];
    a = 0;
    while (a < n_actions) {
        push(counts, hml_vector_zeros(n_states));
        a = a + 1;
    }
    i = 0;
    while (i < len(states)) {
        let s = states[i];
        let a = actions[i];
        let ns = next_states[i];
        P[a][s][ns] = P[a][s][ns] + 1.0;
        counts[a][s] = counts[a][s] + 1.0;
        i = i + 1;
    }
    a = 0;
    while (a < n_actions) {
        let s = 0;
        while (s < n_states) {
            if (counts[a][s] > 0) {
                let ns = 0;
                while (ns < n_states) {
                    P[a][s][ns] = P[a][s][ns] * 1.0 / counts[a][s];
                    ns = ns + 1;
                }
            }
            s = s + 1;
        }
        a = a + 1;
    }
    return P;
}

fn hml_mdp_reward_function(states, actions, rewards) {
    let n_states = 0;
    let n_actions = 0;
    let i = 0;
    while (i < len(states)) {
        if (states[i] > n_states) { n_states = states[i]; }
        if (actions[i] > n_actions) { n_actions = actions[i]; }
        i = i + 1;
    }
    n_states = n_states + 1;
    n_actions = n_actions + 1;
    let R = hml_matrix_zeros(n_actions, n_states);
    let counts = hml_matrix_zeros(n_actions, n_states);
    i = 0;
    while (i < len(states)) {
        let s = states[i];
        let a = actions[i];
        R[a][s] = R[a][s] + rewards[i];
        counts[a][s] = counts[a][s] + 1.0;
        i = i + 1;
    }
    let a = 0;
    while (a < n_actions) {
        let s = 0;
        while (s < n_states) {
            if (counts[a][s] > 0) {
                R[a][s] = R[a][s] * 1.0 / counts[a][s];
            }
            s = s + 1;
        }
        a = a + 1;
    }
    return R;
}

fn hml_gridworld_create(rows, cols, goal, obstacles) {
    let env = {};
    env["rows"] = rows;
    env["cols"] = cols;
    env["goal"] = goal;
    env["obstacles"] = obstacles;
    env["state"] = [0, 0];
    return env;
}
# ═══════════════════════════════════════════════════════════════════════════
# SECTION 27: Bayesian Methods
# ═══════════════════════════════════════════════════════════════════════════

fn hml_naive_bayes_gaussian_fit(X, y) {
    let n_samples = len(X);
    let n_features = len(X[0]);
    let classes = hml_unique(y);
    let n_classes = len(classes);
    let model = {};
    model["classes"] = classes;
    model["priors"] = [];
    model["means"] = [];
    model["vars"] = [];
    let ci = 0;
    while (ci < n_classes) {
        let c = classes[ci];
        let count = 0;
        let i = 0;
        while (i < n_samples) {
            if (y[i] == c) { count = count + 1; }
            i = i + 1;
        }
        push(model["priors"], count * 1.0 / n_samples);
        let class_X = [];
        i = 0;
        while (i < n_samples) {
            if (y[i] == c) { push(class_X, X[i]); }
            i = i + 1;
        }
        let means = [];
        let vars = [];
        let fj = 0;
        while (fj < n_features) {
            let s = 0.0;
            let k = 0;
            while (k < len(class_X)) {
                s = s + class_X[k][fj];
                k = k + 1;
            }
            push(means, s * 1.0 / count);
            s = 0.0;
            k = 0;
            while (k < len(class_X)) {
                let diff = class_X[k][fj] - means[fj];
                s = s + diff * diff;
                k = k + 1;
            }
            push(vars, s * 1.0 / count + 0.000000001);
            fj = fj + 1;
        }
        push(model["means"], means);
        push(model["vars"], vars);
        ci = ci + 1;
    }
    return model;
}

fn hml_naive_bayes_gaussian_predict(model, X) {
    let n_classes = len(model["classes"]);
    let n_samples = len(X);
    let n_features = len(X[0]);
    let preds = [];
    let i = 0;
    while (i < n_samples) {
        let best_class = model["classes"][0];
        let best_log_prob = -1000000000;
        let ci = 0;
        while (ci < n_classes) {
            let log_prob = math_log(model["priors"][ci]);
            let fj = 0;
            while (fj < n_features) {
                let mean = model["means"][ci][fj];
                let var = model["vars"][ci][fj];
                let diff = X[i][fj] - mean;
                log_prob = log_prob - 0.5 * math_log(2.0 * 3.141592653589793 * var) - (diff * diff) * 1.0 / (2.0 * var);
                fj = fj + 1;
            }
            if (log_prob > best_log_prob) {
                best_log_prob = log_prob;
                best_class = model["classes"][ci];
            }
            ci = ci + 1;
        }
        push(preds, best_class);
        i = i + 1;
    }
    return preds;
}

fn hml_naive_bayes_gaussian_predict_proba(model, X) {
    let n_classes = len(model["classes"]);
    let n_samples = len(X);
    let n_features = len(X[0]);
    let probs = [];
    let i = 0;
    while (i < n_samples) {
        let row = [];
        let total = 0.0;
        let ci = 0;
        while (ci < n_classes) {
            let log_prob = math_log(model["priors"][ci]);
            let fj = 0;
            while (fj < n_features) {
                let mean = model["means"][ci][fj];
                let var = model["vars"][ci][fj];
                let diff = X[i][fj] - mean;
                log_prob = log_prob - 0.5 * math_log(2.0 * 3.141592653589793 * var) - (diff * diff) * 1.0 / (2.0 * var);
                fj = fj + 1;
            }
            let prob = math_exp(log_prob);
            push(row, prob);
            total = total + prob;
            ci = ci + 1;
        }
        if (total > 0) {
            let ci = 0;
            while (ci < n_classes) {
                row[ci] = row[ci] / total;
                ci = ci + 1;
            }
        }
        push(probs, row);
        i = i + 1;
    }
    return probs;
}

fn hml_naive_bayes_multinomial_fit(X, y) {
    let n_samples = len(X);
    let n_features = len(X[0]);
    let classes = hml_unique(y);
    let n_classes = len(classes);
    let model = {};
    model["classes"] = classes;
    model["priors"] = [];
    model["feature_probs"] = [];
    let ci = 0;
    while (ci < n_classes) {
        let c = classes[ci];
        let count = 0;
        let feature_sums = hml_vector_zeros(n_features);
        let i = 0;
        while (i < n_samples) {
            if (y[i] == c) {
                count = count + 1;
                let fj = 0;
                while (fj < n_features) {
                    feature_sums[fj] = feature_sums[fj] + X[i][fj];
                    fj = fj + 1;
                }
            }
            i = i + 1;
        }
        push(model["priors"], count * 1.0 / n_samples);
        let total = 0.0;
        let fj = 0;
        while (fj < n_features) {
            total = total + feature_sums[fj];
            fj = fj + 1;
        }
        let probs = [];
        fj = 0;
        while (fj < n_features) {
            push(probs, (feature_sums[fj] + 1.0) / (total + n_features));
            fj = fj + 1;
        }
        push(model["feature_probs"], probs);
        ci = ci + 1;
    }
    return model;
}

fn hml_naive_bayes_multinomial_predict(model, X) {
    let n_classes = len(model["classes"]);
    let n_samples = len(X);
    let n_features = len(X[0]);
    let preds = [];
    let i = 0;
    while (i < n_samples) {
        let best_class = model["classes"][0];
        let best_log_prob = -1000000000;
        let ci = 0;
        while (ci < n_classes) {
            let log_prob = math_log(model["priors"][ci]);
            let fj = 0;
            while (fj < n_features) {
                let p = model["feature_probs"][ci][fj];
                if (X[i][fj] > 0 and p > 0) {
                    log_prob = log_prob + X[i][fj] * math_log(p);
                }
                fj = fj + 1;
            }
            if (log_prob > best_log_prob) {
                best_log_prob = log_prob;
                best_class = model["classes"][ci];
            }
            ci = ci + 1;
        }
        push(preds, best_class);
        i = i + 1;
    }
    return preds;
}

fn hml_naive_bayes_bernoulli_fit(X, y) {
    let n_samples = len(X);
    let n_features = len(X[0]);
    let classes = hml_unique(y);
    let n_classes = len(classes);
    let model = {};
    model["classes"] = classes;
    model["priors"] = [];
    model["feature_probs"] = [];
    let ci = 0;
    while (ci < n_classes) {
        let c = classes[ci];
        let count = 0;
        let feature_counts = hml_vector_zeros(n_features);
        let i = 0;
        while (i < n_samples) {
            if (y[i] == c) {
                count = count + 1;
                let fj = 0;
                while (fj < n_features) {
                    if (X[i][fj] > 0) { feature_counts[fj] = feature_counts[fj] + 1.0; }
                    fj = fj + 1;
                }
            }
            i = i + 1;
        }
        push(model["priors"], count * 1.0 / n_samples);
        let probs = [];
        let fj = 0;
        while (fj < n_features) {
            push(probs, (feature_counts[fj] + 1.0) / (count + 2.0));
            fj = fj + 1;
        }
        push(model["feature_probs"], probs);
        ci = ci + 1;
    }
    return model;
}

fn hml_naive_bayes_bernoulli_predict(model, X) {
    let n_classes = len(model["classes"]);
    let n_samples = len(X);
    let n_features = len(X[0]);
    let preds = [];
    let i = 0;
    while (i < n_samples) {
        let best_class = model["classes"][0];
        let best_log_prob = -1000000000;
        let ci = 0;
        while (ci < n_classes) {
            let log_prob = math_log(model["priors"][ci]);
            let fj = 0;
            while (fj < n_features) {
                let p = model["feature_probs"][ci][fj];
                if (X[i][fj] > 0) {
                    log_prob = log_prob + math_log(p);
                } else {
                    log_prob = log_prob + math_log(1.0 - p);
                }
                fj = fj + 1;
            }
            if (log_prob > best_log_prob) {
                best_log_prob = log_prob;
                best_class = model["classes"][ci];
            }
            ci = ci + 1;
        }
        push(preds, best_class);
        i = i + 1;
    }
    return preds;
}

fn hml_bayesian_ucb(mu, sigma, t) {
    return mu + sigma * math_sqrt(2.0 * math_log(t));
}

fn hml_beta_distribution_sample(alpha, beta) {
    let x = 0.0;
    let y = 0.0;
    let i = 0;
    while (i < 12) {
        x = x + hml_random();
        y = y + hml_random();
        i = i + 1;
    }
    x = x - 6.0;
    y = y - 6.0;
    return x * x / (x * x + y * y + 0.000000001);
}

fn hml_dirichlet_distribution_sample(alpha) {
    let n = len(alpha);
    let samples = [];
    let i = 0;
    while (i < n) {
        let s = 0.0;
        let j = 0;
        while (j < 12) {
            s = s + hml_random();
            j = j + 1;
        }
        s = s - 6.0;
        push(samples, s * s * alpha[i]);
        i = i + 1;
    }
    let total = 0.0;
    i = 0;
    while (i < n) { total = total + samples[i]; i = i + 1; }
    if (total > 0) {
        i = 0;
        while (i < n) { samples[i] = samples[i] / total; i = i + 1; }
    }
    return samples;
}

fn hml_gamma_distribution_sample(shape, scale) {
    let d = shape - 1.0 / 3.0;
    let c = 1.0 / math_sqrt(9.0 * d);
    while (true) {
        let x = 0.0;
        let v = 0.0;
        let i = 0;
        while (i < 12) {
            x = x + hml_random();
            v = v + hml_random();
            i = i + 1;
        }
        x = x - 6.0;
        v = v - 6.0;
        v = 1.0 + c * v;
        if (v <= 0) { continue; }
        v = v * v * v;
        let u = hml_random();
        if (u < 1.0 - 0.0331 * (x * x) * (x * x)) { return d * v * scale; }
        if (math_log(u) < 0.5 * x * x + d * (1.0 - v + math_log(v))) { return d * v * scale; }
    }
    return 0.0;
}

fn hml_gaussian_process_rbf_kernel(X1, X2, length_scale) {
    let n1 = len(X1);
    let n2 = len(X2);
    let K = hml_matrix_zeros(n1, n2);
    let i = 0;
    while (i < n1) {
        let j = 0;
        while (j < n2) {
            let sq_dist = 0.0;
            let d = 0;
            while (d < len(X1[0])) {
                let diff = X1[i][d] - X2[j][d];
                sq_dist = sq_dist + diff * diff;
                d = d + 1;
            }
            K[i][j] = math_exp(-sq_dist / (2.0 * length_scale * length_scale));
            j = j + 1;
        }
        i = i + 1;
    }
    return K;
}

fn hml_gaussian_process_predict(X_train, y_train, X_test, kernel, noise) {
    let K = hml_gaussian_process_rbf_kernel(X_train, X_train, kernel);
    let n = len(K);
    let i = 0;
    while (i < n) {
        K[i][i] = K[i][i] + noise;
        i = i + 1;
    }
    let K_star = hml_gaussian_process_rbf_kernel(X_test, X_train, kernel);
    let K_star_star = hml_gaussian_process_rbf_kernel(X_test, X_test, kernel);
    let n_test = len(K_star);
    let n_train = len(K[0]);
    let means = hml_vector_zeros(n_test);
    let vars = hml_vector_zeros(n_test);
    i = 0;
    while (i < n_test) {
        let j = 0;
        let mean_i = 0.0;
        while (j < n_train) {
            mean_i = mean_i + K_star[i][j] * y_train[j];
            j = j + 1;
        }
        means[i] = mean_i * 1.0 / n_train;
        vars[i] = K_star_star[i][i] + noise;
        i = i + 1;
    }
    return {"mean": means, "var": vars};
}

fn hml_metropolis_hastings(target_log_prob, proposal_std, n_samples, initial) {
    let samples = [];
    let current = initial;
    let current_log_prob = target_log_prob(current);
    let i = 0;
    while (i < n_samples) {
        let proposal = [];
        let j = 0;
        while (j < len(current)) {
            push(proposal, current[j] + (hml_random() - 0.5) * 2.0 * proposal_std);
            j = j + 1;
        }
        let proposal_log_prob = target_log_prob(proposal);
        let accept_ratio = math_exp(proposal_log_prob - current_log_prob);
        if (hml_random() < accept_ratio) {
            current = proposal;
            current_log_prob = proposal_log_prob;
        }
        let copy = [];
        j = 0;
        while (j < len(current)) { push(copy, current[j]); j = j + 1; }
        push(samples, copy);
        i = i + 1;
    }
    return samples;
}

fn hml_hamiltonian_monte_carlo(log_prob, grad_log_prob, n_samples, initial) {
    let samples = [];
    let current = initial;
    let L = 10;
    let eps = 0.01;
    let s = 0;
    while (s < n_samples) {
        let q = [];
        let j = 0;
        while (j < len(current)) { push(q, current[j]); j = j + 1; }
        let p = [];
        j = 0;
        while (j < len(current)) { push(p, (hml_random() - 0.5) * 2.0); j = j + 1; }
        let current_p = [];
        j = 0;
        while (j < len(p)) { push(current_p, p[j]); j = j + 1; }
        let grad = grad_log_prob(q);
        j = 0;
        while (j < len(p)) { p[j] = p[j] - 0.5 * eps * grad[j]; j = j + 1; }
        let step = 0;
        while (step < L) {
            j = 0;
            while (j < len(q)) { q[j] = q[j] + eps * p[j]; j = j + 1; }
            grad = grad_log_prob(q);
            if (step < L - 1) {
                j = 0;
                while (j < len(p)) { p[j] = p[j] - eps * grad[j]; j = j + 1; }
            }
            step = step + 1;
        }
        grad = grad_log_prob(q);
        j = 0;
        while (j < len(p)) { p[j] = p[j] - 0.5 * eps * grad[j]; j = j + 1; }
        j = 0;
        while (j < len(p)) { p[j] = -p[j]; j = j + 1; }
        let current_energy = 0.0;
        j = 0;
        while (j < len(current)) { current_energy = current_energy + 0.5 * current_p[j] * current_p[j]; j = j + 1; }
        let proposed_energy = 0.0;
        j = 0;
        while (j < len(p)) { proposed_energy = proposed_energy + 0.5 * p[j] * p[j]; j = j + 1; }
        let accept_prob = math_exp(-log_prob(q) + log_prob(current) - proposed_energy + current_energy);
        if (hml_random() < accept_prob) { current = q; }
        let copy = [];
        j = 0;
        while (j < len(current)) { push(copy, current[j]); j = j + 1; }
        push(samples, copy);
        s = s + 1;
    }
    return samples;
}

fn hml_bayesian_bootstrap(data, n_samples) {
    let n = len(data);
    let result = [];
    let s = 0;
    while (s < n_samples) {
        let dirichlet = [];
        let i = 0;
        while (i < n) {
            let val = 0.0;
            let j = 0;
            while (j < 12) { val = val + hml_random(); j = j + 1; }
            val = val - 6.0;
            push(dirichlet, math_fabs(val) + 0.01);
            i = i + 1;
        }
        let total = 0.0;
        i = 0;
        while (i < n) { total = total + dirichlet[i]; i = i + 1; }
        i = 0;
        while (i < n) { dirichlet[i] = dirichlet[i] / total; i = i + 1; }
        let weighted = 0.0;
        i = 0;
        while (i < n) { weighted = weighted + dirichlet[i] * data[i]; i = i + 1; }
        push(result, weighted);
        s = s + 1;
    }
    return result;
}

fn hml_prior_predictive_check(prior_sampler, n_samples) {
    let samples = [];
    let i = 0;
    while (i < n_samples) {
        push(samples, prior_sampler());
        i = i + 1;
    }
    return samples;
}

fn hml_posterior_predictive_check(posterior_samples, likelihood, n_samples) {
    let n = len(posterior_samples);
    let predictions = [];
    let i = 0;
    while (i < n_samples) {
        let idx = hml_randint(0, n - 1);
        push(predictions, likelihood(posterior_samples[idx]));
        i = i + 1;
    }
    return predictions;
}

fn hml_bayes_factor(log_likelihood_H0, log_likelihood_H1) {
    return math_exp(log_likelihood_H0 - log_likelihood_H1);
}

fn hml_bayesian_linear_regression_fit(X, y, prior_precision, noise_precision) {
    let n = len(X);
    let d = len(X[0]);
    let XtX = hml_matrix_zeros(d, d);
    let i = 0;
    while (i < d) {
        let j = 0;
        while (j < d) {
            let s = 0.0;
            let k = 0;
            while (k < n) { s = s + X[k][i] * X[k][j]; k = k + 1; }
            XtX[i][j] = s * noise_precision;
            j = j + 1;
        }
        XtX[i][i] = XtX[i][i] + prior_precision;
        i = i + 1;
    }
    let Xty = hml_vector_zeros(d);
    i = 0;
    while (i < d) {
        let s = 0.0;
        let k = 0;
        while (k < n) { s = s + X[k][i] * y[k]; k = k + 1; }
        Xty[i] = s * noise_precision;
        i = i + 1;
    }
    let S_inv = XtX;
    let w_mean = hml_vector_zeros(d);
    i = 0;
    while (i < d) { w_mean[i] = Xty[i]; i = i + 1; }
    return {"mean": w_mean, "precision": S_inv};
}

fn hml_bayesian_linear_regression_predict(model, X) {
    let w = model["mean"];
    let n = len(X);
    let preds = [];
    let i = 0;
    while (i < n) {
        let s = 0.0;
        let j = 0;
        while (j < len(X[0])) { s = s + X[i][j] * w[j]; j = j + 1; }
        push(preds, s);
        i = i + 1;
    }
    return preds;
}

fn hml_conjugate_prior_normal_normal(data, prior_mu, prior_tau, known_sigma) {
    let n = len(data);
    let data_mean = hml_mean(data);
    let sigma2 = known_sigma * known_sigma;
    let posterior_precision = prior_tau + n * 1.0 / sigma2;
    let posterior_mu = (prior_tau * prior_mu + n * data_mean * 1.0 / sigma2) / posterior_precision;
    let posterior_tau = posterior_precision;
    return {"mu": posterior_mu, "tau": posterior_tau};
}

fn hml_conjugate_prior_beta_binomial(successes, trials, alpha_prior, beta_prior) {
    let alpha_post = alpha_prior + successes;
    let beta_post = beta_prior + trials - successes;
    return {"alpha": alpha_post, "beta": beta_post};
}

fn hml_expected_improvement(mu, sigma, best_y, xi) {
    let n = len(mu);
    let ei = hml_vector_zeros(n);
    let i = 0;
    while (i < n) {
        if (sigma[i] > 0) {
            let z = (mu[i] - best_y - xi) / sigma[i];
            ei[i] = (mu[i] - best_y - xi) * (1.0 / (1.0 + math_exp(-z))) + sigma[i] * math_exp(-z * z * 0.5) / math_sqrt(2.0 * 3.141592653589793);
        }
        i = i + 1;
    }
    return ei;
}

fn hml_probability_improvement(mu, sigma, best_y, xi) {
    let n = len(mu);
    let pi = hml_vector_zeros(n);
    let i = 0;
    while (i < n) {
        if (sigma[i] > 0) {
            let z = (mu[i] - best_y - xi) / sigma[i];
            pi[i] = 1.0 / (1.0 + math_exp(-z));
        }
        i = i + 1;
    }
    return pi;
}
