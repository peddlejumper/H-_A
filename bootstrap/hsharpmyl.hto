# ── KNNRegressor ──
class KNNRegressor {
    let n_neighbors = 5;
    let weights = "uniform";
    let X_train = [];
    let y_train = [];

    fn init_knn_regressor(n_neighbors, weights) {
        if (n_neighbors != nullptr) { self.n_neighbors = n_neighbors; }
        if (weights != nullptr) { self.weights = weights; }
        self.X_train = [];
        self.y_train = [];
        return 0;
    }

    fn fit(X, y) {
        self.X_train = X;
        self.y_train = y;
        return 0;
    }

    fn predict(X) {
        let n = len(X);
        let preds = [];
        let i = 0;
        while (i < n) {
            let k = self.n_neighbors;
            let distances = [];
            let j = 0;
            while (j < len(self.X_train)) {
                let dist = 0.0;
                let l = 0;
                while (l < len(X[i])) { let d = X[i][l] - self.X_train[j][l]; dist = dist + d * d; l = l + 1; }
                push(distances, {"dist": math_sqrt(dist), "idx": j});
                j = j + 1;
            }
            let a = 0;
            while (a < len(distances) - 1) {
                let b = 0;
                while (b < len(distances) - a - 1) {
                    if (distances[b]["dist"] > distances[b + 1]["dist"]) {
                        let tmp = distances[b];
                        distances[b] = distances[b + 1];
                        distances[b + 1] = tmp;
                    }
                    b = b + 1;
                }
                a = a + 1;
            }
            let total = 0.0;
            let total_w = 0.0;
            j = 0;
            while (j < k and j < len(distances)) {
                let w = 1.0;
                if (self.weights == "distance" and distances[j]["dist"] > 0.000000001) {
                    w = 1.0 / distances[j]["dist"];
                }
                total = total + w * self.y_train[distances[j]["idx"]];
                total_w = total_w + w;
                j = j + 1;
            }
            if (total_w > 0) { push(preds, total / total_w); }
            else { push(preds, 0.0); }
            i = i + 1;
        }
        return preds;
    }

    fn score(X, y) { return r2_score(y, self.predict(X)); }
}

# ── RadiusNeighborsClassifier ──
class RadiusNeighborsClassifier {
    let radius = 1.0;
    let outlier_label = -1;
    let X_train = [];
    let y_train = [];

    fn init_radius_neighbors_clf(radius, outlier_label) {
        if (radius != nullptr) { self.radius = radius; }
        if (outlier_label != nullptr) { self.outlier_label = outlier_label; }
        self.X_train = [];
        self.y_train = [];
        return 0;
    }

    fn fit(X, y) {
        self.X_train = X;
        self.y_train = y;
        return 0;
    }

    fn predict(X) {
        let n = len(X);
        let preds = [];
        let i = 0;
        while (i < n) {
            let votes = {};
            let j = 0;
            while (j < len(self.X_train)) {
                let dist = 0.0;
                let l = 0;
                while (l < len(X[i])) { let d = X[i][l] - self.X_train[j][l]; dist = dist + d * d; l = l + 1; }
                dist = math_sqrt(dist);
                if (dist <= self.radius) {
                    let v = self.y_train[j];
                    let c = 0;
                    if (dict_keys(votes) != []) {
                        let keys = dict_keys(votes);
                        let found = 0;
                        let kk = 0;
                        while (kk < len(keys)) { if (keys[kk] == v) { found = 1; } kk = kk + 1; }
                        if (found == 1) { c = votes[v]; }
                    }
                    votes[v] = c + 1;
                }
                j = j + 1;
            }
            if (dict_keys(votes) == []) { push(preds, self.outlier_label); }
            else {
                let best = 0;
                let best_c = 0;
                let keys = dict_keys(votes);
                let kk = 0;
                while (kk < len(keys)) {
                    if (votes[keys[kk]] > best_c) { best_c = votes[keys[kk]]; best = keys[kk]; }
                    kk = kk + 1;
                }
                push(preds, best);
            }
            i = i + 1;
        }
        return preds;
    }

    fn score(X, y) { return accuracy_score(self.predict(X), y); }
}

# ── RadiusNeighborsRegressor ──
class RadiusNeighborsRegressor {
    let radius = 1.0;
    let X_train = [];
    let y_train = [];

    fn init_radius_neighbors_reg(radius) {
        if (radius != nullptr) { self.radius = radius; }
        self.X_train = [];
        self.y_train = [];
        return 0;
    }

    fn fit(X, y) {
        self.X_train = X;
        self.y_train = y;
        return 0;
    }

    fn predict(X) {
        let n = len(X);
        let preds = [];
        let i = 0;
        while (i < n) {
            let total = 0.0;
            let count = 0;
            let j = 0;
            while (j < len(self.X_train)) {
                let dist = 0.0;
                let l = 0;
                while (l < len(X[i])) { let d = X[i][l] - self.X_train[j][l]; dist = dist + d * d; l = l + 1; }
                dist = math_sqrt(dist);
                if (dist <= self.radius) { total = total + self.y_train[j]; count = count + 1; }
                j = j + 1;
            }
            if (count > 0) { push(preds, total / count); }
            else { push(preds, 0.0); }
            i = i + 1;
        }
        return preds;
    }

    fn score(X, y) { return r2_score(y, self.predict(X)); }
}

# ── NearestCentroid ──
class NearestCentroid {
    let centroids = [];
    let classes = [];

    fn init_nearest_centroid() {
        self.centroids = [];
        self.classes = [];
        return 0;
    }

    fn fit(X, y) {
        let n = len(X);
        let d = len(X[0]);
        self.classes = hml_unique(y);
        self.centroids = [];
        let c = 0;
        while (c < len(self.classes)) {
            let centroid = hml_vector_zeros(d);
            let count = 0;
            let i = 0;
            while (i < n) {
                if (y[i] == self.classes[c]) {
                    let j = 0;
                    while (j < d) { centroid[j] = centroid[j] + X[i][j]; j = j + 1; }
                    count = count + 1;
                }
                i = i + 1;
            }
            if (count > 0) {
                let j = 0;
                while (j < d) { centroid[j] = centroid[j] / count; j = j + 1; }
            }
            push(self.centroids, centroid);
            c = c + 1;
        }
        return 0;
    }

    fn predict(X) {
        let n = len(X);
        let d = len(X[0]);
        let preds = [];
        let i = 0;
        while (i < n) {
            let best_dist = 1000000000.0;
            let best_c = self.classes[0];
            let c = 0;
            while (c < len(self.classes)) {
                let dist = 0.0;
                let j = 0;
                while (j < d) { let diff = X[i][j] - self.centroids[c][j]; dist = dist + diff * diff; j = j + 1; }
                if (dist < best_dist) { best_dist = dist; best_c = self.classes[c]; }
                c = c + 1;
            }
            push(preds, best_c);
            i = i + 1;
        }
        return preds;
    }

    fn score(X, y) { return accuracy_score(self.predict(X), y); }
}

# ── LVQ ──
class LVQ {
    let n_prototypes = 3;
    let lr = 0.01;
    let max_iter = 100;
    let prototypes = [];
    let prototype_labels = [];

    fn init_lvq(n_prototypes, lr, max_iter) {
        if (n_prototypes != nullptr) { self.n_prototypes = n_prototypes; }
        if (lr != nullptr) { self.lr = lr; }
        if (max_iter != nullptr) { self.max_iter = max_iter; }
        self.prototypes = [];
        self.prototype_labels = [];
        return 0;
    }

    fn fit(X, y) {
        let n = len(X);
        let d = len(X[0]);
        let classes = hml_unique(y);
        let p_per_class = math_floor(self.n_prototypes * 1.0 / len(classes));
        if (p_per_class < 1) { p_per_class = 1; }
        let c = 0;
        while (c < len(classes)) {
            let p = 0;
            while (p < p_per_class) {
                let idx = 0;
                let i = 0;
                while (i < n) { if (y[i] == classes[c]) { idx = i; } i = i + 1; }
                let proto = [];
                let j = 0;
                while (j < d) { push(proto, X[idx][j] + hml_random() * 0.1 - 0.05); j = j + 1; }
                push(self.prototypes, proto);
                push(self.prototype_labels, classes[c]);
                p = p + 1;
            }
            c = c + 1;
        }
        let iter = 0;
        while (iter < self.max_iter) {
            let i = 0;
            while (i < n) {
                let best_dist = 1000000000.0;
                let best_idx = 0;
                let p = 0;
                while (p < len(self.prototypes)) {
                    let dist = 0.0;
                    let j = 0;
                    while (j < d) { let diff = X[i][j] - self.prototypes[p][j]; dist = dist + diff * diff; j = j + 1; }
                    if (dist < best_dist) { best_dist = dist; best_idx = p; }
                    p = p + 1;
                }
                let sign = 1.0;
                if (self.prototype_labels[best_idx] != y[i]) { sign = -1.0; }
                let j = 0;
                while (j < d) {
                    self.prototypes[best_idx][j] = self.prototypes[best_idx][j] + self.lr * sign * (X[i][j] - self.prototypes[best_idx][j]);
                    j = j + 1;
                }
                i = i + 1;
            }
            self.lr = self.lr * 0.99;
            iter = iter + 1;
        }
        return 0;
    }

    fn predict(X) {
        let n = len(X);
        let d = len(X[0]);
        let preds = [];
        let i = 0;
        while (i < n) {
            let best_dist = 1000000000.0;
            let best_idx = 0;
            let p = 0;
            while (p < len(self.prototypes)) {
                let dist = 0.0;
                let j = 0;
                while (j < d) { let diff = X[i][j] - self.prototypes[p][j]; dist = dist + diff * diff; j = j + 1; }
                if (dist < best_dist) { best_dist = dist; best_idx = p; }
                p = p + 1;
            }
            push(preds, self.prototype_labels[best_idx]);
            i = i + 1;
        }
        return preds;
    }

    fn score(X, y) { return accuracy_score(self.predict(X), y); }
}

# ── KMedoids ──
class KMedoids {
    let n_clusters = 3;
    let max_iter = 100;
    let medoids = [];
    let labels = [];

    fn init_kmedoids(n_clusters, max_iter) {
        if (n_clusters != nullptr) { self.n_clusters = n_clusters; }
        if (max_iter != nullptr) { self.max_iter = max_iter; }
        self.medoids = [];
        self.labels = [];
        return 0;
    }

    fn fit(X) {
        let n = len(X);
        let d = len(X[0]);
        let k = self.n_clusters;
        if (k > n) { k = n; }
        self.medoids = [];
        let used = {};
        let i = 0;
        while (i < k) {
            let idx = hml_randint(0, n - 1);
            let start = 0;
            while (start < 100) {
                let found = 0;
                if (dict_keys(used) != []) {
                    let keys = dict_keys(used);
                    let kk = 0;
                    while (kk < len(keys)) { if (keys[kk] == idx) { found = 1; } kk = kk + 1; }
                }
                if (found == 0) { start = 100; }
                else { idx = hml_randint(0, n - 1); start = start + 1; }
            }
            used[idx] = 1;
            let medoid = [];
            let j = 0;
            while (j < d) { push(medoid, X[idx][j]); j = j + 1; }
            push(self.medoids, medoid);
            i = i + 1;
        }
        self.labels = [];
        i = 0;
        while (i < n) { push(self.labels, 0); i = i + 1; }
        let iter = 0;
        while (iter < self.max_iter) {
            i = 0;
            while (i < n) {
                let best_dist = 1000000000.0;
                let best_c = 0;
                let c = 0;
                while (c < k) {
                    let dist = 0.0;
                    let j = 0;
                    while (j < d) { let diff = X[i][j] - self.medoids[c][j]; dist = dist + diff * diff; j = j + 1; }
                    if (dist < best_dist) { best_dist = dist; best_c = c; }
                    c = c + 1;
                }
                self.labels[i] = best_c;
                i = i + 1;
            }
            let c = 0;
            while (c < k) {
                let best_cost = 1000000000.0;
                let best_m = 0;
                i = 0;
                while (i < n) {
                    if (self.labels[i] == c) {
                        let cost = 0.0;
                        let m = 0;
                        while (m < n) {
                            if (self.labels[m] == c) {
                                let dist = 0.0;
                                let j = 0;
                                while (j < d) { let diff = X[i][j] - X[m][j]; dist = dist + diff * diff; j = j + 1; }
                                cost = cost + dist;
                            }
                            m = m + 1;
                        }
                        if (cost < best_cost) { best_cost = cost; best_m = i; }
                    }
                    i = i + 1;
                }
                let j = 0;
                while (j < d) { self.medoids[c][j] = X[best_m][j]; j = j + 1; }
                c = c + 1;
            }
            iter = iter + 1;
        }
        return 0;
    }

    fn predict(X) {
        let n = len(X);
        let d = len(X[0]);
        let k = len(self.medoids);
        let preds = [];
        let i = 0;
        while (i < n) {
            let best_dist = 1000000000.0;
            let best_c = 0;
            let c = 0;
            while (c < k) {
                let dist = 0.0;
                let j = 0;
                while (j < d) { let diff = X[i][j] - self.medoids[c][j]; dist = dist + diff * diff; j = j + 1; }
                if (dist < best_dist) { best_dist = dist; best_c = c; }
                c = c + 1;
            }
            push(preds, best_c);
            i = i + 1;
        }
        return preds;
    }
}

# ── BallTree ──
class BallTree {
    let leaf_size = 40;
    let root = nullptr;
    let data = [];
    let indices = [];

    fn init_ball_tree(leaf_size) {
        if (leaf_size != nullptr) { self.leaf_size = leaf_size; }
        self.root = nullptr;
        self.data = [];
        self.indices = [];
        return 0;
    }

    fn fit(X) {
        self.data = X;
        let n = len(X);
        self.indices = [];
        let i = 0;
        while (i < n) { push(self.indices, i); i = i + 1; }
        self.root = self.build_node(0, n);
        return 0;
    }

    fn build_node(start, end) {
        let n = end - start;
        if (n <= self.leaf_size) {
            let pts = [];
            let i = start;
            while (i < end) { push(pts, self.indices[i]); i = i + 1; }
            return {"type": "leaf", "points": pts};
        }
        let d = len(self.data[0]);
        let centroid = hml_vector_zeros(d);
        let i = start;
        while (i < end) {
            let j = 0;
            while (j < d) { centroid[j] = centroid[j] + self.data[self.indices[i]][j]; j = j + 1; }
            i = i + 1;
        }
        let j = 0;
        while (j < d) { centroid[j] = centroid[j] / n; j = j + 1; }
        let radius = 0.0;
        i = start;
        while (i < end) {
            let dist = 0.0;
            j = 0;
            while (j < d) { let diff = self.data[self.indices[i]][j] - centroid[j]; dist = dist + diff * diff; j = j + 1; }
            if (dist > radius) { radius = dist; }
            i = i + 1;
        }
        radius = math_sqrt(radius);
        let mid = start + math_floor(n / 2);
        return {
            "type": "node",
            "centroid": centroid,
            "radius": radius,
            "left": self.build_node(start, mid),
            "right": self.build_node(mid, end)
        };
    }

    fn query(x, k) {
        return self.query_node(self.root, x, k);
    }

    fn query_node(node, x, k) {
        if (node["type"] == "leaf") {
            let results = [];
            let i = 0;
            let d = len(x);
            while (i < len(node["points"])) {
                let idx = node["points"][i];
                let dist = 0.0;
                let j = 0;
                while (j < d) { let diff = x[j] - self.data[idx][j]; dist = dist + diff * diff; j = j + 1; }
                push(results, {"idx": idx, "dist": math_sqrt(dist)});
                i = i + 1;
            }
            let a = 0;
            while (a < len(results) - 1) {
                let b = 0;
                while (b < len(results) - a - 1) {
                    if (results[b]["dist"] > results[b + 1]["dist"]) {
                        let tmp = results[b];
                        results[b] = results[b + 1];
                        results[b + 1] = tmp;
                    }
                    b = b + 1;
                }
                a = a + 1;
            }
            let top = [];
            i = 0;
            while (i < k and i < len(results)) { push(top, results[i]); i = i + 1; }
            return top;
        }
        return self.query_node(node["left"], x, k);
    }
}

# ── KDTree ──
class KDTree {
    let leaf_size = 40;
    let root = nullptr;
    let data = [];

    fn init_kd_tree(leaf_size) {
        if (leaf_size != nullptr) { self.leaf_size = leaf_size; }
        self.root = nullptr;
        self.data = [];
        return 0;
    }

    fn fit(X) {
        self.data = X;
        let indices = [];
        let i = 0;
        while (i < len(X)) { push(indices, i); i = i + 1; }
        self.root = self.build_kd_node(indices, 0);
        return 0;
    }

    fn build_kd_node(indices, depth) {
        let n = len(indices);
        if (n <= self.leaf_size) { return {"type": "leaf", "points": indices}; }
        let d = len(self.data[0]);
        let axis = depth % d;
        let vals = [];
        let i = 0;
        while (i < n) { push(vals, {"val": self.data[indices[i]][axis], "idx": indices[i]}); i = i + 1; }
        let a = 0;
        while (a < n - 1) {
            let b = 0;
            while (b < n - a - 1) {
                if (vals[b]["val"] > vals[b + 1]["val"]) {
                    let tmp = vals[b];
                    vals[b] = vals[b + 1];
                    vals[b + 1] = tmp;
                }
                b = b + 1;
            }
            a = a + 1;
        }
        let sorted_idx = [];
        i = 0;
        while (i < n) { push(sorted_idx, vals[i]["idx"]); i = i + 1; }
        let mid = math_floor(n / 2);
        let left_idx = [];
        i = 0; while (i < mid) { push(left_idx, sorted_idx[i]); i = i + 1; }
        let right_idx = [];
        i = mid + 1; while (i < n) { push(right_idx, sorted_idx[i]); i = i + 1; }
        return {
            "type": "node",
            "axis": axis,
            "threshold": self.data[sorted_idx[mid]][axis],
            "point": sorted_idx[mid],
            "left": self.build_kd_node(left_idx, depth + 1),
            "right": self.build_kd_node(right_idx, depth + 1)
        };
    }

    fn query(x, k) {
        let results = [];
        self.query_kd_node(self.root, x, k, results, 0);
        let a = 0;
        while (a < len(results) - 1) {
            let b = 0;
            while (b < len(results) - a - 1) {
                if (results[b]["dist"] > results[b + 1]["dist"]) {
                    let tmp = results[b];
                    results[b] = results[b + 1];
                    results[b + 1] = tmp;
                }
                b = b + 1;
            }
            a = a + 1;
        }
        let top = [];
        let i = 0;
        while (i < k and i < len(results)) { push(top, results[i]); i = i + 1; }
        return top;
    }

    fn query_kd_node(node, x, k, results, depth) {
        if (node["type"] == "leaf") {
            let i = 0;
            while (i < len(node["points"])) {
                let idx = node["points"][i];
                let dist = 0.0;
                let j = 0;
                while (j < len(x)) { let diff = x[j] - self.data[idx][j]; dist = dist + diff * diff; j = j + 1; }
                push(results, {"idx": idx, "dist": math_sqrt(dist)});
                i = i + 1;
            }
            return 0;
        }
        let axis = node["axis"];
        let val = x[axis];
        if (val <= node["threshold"]) {
            self.query_kd_node(node["left"], x, k, results, depth + 1);
        }
        else {
            self.query_kd_node(node["right"], x, k, results, depth + 1);
        }
        return 0;
    }
}

# ═══════════════════════════════════════════════════════════════════════════
# SECTION 46: Naive Bayes & Bayesian
# ═══════════════════════════════════════════════════════════════════════════

# ── GaussianNB ──
class GaussianNB {
    let priors = [];
    let means = [];
    let vars = [];
    let classes = [];

    fn init_gaussian_nb() {
        self.priors = [];
        self.means = [];
        self.vars = [];
        self.classes = [];
        return 0;
    }

    fn fit(X, y) {
        self.classes = hml_unique(y);
        let d = len(X[0]);
        let c = 0;
        while (c < len(self.classes)) {
            let count = 0;
            let mean = hml_vector_zeros(d);
            let var = hml_vector_zeros(d);
            let i = 0;
            while (i < len(X)) {
                if (y[i] == self.classes[c]) {
                    count = count + 1;
                    let j = 0;
                    while (j < d) { mean[j] = mean[j] + X[i][j]; j = j + 1; }
                }
                i = i + 1;
            }
            if (count > 0) {
                let j = 0;
                while (j < d) { mean[j] = mean[j] / count; j = j + 1; }
            }
            i = 0;
            while (i < len(X)) {
                if (y[i] == self.classes[c]) {
                    let j = 0;
                    while (j < d) { let diff = X[i][j] - mean[j]; var[j] = var[j] + diff * diff; j = j + 1; }
                }
                i = i + 1;
            }
            if (count > 0) {
                let j = 0;
                while (j < d) { var[j] = var[j] / count; j = j + 1; }
            }
            push(self.priors, count * 1.0 / len(X));
            push(self.means, mean);
            push(self.vars, var);
            c = c + 1;
        }
        return 0;
    }

    fn predict(X) {
        let n = len(X);
        let d = len(X[0]);
        let preds = [];
        let i = 0;
        while (i < n) {
            let best_score = -1000000000.0;
            let best_class = self.classes[0];
            let c = 0;
            while (c < len(self.classes)) {
                let score = math_log(self.priors[c] + 0.000000001);
                let j = 0;
                while (j < d) {
                    let var_j = self.vars[c][j];
                    if (var_j < 0.000000001) { var_j = 0.000000001; }
                    let diff = X[i][j] - self.means[c][j];
                    score = score - 0.5 * math_log(6.283185307 * var_j) - 0.5 * diff * diff / var_j;
                    j = j + 1;
                }
                if (score > best_score) { best_score = score; best_class = self.classes[c]; }
                c = c + 1;
            }
            push(preds, best_class);
            i = i + 1;
        }
        return preds;
    }

    fn score(X, y) { return accuracy_score(self.predict(X), y); }
}

# ── MultinomialNB ──
class MultinomialNB {
    let alpha = 1.0;
    let feature_log_prob = [];
    let class_log_prior = [];
    let classes = [];

    fn init_multinomial_nb(alpha) {
        if (alpha != nullptr) { self.alpha = alpha; }
        self.feature_log_prob = [];
        self.class_log_prior = [];
        self.classes = [];
        return 0;
    }

    fn fit(X, y) {
        self.classes = hml_unique(y);
        let n = len(X);
        let d = len(X[0]);
        let c = 0;
        while (c < len(self.classes)) {
            let count = 0;
            let feat_counts = hml_vector_zeros(d);
            let total = 0;
            let i = 0;
            while (i < n) {
                if (y[i] == self.classes[c]) {
                    count = count + 1;
                    let j = 0;
                    while (j < d) { feat_counts[j] = feat_counts[j] + X[i][j]; total = total + X[i][j]; j = j + 1; }
                }
                i = i + 1;
            }
            push(self.class_log_prior, math_log(count * 1.0 / n));
            let log_prob = [];
            let j = 0;
            while (j < d) { push(log_prob, math_log((feat_counts[j] + self.alpha) / (total + self.alpha * d))); j = j + 1; }
            push(self.feature_log_prob, log_prob);
            c = c + 1;
        }
        return 0;
    }

    fn predict(X) {
        let n = len(X);
        let d = len(X[0]);
        let preds = [];
        let i = 0;
        while (i < n) {
            let best_score = -1000000000.0;
            let best_class = self.classes[0];
            let c = 0;
            while (c < len(self.classes)) {
                let score = self.class_log_prior[c];
                let j = 0;
                while (j < d) { score = score + X[i][j] * self.feature_log_prob[c][j]; j = j + 1; }
                if (score > best_score) { best_score = score; best_class = self.classes[c]; }
                c = c + 1;
            }
            push(preds, best_class);
            i = i + 1;
        }
        return preds;
    }

    fn score(X, y) { return accuracy_score(self.predict(X), y); }
}

# ── BernoulliNB ──
class BernoulliNB {
    let alpha = 1.0;
    let binarize = 0.0;
    let feature_log_prob = [];
    let class_log_prior = [];
    let classes = [];

    fn init_bernoulli_nb(alpha, binarize) {
        if (alpha != nullptr) { self.alpha = alpha; }
        if (binarize != nullptr) { self.binarize = binarize; }
        self.feature_log_prob = [];
        self.class_log_prior = [];
        self.classes = [];
        return 0;
    }

    fn fit(X, y) {
        self.classes = hml_unique(y);
        let n = len(X);
        let d = len(X[0]);
        let c = 0;
        while (c < len(self.classes)) {
            let count = 0;
            let feat_counts = hml_vector_zeros(d);
            let i = 0;
            while (i < n) {
                if (y[i] == self.classes[c]) {
                    count = count + 1;
                    let j = 0;
                    while (j < d) {
                        if (X[i][j] > self.binarize) { feat_counts[j] = feat_counts[j] + 1; }
                        j = j + 1;
                    }
                }
                i = i + 1;
            }
            push(self.class_log_prior, math_log(count * 1.0 / n));
            let log_prob = [];
            let j = 0;
            while (j < d) {
                push(log_prob, math_log((feat_counts[j] + self.alpha) / (count + 2.0 * self.alpha)));
                j = j + 1;
            }
            push(self.feature_log_prob, log_prob);
            c = c + 1;
        }
        return 0;
    }

    fn predict(X) {
        let n = len(X);
        let d = len(X[0]);
        let preds = [];
        let i = 0;
        while (i < n) {
            let best_score = -1000000000.0;
            let best_class = self.classes[0];
            let c = 0;
            while (c < len(self.classes)) {
                let score = self.class_log_prior[c];
                let j = 0;
                while (j < d) {
                    let feat = 0;
                    if (X[i][j] > self.binarize) { feat = 1; }
                    if (feat == 1) {
                        score = score + self.feature_log_prob[c][j];
                    }
                    else {
                        score = score + math_log(1.0 - math_exp(self.feature_log_prob[c][j]) + 0.000000001);
                    }
                    j = j + 1;
                }
                if (score > best_score) { best_score = score; best_class = self.classes[c]; }
                c = c + 1;
            }
            push(preds, best_class);
            i = i + 1;
        }
        return preds;
    }

    fn score(X, y) { return accuracy_score(self.predict(X), y); }
}

# ── ComplementNB ──
class ComplementNB {
    let alpha = 1.0;
    let feature_log_prob = [];
    let class_log_prior = [];
    let classes = [];

    fn init_complement_nb(alpha) {
        if (alpha != nullptr) { self.alpha = alpha; }
        self.feature_log_prob = [];
        self.class_log_prior = [];
        self.classes = [];
        return 0;
    }

    fn fit(X, y) {
        self.classes = hml_unique(y);
        let n = len(X);
        let d = len(X[0]);
        let feat_all = hml_vector_zeros(d);
        let total_all = 0;
        let i = 0;
        while (i < n) {
            let j = 0;
            while (j < d) { feat_all[j] = feat_all[j] + X[i][j]; total_all = total_all + X[i][j]; j = j + 1; }
            i = i + 1;
        }
        let c = 0;
        while (c < len(self.classes)) {
            let count = 0;
            let feat_comp = hml_vector_zeros(d);
            let total_comp = 0;
            let i = 0;
            while (i < n) {
                if (y[i] != self.classes[c]) {
                    count = count + 1;
                    let j = 0;
                    while (j < d) { feat_comp[j] = feat_comp[j] + X[i][j]; total_comp = total_comp + X[i][j]; j = j + 1; }
                }
                i = i + 1;
            }
            push(self.class_log_prior, math_log(count * 1.0 / n));
            let log_prob = [];
            let j = 0;
            while (j < d) {
                let num = feat_comp[j] + self.alpha;
                let denom = total_comp + self.alpha * d;
                push(log_prob, math_log(num / denom));
                j = j + 1;
            }
            push(self.feature_log_prob, log_prob);
            c = c + 1;
        }
        return 0;
    }

    fn predict(X) {
        let n = len(X);
        let d = len(X[0]);
        let preds = [];
        let i = 0;
        while (i < n) {
            let best_score = 1000000000.0;
            let best_class = self.classes[0];
            let c = 0;
            while (c < len(self.classes)) {
                let score = -self.class_log_prior[c];
                let j = 0;
                while (j < d) { score = score - X[i][j] * self.feature_log_prob[c][j]; j = j + 1; }
                if (score < best_score) { best_score = score; best_class = self.classes[c]; }
                c = c + 1;
            }
            push(preds, best_class);
            i = i + 1;
        }
        return preds;
    }

    fn score(X, y) { return accuracy_score(self.predict(X), y); }
}

# ── CategoricalNB ──
class CategoricalNB {
    let alpha = 1.0;
    let feature_log_prob = [];
    let class_log_prior = [];
    let classes = [];

    fn init_categorical_nb(alpha) {
        if (alpha != nullptr) { self.alpha = alpha; }
        self.feature_log_prob = [];
        self.class_log_prior = [];
        self.classes = [];
        return 0;
    }

    fn fit(X, y) {
        self.classes = hml_unique(y);
        let n = len(X);
        let d = len(X[0]);
        let c = 0;
        while (c < len(self.classes)) {
            let count = 0;
            let feat_log = [];
            let j = 0;
            while (j < d) {
                let counts = {};
                let i = 0;
                while (i < n) {
                    if (y[i] == self.classes[c]) {
                        let val = X[i][j];
                        let cnt = 0;
                        if (dict_keys(counts) != []) {
                            let keys = dict_keys(counts);
                            let found = 0;
                            let kk = 0;
                            while (kk < len(keys)) { if (keys[kk] == val) { found = 1; } kk = kk + 1; }
                            if (found == 1) { cnt = counts[val]; }
                        }
                        counts[val] = cnt + 1;
                        count = count + 1;
                    }
                    i = i + 1;
                }
                let feat_probs = {};
                let keys = dict_keys(counts);
                let kk = 0;
                while (kk < len(keys)) {
                    feat_probs[keys[kk]] = (counts[keys[kk]] + self.alpha) / (count + self.alpha * len(keys));
                    kk = kk + 1;
                }
                push(feat_log, feat_probs);
                j = j + 1;
            }
            push(self.class_log_prior, math_log(count * 1.0 / n));
            push(self.feature_log_prob, feat_log);
            c = c + 1;
        }
        return 0;
    }

    fn predict(X) {
        let n = len(X);
        let d = len(X[0]);
        let preds = [];
        let i = 0;
        while (i < n) {
            let best_score = -1000000000.0;
            let best_class = self.classes[0];
            let c = 0;
            while (c < len(self.classes)) {
                let score = self.class_log_prior[c];
                let j = 0;
                while (j < d) {
                    let val = X[i][j];
                    let prob = self.alpha * 0.001;
                    let feat_probs = self.feature_log_prob[c][j];
                    if (dict_keys(feat_probs) != []) {
                        let keys = dict_keys(feat_probs);
                        let found = 0;
                        let kk = 0;
                        while (kk < len(keys)) { if (keys[kk] == val) { found = 1; } kk = kk + 1; }
                        if (found == 1) { prob = feat_probs[val]; }
                    }
                    score = score + math_log(prob + 0.000000001);
                    j = j + 1;
                }
                if (score > best_score) { best_score = score; best_class = self.classes[c]; }
                c = c + 1;
            }
            push(preds, best_class);
            i = i + 1;
        }
        return preds;
    }

    fn score(X, y) { return accuracy_score(self.predict(X), y); }
}

# ── BayesianGaussianMixtureModel ──
class BayesianGaussianMixtureModel {
    let n_components = 3;
    let max_iter = 100;
    let weight_concentration_prior = 1.0;
    let tol = 0.001;
    let means = [];
    let covs = [];
    let weights = [];
    let dof = [];
    let fitted = 0;

    fn init_bayesian_gmm(n_components, max_iter, weight_concentration_prior, tol) {
        if (n_components != nullptr) { self.n_components = n_components; }
        if (max_iter != nullptr) { self.max_iter = max_iter; }
        if (weight_concentration_prior != nullptr) { self.weight_concentration_prior = weight_concentration_prior; }
        if (tol != nullptr) { self.tol = tol; }
        self.means = [];
        self.covs = [];
        self.weights = [];
        self.dof = [];
        self.fitted = 0;
        return 0;
    }

    fn fit(X) {
        let n = len(X);
        let d = len(X[0]);
        let k = self.n_components;
        self.means = [];
        self.covs = [];
        self.weights = [];
        self.dof = [];
        let i = 0;
        while (i < k) {
            let idx = hml_randint(0, n - 1);
            let mean = [];
            let j = 0;
            while (j < d) { push(mean, X[idx][j]); j = j + 1; }
            push(self.means, mean);
            let cov = [];
            j = 0;
            while (j < d) { push(cov, 1.0); j = j + 1; }
            push(self.covs, cov);
            push(self.weights, 1.0 / k);
            push(self.dof, d + 2.0);
            i = i + 1;
        }
        let prior = self.weight_concentration_prior;
        let iter = 0;
        let prev_log_likelihood = -1000000000.0;
        while (iter < self.max_iter) {
            let resp = hml_gmm_e_step(X, self.means, self.covs, self.weights);
            let n_resp = [];
            i = 0;
            while (i < k) {
                let nk = 0.0;
                let j = 0;
                while (j < n) { nk = nk + resp[j][i]; j = j + 1; }
                push(n_resp, nk);
                i = i + 1;
            }
            i = 0;
            while (i < k) {
                let nk = n_resp[i];
                if (nk < 0.000001) { nk = 0.000001; }
                let w_new = [];
                let j = 0;
                while (j < d) {
                    let num = 0.0;
                    let denom = 0.0;
                    let m = 0;
                    while (m < n) { num = num + resp[m][i] * X[m][j]; denom = denom + resp[m][i]; m = m + 1; }
                    push(w_new, num / denom);
                    j = j + 1;
                }
                self.means[i] = w_new;
                let cov_new = [];
                j = 0;
                while (j < d) {
                    let s = 0.0;
                    let m = 0;
                    while (m < n) {
                        let diff = X[m][j] - self.means[i][j];
                        s = s + resp[m][i] * diff * diff;
                        m = m + 1;
                    }
                    let v = (s + 1.0) / (nk + 1.0);
                    if (v < 0.000001) { v = 0.000001; }
                    push(cov_new, v);
                    j = j + 1;
                }
                self.covs[i] = cov_new;
                self.weights[i] = (nk + prior / k) / (n + prior);
                self.dof[i] = d + 2.0 + nk;
                i = i + 1;
            }
            let total_w = 0.0;
            i = 0;
            while (i < k) { total_w = total_w + self.weights[i]; i = i + 1; }
            i = 0;
            while (i < k) { self.weights[i] = self.weights[i] / total_w; i = i + 1; }
            let log_likelihood = 0.0;
            let m = 0;
            while (m < n) {
                let row_prob = 0.0;
                let c = 0;
                while (c < k) {
                    let lp = math_log(self.weights[c] + 0.000000000000001);
                    let j = 0;
                    while (j < d) {
                        let diff = X[m][j] - self.means[c][j];
                        let var_j = self.covs[c][j];
                        if (var_j <= 0) { var_j = 0.000000001; }
                        lp = lp - 0.5 * math_log(2.0 * 3.141592653589793 * var_j) - (diff * diff) * 1.0 / (2.0 * var_j);
                        j = j + 1;
                    }
                    row_prob = row_prob + math_exp(lp);
                    c = c + 1;
                }
                log_likelihood = log_likelihood + math_log(row_prob + 0.000000000000001);
                m = m + 1;
            }
            if (math_fabs(log_likelihood - prev_log_likelihood) < self.tol) { break; }
            prev_log_likelihood = log_likelihood;
            iter = iter + 1;
        }
        self.fitted = 1;
        return 0;
    }

    fn predict(X) {
        let n = len(X);
        let resp = hml_gmm_e_step(X, self.means, self.covs, self.weights);
        let preds = [];
        let i = 0;
        while (i < n) {
            let best = 0;
            let best_val = resp[i][0];
            let c = 1;
            while (c < self.n_components) {
                if (resp[i][c] > best_val) { best_val = resp[i][c]; best = c; }
                c = c + 1;
            }
            push(preds, best);
            i = i + 1;
        }
        return preds;
    }

    fn score_samples(X) {
        let n = len(X);
        let k = self.n_components;
        let d = len(X[0]);
        let scores = [];
        let i = 0;
        while (i < n) {
            let row_prob = 0.0;
            let c = 0;
            while (c < k) {
                let lp = math_log(self.weights[c] + 0.000000000000001);
                let j = 0;
                while (j < d) {
                    let diff = X[i][j] - self.means[c][j];
                    let var_j = self.covs[c][j];
                    if (var_j <= 0) { var_j = 0.000000001; }
                    lp = lp - 0.5 * math_log(2.0 * 3.141592653589793 * var_j) - (diff * diff) * 1.0 / (2.0 * var_j);
                    j = j + 1;
                }
                row_prob = row_prob + math_exp(lp);
                c = c + 1;
            }
            push(scores, math_log(row_prob + 0.000000000000001));
            i = i + 1;
        }
        return scores;
    }
}

# ── BayesianLinearRegressionModel ──
class BayesianLinearRegressionModel {
    let prior_precision = 1.0;
    let noise_precision = 1.0;
    let model = nullptr;
    let fitted = 0;

    fn init_bayesian_lr(prior_precision, noise_precision) {
        if (prior_precision != nullptr) { self.prior_precision = prior_precision; }
        if (noise_precision != nullptr) { self.noise_precision = noise_precision; }
        self.model = nullptr;
        self.fitted = 0;
        return 0;
    }

    fn fit(X, y) {
        self.model = hml_bayesian_linear_regression_fit(X, y, self.prior_precision, self.noise_precision);
        self.fitted = 1;
        return 0;
    }

    fn predict(X) {
        if (self.model == nullptr) { return []; }
        return hml_bayesian_linear_regression_predict(self.model, X);
    }

    fn predict_dist(X) {
        let preds = self.predict(X);
        let n = len(X);
        let d = len(X[0]);
        let sigma = [];
        let i = 0;
        while (i < n) {
            let var_val = 1.0 / self.noise_precision;
            let j = 0;
            while (j < d) {
                var_val = var_val + X[i][j] * X[i][j] * 0.01;
                j = j + 1;
            }
            push(sigma, math_sqrt(var_val));
            i = i + 1;
        }
        return {"mean": preds, "sigma": sigma};
    }

    fn score(X, y) { return r2_score(y, self.predict(X)); }
}

# ── GaussianProcessClassifier ──
class GaussianProcessClassifier {
    let kernel = nullptr;
    let X_train = [];
    let y_train = [];

    fn init_gaussian_process_clf(kernel) {
        self.kernel = kernel;
        self.X_train = [];
        self.y_train = [];
        return 0;
    }

    fn fit(X, y) {
        self.X_train = X;
        self.y_train = y;
        return 0;
    }

    fn predict(X) {
        let n = len(X);
        let n_train = len(self.X_train);
        let d = len(X[0]);
        let preds = [];
        let i = 0;
        while (i < n) {
            let total = 0.0;
            let total_w = 0.0;
            let j = 0;
            while (j < n_train) {
                let dist = 0.0;
                let l = 0;
                while (l < d) { let diff = X[i][l] - self.X_train[j][l]; dist = dist + diff * diff; l = l + 1; }
                let k_val = math_exp(-dist);
                total = total + k_val * self.y_train[j];
                total_w = total_w + k_val;
                j = j + 1;
            }
            if (total_w > 0) { total = total / total_w; }
            if (total >= 0.5) { push(preds, 1); }
            else { push(preds, 0); }
            i = i + 1;
        }
        return preds;
    }

    fn score(X, y) { return accuracy_score(self.predict(X), y); }
}

