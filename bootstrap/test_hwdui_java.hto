# H# zzwUI ↔ Java 协同开发库测试
# ═══════════════════════════════════════════════════════════════════════════

import "bootstrap/hwdui_java.hto";

let _test_count = 0;
let _pass_count = 0;

fn assert(condition, msg) {
    _test_count = _test_count + 1;
    if (condition) {
        _pass_count = _pass_count + 1;
        print("  PASS: " + msg);
    } else {
        print("  FAIL: " + msg);
    }
    return 0;
}

fn test_summary() {
    print("");
    print("═══════════════════════════════════");
    let failed = _test_count - _pass_count;
    print("  Tests: " + _test_count + " | Passed: " + _pass_count + " | Failed: " + failed);
    if (failed == 0) {
        print("  Result: ALL TESTS PASSED");
    } else {
        print("  Result: " + failed + " TEST(S) FAILED");
    }
    print("═══════════════════════════════════");
    return 0;
}

