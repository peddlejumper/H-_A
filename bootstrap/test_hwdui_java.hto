# Section 3: Event Bridge Tests
# ═══════════════════════════════════════════════════════════════════════════

fn test_java_event() {
    let evt = new JavaEvent();
    evt.init_event("actionPerformed", "java.awt.event.ActionListener");
    assert(evt.getName() == "actionPerformed", "JavaEvent.getName");
    assert(evt.getListenerType() == "java.awt.event.ActionListener", "JavaEvent.getListenerType");
    assert(evt.getListenerCount() == 0, "JavaEvent.getListenerCount");
    assert(evt.isStatic() == false, "JavaEvent.isStatic default");
    evt.setStatic(true);
    assert(evt.isStatic() == true, "JavaEvent.setStatic");
    evt.setRemote(true);
    assert(evt.isRemote() == true, "JavaEvent.setRemote");
    let listener = new JavaEventListener();
    listener.init_listener("actionPerformed", fn(sender, args) { return 0; });
    evt.addListener(listener);
    assert(evt.getListenerCount() == 1, "JavaEvent.addListener");
    evt.removeListener(listener);
    assert(evt.getListenerCount() == 0, "JavaEvent.removeListener");
    return 0;
}

fn test_java_event_listener() {
    let count = 0;
    let l = new JavaEventListener();
    l.init_listener("click", fn(sender, args) { count = count + 1; return 0; });
    assert(l.getEventName() == "click", "JavaEventListener.getEventName");
    assert(l.isActive() == true, "JavaEventListener.isActive default");
    l.setId(5);
    assert(l.getId() == 5, "JavaEventListener.setId");
    l.setActive(false);
    assert(l.isActive() == false, "JavaEventListener.setActive");
    l.setOneShot(true);
    assert(l.isOneShot() == true, "JavaEventListener.isOneShot");
    l.setActive(true);
    l.onEvent(nullptr, {});
    assert(count == 1, "JavaEventListener.onEvent calls callback");
    assert(l.isActive() == false, "JavaEventListener one-shot deactivates");
    return 0;
}

fn test_java_cross_event_bus() {
    let bus = new JavaCrossEventBus();
    bus.init_cross_bus();
    let received = false;
    let listener = bus.subscribe("test.event", fn(sender, args) {
        received = true;
        return 0;
    });
    assert(listener != nullptr, "JavaCrossEventBus.subscribe");
    bus.publish("test.event", "mysender", {"data": 42});
    assert(received == true, "JavaCrossEventBus.publish");
    bus.unsubscribe("test.event", listener);
    bus.clearEvent("test.event");
    assert(bus.getEventCount() == 0, "JavaCrossEventBus.clearEvent");
    bus.enableBridge();
    assert(bus.isBridgeEnabled() == true, "JavaCrossEventBus.enableBridge");
    bus.disableBridge();
    assert(bus.isBridgeEnabled() == false, "JavaCrossEventBus.disableBridge");
    bus.clear();
    return 0;
}

fn test_java_ui_dispatcher() {
    let disp = new JavaUIDispatcher();
    disp.init_dispatcher();
    let ran = false;
    disp.invokeLater(fn() { ran = true; return 0; });
    assert(disp.getQueueSize() == 1, "JavaUIDispatcher.invokeLater");
    disp.processQueue();
    assert(ran == true, "JavaUIDispatcher.processQueue");
    assert(disp.getQueueSize() == 0, "JavaUIDispatcher.processQueue clears done");
    disp.invoke(fn() { return 0; });
    disp.clear();
    assert(disp.getQueueSize() == 0, "JavaUIDispatcher.clear");
    return 0;
}

