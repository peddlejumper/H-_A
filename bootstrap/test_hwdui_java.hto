# Section 9: Diagnostics Tests
# ═══════════════════════════════════════════════════════════════════════════

fn test_java_logger() {
    let logger = new JavaLogger();
    logger.init_logger();
    assert(logger.getLevel() == "info", "JavaLogger.getLevel default");
    logger.setLevel("debug");
    logger.setIncludeTimestamp(false);
    logger.setIncludeLevel(true);
    logger.setLogFile("/tmp/java_app.log");
    assert(logger.getLogFile() == "/tmp/java_app.log", "JavaLogger.setLogFile");
    logger.setMaxLogSize(1048576);
    logger.addCategory("network");
    logger.trace("trace msg");
    logger.debug("debug msg");
    logger.info("info msg");
    logger.warn("warn msg");
    logger.error("error msg");
    logger.fatal("fatal msg");
    return 0;
}

fn test_java_profiler() {
    let p = new JavaProfiler();
    p.init_profiler();
    p.start("my_operation");
    p.stop("my_operation");
    assert(p.getMeasurementCount() == 1, "JavaProfiler.start/stop");
    assert(p.getTotalMeasurements() == 1, "JavaProfiler.getTotalMeasurements");
    assert(p.isRunning("my_operation") == false, "JavaProfiler.isRunning false");
    p.start("ongoing");
    assert(p.isRunning("ongoing") == true, "JavaProfiler.isRunning true");
    p.reset();
    assert(p.getMeasurementCount() == 0, "JavaProfiler.reset");
    p.report();
    return 0;
}

fn test_java_debugger() {
    let dbg = new JavaDebugger();
    dbg.init_debugger();
    assert(dbg.isAttached() == false, "JavaDebugger.isAttached default");
    dbg.attach();
    assert(dbg.isAttached() == true, "JavaDebugger.attach");
    dbg.setBreakpoint("Main.java", 42);
    assert(dbg.hasBreakpoint("Main.java", 42) == true, "JavaDebugger.setBreakpoint");
    dbg.removeBreakpoint("Main.java", 42);
    assert(dbg.hasBreakpoint("Main.java", 42) == false, "JavaDebugger.removeBreakpoint");
    dbg.setBreakpoint("Main.java", 10);
    dbg.setBreakpoint("Main.java", 20);
    assert(dbg.getBreakpointCount() == 2, "JavaDebugger.getBreakpointCount");
    dbg.clearBreakpoints();
    assert(dbg.getBreakpointCount() == 0, "JavaDebugger.clearBreakpoints");
    dbg.setDebugPort(8000);
    assert(dbg.getDebugPort() == 8000, "JavaDebugger.setDebugPort");
    dbg.setStepMode("step_over");
    assert(dbg.getStepMode() == "step_over", "JavaDebugger.setStepMode");
    dbg.setCurrentLocation("Main.java", 15);
    assert(dbg.getCurrentFile() == "Main.java", "JavaDebugger.getCurrentFile");
    assert(dbg.getCurrentLine() == 15, "JavaDebugger.getCurrentLine");
    dbg.detach();
    assert(dbg.isAttached() == false, "JavaDebugger.detach");
    return 0;
}

fn test_java_config() {
    let cfg = new JavaConfig();
    cfg.init_config();
    assert(cfg.isLoaded() == false, "JavaConfig.isLoaded default");
    cfg.load("/etc/app.properties");
    assert(cfg.isLoaded() == true, "JavaConfig.load");
    assert(cfg.getConfigFile() == "/etc/app.properties", "JavaConfig.getConfigFile");
    cfg.set("app.name", "MyJavaApp");
    assert(cfg.hasKey("app.name") == true, "JavaConfig.hasKey");
    assert(cfg.get("app.name", "default") == "MyJavaApp", "JavaConfig.get");
    assert(cfg.get("missing.key", "fallback") == "fallback", "JavaConfig.get with default");
    cfg.setSection("database", {"host": "localhost", "port": 5432});
    let section = cfg.getSection("database");
    assert(section != nullptr, "JavaConfig.setSection/getSection");
    let keys = cfg.getKeys();
    assert(len(keys) == 1, "JavaConfig.getKeys");
    cfg.remove("app.name");
    assert(cfg.hasKey("app.name") == false, "JavaConfig.remove");
    cfg.clear();
    let keys2 = cfg.getKeys();
    assert(len(keys2) == 0, "JavaConfig.clear");
    return 0;
}

fn test_java_environment() {
    let env = new JavaEnvironment();
    env.init_env();
    env.setOSName("Mac OS X");
    assert(env.getOSName() == "Mac OS X", "JavaEnvironment.setOSName");
    env.setJavaVersion("17");
    assert(env.getJavaVersion() == "17", "JavaEnvironment.setJavaVersion");
    env.setJavaVendor("Oracle");
    assert(env.getJavaVendor() == "Oracle", "JavaEnvironment.setJavaVendor");
    env.setIs64Bit(true);
    assert(env.is64Bit() == true, "JavaEnvironment.is64Bit");
    env.setMachineName("dev-server");
    env.setUserName("developer");
    env.setProcessorCount(8);
    assert(env.getProcessorCount() == 8, "JavaEnvironment.getProcessorCount");
    env.setWorkingDirectory("/project");
    assert(env.getWorkingDirectory() == "/project", "JavaEnvironment.getWorkingDirectory");
    env.setClassPath("/libs/*:/classes");
    assert(env.getClassPath() == "/libs/*:/classes", "JavaEnvironment.getClassPath");
    env.setSystemProperty("java.io.tmpdir", "/tmp");
    assert(env.getSystemProperty("java.io.tmpdir") == "/tmp", "JavaEnvironment.getSystemProperty");
    let props = env.getSystemProperties();
    assert(len(props) == 1, "JavaEnvironment.getSystemProperties");
    return 0;
}

fn test_java_process() {
    let proc = new JavaProcess();
    proc.init_process("java", ["-jar", "app.jar"]);
    assert(proc.getProcessName() == "java", "JavaProcess.getProcessName");
    assert(len(proc.getArguments()) == 2, "JavaProcess.getArguments");
    assert(proc.isRunning() == false, "JavaProcess.isRunning default");
    proc.setWorkingDir("/app");
    assert(proc.getWorkingDir() == "/app", "JavaProcess.setWorkingDir");
    proc.setRedirectOutput(true);
    proc.start();
    assert(proc.isRunning() == true, "JavaProcess.start");
    proc.destroy();
    assert(proc.isRunning() == false, "JavaProcess.destroy");
    return 0;
}

