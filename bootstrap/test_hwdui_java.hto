fn test_java_object() {
    let obj = new JavaObject();
    obj.init_jobj(100, "java.util.ArrayList");
    assert(obj.getObjectId() == 100, "JavaObject.getObjectId");
    assert(obj.getTypeName() == "java.util.ArrayList", "JavaObject.getTypeName");
    assert(obj.isDisposed() == false, "JavaObject.isDisposed");
    obj.setProperty("capacity", 16);
    assert(obj.getProperty("capacity") == 16, "JavaObject.setProperty/getProperty");
    assert(obj.hasProperty("capacity") == true, "JavaObject.hasProperty");
    assert(obj.hasProperty("nonexistent") == false, "JavaObject.hasProperty false");
    obj.cacheMethod("add");
    obj.cacheMethod("remove");
    assert(obj.hasMethod("add") == true, "JavaObject.hasMethod");
    assert(obj.hasMethod("clear") == false, "JavaObject.hasMethod false");
    obj.setRemote("localhost:1099");
    assert(obj.isRemote() == true, "JavaObject.isRemote");
    assert(obj.getRemoteEndpoint() == "localhost:1099", "JavaObject.getRemoteEndpoint");
    obj.dispose();
    assert(obj.isDisposed() == true, "JavaObject.dispose");
    return 0;
}

fn test_java_object_cache() {
    let cache = new JavaObjectCache();
    cache.init_cache();
    let obj1 = new JavaObject();
    obj1.init_jobj(0, "String");
    let id1 = cache.add(obj1);
    assert(id1 == 1, "JavaObjectCache.add id=1");
    let retrieved = cache.get(id1);
    assert(retrieved != nullptr, "JavaObjectCache.get");
    assert(retrieved.getTypeName() == "String", "JavaObjectCache.get type");
    assert(cache.getCount() == 1, "JavaObjectCache.getCount");
    assert(cache.contains(id1) == true, "JavaObjectCache.contains");
    cache.remove(id1);
    assert(cache.contains(id1) == false, "JavaObjectCache.remove");
    assert(cache.getCount() == 0, "JavaObjectCache empty after remove");
    let obj2 = new JavaObject();
    obj2.init_jobj(0, "Integer");
    cache.add(obj2);
    cache.clear();
    assert(cache.getCount() == 0, "JavaObjectCache.clear");
    return 0;
}

fn test_java_jar_info() {
    let jar = new JavaJarInfo();
    jar.init_jar("guava", "31.1", "/libs/guava.jar");
    assert(jar.getName() == "guava", "JavaJarInfo.getName");
    assert(jar.getVersion() == "31.1", "JavaJarInfo.getVersion");
    assert(jar.getPath() == "/libs/guava.jar", "JavaJarInfo.getPath");
    assert(jar.isLoaded() == false, "JavaJarInfo.isLoaded default");
    jar.setLoaded(true);
    assert(jar.isLoaded() == true, "JavaJarInfo.setLoaded");
    jar.setModule(true);
    assert(jar.isModule() == true, "JavaJarInfo.isModule");
    jar.setModuleName("com.google.common");
    assert(jar.getModuleName() == "com.google.common", "JavaJarInfo.getModuleName");
    let ti = new JavaTypeInfo();
    ti.init_j_type("Lists", "com.google.common.collect", "guava");
    jar.addType(ti);
    assert(jar.getTypeCount() == 1, "JavaJarInfo.addType");
    let found = jar.getType("Lists");
    assert(found != nullptr, "JavaJarInfo.getType");
    jar.addDependency("jsr305");
    assert(jar.getDependencyCount() == 1, "JavaJarInfo.addDependency");
    return 0;
}

fn test_java_class_loader() {
    let loader = new JavaClassLoader();
    loader.init_loader();
    let jar = new JavaJarInfo();
    jar.init_jar("test-lib", "1.0", "/libs/test.jar");
    loader.register(jar);
    assert(loader.getJarCount() == 1, "JavaClassLoader.register");
    let loaded = loader.load("test-lib");
    assert(loaded != nullptr, "JavaClassLoader.load");
    assert(loader.isLoaded("test-lib") == true, "JavaClassLoader.isLoaded");
    assert(loader.getLoadedCount() == 1, "JavaClassLoader.getLoadedCount");
    loader.unload("test-lib");
    assert(loader.isLoaded("test-lib") == false, "JavaClassLoader.unload");
    loader.addClassPathEntry("/custom/classes");
    loader.clear();
    assert(loader.getJarCount() == 0, "JavaClassLoader.clear");
    return 0;
}

fn test_java_constructor() {
    let ctor = new JavaConstructor();
    ctor.init_ctor("java.util.ArrayList");
    ctor.addParam("int", "initialCapacity");
    assert(ctor.getParamCount() == 1, "JavaConstructor.addParam");
    assert(ctor.getParamType(0) == "int", "JavaConstructor.getParamType");
    assert(ctor.getParamNames()[0] == "initialCapacity", "JavaConstructor.getParamNames");
    return 0;
}

fn test_java_method() {
    let m = new JavaMethod();
    m.init_method("add", "boolean");
    m.addParam("java.lang.Object", "element");
    m.setStatic(false);
    m.setSynchronized(true);
    m.setVisibility("public");
    m.addAnnotation("@Override");
    m.addThrows("IllegalArgumentException");
    assert(m.getName() == "add", "JavaMethod.getName");
    assert(m.getReturnType() == "boolean", "JavaMethod.getReturnType");
    assert(m.getParamCount() == 1, "JavaMethod.getParamCount");
    assert(m.isStatic() == false, "JavaMethod.isStatic");
    assert(m.isSynchronized() == true, "JavaMethod.isSynchronized");
    assert(m.getVisibility() == "public", "JavaMethod.getVisibility");
    assert(m.hasAnnotation("@Override") == true, "JavaMethod.hasAnnotation");
    return 0;
}

fn test_java_field() {
    let f = new JavaField();
    f.init_field("MAX_VALUE", "int");
    f.setStatic(true);
    f.setFinal(true);
    f.setVisibility("public");
    assert(f.getName() == "MAX_VALUE", "JavaField.getName");
    assert(f.getType() == "int", "JavaField.getType");
    assert(f.isStatic() == true, "JavaField.isStatic");
    assert(f.isFinal() == true, "JavaField.isFinal");
    f.setTransient(true);
    assert(f.isTransient() == true, "JavaField.isTransient");
    f.setVolatile(true);
    assert(f.isVolatile() == true, "JavaField.isVolatile");
    return 0;
}

