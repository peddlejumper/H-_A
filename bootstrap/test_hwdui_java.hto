fn test_java_global_init() {
    assert(java_init() == true, "java_init");
    assert(java_is_ready() == true, "java_is_ready");
    java_shutdown();
    assert(java_is_ready() == false, "java_shutdown");
    java_init();
    return 0;
}

fn test_java_global_accessors() {
    let m = java_get_mapper();
    assert(m != nullptr, "java_get_mapper");
    let c = java_get_cache();
    assert(c != nullptr, "java_get_cache");
    let bus = java_get_event_bus();
    assert(bus != nullptr, "java_get_event_bus");
    let bm = java_get_binding_manager();
    assert(bm != nullptr, "java_get_binding_manager");
    let s = java_get_serializer();
    assert(s != nullptr, "java_get_serializer");
    let d = java_get_deserializer();
    assert(d != nullptr, "java_get_deserializer");
    let tc = java_get_type_converter();
    assert(tc != nullptr, "java_get_type_converter");
    let logger = java_get_logger();
    assert(logger != nullptr, "java_get_logger");
    let profiler = java_get_profiler();
    assert(profiler != nullptr, "java_get_profiler");
    let config = java_get_config();
    assert(config != nullptr, "java_get_config");
    let env = java_get_env();
    assert(env != nullptr, "java_get_env");
    let loader = java_get_class_loader();
    assert(loader != nullptr, "java_get_class_loader");
    let factory = java_get_control_factory();
    assert(factory != nullptr, "java_get_control_factory");
    let bridge = java_get_style_bridge();
    assert(bridge != nullptr, "java_get_style_bridge");
    let fxml = java_get_fxml();
    assert(fxml != nullptr, "java_get_fxml");
    let bundle = java_get_resource_bundle();
    assert(bundle != nullptr, "java_get_resource_bundle");
    let maven = java_get_maven();
    assert(maven != nullptr, "java_get_maven");
    let exec = java_get_executor();
    assert(exec != nullptr, "java_get_executor");
    assert(java_get_version() == "1.0.0", "java_get_version");
    java_summary();
    return 0;
}

