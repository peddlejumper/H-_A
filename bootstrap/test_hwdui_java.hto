fn test_java_maven_artifact() {
    let art = new JavaMavenArtifact();
    art.init_artifact("org.springframework", "spring-core", "5.3.20");
    assert(art.getGroupId() == "org.springframework", "JavaMavenArtifact.getGroupId");
    assert(art.getArtifactId() == "spring-core", "JavaMavenArtifact.getArtifactId");
    assert(art.getVersion() == "5.3.20", "JavaMavenArtifact.getVersion");
    assert(art.getScope() == "compile", "JavaMavenArtifact.getScope default");
    art.setScope("runtime");
    assert(art.getScope() == "runtime", "JavaMavenArtifact.setScope");
    art.setDescription("Spring Core Framework");
    assert(art.getDescription() == "Spring Core Framework", "JavaMavenArtifact.setDescription");
    art.addDependency("org.springframework", "spring-beans", "5.3.20");
    let deps = art.getDependencies();
    assert(len(deps) == 1, "JavaMavenArtifact.addDependency");
    art.setInstalled(true);
    art.setInstallPath("/.m2/repository");
    assert(art.isInstalled() == true, "JavaMavenArtifact.setInstalled");
    assert(art.getId() == "org.springframework:spring-core", "JavaMavenArtifact.getId");
    return 0;
}

fn test_java_maven_manager() {
    let maven = new JavaMavenManager();
    maven.init_maven();
    let repos = maven.getRepositories();
    assert(len(repos) >= 1, "JavaMavenManager default repos");
    maven.addRepository("https://repo.spring.io/release");
    assert(len(maven.getRepositories()) == 2, "JavaMavenManager.addRepository");
    let art = new JavaMavenArtifact();
    art.init_artifact("junit", "junit", "4.13.2");
    maven.install(art);
    assert(maven.isInstalled("junit:junit") == true, "JavaMavenManager.install");
    let retrieved = maven.getArtifact("junit:junit");
    assert(retrieved != nullptr, "JavaMavenManager.getArtifact");
    let installed = maven.getInstalledArtifacts();
    assert(len(installed) == 1, "JavaMavenManager.getInstalledArtifacts");
    maven.uninstall("junit:junit");
    assert(maven.isInstalled("junit:junit") == false, "JavaMavenManager.uninstall");
    maven.setLocalRepo("/custom/repo");
    assert(maven.getLocalRepo() == "/custom/repo", "JavaMavenManager.setLocalRepo");
    assert(maven.getArtifactCount() == 0, "JavaMavenManager.getArtifactCount");
    return 0;
}

fn test_java_project() {
    let proj = new JavaProject();
    proj.init_project("myapp", "application");
    assert(proj.getName() == "myapp", "JavaProject.getName");
    assert(proj.getProjectType() == "application", "JavaProject.getProjectType");
    assert(proj.getBuildTool() == "maven", "JavaProject.getBuildTool default");
    proj.setGroupId("com.mycompany");
    assert(proj.getGroupId() == "com.mycompany", "JavaProject.setGroupId");
    proj.setArtifactId("myapp-core");
    assert(proj.getArtifactId() == "myapp-core", "JavaProject.setArtifactId");
    proj.setVersion("2.0.0");
    assert(proj.getVersion() == "2.0.0", "JavaProject.setVersion");
    proj.setMainClass("com.mycompany.Main");
    assert(proj.getMainClass() == "com.mycompany.Main", "JavaProject.setMainClass");
    proj.setJavaVersion("21");
    assert(proj.getJavaVersion() == "21", "JavaProject.setJavaVersion");
    proj.setBuildTool("gradle");
    assert(proj.getBuildTool() == "gradle", "JavaProject.setBuildTool");
    let art = new JavaMavenArtifact();
    art.init_artifact("com.google.guava", "guava", "31.1");
    proj.addDependency(art);
    assert(len(proj.getDependencies()) == 1, "JavaProject.addDependency");
    proj.addPlugin("maven-compiler-plugin", "3.10.1");
    assert(len(proj.getPlugins()) == 1, "JavaProject.addPlugin");
    proj.addSourceDir("src/main/java");
    assert(len(proj.getSourceDirs()) == 1, "JavaProject.addSourceDir");
    return 0;
}

fn test_java_module() {
    let mod = new JavaModule();
    mod.init_module("backend");
    assert(mod.getName() == "backend", "JavaModule.getName");
    assert(mod.getProjectCount() == 0, "JavaModule.getProjectCount default");
    let proj1 = new JavaProject();
    proj1.init_project("api", "library");
    let proj2 = new JavaProject();
    proj2.init_project("core", "library");
    mod.addProject(proj1);
    mod.addProject(proj2);
    assert(mod.getProjectCount() == 2, "JavaModule.addProject");
    let found = mod.getProject("api");
    assert(found != nullptr, "JavaModule.getProject");
    assert(mod.getProject("nonexistent") == nullptr, "JavaModule.getProject missing");
    mod.setBuildConfig("release");
    assert(mod.getBuildConfig() == "release", "JavaModule.setBuildConfig");
    mod.removeProject("api");
    assert(mod.getProjectCount() == 1, "JavaModule.removeProject");
    return 0;
}

# ═══════════════════════════════════════════════════════════════════════════
# Section 11: FXML Tests
# ═══════════════════════════════════════════════════════════════════════════

fn test_java_fxml() {
    let fxml = new JavaFXML();
    fxml.init_fxml();
    let namespaces = fxml.getNamespaces();
    let ns_count = 0;
    for k in namespaces {
        ns_count = ns_count + 1;
    }
    assert(ns_count >= 1, "JavaFXML.init_fxml namespaces");
    fxml.addNamespace("custom", "http://example.com/fxml");
    fxml.setRootElement("VBox");
    assert(fxml.getRootElement() == "VBox", "JavaFXML.setRootElement");
    fxml.setControllerClass("com.example.MainController");
    assert(fxml.getControllerClass() == "com.example.MainController", "JavaFXML.setControllerClass");
    fxml.addResource("app.title", "My Application");
    assert(fxml.getResource("app.title") == "My Application", "JavaFXML.addResource");
    fxml.setContent("<VBox><Button text='Click'/></VBox>");
    assert(fxml.getContent() == "<VBox><Button text='Click'/></VBox>", "JavaFXML.setContent");
    fxml.clear();
    return 0;
}

fn test_style_bridge() {
    let bridge = new JavaStyleBridge();
    bridge.init_style_bridge();
    assert(bridge.getMappingCount() > 0, "JavaStyleBridge default mappings");
    let hw_styles = {"bg_color": "red", "font_size": 14};
    let jfx_styles = bridge.toJavaFX(hw_styles);
    assert(jfx_styles["-fx-background-color"] == "red", "JavaStyleBridge.toJavaFX bg");
    assert(jfx_styles["-fx-font-size"] == 14, "JavaStyleBridge.toJavaFX font");
    let jfx_in = {"-fx-background-color": "blue", "-fx-text-fill": "white"};
    let hw_out = bridge.toHwdUI(jfx_in);
    assert(hw_out["bg_color"] == "blue", "JavaStyleBridge.toHwdUI bg");
    assert(hw_out["fg_color"] == "white", "JavaStyleBridge.toHwdUI fg");
    bridge.addMapping("border_radius", "-fx-border-radius");
    assert(bridge.getMappingCount() > 0, "JavaStyleBridge.addMapping");
    return 0;
}

# ═══════════════════════════════════════════════════════════════════════════
# Section 12: Resource Tests
# ═══════════════════════════════════════════════════════════════════════════

fn test_java_resource_bundle() {
    let bundle = new JavaResourceBundle();
    bundle.init_bundle();
    bundle.setLocale("zh_CN");
    assert(bundle.getLocale() == "zh_CN", "JavaResourceBundle.setLocale");
    bundle.setBaseName("messages");
    assert(bundle.getBaseName() == "messages", "JavaResourceBundle.setBaseName");
    bundle.addResource("hello", "你好");
    bundle.addResource("count", 42);
    bundle.addResource("enabled", true);
    assert(bundle.getString("hello") == "你好", "JavaResourceBundle.getString");
    assert(bundle.getInteger("count") == 42, "JavaResourceBundle.getInteger");
    assert(bundle.getBoolean("enabled") == true, "JavaResourceBundle.getBoolean");
    assert(bundle.getString("missing") == "missing", "JavaResourceBundle.getString fallback");
    assert(bundle.hasResource("hello") == true, "JavaResourceBundle.hasResource");
    assert(bundle.getResourceCount() == 3, "JavaResourceBundle.getResourceCount");
    bundle.removeResource("count");
    assert(bundle.hasResource("count") == false, "JavaResourceBundle.removeResource");
    bundle.clear();
    assert(bundle.getResourceCount() == 0, "JavaResourceBundle.clear");
    return 0;
}

fn test_java_file_watcher() {
    let watcher = new JavaFileWatcher();
    watcher.init_watcher("/watch/dir", "*.java");
    assert(watcher.getPath() == "/watch/dir", "JavaFileWatcher.getPath");
    assert(watcher.getFilter() == "*.java", "JavaFileWatcher.getFilter");
    assert(watcher.isWatching() == false, "JavaFileWatcher.isWatching default");
    watcher.start();
    assert(watcher.isWatching() == true, "JavaFileWatcher.start");
    watcher.stop();
    assert(watcher.isWatching() == false, "JavaFileWatcher.stop");
    watcher.setIncludeSubdirs(false);
    return 0;
}

