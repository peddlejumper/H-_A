# Section 1: Core Interop Tests
# ═══════════════════════════════════════════════════════════════════════════

fn test_java_type_info() {
    let ti = new JavaTypeInfo();
    ti.init_j_type("String", "java.lang", "rt.jar");
    assert(ti.getTypeName() == "String", "JavaTypeInfo.getTypeName");
    assert(ti.getPackageName() == "java.lang", "JavaTypeInfo.getPackageName");
    assert(ti.getJarSource() == "rt.jar", "JavaTypeInfo.getJarSource");
    assert(ti.getFullName() == "java.lang.String", "JavaTypeInfo.getFullName");
    ti.setPrimitive(true);
    assert(ti.isPrimitive() == true, "JavaTypeInfo.setPrimitive");
    ti.setGeneric(true);
    assert(ti.isGeneric() == true, "JavaTypeInfo.isGeneric");
    ti.setEnum(true);
    assert(ti.isEnum() == true, "JavaTypeInfo.setEnum");
    ti.setAnnotation(true);
    assert(ti.isAnnotation() == true, "JavaTypeInfo.isAnnotation");
    ti.setInterface(true);
    assert(ti.isInterface() == true, "JavaTypeInfo.isInterface");
    ti.addGenericArg("T");
    let args = ti.getGenericArgs();
    assert(len(args) == 1, "JavaTypeInfo.addGenericArg");
    ti.setSuperClass("java.lang.Object");
    assert(ti.getSuperClass() == "java.lang.Object", "JavaTypeInfo.setSuperClass");
    ti.addModifier("public");
    let mods = ti.getModifiers();
    assert(len(mods) == 1, "JavaTypeInfo.addModifier");
    return 0;
}

fn test_java_type_mapper() {
    let m = new JavaTypeMapper();
    m.init_mapper();
    let jtype = m.toJava("int");
    assert(jtype == "int", "TypeMapper: int → int");
    jtype = m.toJava("float");
    assert(jtype == "double", "TypeMapper: float → double");
    jtype = m.toJava("string");
    assert(jtype == "java.lang.String", "TypeMapper: string → String");
    jtype = m.toJava("bool");
    assert(jtype == "boolean", "TypeMapper: bool → boolean");
    jtype = m.toJava("list");
    assert(jtype == "java.util.ArrayList", "TypeMapper: list → ArrayList");
    jtype = m.toJava("dict");
    assert(jtype == "java.util.HashMap", "TypeMapper: dict → HashMap");
    let hs_type = m.toHSharp("java.lang.String");
    assert(hs_type == "string", "TypeMapper: String → string");
    hs_type = m.toHSharp("java.lang.Integer");
    assert(hs_type == "int32", "TypeMapper: Integer → int32");
    assert(m.isPrimitive("int") == true, "TypeMapper.isPrimitive: int");
    assert(m.isPrimitive("java.lang.String") == false, "TypeMapper.isPrimitive: String");
    m.registerCustom("MyType", "com.example.MyType");
    let mapped = m.toJava("MyType");
    assert(mapped == "com.example.MyType", "TypeMapper: custom mapping");
    return 0;
}

fn test_java_value() {
    let v = new JavaValue();
    v.init_jval(42, "int");
    assert(v.getValue() == 42, "JavaValue.getValue");
    assert(v.getTypeName() == "int", "JavaValue.getTypeName");
    assert(v.isNull() == false, "JavaValue.isNull");
    assert(v.asInt() == 42, "JavaValue.asInt");
    let v2 = new JavaValue();
    v2.init_jval(nullptr, "java.lang.Object");
    assert(v2.isNull() == true, "JavaValue.isNull true");
    assert(v2.asInt() == 0, "JavaValue.asInt nullptr→0");
    assert(v2.asString() == "", "JavaValue.asString nullptr→empty");
    assert(v2.asBool() == false, "JavaValue.asBool nullptr→false");
    let v3 = new JavaValue();
    v3.init_jval(3.14, "double");
    v3.setPrimitive(true);
    assert(v3.isPrimitive() == true, "JavaValue.setPrimitive");
    assert(v3.asFloat() == 3.14, "JavaValue.asFloat");
    let v4 = new JavaValue();
    v4.init_jval([1, 2, 3], "java.util.List");
    let lst = v4.asList();
    assert(lst != nullptr, "JavaValue.asList");
    let v5 = new JavaValue();
    v5.init_jval({"a": 1}, "java.util.Map");
    let d = v5.asDict();
    assert(d != nullptr, "JavaValue.asDict");
    return 0;
}

fn test_java_invoke() {
    let inv = new JavaInvoke();
    inv.init_invoke("toString", []);
    assert(inv.getMethodName() == "toString", "JavaInvoke.getMethodName");
    assert(inv.getArgCount() == 0, "JavaInvoke.getArgCount");
    assert(inv.isStatic() == false, "JavaInvoke.isStatic default");
    inv.setStatic(true);
    assert(inv.isStatic() == true, "JavaInvoke.setStatic");
    inv.setTimeout(5000);
    assert(inv.getTimeout() == 5000, "JavaInvoke.setTimeout");
    inv.setGetter("name");
    assert(inv.isGetter() == true, "JavaInvoke.setGetter");
    assert(inv.getPropertyName() == "name", "JavaInvoke.getPropertyName");
    let inv2 = new JavaInvoke();
    inv2.init_invoke("setName", ["Alice"]);
    inv2.setSetter("name", "Bob");
    assert(inv2.isSetter() == true, "JavaInvoke.setSetter");
    assert(len(inv2.getArgs()) == 1, "JavaInvoke.setSetter args");
    return 0;
}

fn test_java_result() {
    let r = new JavaResult();
    r.init_result();
    assert(r.isSuccess() == false, "JavaResult.isSuccess default");
    r.setSuccess(42);
    assert(r.isSuccess() == true, "JavaResult.setSuccess");
    assert(r.getValue() == 42, "JavaResult.getValue");
    assert(r.isException() == false, "JavaResult.isException");
    r.setError("Something wrong", "RuntimeException");
    assert(r.isSuccess() == false, "JavaResult.setError");
    assert(r.getError() == "Something wrong", "JavaResult.getError");
    assert(r.getErrorType() == "RuntimeException", "JavaResult.getErrorType");
    r.setCallId(7);
    assert(r.getCallId() == 7, "JavaResult.setCallId");
    r.setDuration(150);
    assert(r.getDuration() == 150, "JavaResult.setDuration");
    let val = r.unwrap();
    assert(val == nullptr, "JavaResult.unwrap on error");
    return 0;
}

