# Section 4: UI Bridge Tests
# ═══════════════════════════════════════════════════════════════════════════

fn test_zwui_java_control_bridge() {
    let hw = {"x": 0, "y": 0, "width": 100, "height": 50, "text": "Hello"};
    let jc = {"x": 10, "y": 20, "width": 200, "height": 100, "text": ""};
    let bridge = new ZzwUIJavaControlBridge();
    bridge.init_bridge(hw, jc);
    bridge.bindProperty("width", "width");
    bridge.bindProperty("height", "height");
    assert(bridge.isEnabled() == true, "ZzwUIJavaControlBridge.isEnabled");
    bridge.syncToJava();
    assert(jc["width"] == 100, "ZzwUIJavaControlBridge.syncToJava width");
    assert(jc["height"] == 50, "ZzwUIJavaControlBridge.syncToJava height");
    hw["width"] = 300;
    jc["height"] = 150;
    bridge.syncBoth();
    assert(jc["width"] == 300, "ZzwUIJavaControlBridge.syncBoth Java width");
    assert(hw["height"] == 50, "ZzwUIJavaControlBridge.syncBoth H# height");
    bridge.unbindProperty("width");
    let bindings = bridge.getPropertyBindings();
    assert(len(bindings) == 1, "ZzwUIJavaControlBridge.unbindProperty");
    bridge.setEnabled(false);
    assert(bridge.isEnabled() == false, "ZzwUIJavaControlBridge.setEnabled");
    bridge.dispose();
    return 0;
}

fn test_java_window_bridge() {
    let hw = {"title": "Old", "width": 800, "height": 600, "x": 0, "y": 0};
    let jw = {"title": "New", "width": 1024, "height": 768, "x": 100, "y": 100};
    let bridge = new JavaWindowBridge();
    bridge.init_win_bridge(hw, jw);
    bridge.bindTitle();
    bridge.bindSize();
    bridge.bindPosition();
    assert(bridge.isTitleBound() == true, "JavaWindowBridge.bindTitle");
    assert(bridge.isSizeBound() == true, "JavaWindowBridge.bindSize");
    assert(bridge.isPositionBound() == true, "JavaWindowBridge.bindPosition");
    bridge.syncTitle();
    assert(hw["title"] == "New", "JavaWindowBridge.syncTitle");
    bridge.syncSize();
    assert(hw["width"] == 1024, "JavaWindowBridge.syncSize width");
    assert(hw["height"] == 768, "JavaWindowBridge.syncSize height");
    bridge.syncPosition();
    assert(hw["x"] == 100, "JavaWindowBridge.syncPosition x");
    assert(hw["y"] == 100, "JavaWindowBridge.syncPosition y");
    bridge.syncAll();
    return 0;
}

fn test_java_ui_host() {
    let parent = {};
    let host = new JavaUIHost();
    host.init_host(parent);
    assert(host.isActive() == false, "JavaUIHost.isActive default");
    host.activate();
    assert(host.isActive() == true, "JavaUIHost.activate");
    let w1 = {"name": "button1"};
    let w2 = {"name": "label1"};
    host.hostWidget(w1);
    host.hostWidget(w2);
    assert(host.getWidgetCount() == 2, "JavaUIHost.hostWidget");
    host.removeWidget(w1);
    assert(host.getWidgetCount() == 1, "JavaUIHost.removeWidget");
    host.setLayoutEngine("JavaFX");
    assert(host.getLayoutEngine() == "JavaFX", "JavaUIHost.setLayoutEngine");
    host.deactivate();
    assert(host.isActive() == false, "JavaUIHost.deactivate");
    host.clear();
    assert(host.getWidgetCount() == 0, "JavaUIHost.clear");
    return 0;
}

fn test_java_control_factory() {
    let factory = new JavaControlFactory();
    factory.init_factory();
    let jtype = factory.getJavaType("Button");
    assert(jtype == "javafx.scene.control.Button", "JavaControlFactory.getJavaType Button");
    jtype = factory.getJavaType("Label");
    assert(jtype == "javafx.scene.control.Label", "JavaControlFactory.getJavaType Label");
    jtype = factory.getJavaType("TextBox");
    assert(jtype == "javafx.scene.control.TextField", "JavaControlFactory.getJavaType TextBox");
    assert(factory.hasType("Button") == true, "JavaControlFactory.hasType true");
    assert(factory.hasType("UnknownWidget") == false, "JavaControlFactory.hasType false");
    let types = factory.getSupportedTypes();
    assert(len(types) >= 10, "JavaControlFactory.getSupportedTypes");
    let ctrl = factory.createControl("Button");
    assert(ctrl != nullptr, "JavaControlFactory.createControl");
    factory.register("Custom", "com.myapp.CustomControl");
    assert(factory.getJavaType("Custom") == "com.myapp.CustomControl", "JavaControlFactory.register");
    return 0;
}

# ═══════════════════════════════════════════════════════════════════════════
# Section 5: Data Binding Tests
# ═══════════════════════════════════════════════════════════════════════════

fn test_java_binding() {
    let src = {"Name": "Alice", "Age": 30};
    let tgt = {"Text": "", "Value": 0};
    let b = new JavaBinding();
    b.init_binding(src, "Name", tgt, "Text");
    assert(b.getMode() == "twoWay", "JavaBinding.getMode default");
    b.setMode("oneWay");
    assert(b.getMode() == "oneWay", "JavaBinding.setMode");
    assert(b.isActive() == true, "JavaBinding.isActive default");
    b.updateTarget();
    assert(tgt["Text"] == "Alice", "JavaBinding.updateTarget");
    tgt["Text"] = "Bob";
    b.updateSource();
    assert(src["Name"] == "Alice", "JavaBinding.updateSource oneWay blocked");
    b.setMode("twoWay");
    b.updateSource();
    assert(src["Name"] == "Bob", "JavaBinding.updateSource twoWay");
    b.setActive(false);
    assert(b.isActive() == false, "JavaBinding.setActive");
    b.setFallbackValue("N/A");
    src["Name"] = nullptr;
    b.setActive(true);
    b.updateTarget();
    assert(tgt["Text"] == "N/A", "JavaBinding.fallbackValue");
    return 0;
}

fn test_java_multi_binding() {
    let src1 = {"FirstName": "John"};
    let src2 = {"LastName": "Doe"};
    let tgt = {"FullName": ""};
    let mb = new JavaMultiBinding();
    mb.init_multi_binding(tgt, "FullName");
    let b1 = new JavaBinding();
    b1.init_binding(src1, "FirstName", tgt, "FullName");
    let b2 = new JavaBinding();
    b2.init_binding(src2, "LastName", tgt, "FullName");
    mb.addBinding(b1);
    mb.addBinding(b2);
    assert(mb.getBindingCount() == 2, "JavaMultiBinding.addBinding");
    mb.setConverter(fn(values) {
        return values[0] + " " + values[1];
    });
    mb.update();
    assert(tgt["FullName"] == "John Doe", "JavaMultiBinding.converter");
    mb.removeBinding(b1);
    assert(mb.getBindingCount() == 1, "JavaMultiBinding.removeBinding");
    mb.setActive(false);
    return 0;
}

fn test_java_binding_manager() {
    let mgr = new JavaBindingManager();
    mgr.init_binding_mgr();
    let src = {"X": 10};
    let tgt = {"Left": 0};
    let b = new JavaBinding();
    b.init_binding(src, "X", tgt, "Left");
    mgr.addBinding(b);
    assert(mgr.getBindingCount() == 1, "JavaBindingManager.addBinding");
    mgr.updateAll();
    assert(tgt["Left"] == 10, "JavaBindingManager.updateAll");
    mgr.setDeferUpdates(true);
    src["X"] = 20;
    assert(tgt["Left"] == 10, "JavaBindingManager.deferUpdates");
    mgr.setDeferUpdates(false);
    assert(tgt["Left"] == 20, "JavaBindingManager.deferred flush");
    let src_bindings = mgr.getBindingsForSource(src);
    assert(len(src_bindings) == 1, "JavaBindingManager.getBindingsForSource");
    let tgt_bindings = mgr.getBindingsForTarget(tgt);
    assert(len(tgt_bindings) == 1, "JavaBindingManager.getBindingsForTarget");
    mgr.removeBinding(b);
    assert(mgr.getBindingCount() == 0, "JavaBindingManager.removeBinding");
    mgr.clear();
    return 0;
}

fn test_java_binding_expression() {
    let src = {"Value": 100};
    let tgt = {"Text": ""};
    let b = new JavaBinding();
    b.init_binding(src, "Value", tgt, "Text");
    b.setMode("oneWay");
    let expr = new JavaBindingExpression();
    expr.init_expr(b, tgt, "Text");
    assert(expr.isDirty() == false, "JavaBindingExpression.isDirty default");
    expr.markDirty();
    assert(expr.isDirty() == true, "JavaBindingExpression.markDirty");
    expr.refresh();
    assert(tgt["Text"] == 100, "JavaBindingExpression.refresh");
    assert(expr.isDirty() == false, "JavaBindingExpression.refresh clears dirty");
    assert(expr.getBinding() == b, "JavaBindingExpression.getBinding");
    assert(expr.getTargetProperty() == "Text", "JavaBindingExpression.getTargetProperty");
    return 0;
}

# ═══════════════════════════════════════════════════════════════════════════
# Section 6: RPC/Service Tests
# ═══════════════════════════════════════════════════════════════════════════

fn test_java_service_host() {
    let host = new JavaServiceHost();
    host.init_host("TestService", 8080);
    assert(host.getHostName() == "TestService", "JavaServiceHost.getHostName");
    assert(host.getPort() == 8080, "JavaServiceHost.getPort");
    assert(host.isRunning() == false, "JavaServiceHost.isRunning default");
    host.start();
    assert(host.isRunning() == true, "JavaServiceHost.start");
    host.registerService("getUser", "handler_get_user");
    assert(host.getServiceCount() == 1, "JavaServiceHost.registerService");
    assert(host.hasService("getUser") == true, "JavaServiceHost.hasService");
    let svc = host.getService("getUser");
    assert(svc == "handler_get_user", "JavaServiceHost.getService");
    host.unregisterService("getUser");
    assert(host.hasService("getUser") == false, "JavaServiceHost.unregisterService");
    host.setMaxConnections(50);
    assert(host.getMaxConnections() == 50, "JavaServiceHost.setMaxConnections");
    host.addEndpoint("/api/v1");
    let eps = host.getEndpoints();
    assert(len(eps) == 1, "JavaServiceHost.addEndpoint");
    host.stop();
    assert(host.isRunning() == false, "JavaServiceHost.stop");
    return 0;
}

fn test_java_rpc_client() {
    let client = new JavaRPCClient();
    client.init_client("http://localhost:8080/rpc");
    assert(client.getEndpoint() == "http://localhost:8080/rpc", "JavaRPCClient.getEndpoint");
    client.setTimeout(10000);
    assert(client.getTimeout() == 10000, "JavaRPCClient.setTimeout");
    client.setAuthToken("bearer-xyz");
    client.setHeader("Content-Type", "application/json");
    client.connect();
    assert(client.isConnected() == true, "JavaRPCClient.connect");
    let result = client.call("getUser", [123]);
    assert(result != nullptr, "JavaRPCClient.call");
    assert(client.getCallCount() == 1, "JavaRPCClient.getCallCount");
    client.disconnect();
    assert(client.isConnected() == false, "JavaRPCClient.disconnect");
    return 0;
}

fn test_java_rpc_message() {
    let msg = new JavaRPCMessage();
    msg.init_msg("getUser", [{"id": 123}]);
    assert(msg.getMethod() == "getUser", "JavaRPCMessage.getMethod");
    assert(msg.getParamCount() == 1, "JavaRPCMessage.getParamCount");
    assert(msg.isRequest() == true, "JavaRPCMessage.isRequest default");
    assert(msg.isNotification() == false, "JavaRPCMessage.isNotification default");
    msg.setNotification(true);
    assert(msg.isNotification() == true, "JavaRPCMessage.setNotification");
    msg.setCorrelationId("corr-1");
    assert(msg.getCorrelationId() == "corr-1", "JavaRPCMessage.setCorrelationId");
    msg.setId(42);
    assert(msg.getId() == 42, "JavaRPCMessage.setId");
    msg.setHeader("X-Trace", "abc123");
    return 0;
}

fn test_java_rpc_response() {
    let resp = new JavaRPCResponse();
    resp.init_response(1);
    assert(resp.getMessageId() == 1, "JavaRPCResponse.getMessageId");
    assert(resp.isSuccess() == false, "JavaRPCResponse.isSuccess default");
    resp.setSuccess({"name": "Alice"});
    assert(resp.isSuccess() == true, "JavaRPCResponse.setSuccess");
    assert(resp.getResult() != nullptr, "JavaRPCResponse.getResult");
    let resp2 = new JavaRPCResponse();
    resp2.init_response(2);
    resp2.setError(500, "Internal Error");
    assert(resp2.isSuccess() == false, "JavaRPCResponse.setError");
    assert(resp2.getErrorCode() == 500, "JavaRPCResponse.getErrorCode");
    assert(resp2.getError() == "Internal Error", "JavaRPCResponse.getError");
    resp2.setCorrelationId("corr-2");
    assert(resp2.getCorrelationId() == "corr-2", "JavaRPCResponse.setCorrelationId");
    return 0;
}

fn test_java_rpc_context() {
    let req = new JavaRPCMessage();
    req.init_msg("getData", []);
    let resp = new JavaRPCResponse();
    resp.init_response(1);
    let ctx = new JavaRPCContext();
    ctx.init_context(req, resp);
    assert(ctx.getRequest() == req, "JavaRPCContext.getRequest");
    assert(ctx.getResponse() == resp, "JavaRPCContext.getResponse");
    assert(ctx.isAuthenticated() == false, "JavaRPCContext.isAuthenticated default");
    ctx.setAuthenticated(true);
    ctx.setPrincipal("admin");
    assert(ctx.isAuthenticated() == true, "JavaRPCContext.setAuthenticated");
    assert(ctx.getPrincipal() == "admin", "JavaRPCContext.setPrincipal");
    ctx.setUserData({"role": "admin"});
    assert(ctx.getUserData() != nullptr, "JavaRPCContext.setUserData");
    return 0;
}

fn test_java_socket_channel() {
    let ch = new JavaSocketChannel();
    ch.init_channel("localhost", 9000);
    assert(ch.getHost() == "localhost", "JavaSocketChannel.getHost");
    assert(ch.getPort() == 9000, "JavaSocketChannel.getPort");
    assert(ch.isConnected() == false, "JavaSocketChannel.isConnected default");
    ch.setBufferSize(8192);
    ch.setSSL(true);
    assert(ch.isSSL() == true, "JavaSocketChannel.setSSL");
    ch.connect();
    assert(ch.isConnected() == true, "JavaSocketChannel.connect");
    ch.disconnect();
    assert(ch.isConnected() == false, "JavaSocketChannel.disconnect");
    return 0;
}

fn test_java_mapped_byte_buffer() {
    let mbb = new JavaMappedByteBuffer();
    mbb.init_mbb("shared_buffer", 65536);
    assert(mbb.getName() == "shared_buffer", "JavaMappedByteBuffer.getName");
    assert(mbb.getSize() == 65536, "JavaMappedByteBuffer.getSize");
    assert(mbb.isOpen() == false, "JavaMappedByteBuffer.isOpen default");
    mbb.open();
    assert(mbb.isOpen() == true, "JavaMappedByteBuffer.open");
    mbb.setAccess("read_only");
    assert(mbb.getAccess() == "read_only", "JavaMappedByteBuffer.setAccess");
    mbb.close();
    assert(mbb.isOpen() == false, "JavaMappedByteBuffer.close");
    return 0;
}

# ═══════════════════════════════════════════════════════════════════════════
# Section 7: Serialization Tests
# ═══════════════════════════════════════════════════════════════════════════

fn test_java_serializer() {
    let mapper = new JavaTypeMapper();
    mapper.init_mapper();
    let s = new JavaSerializer(mapper);
    s.init_serializer(mapper);
    assert(s.getFormat() == "json", "JavaSerializer.getFormat default");
    s.setFormat("messagepack");
    assert(s.getFormat() == "messagepack", "JavaSerializer.setFormat");
    s.setIndent(true);
    assert(s.isIndent() == true, "JavaSerializer.setIndent");
    let result = s.serialize(42, "int");
    assert(result != nullptr, "JavaSerializer.serialize");
    let obj = {"name": "test", "value": 100};
    let serialized = s.serializeObject(obj);
    assert(serialized != nullptr, "JavaSerializer.serializeObject");
    let lst = s.serializeList([1, 2, 3]);
    assert(lst != nullptr, "JavaSerializer.serializeList");
    assert(len(lst) == 3, "JavaSerializer.serializeList length");
    s.registerCustomSerializer("MyType", fn(val) { return {"__custom__": val}; });
    return 0;
}

fn test_java_deserializer() {
    let mapper = new JavaTypeMapper();
    mapper.init_mapper();
    let d = new JavaDeserializer(mapper);
    d.init_deserializer(mapper);
    assert(d.getFormat() == "json", "JavaDeserializer.getFormat default");
    d.setFormat("messagepack");
    assert(d.getFormat() == "messagepack", "JavaDeserializer.setFormat");
    d.setStrict(true);
    assert(d.isStrict() == true, "JavaDeserializer.setStrict");
    let data = {"__type__": "int", "value": 42};
    let result = d.deserialize(data);
    assert(result == 42, "JavaDeserializer.deserialize");
    let null_result = d.deserialize(nullptr);
    assert(null_result == nullptr, "JavaDeserializer.deserialize nullptr");
    d.registerCustomDeserializer("MyType", fn(data) { return data; });
    return 0;
}

fn test_java_messagepack() {
    let mp = new JavaMessagePack();
    mp.init_msgpack();
    mp.setByteOrder("little_endian");
    mp.setUseExtTypes(false);
    mp.setMaxStrLen(1024);
    let packed = mp.pack([1, 2, 3]);
    assert(packed != nullptr, "JavaMessagePack.pack");
    return 0;
}

fn test_java_json() {
    let j = new JavaJSON();
    j.init_json();
    j.setEscapeUnicode(true);
    j.setMaxDepth(50);
    j.setAllowComments(true);
    assert(j.stringify(nullptr) == "null", "JavaJSON.stringify null");
    assert(j.stringify(true) == "true", "JavaJSON.stringify true");
    assert(j.stringify(false) == "false", "JavaJSON.stringify false");
    return 0;
}

fn test_java_type_converter() {
    let tc = new JavaTypeConverter();
    tc.init_converter();
    tc.registerConverter("int", "string", fn(val) { return str(val); });
    assert(tc.canConvert("int", "string") == true, "JavaTypeConverter.canConvert");
    let result = tc.convert(42, "int", "string");
    assert(result != nullptr, "JavaTypeConverter.convert");
    tc.setFallback(fn(val, ft, tt) { return val; });
    tc.clear();
    return 0;
}

# ═══════════════════════════════════════════════════════════════════════════
# Section 8: Async Tests
# ═══════════════════════════════════════════════════════════════════════════

fn test_java_future() {
    let f = new JavaFuture();
    f.init_future();
    assert(f.getStatus() == "created", "JavaFuture.getStatus created");
    assert(f.isDone() == false, "JavaFuture.isDone default");
    assert(f.isFaulted() == false, "JavaFuture.isFaulted default");
    assert(f.isCancelled() == false, "JavaFuture.isCancelled default");
    f.setId(1);
    assert(f.getId() == 1, "JavaFuture.setId");
    f.complete("result");
    assert(f.isDone() == true, "JavaFuture.complete");
    assert(f.getStatus() == "completed", "JavaFuture.getStatus completed");
    assert(f.getResult() == "result", "JavaFuture.getResult");
    let f2 = new JavaFuture();
    f2.init_future();
    f2.fail("error");
    assert(f2.isFaulted() == true, "JavaFuture.fail");
    assert(f2.getException() == "error", "JavaFuture.getException");
    let f3 = new JavaFuture();
    f3.init_future();
    f3.cancel();
    assert(f3.isCancelled() == true, "JavaFuture.cancel");
    return 0;
}

fn test_java_executor_service() {
    let exec = new JavaExecutorService();
    exec.init_executor();
    assert(exec.getPoolSize() == 4, "JavaExecutorService.getPoolSize default");
    exec.setPoolSize(8);
    assert(exec.getPoolSize() == 8, "JavaExecutorService.setPoolSize");
    assert(exec.isShutdown() == false, "JavaExecutorService.isShutdown default");
    let task = new JavaFuture();
    task.init_future();
    exec.submit(task);
    assert(exec.getPendingCount() == 1, "JavaExecutorService.submit");
    exec.execute();
    assert(exec.isTerminated() == false, "JavaExecutorService.execute");
    exec.shutdown();
    assert(exec.isShutdown() == true, "JavaExecutorService.shutdown");
    exec.setQueueType("lifo");
    assert(exec.getQueueType() == "lifo", "JavaExecutorService.setQueueType");
    exec.shutdownNow();
    return 0;
}

fn test_java_cancellation_token() {
    let token = new JavaCancellationToken();
    token.init_token();
    assert(token.isCancelled() == false, "JavaCancellationToken.isCancelled default");
    token.cancel();
    assert(token.isCancelled() == true, "JavaCancellationToken.cancel");
    let called = false;
    let token2 = new JavaCancellationToken();
    token2.init_token();
    token2.setOnCancel(fn() { called = true; return 0; });
    token2.cancel();
    assert(called == true, "JavaCancellationToken.setOnCancel");
    return 0;
}

fn test_java_async_result() {
    let f = new JavaFuture();
    f.init_future();
    let ar = new JavaAsyncResult();
    ar.init_async_result(f);
    assert(ar.getFuture() == f, "JavaAsyncResult.getFuture");
    assert(ar.isCompleted() == false, "JavaAsyncResult.isCompleted default");
    ar.setCompleted(true);
    assert(ar.isCompleted() == true, "JavaAsyncResult.setCompleted");
    ar.setCompletedSynchronously(true);
    ar.setAsyncState({"progress": 50});
    assert(ar.getAsyncState() != nullptr, "JavaAsyncResult.setAsyncState");
    return 0;
}

fn test_java_thread_pool() {
    let pool = new JavaThreadPool();
    pool.init_pool();
    assert(pool.getCorePoolSize() == 2, "JavaThreadPool.getCorePoolSize default");
    pool.setCorePoolSize(4);
    assert(pool.getCorePoolSize() == 4, "JavaThreadPool.setCorePoolSize");
    pool.setMaxPoolSize(16);
    assert(pool.getMaxPoolSize() == 16, "JavaThreadPool.setMaxPoolSize");
    pool.setKeepAliveMs(120000);
    pool.execute(fn() { return 0; });
    assert(pool.getActiveCount() == 0, "JavaThreadPool.execute returns");
    return 0;
}

