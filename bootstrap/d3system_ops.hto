fn d3_region_container_filter_by_volume_min(d3Obj, minVolume) {
    let results = [];
    let i = 0;
    let count = len(d3Obj.regions);
    while (i < count) {
        let vol = d3_region_get_volume(d3Obj.regions[i]);
        if (vol >= minVolume) {
            push(results, d3Obj.regions[i]);
        }
        i = i + 1;
    }
    return results;
}

fn d3_region_container_filter_by_volume_max(d3Obj, maxVolume) {
    let results = [];
    let i = 0;
    let count = len(d3Obj.regions);
    while (i < count) {
        let vol = d3_region_get_volume(d3Obj.regions[i]);
        if (vol <= maxVolume) {
            push(results, d3Obj.regions[i]);
        }
        i = i + 1;
    }
    return results;
}

fn d3_region_container_get_names(d3Obj) {
    let names = [];
    let i = 0;
    let count = len(d3Obj.regions);
    while (i < count) {
        push(names, d3Obj.regions[i]["name"]);
        i = i + 1;
    }
    return names;
}

fn d3_region_container_get_total_volume(d3Obj) {
    return d3_system_summary(d3Obj);
}

fn d3_region_container_get_largest(d3Obj) {
    let regions = d3Obj.regions;
    let count = len(regions);
    if (count == 0) {
        return [];
    }
    let largest = regions[0];
    let largestVol = d3_region_get_volume(largest);
    let i = 1;
    while (i < count) {
        let vol = d3_region_get_volume(regions[i]);
        if (vol > largestVol) {
            largest = regions[i];
            largestVol = vol;
        }
        i = i + 1;
    }
    return largest;
}

fn d3_region_container_get_smallest(d3Obj) {
    let regions = d3Obj.regions;
    let count = len(regions);
    if (count == 0) {
        return [];
    }
    let smallest = regions[0];
    let smallestVol = d3_region_get_volume(smallest);
    let i = 1;
    while (i < count) {
        let vol = d3_region_get_volume(regions[i]);
        if (vol < smallestVol) {
            smallest = regions[i];
            smallestVol = vol;
        }
        i = i + 1;
    }
    return smallest;
}

