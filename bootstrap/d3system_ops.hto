# Dict Key Utility
# ============================================================

fn d3_dict_keys(d) {
    let keys = [];
    push(keys, "name");
    push(keys, "params");
    push(keys, "is_public");
    push(keys, "__type");
    push(keys, "coords");
    push(keys, "implements");
    push(keys, "methods");
    push(keys, "classes");
    push(keys, "body");
    push(keys, "d3_ref");
    push(keys, "parent_d3");
    push(keys, "env");
    push(keys, "__parent_3d");
    push(keys, "region");
    push(keys, "class");
    push(keys, "class_name");
    return keys;
}

# ============================================================
# 6. 数据容器 (Data Container Operations)
#    数据的导出、序列化、打包、反序列化
# ============================================================

fn d3_data_export_region(d3Obj, regionName) {
    return d3_export_region_data(d3Obj, regionName);
}

fn d3_data_pack_region(rgn) {
    let data = [];
    let c = rgn.coords;
    push(data, rgn["name"]);
    push(data, c[0]);
    push(data, c[1]);
    push(data, c[2]);
    push(data, c[3]);
    push(data, c[4]);
    push(data, c[5]);
    push(data, rgn["parent_d3"]);
    return data;
}

fn d3_data_pack_region_full(rgn) {
    let data = d3_data_pack_region(rgn);
    let dims = d3_region_get_dimensions(rgn);
    push(data, dims[0]);
    push(data, dims[1]);
    push(data, dims[2]);
    let vol = d3_region_get_volume(rgn);
    push(data, vol);
    let mc = d3_region_method_count(rgn);
    push(data, mc);
    let cc = d3_region_class_count(rgn);
    push(data, cc);
    let impls = rgn["implements"];
    let ic = len(impls);
    push(data, ic);
    let ii = 0;
    while (ii < ic) {
        push(data, impls[ii]);
        ii = ii + 1;
    }
    return data;
}

fn d3_data_unpack_region(data) {
    let rgn = {};
    rgn["__type"] = "region";
    rgn["name"] = data[0];
    rgn["coords"] = [data[1], data[2], data[3], data[4], data[5], data[6]];
    rgn["parent_d3"] = data[7];
    rgn["implements"] = [];
    rgn["methods"] = [];
    rgn["classes"] = [];
    rgn["d3_ref"] = [];
    return rgn;
}

fn d3_data_export_all_regions(d3Obj) {
    let allData = [];
    let i = 0;
    let count = len(d3Obj.regions);
    while (i < count) {
        let packed = d3_data_pack_region(d3Obj.regions[i]);
        push(allData, packed);
        i = i + 1;
    }
    return allData;
}

fn d3_data_export_all_regions_full(d3Obj) {
    let allData = [];
    let i = 0;
    let count = len(d3Obj.regions);
    while (i < count) {
        let packed = d3_data_pack_region_full(d3Obj.regions[i]);
        push(allData, packed);
        i = i + 1;
    }
    return allData;
}

fn d3_data_serialize_system(d3Obj) {
    let serialized = [];
    push(serialized, d3Obj["name"]);
    push(serialized, d3Obj["__type"]);
    let pc = len(d3Obj.properties);
    push(serialized, pc);
    let pi = 0;
    while (pi < pc) {
        let p = d3Obj.properties[pi];
        push(serialized, p["name"]);
        push(serialized, p["is_public"]);
        push(serialized, len(p["params"]));
        pi = pi + 1;
    }
    let rc = len(d3Obj.regions);
    push(serialized, rc);
    let ri = 0;
    while (ri < rc) {
        let r = d3Obj.regions[ri];
        let packed = d3_data_pack_region_full(r);
        let pk = 0;
        let pkc = len(packed);
        while (pk < pkc) {
            push(serialized, packed[pk]);
            pk = pk + 1;
        }
        ri = ri + 1;
    }
    let ric = len(d3Obj.region_interfaces);
    push(serialized, ric);
    let rii = 0;
    while (rii < ric) {
        let iface = d3Obj.region_interfaces[rii];
        push(serialized, iface["name"]);
        rii = rii + 1;
    }
    return serialized;
}

fn d3_data_system_snapshot(d3Obj) {
    let snapshot = {};
    snapshot["name"] = d3Obj["name"];
    snapshot["type"] = d3Obj["__type"];
    snapshot["property_count"] = d3_property_count(d3Obj);
    snapshot["region_count"] = d3_figure_get_region_count(d3Obj);
    snapshot["interface_count"] = d3_figure_get_interface_count(d3Obj);
    snapshot["bounds"] = d3_figure_get_bounds(d3Obj);
    snapshot["center"] = d3_figure_get_center(d3Obj);
    snapshot["dimensions"] = d3_figure_get_dimensions(d3Obj);
    snapshot["total_volume"] = d3_figure_get_total_volume(d3Obj);
    snapshot["total_classes"] = d3_class_count_all(d3Obj);
    let names = d3_region_container_get_names(d3Obj);
    snapshot["region_names"] = names;
    return snapshot;
}

fn d3_data_diff_regions(d3ObjA, d3ObjB) {
    let namesA = d3_region_container_get_names(d3ObjA);
    let namesB = d3_region_container_get_names(d3ObjB);
    let onlyA = [];
    let onlyB = [];
    let common = [];
    let i = 0;
    let ca = len(namesA);
    while (i < ca) {
        let found = false;
        let j = 0;
        let cb = len(namesB);
        while (j < cb) {
            if (namesA[i] == namesB[j]) {
                found = true;
            }
            j = j + 1;
        }
        if (found) {
            push(common, namesA[i]);
        }
        if (found == false) {
            push(onlyA, namesA[i]);
        }
        i = i + 1;
    }
    let k = 0;
    let cb2 = len(namesB);
    while (k < cb2) {
        let found = false;
        let m = 0;
        let ca2 = len(common);
        while (m < ca2) {
            if (namesB[k] == common[m]) {
                found = true;
            }
            m = m + 1;
        }
        if (found == false) {
            push(onlyB, namesB[k]);
        }
        k = k + 1;
    }
    let result = {};
    result["only_in_first"] = onlyA;
    result["only_in_second"] = onlyB;
    result["common"] = common;
    return result;
}

fn d3_data_count_intersections(d3Obj) {
    let regions = d3Obj.regions;
    let count = len(regions);
    let intersections = 0;
    let i = 0;
    while (i < count) {
        let j = i + 1;
        while (j < count) {
            if (d3_bbox_intersects(regions[i].coords, regions[j].coords)) {
                intersections = intersections + 1;
            }
            j = j + 1;
        }
        i = i + 1;
    }
    return intersections;
}

