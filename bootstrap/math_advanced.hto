# SECTION 16: Sorting & Helper Functions
# ═══════════════════════════════════════════════════════════════════

fn math_sort_ascending(arr) {
    let n = len(arr);
    let i = 0;
    while (i < n - 1) {
        let j = 0;
        while (j < n - i - 1) {
            if (arr[j] > arr[j + 1]) {
                let temp = arr[j];
                arr[j] = arr[j + 1];
                arr[j + 1] = temp;
            }
            j = j + 1;
        }
        i = i + 1;
    }
    return arr;
}

fn math_sort_descending(arr) {
    let n = len(arr);
    let i = 0;
    while (i < n - 1) {
        let j = 0;
        while (j < n - i - 1) {
            if (arr[j] < arr[j + 1]) {
                let temp = arr[j];
                arr[j] = arr[j + 1];
                arr[j + 1] = temp;
            }
            j = j + 1;
        }
        i = i + 1;
    }
    return arr;
}

fn math_linspace(start, end, n) {
    let result = [];
    if (n <= 1) { push(result, start); return result; }
    let step = (end - start) / (n - 1);
    let i = 0;
    while (i < n) {
        push(result, start + i * step);
        i = i + 1;
    }
    return result;
}

fn math_arange(start, end, step) {
    if (step == nullptr) { step = 1.0; }
    let result = [];
    let x = start;
    while (x < end) {
        push(result, x);
        x = x + step;
    }
    return result;
}

fn math_logspace(start, end, n) {
    let result = [];
    if (n <= 1) { push(result, math_pow(10.0, start)); return result; }
    let step = (end - start) / (n - 1);
    let i = 0;
    while (i < n) {
        push(result, math_pow(10.0, start + i * step));
        i = i + 1;
    }
    return result;
}

fn math_count_if(arr, predicate) {
    let count = 0;
    let i = 0;
    while (i < len(arr)) {
        if (predicate(arr[i])) { count = count + 1; }
        i = i + 1;
    }
    return count;
}

fn math_filter(arr, predicate) {
    let result = [];
    let i = 0;
    while (i < len(arr)) {
        if (predicate(arr[i])) { push(result, arr[i]); }
        i = i + 1;
    }
    return result;
}

fn math_map(arr, fn) {
    let result = [];
    let i = 0;
    while (i < len(arr)) {
        push(result, fn(arr[i]));
        i = i + 1;
    }
    return result;
}

fn math_reduce(arr, fn, init) {
    let result = init;
    let i = 0;
    while (i < len(arr)) {
        result = fn(result, arr[i]);
        i = i + 1;
    }
    return result;
}

