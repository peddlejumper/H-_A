import "bootstrap/d3system.hto";
import "bootstrap/d3system_ops.hto";

# ============================================================
# Test 3D System Definition
# ============================================================

3dsizepower TestWorld {
    public abs{T, T, size}
    public size[auto{size=auto^3d}]

    region_interface IInteractive {
        fn on_enter(x, y, z);
        fn on_exit(x, y, z);
    }

    region HomeBase(0, 0, 0, 100, 100, 100) {
        fn welcome() {
            print("Welcome to HomeBase");
        }
        class BaseEntity {
            fn describe() {
                print("I am a BaseEntity");
            }
        }
    }

    region MiningZone(100, 0, 0, 300, 200, 200) {
        fn collect() {
            print("Collecting ore");
        }
        class MinerBot {
            fn work() {
                print("Mining...");
            }
        }
    }

    region StorageArea(300, 0, 0, 450, 150, 150) {
        fn store() {
            print("Storing items");
        }
    }
}

em3d ExtendedWorld extends TestWorld {
    public extra_data[auto{capacity=1000}]

    region WarpPoint(450, 0, 0, 600, 200, 200) {
        fn activate() {
            print("Warp activated!");
        }
        class WarpEngine {
            fn jump() {
                print("Jumping to destination");
            }
        }
    }
}

# ============================================================
# Initialize region metadata (class_names, method_names)
# ============================================================
d3_system_init(TestWorld, [], []);
d3_system_init(ExtendedWorld, [], []);

d3_class_register_names(TestWorld, "HomeBase", ["BaseEntity"]);
d3_class_register_names(TestWorld, "MiningZone", ["MinerBot"]);
d3_class_register_names(TestWorld, "StorageArea", []);
d3_class_register_names(ExtendedWorld, "WarpPoint", ["WarpEngine"]);
d3_class_register_names(ExtendedWorld, "HomeBase", ["BaseEntity"]);
d3_class_register_names(ExtendedWorld, "MiningZone", ["MinerBot"]);
d3_class_register_names(ExtendedWorld, "StorageArea", []);

let hm = d3_find_region_by_name(TestWorld, "HomeBase");
hm["_method_names"] = ["welcome"];
let mz = d3_find_region_by_name(TestWorld, "MiningZone");
mz["_method_names"] = ["collect"];
let sa = d3_find_region_by_name(TestWorld, "StorageArea");
sa["_method_names"] = ["store"];
let wp = d3_find_region_by_name(ExtendedWorld, "WarpPoint");
wp["_method_names"] = ["activate"];

# ============================================================
# Section 1: 代码内外部属性 Tests
# ============================================================
print("");
print("=== SECTION 1: Property Operations (代码内外部属性) ===");
print("");
print("1.1 Property count:");
let pc = d3_property_count(TestWorld);
print(pc);
print("");

print("1.2 Property names:");
let names = d3_property_list_names(TestWorld);
print(names);
print("");

print("1.3 Check 'abs' exists:");
let hasAbs = d3_property_has(TestWorld, "abs");
print(hasAbs);
print("");

print("1.4 Get 'abs' property:");
let absProp = d3_property_get(TestWorld, "abs");
print(absProp["name"]);
print("");

print("1.5 'abs' is public:");
let absPub = d3_property_is_public(TestWorld, "abs");
print(absPub);
print("");

print("1.6 Get 'abs' params:");
let absParams = d3_property_get_params(TestWorld, "abs");
print(absParams);
print("");

print("1.7 List public properties:");
let pubList = d3_property_list_public(TestWorld);
print(len(pubList));
print("");

print("1.8 List ExtendedWorld properties (includes inherited):");
let ewpc = d3_property_count(ExtendedWorld);
print(ewpc);
print("");

print("1.9 Has 'extra_data' in ExtendedWorld:");
let hasExtra = d3_property_has(ExtendedWorld, "extra_data");
print(hasExtra);
print("");

print("1.10 Set new property:");
let result = d3_property_set(TestWorld, "custom_prop", ["hello"]);
print(result);
let verifyNew = d3_property_has(TestWorld, "custom_prop");
print(verifyNew);
print("");

print("1.11 Remove property:");
let removed = d3_property_remove(TestWorld, "custom_prop");
print(removed);
let verifyRemoved = d3_property_has(TestWorld, "custom_prop");
print(verifyRemoved);
print("");

