let spca = new SparsePCA();
spca.init_sparse_pca(10, 1.0, 100);
assert(spca.alpha == 1.0, "SparsePCA init_sparse_pca");

let ipca = new IncrementalPCA();
ipca.init_incremental_pca(10, 100);
