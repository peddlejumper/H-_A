# ═══════════════════════════════════════════════════════════════════════════
# Section 42: Ensemble Methods
# ═══════════════════════════════════════════════════════════════════════════
print("── Section 42: Ensemble Methods ──");

let rfc = new RandomForestClassifier();
rfc.init_random_forest_classifier(100, 10, 2, "sqrt");
assert(rfc.n_estimators == 100, "RandomForestClassifier init");
assert(rfc.max_features == "sqrt", "RandomForestClassifier max_features");

let rfr = new RandomForestRegressor();
rfr.init_random_forest_regressor(100, 10, 2, "sqrt");
assert(rfr.n_estimators == 100, "RandomForestRegressor init");

let etc = new ExtraTreesClassifier();
etc.init_extra_trees(100, 10);
assert(etc.n_estimators == 100, "ExtraTreesClassifier init_extra_trees");

let etr = new ExtraTreesRegressor();
etr.init_extra_trees_reg(100, 10);
assert(etr.n_estimators == 100, "ExtraTreesRegressor init_extra_trees_reg");

let sc = new StackingClassifier();
sc.init_stacking_classifier([rfc, etc], rfc);
assert(sc.base_estimators != nullptr, "StackingClassifier init");

let sr = new StackingRegressor();
sr.init_stacking_regressor([rfr, etr], rfr);
assert(sr.base_estimators != nullptr, "StackingRegressor init");

let bc = new BlendingClassifier();
bc.init_blending([rfc, etc], rfc, 0.2);
assert(bc.holdout_ratio == 0.2, "BlendingClassifier init_blending");

let we = new WeightedEnsemble();
we.init_weighted_ensemble([rfc, etc], [0.6, 0.4]);
assert(we.weights != nullptr, "WeightedEnsemble init_weighted_ensemble");

let hgb_c = new HistGradientBoostingClassifier();
hgb_c.init_hist_gradient_boosting(100, 0.1, 3);
assert(hgb_c.learning_rate == 0.1, "HistGradientBoostingClassifier init");

let hgb_r = new HistGradientBoostingRegressor();
hgb_r.init_hist_gradient_boosting_reg(100, 0.1, 3);
assert(hgb_r.learning_rate == 0.1, "HistGradientBoostingRegressor init");

