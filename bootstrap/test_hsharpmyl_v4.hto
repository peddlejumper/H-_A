# Section 40: Model Selection & Cross-Validation
# ═══════════════════════════════════════════════════════════════════════════
print("── Section 40: Model Selection & Cross-Validation ──");

let kf = new KFold();
kf.init_kfold(5, true, 42);
assert(kf.n_splits == 5, "KFold init_kfold");
assert(kf.shuffle == true, "KFold shuffle");

let skf = new StratifiedKFold();
skf.init_stratified_kfold(5, true);
assert(skf.n_splits == 5, "StratifiedKFold init_stratified_kfold");

let tss = new TimeSeriesSplit();
tss.init_ts_split(5);
assert(tss.n_splits == 5, "TimeSeriesSplit init_ts_split");

let loo = new LeaveOneOut();
loo.init_loo();
assert(loo != nullptr, "LeaveOneOut init_loo");

let lpo = new LeavePOut();
lpo.init_lpo(2);
assert(lpo.p == 2, "LeavePOut init_lpo");

let ss = new ShuffleSplit();
ss.init_shuffle_split(10, 0.2);
assert(ss.n_splits == 10, "ShuffleSplit init_shuffle_split");

let rkf = new RepeatedKFold();
rkf.init_repeated_kfold(5, 3);
assert(rkf.n_repeats == 3, "RepeatedKFold init_repeated_kfold");

let tts = new TrainTestSplit();
tts.init_train_test_split(0.2, true);
assert(tts.test_size == 0.2, "TrainTestSplit init_train_test_split");

let cv = new CrossValidate();
cv.init_cross_validate(5, "accuracy");
assert(cv.cv == 5, "CrossValidate init_cross_validate");

