let ica = new FastICA();
ica.init_fast_ica(10, 200);
assert(ica.n_components == 10, "FastICA init_fast_ica");

let iso = new Isomap();
iso.init_isomap(2, 5);
assert(iso.n_neighbors == 5, "Isomap init_isomap");

let mds = new MDS();
mds.init_mds(2, 300);
assert(mds.n_components == 2, "MDS init_mds");

let tsne = new TSNE();
tsne.init_tsne(2, 30.0, 1000, 200.0);
assert(tsne.perplexity == 30.0, "TSNE init_tsne");
assert(tsne.learning_rate == 200.0, "TSNE learning_rate");

let kpca = new KernelPCA();
kpca.init_kernel_pca(10, "rbf", 1.0);
