# ═══════════════════════════════════════════════════════════════════════════
# H#ML v4 — Class Type Test Suite
# ═══════════════════════════════════════════════════════════════════════════
import "bootstrap/hsharpmyl.hto";

let _test_count = 0;
let _pass_count = 0;

fn assert(condition, msg) {
    _test_count = _test_count + 1;
    if (condition) {
        _pass_count = _pass_count + 1;
        print("  PASS: " + msg);
    } else {
        print("  FAIL: " + msg);
    }
    return 0;
}

fn test_summary() {
    print("");
    print("Test Results: " + _pass_count + "/" + _test_count + " passed");
    if (_pass_count == _test_count) {
        print("ALL TESTS PASSED ✓");
    } else {
        let failed = _test_count - _pass_count;
        print("FAILED: " + failed + " tests");
    }
    return 0;
}

# ═══════════════════════════════════════════════════════════════════════════
# Section 34: Deep Learning Layers
# ═══════════════════════════════════════════════════════════════════════════
print("── Section 34: Deep Learning Layers ──");

let dl = new DenseLayer();
dl.init_dense(4, 3, nullptr, 0.01);
assert(dl.input_dim == 4, "DenseLayer init_dense");
assert(dl.output_dim == 3, "DenseLayer output_dim");

let dp = new DropoutLayer();
dp.init_dropout(0.5);
assert(dp.rate == 0.5, "DropoutLayer init_dropout");

let fl = new FlattenLayer();
fl.init_flatten();
assert(fl != nullptr, "FlattenLayer init_flatten");

let ln = new LayerNorm();
ln.init_layernorm(10);
assert(ln.normalized_shape == 10, "LayerNorm init_layernorm");

let emb = new EmbeddingLayer();
emb.init_embedding(100, 32);
assert(emb.num_embeddings == 100, "EmbeddingLayer init_embedding");
assert(emb.embedding_dim == 32, "EmbeddingLayer embedding_dim");

let rnn = new RNNCell();
rnn.init_rnncell(16, 8);
assert(rnn.input_size == 16, "RNNCell init_rnncell");
assert(rnn.hidden_size == 8, "RNNCell hidden_size");

let lstm = new LSTMCell();
lstm.init_lstmcell(16, 8);
assert(lstm.input_size == 16, "LSTMCell init_lstmcell");

let gru = new GRUCell();
gru.init_grucell(16, 8);
assert(gru.hidden_size == 8, "GRUCell init_grucell");

let attn = new AttentionLayer();
attn.init_attention(64);
assert(attn.d_model == 64, "AttentionLayer init_attention");

let mha = new MultiHeadAttentionLayer();
mha.init_multihead_attention(64, 8);
assert(mha.n_heads == 8, "MultiHeadAttentionLayer init_multihead_attention");

let seq = new SequentialModel();
seq.init_sequential([dl, dp]);
assert(seq.layers != nullptr, "SequentialModel init_sequential");

let bn = new BatchNorm1D();
bn.init_batchnorm1d(10, 0.9);
assert(bn.num_features == 10, "BatchNorm1D init_batchnorm1d");

let conv1d = new Conv1DLayer();
conv1d.init_conv1d(3, 16, 3, 1);
assert(conv1d.out_channels == 16, "Conv1DLayer init_conv1d");

let conv2d = new Conv2DLayer();
conv2d.init_conv2d(3, 16, 3, 1);
assert(conv2d.out_channels == 16, "Conv2DLayer init_conv2d");

let mp1 = new MaxPool1DLayer();
mp1.init_maxpool1d(2, 2);
assert(mp1.pool_size == 2, "MaxPool1DLayer init_maxpool1d");

let mp2 = new MaxPool2DLayer();
mp2.init_maxpool2d(2, 2);
assert(mp2.pool_size == 2, "MaxPool2DLayer init_maxpool2d");

let ap1 = new AvgPool1DLayer();
ap1.init_avgpool1d(2, 2);
assert(ap1.pool_size == 2, "AvgPool1DLayer init_avgpool1d");

let ap2 = new AvgPool2DLayer();
ap2.init_avgpool2d(2, 2);
assert(ap2.pool_size == 2, "AvgPool2DLayer init_avgpool2d");

let bn2 = new BatchNorm2D();
bn2.init_batchnorm2d(16);
assert(bn2.num_features == 16, "BatchNorm2D init_batchnorm2d");

let res = new ResidualBlock();
res.init_residual([dl]);
assert(len(res.layers) == 1, "ResidualBlock init_residual");

