let mnb = new MultinomialNB();
mnb.init_multinomial_nb(1.0);
assert(mnb.alpha == 1.0, "MultinomialNB init_multinomial_nb");

let bnb = new BernoulliNB();
bnb.init_bernoulli_nb(1.0, 0.0);
assert(bnb.alpha == 1.0, "BernoulliNB init_bernoulli_nb");

let cnb = new ComplementNB();
cnb.init_complement_nb(1.0);
assert(cnb.alpha == 1.0, "ComplementNB init_complement_nb");

let catnb = new CategoricalNB();
catnb.init_categorical_nb(1.0);
assert(catnb.alpha == 1.0, "CategoricalNB init_categorical_nb");

let bgmm = new BayesianGaussianMixtureModel();
bgmm.init_bayesian_gmm(3, 100, 1.0, 0.001);
assert(bgmm.n_components == 3, "BayesianGaussianMixtureModel init");

let blr = new BayesianLinearRegressionModel();
blr.init_bayesian_lr(1.0, 1.0);
assert(blr.prior_precision == 1.0, "BayesianLinearRegressionModel init");

let gpc = new GaussianProcessClassifier();
gpc.init_gaussian_process_clf("rbf");
assert(gpc.kernel == "rbf", "GaussianProcessClassifier init");

# ═══════════════════════════════════════════════════════════════════════════
# Section 47: Anomaly Detection
# ═══════════════════════════════════════════════════════════════════════════
print("── Section 47: Anomaly Detection ──");

let iforest = new IsolationForest();
iforest.init_isolation_forest(100, 256, 0.1);
assert(iforest.n_estimators == 100, "IsolationForest init_isolation_forest");
assert(iforest.contamination == 0.1, "IsolationForest contamination");

let lof = new LocalOutlierFactor();
lof.init_lof(20, 0.1);
assert(lof.n_neighbors == 20, "LocalOutlierFactor init_lof");

let ee = new EllipticEnvelope();
ee.init_elliptic_envelope(0.1);
assert(ee.contamination == 0.1, "EllipticEnvelope init_elliptic_envelope");

let ocs = new OneClassSVM();
ocs.init_one_class_svm(0.5, "rbf", 1.0);
assert(ocs.nu == 0.5, "OneClassSVM init_one_class_svm");

let rc = new RobustCovariance();
rc.init_robust_covariance(0.1);
assert(rc.contamination == 0.1, "RobustCovariance init_robust_covariance");

let db_out = new DBSCANOutlierDetector();
db_out.init_dbscan_outlier(0.5, 5);
assert(db_out.eps == 0.5, "DBSCANOutlierDetector init_dbscan_outlier");

let hbos = new HBOS();
hbos.init_hbos(10);
assert(hbos.n_bins == 10, "HBOS init_hbos");

let abod = new ABOD();
abod.init_abod(10);
assert(abod.n_neighbors == 10, "ABOD init_abod");

# ═══════════════════════════════════════════════════════════════════════════
# Section 48: Pipeline & Workflow
# ═══════════════════════════════════════════════════════════════════════════
print("── Section 48: Pipeline & Workflow ──");

let pv = new PipelineVerbose();
pv.init_pipeline_verbose([rs, ohe], true);
assert(pv.verbose == true, "PipelineVerbose init_pipeline_verbose");

let fu = new FeatureUnionExtended();
fu.init_feature_union([rs, ohe], [1.0, 1.0]);
assert(fu.transformers != nullptr, "FeatureUnionExtended init_feature_union");

let pp = new ParallelPipeline();
pp.init_parallel_pipeline([rfc, etc]);
assert(pp.estimators != nullptr, "ParallelPipeline init_parallel_pipeline");

let dag = new DAGPipeline();
dag.init_dag_pipeline();
assert(dag != nullptr, "DAGPipeline init_dag_pipeline");

let cmx = new TransformerMixin();
cmx.init_transformer_mixin();
assert(cmx != nullptr, "TransformerMixin init_transformer_mixin");

let emx = new EstimatorMixin();
emx.init_estimator_mixin();
assert(emx != nullptr, "EstimatorMixin init_estimator_mixin");

let me = new MetaEstimator();
me.init_meta_estimator(rfc);
assert(me.base_estimator != nullptr, "MetaEstimator init_meta_estimator");

let cc = new CalibratedClassifier();
cc.init_calibrated_clf(rfc, "sigmoid");
assert(cc.method == "sigmoid", "CalibratedClassifier init_calibrated_clf");

let vr = new VotingRegressor();
vr.init_voting_regressor([rfr, etr], [1.0, 1.0]);
assert(vr.estimators != nullptr, "VotingRegressor init_voting_regressor");

let scv = new StackingCV();
scv.init_stacking_cv([rfc, etc], rfc, 5);
assert(scv.cv == 5, "StackingCV init_stacking_cv");

# ═══════════════════════════════════════════════════════════════════════════
# Section 49: Data Utilities
# ═══════════════════════════════════════════════════════════════════════════
print("── Section 49: Data Utilities ──");

let dl2 = new DataLoader();
dl2.init_data_loader([[1,2],[3,4]], [0,1], 2, true);
assert(dl2.batch_size == 2, "DataLoader init_data_loader");
assert(dl2.shuffle == true, "DataLoader shuffle");

let bg = new BatchGenerator();
bg.init_batch_generator([[1,2],[3,4],[5,6]], 2);
assert(bg.batch_size == 2, "BatchGenerator init_batch_generator");

let ds = new Dataset();
ds.init_dataset([[1,2],[3,4]], [0,1], ["x1","x2"], "test dataset");
assert(ds.feature_names != nullptr, "Dataset init_dataset");

let lds = new LabeledDataset();
lds.init_labeled_dataset([[1,2],[3,4]], [0,1], ["cat","dog"]);
assert(lds.labels != nullptr, "LabeledDataset init_labeled_dataset");

let isamp = new ImbalancedSampler();
isamp.init_imbalanced_sampler("oversample");
assert(isamp.strategy == "oversample", "ImbalancedSampler init_imbalanced_sampler");

let ssamp = new StratifiedSampler();
ssamp.init_stratified_sampler(5);
assert(ssamp.n_splits == 5, "StratifiedSampler init_stratified_sampler");

let tvs = new TrainValSplit();
tvs.init_train_val_split(0.2, 0.1, true);
assert(tvs.test_size == 0.2, "TrainValSplit init_train_val_split");

let sd = new ShuffleData();
sd.init_shuffle_data(42);
assert(sd.random_state == 42, "ShuffleData init_shuffle_data");

let dn = new DataNormalizer();
dn.init_data_normalizer("minmax");
assert(dn.method == "minmax", "DataNormalizer init_data_normalizer");

let fs = new FeatureSelector();
fs.init_feature_selector("variance", 0.01);
assert(fs.method == "variance", "FeatureSelector init_feature_selector");

# ═══════════════════════════════════════════════════════════════════════════
# Section 50: Model Persistence & Deployment
# ═══════════════════════════════════════════════════════════════════════════
print("── Section 50: Model Persistence & Deployment ──");

let ms = new ModelSaver();
ms.init_model_saver();
assert(ms != nullptr, "ModelSaver init_model_saver");

let ml = new ModelLoader();
ml.init_model_loader();
assert(ml != nullptr, "ModelLoader init_model_loader");

let ckpt = new Checkpoint();
ckpt.init_checkpoint("./checkpoints", 5);
assert(ckpt.max_to_keep == 5, "Checkpoint init_checkpoint");

let es = new EarlyStopping();
es.init_early_stopping(10, 0.001);
assert(es.patience == 10, "EarlyStopping init_early_stopping");
assert(es.min_delta == 0.001, "EarlyStopping min_delta");

let rlrp = new ReduceLROnPlateau();
rlrp.init_reduce_lr_plateau(0.5, 5, 0.0001);
assert(rlrp.factor == 0.5, "ReduceLROnPlateau init_reduce_lr_plateau");
assert(rlrp.min_lr == 0.0001, "ReduceLROnPlateau min_lr");

let mc = new ModelCheckpoint();
mc.init_model_checkpoint(true);
assert(mc.save_best_only == true, "ModelCheckpoint init_model_checkpoint");

let tbl = new TensorBoardLogger();
tbl.init_tensorboard_logger("./logs");
assert(tbl.log_dir == "./logs", "TensorBoardLogger init_tensorboard_logger");

let csvl = new CSVLogger();
csvl.init_csv_logger("./logs/training.csv");
assert(csvl.log_path == "./logs/training.csv", "CSVLogger init_csv_logger");

let lcb = new LambdaCallback();
lcb.init_lambda_callback(nullptr, nullptr, nullptr, nullptr, nullptr, nullptr);
assert(lcb != nullptr, "LambdaCallback init_lambda_callback");

let cbl = new CallbackList();
cbl.init_callback_list([es, mc]);
assert(cbl.callbacks != nullptr, "CallbackList init_callback_list");

