class DotNetXAML {
    let xaml_content = "";
    let namespaces = {};
    let resources = {};
    let root_element = "";

    fn init_xaml() {
        self.xaml_content = "";
        self.namespaces = {};
        self.resources = {};
        self.root_element = "";
        self._add_default_namespaces();
        return 0;
    }

    fn _add_default_namespaces() {
        self.namespaces["default"] = "http://schemas.microsoft.com/winfx/2006/xaml/presentation";
        self.namespaces["x"] = "http://schemas.microsoft.com/winfx/2006/xaml";
        return 0;
    }

    fn addNamespace(prefix, uri) {
        self.namespaces[prefix] = uri;
        return 0;
    }

    fn setRootElement(element) {
        self.root_element = element;
        return 0;
    }

    fn addResource(key, value) {
        self.resources[key] = value;
        return 0;
    }

    fn getResource(key) {
        return self.resources[key];
    }

    fn setContent(xaml) {
        self.xaml_content = xaml;
        return 0;
    }

    fn getContent() { return self.xaml_content; }
    fn getRootElement() { return self.root_element; }
    fn getResources() { return self.resources; }
    fn getNamespaces() { return self.namespaces; }

    fn clear() {
        self.xaml_content = "";
        self.resources = {};
        self.root_element = "";
        return 0;
    }
}


class DotNetXAMLReader {
    let xaml = nullptr;
    let parsed_elements = [];

    fn init_reader(xaml) {
        self.xaml = xaml;
        self.parsed_elements = [];
        return 0;
    }

    fn parse() {
        if (self.xaml == nullptr) { return []; }
        return self.parsed_elements;
    }

    fn getElements() { return self.parsed_elements; }
    fn getElementCount() { return len(self.parsed_elements); }
}


class DotNetStyleBridge {
    let hwidget_styles = {};
    let xaml_styles = {};
    let mapped_properties = [];

    fn init_style_bridge() {
        self.hwidget_styles = {};
        self.xaml_styles = {};
        self.mapped_properties = [];
        self._register_mappings();
        return 0;
    }

    fn _register_mappings() {
        push(self.mapped_properties, {"hwdui": "bg_color", "xaml": "Background"});
        push(self.mapped_properties, {"hwdui": "fg_color", "xaml": "Foreground"});
        push(self.mapped_properties, {"hwdui": "border_color", "xaml": "BorderBrush"});
        push(self.mapped_properties, {"hwdui": "border_width", "xaml": "BorderThickness"});
        push(self.mapped_properties, {"hwdui": "font_size", "xaml": "FontSize"});
        push(self.mapped_properties, {"hwdui": "font_family", "xaml": "FontFamily"});
        push(self.mapped_properties, {"hwdui": "padding", "xaml": "Padding"});
        return 0;
    }

    fn addMapping(hwdui_prop, xaml_prop) {
        push(self.mapped_properties, {"hwdui": hwdui_prop, "xaml": xaml_prop});
        return 0;
    }

    fn toXAML(hwdui_styles) {
        let xaml = {};
        let i = 0;
        while (i < len(self.mapped_properties)) {
            let mapping = self.mapped_properties[i];
            let hprop = mapping["hwdui"];
            let xprop = mapping["xaml"];
            let val = hwdui_styles[hprop];
            if (val != nullptr) {
                xaml[xprop] = val;
            }
            i = i + 1;
        }
        return xaml;
    }

    fn toHwdUI(xaml_styles) {
        let hwdui = {};
        let i = 0;
        while (i < len(self.mapped_properties)) {
            let mapping = self.mapped_properties[i];
            let hprop = mapping["hwdui"];
            let xprop = mapping["xaml"];
            let val = xaml_styles[xprop];
            if (val != nullptr) {
                hwdui[hprop] = val;
            }
            i = i + 1;
        }
        return hwdui;
    }

    fn getMappings() { return self.mapped_properties; }
    fn getMappingCount() { return len(self.mapped_properties); }
}


