    fn isSizeBound() { return self.size_binding; }
    fn isPositionBound() { return self.position_binding; }
}


class ZzwUIHost {
    let hosted_widgets = [];
    let dotnet_parent = nullptr;
    let is_active = false;
    let layout_engine = "zzwUI";

    fn init_host(parent) {
        self.hosted_widgets = [];
        self.dotnet_parent = parent;
        self.is_active = false;
        self.layout_engine = "zzwUI";
        return 0;
    }

    fn hostWidget(widget) {
        push(self.hosted_widgets, widget);
        if (self.dotnet_parent != nullptr) {
            self.dotnet_parent["children"] = self.hosted_widgets;
        }
        return 0;
    }

    fn removeWidget(widget) {
        let new_widgets = [];
        let i = 0;
        while (i < len(self.hosted_widgets)) {
            if (self.hosted_widgets[i] != widget) {
                push(new_widgets, self.hosted_widgets[i]);
            }
            i = i + 1;
        }
        self.hosted_widgets = new_widgets;
        return 0;
    }

    fn activate() {
        self.is_active = true;
        return 0;
    }

    fn deactivate() {
        self.is_active = false;
        return 0;
    }

    fn isActive() { return self.is_active; }

    fn doLayout() {
        let i = 0;
        while (i < len(self.hosted_widgets)) {
            let w = self.hosted_widgets[i];
            if (w.do_layout != nullptr) {
                w.do_layout();
            }
            i = i + 1;
        }
        return 0;
    }

    fn getWidgetCount() { return len(self.hosted_widgets); }
    fn getHostedWidgets() { return self.hosted_widgets; }
    fn setLayoutEngine(engine) { self.layout_engine = engine; return 0; }
    fn getLayoutEngine() { return self.layout_engine; }

    fn clear() {
        self.hosted_widgets = [];
        return 0;
    }
}


class DotNetControlFactory {
    let control_map = {};
    let default_ctor = nullptr;

    fn init_factory() {
        self.control_map = {};
        self.default_ctor = nullptr;
        self._register_defaults();
        return 0;
    }

    fn _register_defaults() {
        self.register("Button", "System.Windows.Controls.Button");
        self.register("Label", "System.Windows.Controls.Label");
        self.register("TextBox", "System.Windows.Controls.TextBox");
        self.register("CheckBox", "System.Windows.Controls.CheckBox");
        self.register("RadioButton", "System.Windows.Controls.RadioButton");
        self.register("Slider", "System.Windows.Controls.Slider");
        self.register("ProgressBar", "System.Windows.Controls.ProgressBar");
        self.register("ListBox", "System.Windows.Controls.ListBox");
        self.register("ComboBox", "System.Windows.Controls.ComboBox");
        self.register("ScrollView", "System.Windows.Controls.ScrollViewer");
        self.register("TabControl", "System.Windows.Controls.TabControl");
        self.register("TreeView", "System.Windows.Controls.TreeView");
        self.register("Menu", "System.Windows.Controls.Menu");
        self.register("Image", "System.Windows.Controls.Image");
        self.register("Panel", "System.Windows.Controls.Panel");
        self.register("Grid", "System.Windows.Controls.Grid");
        self.register("StackPanel", "System.Windows.Controls.StackPanel");
        self.register("Border", "System.Windows.Controls.Border");
        self.register("Canvas", "System.Windows.Controls.Canvas");
        self.register("DockPanel", "System.Windows.Controls.DockPanel");
        self.register("Splitter", "System.Windows.Controls.GridSplitter");
        self.register("ToggleSwitch", "System.Windows.Controls.ToggleSwitch");
        self.register("PasswordBox", "System.Windows.Controls.PasswordBox");
        return 0;
    }

    fn register(hwidget_type, dntype) {
        self.control_map[hwidget_type] = dntype;
        return 0;
    }

    fn getDotNetType(hwidget_type) {
        return self.control_map[hwidget_type];
    }

    fn createControl(hwidget_type) {
        let dntype = self.control_map[hwidget_type];
        if (dntype == nullptr) {
            return nullptr;
        }
        return {"__type__": dntype, "widget_type": hwidget_type};
    }

    fn getSupportedTypes() {
        let types = [];
        for k in self.control_map {
            push(types, k);
        }
        return types;
    }

    fn hasType(hwidget_type) {
        return self.control_map[hwidget_type] != nullptr;
    }
}


# ═══════════════════════════════════════════════════════════════════════════
# Section 5: 数据绑定层 — 双向绑定
# ═══════════════════════════════════════════════════════════════════════════

class DotNetBinding {
    let source = nullptr;
    let source_path = "";
    let target = nullptr;
    let target_path = "";
    let mode = "twoWay";
    let converter = nullptr;
    let converter_parameter = nullptr;
    let is_active = true;
    let update_source_trigger = "propertyChanged";
    let fallback_value = nullptr;
    let target_null_value = nullptr;

    fn init_binding(src, src_path, tgt, tgt_path) {
        self.source = src;
        self.source_path = src_path;
        self.target = tgt;
        self.target_path = tgt_path;
        self.mode = "twoWay";
        self.converter = nullptr;
        self.converter_parameter = nullptr;
        self.is_active = true;
        self.update_source_trigger = "propertyChanged";
        self.fallback_value = nullptr;
        self.target_null_value = nullptr;
        return 0;
    }

    fn setMode(m) { self.mode = m; return 0; }
    fn setConverter(c) { self.converter = c; return 0; }
    fn setConverterParameter(p) { self.converter_parameter = p; return 0; }
    fn setActive(v) { self.is_active = v; return 0; }
    fn setUpdateSourceTrigger(t) { self.update_source_trigger = t; return 0; }
    fn setFallbackValue(v) { self.fallback_value = v; return 0; }
    fn setTargetNullValue(v) { self.target_null_value = v; return 0; }

    fn getMode() { return self.mode; }
    fn isActive() { return self.is_active; }

    fn updateSource() {
        if (self.is_active == false) { return 0; }
        if (self.mode == "oneWay") { return 0; }
        let val = self.target[self.target_path];
        if (val == nullptr and self.target_null_value != nullptr) {
            val = self.target_null_value;
        }
        if (self.converter != nullptr) {
            val = self.converter(val, self.converter_parameter);
        }
        self.source[self.source_path] = val;
        return 0;
    }

    fn updateTarget() {
        if (self.is_active == false) { return 0; }
        if (self.mode == "oneWayToSource") { return 0; }
        let val = self.source[self.source_path];
        if (val == nullptr) {
            val = self.fallback_value;
        }
        if (self.converter != nullptr) {
            val = self.converter(val, self.converter_parameter);
        }
        self.target[self.target_path] = val;
        return 0;
    }

    fn update() {
        self.updateTarget();
        return 0;
    }

    fn getSource() { return self.source; }
    fn getSourcePath() { return self.source_path; }
    fn getTarget() { return self.target; }
    fn getTargetPath() { return self.target_path; }
}


class DotNetMultiBinding {
    let bindings = [];
    let target = nullptr;
    let target_path = "";
    let converter = nullptr;
    let is_active = true;

    fn init_multi_binding(tgt, tgt_path) {
        self.bindings = [];
        self.target = tgt;
        self.target_path = tgt_path;
        self.converter = nullptr;
        self.is_active = true;
        return 0;
    }

    fn addBinding(binding) {
        push(self.bindings, binding);
        return 0;
    }

    fn removeBinding(binding) {
        let new_bindings = [];
        let i = 0;
        while (i < len(self.bindings)) {
            if (self.bindings[i] != binding) {
                push(new_bindings, self.bindings[i]);
            }
            i = i + 1;
        }
        self.bindings = new_bindings;
        return 0;
    }

    fn setConverter(c) { self.converter = c; return 0; }
    fn setActive(v) { self.is_active = v; return 0; }

    fn update() {
        if (self.is_active == false) { return 0; }
        let values = [];
        let i = 0;
        while (i < len(self.bindings)) {
            let b = self.bindings[i];
            let val = b.source[b.source_path];
            push(values, val);
            i = i + 1;
        }
        if (self.converter != nullptr) {
            let result = self.converter(values);
            self.target[self.target_path] = result;
        }
        return 0;
    }

    fn getBindingCount() { return len(self.bindings); }
}


class DotNetBindingManager {
    let bindings = [];
    let is_updating = false;
    let defer_updates = false;

    fn init_binding_mgr() {
        self.bindings = [];
        self.is_updating = false;
        self.defer_updates = false;
        return 0;
    }

    fn addBinding(binding) {
        push(self.bindings, binding);
        return 0;
    }

    fn removeBinding(binding) {
        let new_bindings = [];
        let i = 0;
        while (i < len(self.bindings)) {
            if (self.bindings[i] != binding) {
                push(new_bindings, self.bindings[i]);
            }
            i = i + 1;
        }
        self.bindings = new_bindings;
        return 0;
    }

    fn updateAll() {
        if (self.defer_updates) { return 0; }
        self.is_updating = true;
        let i = 0;
        while (i < len(self.bindings)) {
            self.bindings[i].update();
            i = i + 1;
        }
        self.is_updating = false;
        return 0;
    }

    fn updateSource(binding) {
        binding.updateSource();
        return 0;
    }

    fn updateTarget(binding) {
        binding.updateTarget();
        return 0;
    }

    fn setDeferUpdates(v) {
        self.defer_updates = v;
        if (v == false) {
            self.updateAll();
        }
        return 0;
    }

    fn getBindingCount() { return len(self.bindings); }
    fn isUpdating() { return self.is_updating; }

    fn clear() {
        self.bindings = [];
        return 0;
    }

    fn getBindingsForSource(source) {
        let result = [];
        let i = 0;
        while (i < len(self.bindings)) {
            if (self.bindings[i].getSource() == source) {
                push(result, self.bindings[i]);
            }
            i = i + 1;
        }
        return result;
    }

    fn getBindingsForTarget(target) {
        let result = [];
        let i = 0;
        while (i < len(self.bindings)) {
            if (self.bindings[i].getTarget() == target) {
                push(result, self.bindings[i]);
            }
            i = i + 1;
        }
        return result;
    }
}


class DotNetBindingExpression {
    let binding = nullptr;
    let target = nullptr;
    let target_property = "";
    let is_dirty = false;

    fn init_expr(binding, tgt, tgt_prop) {
        self.binding = binding;
        self.target = tgt;
        self.target_property = tgt_prop;
        self.is_dirty = false;
        return 0;
    }

    fn markDirty() {
        self.is_dirty = true;
        return 0;
    }

    fn isDirty() { return self.is_dirty; }

    fn refresh() {
        if (self.binding != nullptr) {
            self.binding.updateTarget();
        }
        self.is_dirty = false;
        return 0;
    }

    fn getBinding() { return self.binding; }
    fn getTarget() { return self.target; }
    fn getTargetProperty() { return self.target_property; }
}


