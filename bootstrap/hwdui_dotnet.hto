class DotNetResourceManager {
    let resources = {};
    let culture = "";
    let base_name = "";

    fn init_res_mgr() {
        self.resources = {};
        self.culture = "";
        self.base_name = "";
        return 0;
    }

    fn setCulture(c) { self.culture = c; return 0; }
    fn setBaseName(name) { self.base_name = name; return 0; }

    fn addResource(key, value) {
        self.resources[key] = value;
        return 0;
    }

    fn getResource(key) {
        return self.resources[key];
    }

    fn getString(key) {
        let val = self.resources[key];
        if (val == nullptr) { return key; }
        return val;
    }

    fn getInteger(key) {
        let val = self.resources[key];
        if (val == nullptr) { return 0; }
        return val;
    }

    fn getBoolean(key) {
        let val = self.resources[key];
        if (val == nullptr) { return false; }
        return val;
    }

    fn hasResource(key) {
        return self.resources[key] != nullptr;
    }

    fn removeResource(key) {
        self.resources[key] = nullptr;
        return 0;
    }

    fn clear() {
        self.resources = {};
        return 0;
    }

    fn getResourceCount() {
        let count = 0;
        for k in self.resources {
            if (self.resources[k] != nullptr) {
                count = count + 1;
            }
        }
        return count;
    }

    fn getCulture() { return self.culture; }
    fn getBaseName() { return self.base_name; }
}


class DotNetFileWatcher {
    let path = "";
    let filter = "*";
    let is_watching = false;
    let onChanged = nullptr;
    let onCreated = nullptr;
    let onDeleted = nullptr;
    let onRenamed = nullptr;
    let include_subdirs = true;

    fn init_watcher(path, filter) {
        self.path = path;
        self.filter = filter;
        self.is_watching = false;
        self.onChanged = nullptr;
        self.onCreated = nullptr;
        self.onDeleted = nullptr;
        self.onRenamed = nullptr;
        self.include_subdirs = true;
        return 0;
    }

    fn start() {
        self.is_watching = true;
        return 0;
    }

    fn stop() {
        self.is_watching = false;
        return 0;
    }

    fn isWatching() { return self.is_watching; }

    fn setOnChanged(callback) { self.onChanged = callback; return 0; }
    fn setOnCreated(callback) { self.onCreated = callback; return 0; }
    fn setOnDeleted(callback) { self.onDeleted = callback; return 0; }
    fn setOnRenamed(callback) { self.onRenamed = callback; return 0; }
    fn setIncludeSubdirs(v) { self.include_subdirs = v; return 0; }

    fn getPath() { return self.path; }
    fn getFilter() { return self.filter; }
}


# ═══════════════════════════════════════════════════════════════════════════
# Section 13: 全局函数与初始化
# ═══════════════════════════════════════════════════════════════════════════

let _dn_mapper = new DotNetTypeMapper();
let _dn_cache = new DotNetObjectCache();
let _dn_event_bus = new DotNetCrossEventBus();
let _dn_binding_mgr = new DotNetBindingManager();
let _dn_serializer = new DotNetSerializer(_dn_mapper);
let _dn_deserializer = new DotNetDeserializer(_dn_mapper);
let _dn_type_converter = new DotNetTypeConverter();
let _dn_logger = new DotNetLogger();
let _dn_profiler = new DotNetProfiler();
let _dn_config = new DotNetConfig();
let _dn_env = new DotNetEnvironment();
let _dn_assembly_loader = new DotNetAssemblyLoader();
let _dn_control_factory = new DotNetControlFactory();
let _dn_style_bridge = new DotNetStyleBridge();
let _dn_xaml = new DotNetXAML();
let _dn_resource_mgr = new DotNetResourceManager();
let _dn_nuget = new DotNetNuGetManager();
let _dn_task_scheduler = new DotNetTaskScheduler();
let _dn_is_initialized = false;

_dn_mapper.init_mapper();
_dn_cache.init_cache();
_dn_event_bus.init_cross_bus();
_dn_binding_mgr.init_binding_mgr();
_dn_serializer.init_serializer(_dn_mapper);
_dn_deserializer.init_deserializer(_dn_mapper);
_dn_type_converter.init_converter();
_dn_logger.init_logger();
_dn_profiler.init_profiler();
_dn_config.init_config();
_dn_env.init_env();
_dn_assembly_loader.init_loader();
_dn_control_factory.init_factory();
_dn_style_bridge.init_style_bridge();
_dn_xaml.init_xaml();
_dn_resource_mgr.init_res_mgr();
_dn_nuget.init_nuget();
_dn_task_scheduler.init_scheduler();

fn dotnet_init() {
    _dn_is_initialized = true;
    _dn_logger.info("dotnet_init: H# ↔ .NET interop initialized");
    _dn_logger.info("dotnet_init: " + "type mappings, object cache, event bus, bindings ready");
    return true;
}

fn dotnet_shutdown() {
    _dn_cache.clear();
    _dn_event_bus.clear();
    _dn_binding_mgr.clear();
    _dn_config.clear();
    _dn_task_scheduler.cancelAll();
    _dn_is_initialized = false;
    _dn_logger.info("dotnet_shutdown: H# ↔ .NET interop shut down");
    return 0;
}

fn dotnet_is_ready() {
    return _dn_is_initialized;
}

