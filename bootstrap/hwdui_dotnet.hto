# ═══════════════════════════════════════════════════════════════════════════
# hwdui_dotnet.hto — H# zzwUI ↔ .NET 协同开发库
# ═══════════════════════════════════════════════════════════════════════════
# 提供 H# 与 .NET 运行时之间的完整互操作基础设施：
# - 类型映射与值转换
# - 对象代理与反射调用
# - 跨运行时事件总线
# - zzwUI 控件 ↔ .NET 控件桥接
# - 双向数据绑定
# - RPC 远程过程调用
# - 序列化与反序列化
# - 异步任务桥接
# - 诊断与配置
# ═══════════════════════════════════════════════════════════════════════════

import "bootstrap/hwdui.hto";

# ═══════════════════════════════════════════════════════════════════════════
# Section 1: 核心互操作层 — 类型映射、值包装、调用代理
# ═══════════════════════════════════════════════════════════════════════════

class DotNetTypeInfo {
    let type_name = "";
    let namespace = "";
    let assembly = "";
    let is_value_type = false;
    let is_generic = false;
    let generic_args = [];
    let base_type = "";
    let interfaces = [];
    let is_enum = false;
    let is_array = false;
    let is_primitive = false;
    let full_name = "";
    let clr_type = "";

    fn init_dn_type(name, ns, assm) {
        self.name = name;
        self.namespace = ns;
        self.assembly = assm;
        self.is_value_type = false;
        self.is_generic = false;
        self.generic_args = [];
        self.base_type = "";
        self.interfaces = [];
        self.is_enum = false;
        self.is_array = false;
        self.is_primitive = false;
        self.full_name = ns + "." + name;
        if (ns == "") {
            self.full_name = name;
        }
        self.clr_type = "";
        return 0;
    }

    fn setValueType(v) { self.is_value_type = v; return 0; }
    fn setGeneric(v) { self.is_generic = v; return 0; }
    fn addGenericArg(arg) { push(self.generic_args, arg); return 0; }
    fn setBaseType(bt) { self.base_type = bt; return 0; }
    fn addInterface(iface) { push(self.interfaces, iface); return 0; }
    fn setEnum(v) { self.is_enum = v; return 0; }
    fn setArray(v) { self.is_array = v; return 0; }
    fn setPrimitive(v) { self.is_primitive = v; return 0; }
    fn setCLRType(clr) { self.clr_type = clr; return 0; }

    fn getFullName() { return self.full_name; }
    fn getTypeName() { return self.type_name; }
    fn getNamespace() { return self.namespace; }
    fn getAssembly() { return self.assembly; }
    fn isValueType() { return self.is_value_type; }
    fn isGeneric() { return self.is_generic; }
    fn isEnum() { return self.is_enum; }
    fn isArray() { return self.is_array; }
    fn isPrimitive() { return self.is_primitive; }
    fn getBaseType() { return self.base_type; }
    fn getInterfaces() { return self.interfaces; }
    fn getGenericArgs() { return self.generic_args; }
}


class DotNetTypeMapper {
    let type_map = {};
    let reverse_map = {};
    let primitive_types = [];
    let numeric_types = [];

    fn init_mapper() {
        self.type_map = {};
        self.reverse_map = {};
        self.primitive_types = [];
        self.numeric_types = [];
        self._register_defaults();
        return 0;
    }

    fn _register_defaults() {
        self.register("int", "System.Int32", true);
        self.register("float", "System.Double", true);
        self.register("bool", "System.Boolean", true);
        self.register("string", "System.String", false);
        self.register("null", "System.Object", false);
        self.register("list", "System.Collections.Generic.List", false);
        self.register("dict", "System.Collections.Generic.Dictionary", false);
        self.register("int64", "System.Int64", true);
        self.register("int16", "System.Int16", true);
        self.register("byte", "System.Byte", true);
        self.register("char", "System.Char", true);
        self.register("decimal", "System.Decimal", true);
        self.register("single", "System.Single", true);
        self.register("uint", "System.UInt32", true);
        self.register("uint64", "System.UInt64", true);
        self.register("uint16", "System.UInt16", true);
        self.register("sbyte", "System.SByte", true);
        return 0;
    }

    fn register(htype, dntype, prim) {
        self.type_map[htype] = {"dotnet": dntype, "primitive": prim};
        self.reverse_map[dntype] = htype;
        if (prim) {
            push(self.primitive_types, dntype);
        }
        return 0;
    }

    fn unregister(dntype) {
        let htype = self.reverse_map[dntype];
        if (htype != nullptr) {
            self.type_map[htype] = nullptr;
        }
        self.reverse_map[dntype] = nullptr;
        return 0;
    }

    fn toDotNet(htype) {
        let info = self.type_map[htype];
        if (info != nullptr) {
            return info["dotnet"];
        }
        return "System.Object";
    }

    fn toHSharp(dntype) {
        let htype = self.reverse_map[dntype];
        if (htype != nullptr) {
            return htype;
        }
        return "object";
    }

    fn isPrimitive(dntype) {
        let i = 0;
        while (i < len(self.primitive_types)) {
            if (self.primitive_types[i] == dntype) {
                return true;
            }
            i = i + 1;
        }
        return false;
    }

    fn getTypeInfo(dntype) {
        let info = new DotNetTypeInfo();
        let parts = self._splitTypeName(dntype);
        info.init_dn_type(parts["name"], parts["namespace"], "");
        return info;
    }

    fn _splitTypeName(full_name) {
        let last_dot = -1;
        let i = 0;
        while (i < len(full_name)) {
            if (full_name[i] == ".") {
                last_dot = i;
            }
            i = i + 1;
        }
        if (last_dot < 0) {
            return {"namespace": "", "name": full_name};
        }
        let ns = "";
        i = 0;
        while (i < last_dot) {
            ns = ns + full_name[i];
            i = i + 1;
        }
        let nm = "";
        i = last_dot + 1;
        while (i < len(full_name)) {
            nm = nm + full_name[i];
            i = i + 1;
        }
        return {"namespace": ns, "name": nm};
    }

    fn registerCustom(htype, dntype) {
        self.register(htype, dntype, false);
        return 0;
    }

    fn clear() {
        self.type_map = {};
        self.reverse_map = {};
        self.primitive_types = [];
        return 0;
    }
}


class DotNetValue {
    let value = nullptr;
    let type_name = "System.Object";
    let is_null = true;
    let is_primitive = false;
    let array_rank = 0;
    let generic_args = [];

    fn init_dnval(val, tn) {
        self.value = val;
        self.type_name = tn;
        self.is_null = (val == nullptr);
        self.is_primitive = false;
        self.array_rank = 0;
        self.generic_args = [];
        return 0;
    }

    fn setPrimitive(p) { self.is_primitive = p; return 0; }
    fn setArrayRank(r) { self.array_rank = r; return 0; }
    fn addGenericArg(arg) { push(self.generic_args, arg); return 0; }

    fn getValue() { return self.value; }
    fn getTypeName() { return self.type_name; }
    fn isNull() { return self.is_null; }
    fn isPrimitive() { return self.is_primitive; }
    fn getArrayRank() { return self.array_rank; }
    fn getGenericArgs() { return self.generic_args; }

    fn asInt() {
        if (self.is_null) { return 0; }
        return self.value;
    }

    fn asFloat() {
        if (self.is_null) { return 0.0; }
        return self.value;
    }

    fn asBool() {
        if (self.is_null) { return false; }
        return self.value;
    }

    fn asString() {
        if (self.is_null) { return ""; }
        return self.value;
    }

    fn asList() {
        if (self.is_null) { return []; }
        return self.value;
    }

    fn asDict() {
        if (self.is_null) { return {}; }
        return self.value;
    }
}


class DotNetInvoke {
    let target = nullptr;
    let method_name = "";
    let args = [];
    let type_args = [];
    let is_static = false;
    let is_property_get = false;
    let is_property_set = false;
    let property_name = "";
    let timeout_ms = 30000;
    let call_id = 0;

    fn init_invoke(method, arg_list) {
        self.method_name = method;
        self.args = arg_list;
        self.type_args = [];
        self.is_static = false;
        self.is_property_get = false;
        self.is_property_set = false;
        self.timeout_ms = 30000;
        self.call_id = 0;
        return 0;
    }

    fn setTarget(t) { self.target = t; return 0; }
    fn setStatic(v) { self.is_static = v; return 0; }
    fn addTypeArg(ta) { push(self.type_args, ta); return 0; }
    fn setTimeout(ms) { self.timeout_ms = ms; return 0; }

    fn setPropertyGet(prop_name) {
        self.is_property_get = true;
        self.property_name = prop_name;
        return 0;
    }

    fn setPropertySet(prop_name, value) {
        self.is_property_set = true;
        self.property_name = prop_name;
        self.args = [value];
        return 0;
    }

    fn getMethodName() { return self.method_name; }
    fn getArgs() { return self.args; }
    fn getArgCount() { return len(self.args); }
    fn isStatic() { return self.is_static; }
    fn isPropertyGet() { return self.is_property_get; }
    fn isPropertySet() { return self.is_property_set; }
    fn getPropertyName() { return self.property_name; }
    fn getTimeout() { return self.timeout_ms; }
}


class DotNetResult {
    let value = nullptr;
    let success = false;
    let error_message = "";
    let error_type = "";
    let stack_trace = "";
    let call_id = 0;
    let duration_ms = 0;
    let is_exception = false;

    fn init_result() {
        self.value = nullptr;
        self.success = false;
        self.error_message = "";
        self.error_type = "";
        self.stack_trace = "";
        self.call_id = 0;
        self.duration_ms = 0;
        self.is_exception = false;
        return 0;
    }

    fn setSuccess(val) {
        self.value = val;
        self.success = true;
        return 0;
    }

    fn setError(msg, etype) {
        self.error_message = msg;
        self.error_type = etype;
        self.success = false;
        self.is_exception = true;
        return 0;
    }

    fn setStackTrace(trace) { self.stack_trace = trace; return 0; }
    fn setCallId(id) { self.call_id = id; return 0; }
    fn setDuration(ms) { self.duration_ms = ms; return 0; }

    fn isSuccess() { return self.success; }
    fn isException() { return self.is_exception; }
    fn getValue() { return self.value; }
    fn getError() { return self.error_message; }
    fn getErrorType() { return self.error_type; }
    fn getStackTrace() { return self.stack_trace; }
    fn getDuration() { return self.duration_ms; }

    fn unwrap() {
        if (self.success == false) {
            print("DotNetError: " + self.error_message);
            return nullptr;
        }
        return self.value;
    }

    fn expect(msg) {
        if (self.success == false) {
            print("DotNetError: " + msg + " - " + self.error_message);
        }
        return self.value;
    }
}


# ═══════════════════════════════════════════════════════════════════════════
# Section 2: 对象桥接层 — 对象代理、类型描述、程序集
# ═══════════════════════════════════════════════════════════════════════════

class DotNetObject {
    let object_id = 0;
    let type_name = "";
    let is_disposed = false;
    let properties = {};
    let cached_methods = [];
    let cached_properties = [];
    let is_remote = false;
    let remote_endpoint = "";
    let metadata = {};

    fn init_dnobj(obj_id, tn) {
        self.object_id = obj_id;
        self.type_name = tn;
        self.is_disposed = false;
        self.properties = {};
        self.cached_methods = [];
        self.cached_properties = [];
        self.is_remote = false;
        self.remote_endpoint = "";
        self.metadata = {};
        return 0;
    }

    fn getObjectId() { return self.object_id; }
    fn getTypeName() { return self.type_name; }
    fn isDisposed() { return self.is_disposed; }

    fn setProperty(name, value) {
        self.properties[name] = value;
        return 0;
    }

    fn getProperty(name) {
        return self.properties[name];
    }

    fn hasProperty(name) {
        return self.properties[name] != nullptr;
    }

    fn cacheMethod(method_name) {
        push(self.cached_methods, method_name);
        return 0;
    }

    fn hasMethod(method_name) {
        let i = 0;
        while (i < len(self.cached_methods)) {
            if (self.cached_methods[i] == method_name) {
                return true;
            }
            i = i + 1;
        }
        return false;
    }

    fn cacheProperty(prop_name) {
        push(self.cached_properties, prop_name);
        return 0;
    }

    fn setRemote(endpoint) {
        self.is_remote = true;
        self.remote_endpoint = endpoint;
        return 0;
    }

    fn isRemote() { return self.is_remote; }
    fn getRemoteEndpoint() { return self.remote_endpoint; }

    fn dispose() {
        self.is_disposed = true;
        self.properties = {};
        self.cached_methods = [];
        self.cached_properties = [];
        return 0;
    }

    fn setMetadata(key, value) {
        self.metadata[key] = value;
        return 0;
    }

    fn getMetadata(key) {
        return self.metadata[key];
    }
}


class DotNetObjectCache {
    let objects = {};
    let id_counter = 0;
    let max_cached = 1000;
    let lru_queue = [];

    fn init_cache() {
        self.objects = {};
        self.id_counter = 0;
        self.max_cached = 1000;
        self.lru_queue = [];
        return 0;
    }

    fn add(obj) {
        let obj_id = self._next_id();
        obj.object_id = obj_id;
        self.objects[obj_id] = obj;
        push(self.lru_queue, obj_id);
        if (len(self.lru_queue) > self.max_cached) {
            let oldest = self.lru_queue[0];
            let new_q = [];
            let i = 1;
            while (i < len(self.lru_queue)) {
                push(new_q, self.lru_queue[i]);
                i = i + 1;
            }
            self.lru_queue = new_q;
            self.objects[oldest] = nullptr;
        }
        return obj_id;
    }

    fn get(obj_id) {
        let obj = self.objects[obj_id];
        if (obj != nullptr) {
            self._touch(obj_id);
        }
        return obj;
    }

    fn remove(obj_id) {
        let obj = self.objects[obj_id];
        if (obj != nullptr) {
            obj.dispose();
        }
        self.objects[obj_id] = nullptr;
        let new_q = [];
        let i = 0;
        while (i < len(self.lru_queue)) {
            if (self.lru_queue[i] != obj_id) {
                push(new_q, self.lru_queue[i]);
            }
            i = i + 1;
        }
        self.lru_queue = new_q;
        return 0;
    }

    fn clear() {
        let keys = [];
        for k in self.objects {
            let obj = self.objects[k];
            if (obj != nullptr) {
                obj.dispose();
            }
        }
        self.objects = {};
        self.lru_queue = [];
        self.id_counter = 0;
        return 0;
    }

    fn getCount() {
        let count = 0;
        for k in self.objects {
            if (self.objects[k] != nullptr) {
                count = count + 1;
            }
        }
        return count;
    }

    fn contains(obj_id) {
        return self.objects[obj_id] != nullptr;
    }

    fn _next_id() {
        self.id_counter = self.id_counter + 1;
        return self.id_counter;
    }

    fn _touch(obj_id) {
        let new_q = [];
        let i = 0;
        while (i < len(self.lru_queue)) {
            if (self.lru_queue[i] != obj_id) {
                push(new_q, self.lru_queue[i]);
            }
            i = i + 1;
        }
        push(new_q, obj_id);
        self.lru_queue = new_q;
        return 0;
    }
}


class DotNetAssembly {
    let name = "";
    let version = "";
    let path = "";
    let types = [];
    let references = [];
    let is_loaded = false;
    let is_netcore = false;
    let target_framework = "";

    fn init_assembly(name, ver, path) {
        self.name = name;
        self.version = ver;
        self.path = path;
        self.types = [];
        self.references = [];
        self.is_loaded = false;
        self.is_netcore = false;
        self.target_framework = "";
        return 0;
    }

    fn addType(type_info) {
        push(self.types, type_info);
        return 0;
    }

    fn addReference(ref_name) {
        push(self.references, ref_name);
        return 0;
    }

    fn getType(type_name) {
        let i = 0;
        while (i < len(self.types)) {
            let t = self.types[i];
            if (t.getFullName() == type_name or t.getTypeName() == type_name) {
                return t;
            }
            i = i + 1;
        }
        return nullptr;
    }

    fn getTypeCount() { return len(self.types); }
    fn getReferenceCount() { return len(self.references); }
    fn getName() { return self.name; }
    fn getVersion() { return self.version; }
    fn getPath() { return self.path; }
    fn isLoaded() { return self.is_loaded; }
    fn setLoaded(v) { self.is_loaded = v; return 0; }
    fn setNetCore(v) { self.is_netcore = v; return 0; }
    fn setTargetFramework(tf) { self.target_framework = tf; return 0; }
    fn getTargetFramework() { return self.target_framework; }
    fn isNetCore() { return self.is_netcore; }
}


class DotNetAssemblyLoader {
    let assemblies = {};
    let loaded_count = 0;
    let search_paths = [];

    fn init_loader() {
        self.assemblies = {};
        self.loaded_count = 0;
        self.search_paths = [];
        return 0;
    }

    fn addSearchPath(path) {
        push(self.search_paths, path);
        return 0;
    }

    fn register(assm) {
        self.assemblies[assm.name] = assm;
        return 0;
    }

    fn getAssembly(name) {
        return self.assemblies[name];
    }

    fn load(name) {
        let assm = self.assemblies[name];
        if (assm != nullptr) {
            assm.setLoaded(true);
            self.loaded_count = self.loaded_count + 1;
        }
        return assm;
    }

    fn unload(name) {
        let assm = self.assemblies[name];
        if (assm != nullptr) {
            assm.setLoaded(false);
            self.loaded_count = self.loaded_count - 1;
        }
        return 0;
    }

    fn isLoaded(name) {
        let assm = self.assemblies[name];
        if (assm != nullptr) {
            return assm.isLoaded();
        }
        return false;
    }

    fn getLoadedCount() { return self.loaded_count; }
    fn getAssemblyCount() {
        let count = 0;
        for k in self.assemblies {
            count = count + 1;
        }
        return count;
    }

    fn clear() {
        self.assemblies = {};
        self.loaded_count = 0;
        return 0;
    }
}


class DotNetConstructor {
    let type_name = "";
    let params = [];
    let param_names = [];
    let is_static = false;

    fn init_ctor(tn) {
        self.type_name = tn;
        self.params = [];
        self.param_names = [];
        self.is_static = false;
        return 0;
    }

    fn addParam(ptype, pname) {
        push(self.params, ptype);
        push(self.param_names, pname);
        return 0;
    }

    fn getParamCount() { return len(self.params); }
    fn getParams() { return self.params; }
    fn getParamNames() { return self.param_names; }
    fn getParamType(index) {
        if (index >= 0 and index < len(self.params)) {
            return self.params[index];
        }
        return "";
    }
}


class DotNetMethod {
    let name = "";
    let return_type = "System.Void";
    let params = [];
    let param_names = [];
    let is_static = false;
    let is_async = false;
    let is_extension = false;
    let visibility = "public";
    let attributes = [];

    fn init_method(name, ret_type) {
        self.name = name;
        self.return_type = ret_type;
        self.params = [];
        self.param_names = [];
        self.is_static = false;
        self.is_async = false;
        self.is_extension = false;
        self.visibility = "public";
        self.attributes = [];
        return 0;
    }

    fn addParam(ptype, pname) {
        push(self.params, ptype);
        push(self.param_names, pname);
        return 0;
    }

    fn setStatic(v) { self.is_static = v; return 0; }
    fn setAsync(v) { self.is_async = v; return 0; }
    fn setExtension(v) { self.is_extension = v; return 0; }
    fn setVisibility(v) { self.visibility = v; return 0; }
    fn addAttribute(attr) { push(self.attributes, attr); return 0; }

    fn getName() { return self.name; }
    fn getReturnType() { return self.return_type; }
    fn getParamCount() { return len(self.params); }
    fn getParams() { return self.params; }
    fn getParamNames() { return self.param_names; }
    fn isStatic() { return self.is_static; }
    fn isAsync() { return self.is_async; }
    fn isExtension() { return self.is_extension; }
    fn getVisibility() { return self.visibility; }
    fn hasAttribute(name) {
        let i = 0;
        while (i < len(self.attributes)) {
            if (self.attributes[i] == name) {
                return true;
            }
            i = i + 1;
        }
        return false;
    }
}


class DotNetProperty {
    let name = "";
    let type_name = "";
    let can_read = false;
    let can_write = false;
    let is_static = false;
    let is_indexer = false;
    let visibility = "public";

    fn init_prop(name, tn) {
        self.name = name;
        self.type_name = tn;
        self.can_read = false;
        self.can_write = false;
        self.is_static = false;
        self.is_indexer = false;
        self.visibility = "public";
        return 0;
    }

    fn setReadable(v) { self.can_read = v; return 0; }
    fn setWritable(v) { self.can_write = v; return 0; }
    fn setStatic(v) { self.is_static = v; return 0; }
    fn setIndexer(v) { self.is_indexer = v; return 0; }
    fn setVisibility(v) { self.visibility = v; return 0; }

    fn getName() { return self.name; }
    fn getType() { return self.type_name; }
    fn canRead() { return self.can_read; }
    fn canWrite() { return self.can_write; }
    fn isStatic() { return self.is_static; }
    fn isIndexer() { return self.is_indexer; }
}


class DotNetField {
    let name = "";
    let type_name = "";
    let is_static = false;
    let is_readonly = false;
    let is_const = false;
    let visibility = "public";

    fn init_field(name, tn) {
        self.name = name;
        self.type_name = tn;
        self.is_static = false;
        self.is_readonly = false;
        self.is_const = false;
        self.visibility = "public";
        return 0;
    }

    fn setStatic(v) { self.is_static = v; return 0; }
    fn setReadonly(v) { self.is_readonly = v; return 0; }
    fn setConst(v) { self.is_const = v; return 0; }
    fn setVisibility(v) { self.visibility = v; return 0; }

    fn getName() { return self.name; }
    fn getType() { return self.type_name; }
    fn isStatic() { return self.is_static; }
    fn isReadonly() { return self.is_readonly; }
    fn isConst() { return self.is_const; }
}


# ═══════════════════════════════════════════════════════════════════════════
# Section 3: 事件桥接层 — 跨运行时事件总线
# ═══════════════════════════════════════════════════════════════════════════

class DotNetEvent {
    let name = "";
    let handler_type = "";
    let is_static = false;
    let subscribers = [];
    let is_remote = false;

    fn init_event(name, handler) {
        self.name = name;
        self.handler_type = handler;
        self.is_static = false;
        self.subscribers = [];
        self.is_remote = false;
        return 0;
    }

    fn addSubscriber(subscriber) {
        push(self.subscribers, subscriber);
        return 0;
    }

    fn removeSubscriber(subscriber) {
        let new_subs = [];
        let i = 0;
        while (i < len(self.subscribers)) {
            if (self.subscribers[i] != subscriber) {
                push(new_subs, self.subscribers[i]);
            }
            i = i + 1;
        }
        self.subscribers = new_subs;
        return 0;
    }

    fn getSubscriberCount() { return len(self.subscribers); }
    fn getSubscribers() { return self.subscribers; }
    fn getName() { return self.name; }
    fn getHandlerType() { return self.handler_type; }
    fn setStatic(v) { self.is_static = v; return 0; }
    fn isStatic() { return self.is_static; }
    fn setRemote(v) { self.is_remote = v; return 0; }
    fn isRemote() { return self.is_remote; }
}


class DotNetEventHandler {
    let handler_id = 0;
    let event_name = "";
    let callback = nullptr;
    let is_oneshot = false;
    let filter = nullptr;
    let is_active = true;

    fn init_handler(event_name, callback) {
        self.event_name = event_name;
        self.callback = callback;
        self.is_oneshot = false;
        self.filter = nullptr;
        self.is_active = true;
        self.handler_id = 0;
        return 0;
    }

    fn setOneShot(v) { self.is_oneshot = v; return 0; }
    fn setFilter(filter_fn) { self.filter = filter_fn; return 0; }
    fn setActive(v) { self.is_active = v; return 0; }
    fn setId(id) { self.handler_id = id; return 0; }

    fn getId() { return self.handler_id; }
    fn getEventName() { return self.event_name; }
    fn isActive() { return self.is_active; }
    fn isOneShot() { return self.is_oneshot; }

    fn invoke(sender, args) {
        if (self.is_active == false) { return 0; }
        if (self.filter != nullptr) {
            if (self.filter(sender, args) == false) {
                return 0;
            }
        }
        if (self.callback != nullptr) {
            self.callback(sender, args);
        }
        if (self.is_oneshot) {
            self.is_active = false;
        }
        return 0;
    }
}


class DotNetCrossEventBus {
    let events = {};
    let remote_events = {};
    let handler_counter = 0;
    let bridge_enabled = false;

    fn init_cross_bus() {
        self.events = {};
        self.remote_events = {};
        self.handler_counter = 0;
        self.bridge_enabled = false;
        return 0;
    }

    fn subscribe(event_name, callback) {
        let evt = self.events[event_name];
        if (evt == nullptr) {
            evt = new DotNetEvent();
            evt.init_event(event_name, "System.EventHandler");
            self.events[event_name] = evt;
        }
        let handler = new DotNetEventHandler();
        handler.init_handler(event_name, callback);
        self.handler_counter = self.handler_counter + 1;
        handler.setId(self.handler_counter);
        evt.addSubscriber(handler);
        return handler;
    }

    fn unsubscribe(event_name, handler) {
        let evt = self.events[event_name];
        if (evt != nullptr) {
            evt.removeSubscriber(handler);
        }
        return 0;
    }

    fn publish(event_name, sender, args) {
        let evt = self.events[event_name];
        if (evt == nullptr) { return 0; }
        let subs = evt.getSubscribers();
        let i = 0;
        while (i < len(subs)) {
            subs[i].invoke(sender, args);
            i = i + 1;
        }
        return 0;
    }

    fn subscribeRemote(event_name, callback) {
        return self.subscribe(event_name, callback);
    }

    fn publishRemote(event_name, data) {
        let evt = self.remote_events[event_name];
        if (evt == nullptr) {
            evt = new DotNetEvent();
            evt.init_event(event_name, "System.EventHandler");
            evt.setRemote(true);
            self.remote_events[event_name] = evt;
        }
        return self.publish(event_name, nullptr, data);
    }

    fn enableBridge() {
        self.bridge_enabled = true;
        return 0;
    }

    fn disableBridge() {
        self.bridge_enabled = false;
        return 0;
    }

    fn isBridgeEnabled() { return self.bridge_enabled; }

    fn getEventCount() {
        let count = 0;
        for k in self.events {
            count = count + 1;
        }
        for k in self.remote_events {
            count = count + 1;
        }
        return count;
    }

    fn clear() {
        self.events = {};
        self.remote_events = {};
        self.handler_counter = 0;
        return 0;
    }

    fn clearEvent(event_name) {
        let new_events = {};
        for k in self.events {
            if (k != event_name) {
                new_events[k] = self.events[k];
            }
        }
        self.events = new_events;
        let new_remote = {};
        for k in self.remote_events {
            if (k != event_name) {
                new_remote[k] = self.remote_events[k];
            }
        }
        self.remote_events = new_remote;
        return 0;
    }
}


class DotNetUIDispatcher {
    let invoke_queue = [];
    let is_processing = false;
    let main_thread_id = 0;
    let sync_context = nullptr;

    fn init_dispatcher() {
        self.invoke_queue = [];
        self.is_processing = false;
        self.main_thread_id = 0;
        self.sync_context = nullptr;
        return 0;
    }

    fn invoke(action) {
        push(self.invoke_queue, {"action": action, "sync": true, "result": nullptr, "done": false});
        return 0;
    }

    fn beginInvoke(action) {
        push(self.invoke_queue, {"action": action, "sync": false, "result": nullptr, "done": false});
        return 0;
    }

    fn processQueue() {
        if (self.is_processing) { return 0; }
        self.is_processing = true;
        let i = 0;
        while (i < len(self.invoke_queue)) {
            let item = self.invoke_queue[i];
            if (item["done"] == false and item["action"] != nullptr) {
                item["action"]();
                item["done"] = true;
            }
            i = i + 1;
        }
        let new_q = [];
        i = 0;
        while (i < len(self.invoke_queue)) {
            if (self.invoke_queue[i]["done"] == false) {
                push(new_q, self.invoke_queue[i]);
            }
            i = i + 1;
        }
        self.invoke_queue = new_q;
        self.is_processing = false;
        return 0;
    }

    fn getQueueSize() { return len(self.invoke_queue); }
    fn clear() { self.invoke_queue = []; return 0; }
}


# ═══════════════════════════════════════════════════════════════════════════
# Section 4: UI 桥接层 — zzwUI 控件 ↔ .NET 控件
# ═══════════════════════════════════════════════════════════════════════════

class ZzwUIControlBridge {
    let hwidget = nullptr;
    let dotnet_control = nullptr;
    let bridge_id = 0;
    let property_bindings = [];
    let event_bindings = [];
    let is_syncing = false;
    let sync_direction = "both";
    let enabled = true;

    fn init_bridge(hw, dnctrl) {
        self.hwidget = hw;
        self.dotnet_control = dnctrl;
        self.property_bindings = [];
        self.event_bindings = [];
        self.is_syncing = false;
        self.sync_direction = "both";
        self.enabled = true;
        self.bridge_id = 0;
        return 0;
    }

    fn setSyncDirection(dir) {
        self.sync_direction = dir;
        return 0;
    }

    fn setEnabled(v) {
        self.enabled = v;
        return 0;
    }

    fn isEnabled() { return self.enabled; }

    fn bindProperty(hprop, dnprop) {
        push(self.property_bindings, {"hsharp": hprop, "dotnet": dnprop});
        return 0;
    }

    fn bindEvent(hevent, dnevent) {
        push(self.event_bindings, {"hsharp": hevent, "dotnet": dnevent});
        return 0;
    }

    fn syncToDotNet() {
        if (self.enabled == false) { return 0; }
        if (self.sync_direction == "hsharp_to_dotnet" or self.sync_direction == "both") {
            self.is_syncing = true;
            let i = 0;
            while (i < len(self.property_bindings)) {
                let binding = self.property_bindings[i];
                let hprop = binding["hsharp"];
                let dnprop = binding["dotnet"];
                let val = self.hwidget[hprop];
                if (val != nullptr) {
                    self.dotnet_control[dnprop] = val;
                }
                i = i + 1;
            }
            self.is_syncing = false;
        }
        return 0;
    }

    fn syncToHSharp() {
        if (self.enabled == false) { return 0; }
        if (self.sync_direction == "dotnet_to_hsharp" or self.sync_direction == "both") {
            self.is_syncing = true;
            let i = 0;
            while (i < len(self.property_bindings)) {
                let binding = self.property_bindings[i];
                let hprop = binding["hsharp"];
                let dnprop = binding["dotnet"];
                let val = self.dotnet_control[dnprop];
                if (val != nullptr) {
                    self.hwidget[hprop] = val;
                }
                i = i + 1;
            }
            self.is_syncing = false;
        }
        return 0;
    }

    fn syncBoth() {
        self.syncToDotNet();
        self.syncToHSharp();
        return 0;
    }

    fn getHWidget() { return self.hwidget; }
    fn getDotNetControl() { return self.dotnet_control; }
    fn getPropertyBindings() { return self.property_bindings; }
    fn getEventBindings() { return self.event_bindings; }

    fn unbindProperty(hprop) {
        let new_bindings = [];
        let i = 0;
        while (i < len(self.property_bindings)) {
            if (self.property_bindings[i]["hsharp"] != hprop) {
                push(new_bindings, self.property_bindings[i]);
            }
            i = i + 1;
        }
        self.property_bindings = new_bindings;
        return 0;
    }

    fn unbindAll() {
        self.property_bindings = [];
        self.event_bindings = [];
        return 0;
    }

    fn dispose() {
        self.unbindAll();
        self.hwidget = nullptr;
        self.dotnet_control = nullptr;
        self.enabled = false;
        return 0;
    }
}


class DotNetWindowBridge {
    let hwindow = nullptr;
    let dotnet_window = nullptr;
    let title_binding = false;
    let size_binding = false;
    let position_binding = false;
