fn dotnet_summary() {
    print("");
    print("══════════════════════════════════════════════");
    print("  H# zzwUI ↔ .NET 协同开发库 v1.0");
    print("══════════════════════════════════════════════");
    print("  Core: TypeMapper, DotNetValue, Invoke/Result");
    print("  Objects: Proxy, Cache, Assembly, Method, Property");
    print("  Events: CrossEventBus, UIDispatcher, Handler");
    print("  UI Bridge: ControlBridge, WindowBridge, Host");
    print("  Data: Binding, MultiBinding, BindingManager");
    print("  RPC: ServiceHost, Client, Message, Pipe");
    print("  Serialization: Serializer, Deserializer, JSON");
    print("  Async: Task, Scheduler, ThreadPool, Token");
    print("  Diagnostics: Logger, Profiler, Debugger, Config");
    print("  Project: NuGet, Project, Solution, XAML");
    print("══════════════════════════════════════════════");
    return 0;
}

dotnet_summary();