        self.clr_version = "";
        self.framework = "";
        self.is_64bit = true;
        self.machine_name = "";
        self.user_name = "";
        self.processor_count = 0;
        self.working_directory = ".";
        self.environment_vars = {};
        return 0;
    }

    fn setOSVersion(v) { self.os_version = v; return 0; }
    fn setCLRVersion(v) { self.clr_version = v; return 0; }
    fn setFramework(v) { self.framework = v; return 0; }
    fn setIs64Bit(v) { self.is_64bit = v; return 0; }
    fn setMachineName(v) { self.machine_name = v; return 0; }
    fn setUserName(v) { self.user_name = v; return 0; }
    fn setProcessorCount(v) { self.processor_count = v; return 0; }
    fn setWorkingDirectory(v) { self.working_directory = v; return 0; }

    fn setEnvVar(key, value) {
        self.environment_vars[key] = value;
        return 0;
    }

    fn getEnvVar(key) {
        return self.environment_vars[key];
