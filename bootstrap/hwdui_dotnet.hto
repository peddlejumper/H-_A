class DotNetNuGetPackage {
    let package_id = "";
    let version = "";
    let authors = [];
    let description = "";
    let dependencies = [];
    let frameworks = [];
    let is_installed = false;
    let install_path = "";

    fn init_pkg(id, ver) {
        self.package_id = id;
        self.version = ver;
        self.authors = [];
        self.description = "";
        self.dependencies = [];
        self.frameworks = [];
        self.is_installed = false;
        self.install_path = "";
        return 0;
    }

    fn addAuthor(author) { push(self.authors, author); return 0; }
    fn setDescription(desc) { self.description = desc; return 0; }
    fn addDependency(id, ver) { push(self.dependencies, {"id": id, "version": ver}); return 0; }
    fn addFramework(fw) { push(self.frameworks, fw); return 0; }
    fn setInstalled(v) { self.is_installed = v; return 0; }
    fn setInstallPath(path) { self.install_path = path; return 0; }

    fn getId() { return self.package_id; }
    fn getVersion() { return self.version; }
    fn getAuthors() { return self.authors; }
    fn getDescription() { return self.description; }
    fn getDependencies() { return self.dependencies; }
    fn getFrameworks() { return self.frameworks; }
    fn isInstalled() { return self.is_installed; }
    fn getInstallPath() { return self.install_path; }
}


class DotNetNuGetManager {
    let packages = {};
    let sources = [];
    let cache_dir = "";

    fn init_nuget() {
        self.packages = {};
        self.sources = [];
        self.cache_dir = "";
        self._add_default_sources();
        return 0;
    }

    fn _add_default_sources() {
        push(self.sources, "https://api.nuget.org/v3/index.json");
        return 0;
    }

    fn addSource(source) {
        push(self.sources, source);
        return 0;
    }

    fn removeSource(source) {
        let new_sources = [];
        let i = 0;
        while (i < len(self.sources)) {
            if (self.sources[i] != source) {
                push(new_sources, self.sources[i]);
            }
            i = i + 1;
        }
        self.sources = new_sources;
        return 0;
    }

    fn install(package_id, version) {
        let pkg = new DotNetNuGetPackage();
        pkg.init_pkg(package_id, version);
        pkg.setInstalled(true);
        self.packages[package_id] = pkg;
        return pkg;
    }

    fn uninstall(package_id) {
        self.packages[package_id] = nullptr;
        return 0;
    }

    fn isInstalled(package_id) {
        let pkg = self.packages[package_id];
        if (pkg != nullptr) {
            return pkg.isInstalled();
        }
        return false;
    }

    fn getPackage(package_id) {
        return self.packages[package_id];
    }

    fn getInstalledPackages() {
        let installed = [];
        for k in self.packages {
            let pkg = self.packages[k];
            if (pkg != nullptr and pkg.isInstalled()) {
                push(installed, pkg);
            }
        }
        return installed;
    }

    fn setCacheDir(dir) { self.cache_dir = dir; return 0; }
    fn getCacheDir() { return self.cache_dir; }
    fn getSources() { return self.sources; }
    fn getPackageCount() {
        let count = 0;
        for k in self.packages {
            if (self.packages[k] != nullptr) {
                count = count + 1;
            }
        }
        return count;
    }
}


class DotNetProject {
    let name = "";
    let project_type = "";
    let target_framework = "";
    let references = [];
    let packages = [];
    let source_files = [];
    let output_type = "";
    let root_namespace = "";

    fn init_project(name, proj_type) {
        self.name = name;
        self.project_type = proj_type;
        self.target_framework = "net8.0";
        self.references = [];
        self.packages = [];
        self.source_files = [];
        self.output_type = "exe";
        self.root_namespace = name;
        return 0;
    }

    fn addReference(ref) { push(self.references, ref); return 0; }
    fn addPackage(pkg_id, ver) { push(self.packages, {"id": pkg_id, "version": ver}); return 0; }
    fn addSourceFile(file) { push(self.source_files, file); return 0; }
    fn setTargetFramework(tf) { self.target_framework = tf; return 0; }
    fn setOutputType(ot) { self.output_type = ot; return 0; }
    fn setRootNamespace(ns) { self.root_namespace = ns; return 0; }

    fn getName() { return self.name; }
    fn getProjectType() { return self.project_type; }
    fn getTargetFramework() { return self.target_framework; }
    fn getReferences() { return self.references; }
    fn getPackages() { return self.packages; }
    fn getSourceFiles() { return self.source_files; }
    fn getOutputType() { return self.output_type; }
    fn getRootNamespace() { return self.root_namespace; }
}


class DotNetSolution {
    let name = "";
    let projects = [];
    let config = "";

    fn init_sln(name) {
        self.name = name;
        self.projects = [];
        self.config = "debug";
        return 0;
    }

    fn addProject(project) {
        push(self.projects, project);
        return 0;
    }

    fn removeProject(name) {
        let new_projects = [];
        let i = 0;
        while (i < len(self.projects)) {
            if (self.projects[i].getName() != name) {
                push(new_projects, self.projects[i]);
            }
            i = i + 1;
        }
        self.projects = new_projects;
        return 0;
    }

    fn getProject(name) {
        let i = 0;
        while (i < len(self.projects)) {
            if (self.projects[i].getName() == name) {
                return self.projects[i];
            }
            i = i + 1;
        }
        return nullptr;
    }

    fn getProjectCount() { return len(self.projects); }
    fn getProjects() { return self.projects; }
    fn getName() { return self.name; }
    fn setConfig(c) { self.config = c; return 0; }
    fn getConfig() { return self.config; }
}


