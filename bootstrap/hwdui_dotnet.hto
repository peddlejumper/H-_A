        self.hwindow = hw;
        self.dotnet_window = dnw;
        self.title_binding = false;
        self.size_binding = false;
        self.position_binding = false;
        self.visibility_binding = false;
        self.state_binding = false;
        return 0;
    }

    fn bindTitle() {
        self.title_binding = true;
        return 0;
    }

    fn bindSize() {
        self.size_binding = true;
        return 0;
    }

    fn bindPosition() {
        self.position_binding = true;
        return 0;
    }

    fn bindVisibility() {
        self.visibility_binding = true;
        return 0;
    }

    fn bindState() {
        self.state_binding = true;
        return 0;
    }

    fn syncTitle() {
        if (self.title_binding and self.hwindow != nullptr and self.dotnet_window != nullptr) {
            self.hwindow["title"] = self.dotnet_window["title"];
        }
        return 0;
    }

    fn syncSize() {
        if (self.size_binding and self.hwindow != nullptr and self.dotnet_window != nullptr) {
            self.hwindow["width"] = self.dotnet_window["width"];
            self.hwindow["height"] = self.dotnet_window["height"];
        }
        return 0;
    }

    fn syncPosition() {
        if (self.position_binding and self.hwindow != nullptr and self.dotnet_window != nullptr) {
            self.hwindow["x"] = self.dotnet_window["x"];
            self.hwindow["y"] = self.dotnet_window["y"];
        }
        return 0;
    }

    fn syncAll() {
        self.syncTitle();
        self.syncSize();
        self.syncPosition();
        return 0;
    }

    fn getHWindow() { return self.hwindow; }
    fn getDotNetWindow() { return self.dotnet_window; }
