class DotNetServiceHost {
    let services = {};
    let endpoints = [];
    let is_running = false;
    let port = 0;
    let host_name = "";
    let max_connections = 100;
    let active_connections = 0;

    fn init_host(name, port) {
        self.services = {};
        self.endpoints = [];
        self.is_running = false;
        self.port = port;
        self.host_name = name;
        self.max_connections = 100;
        self.active_connections = 0;
        return 0;
    }

    fn registerService(name, instance) {
        self.services[name] = instance;
        return 0;
    }

    fn unregisterService(name) {
        self.services[name] = nullptr;
        return 0;
    }

    fn getService(name) {
        return self.services[name];
    }

    fn hasService(name) {
        return self.services[name] != nullptr;
    }

    fn addEndpoint(endpoint) {
        push(self.endpoints, endpoint);
        return 0;
    }

    fn start() {
        self.is_running = true;
        return 0;
    }

    fn stop() {
        self.is_running = false;
        return 0;
    }

    fn isRunning() { return self.is_running; }
    fn getPort() { return self.port; }
    fn getHostName() { return self.host_name; }
    fn getServiceCount() {
        let count = 0;
        for k in self.services {
            if (self.services[k] != nullptr) {
                count = count + 1;
            }
        }
        return count;
    }

    fn getEndpoints() { return self.endpoints; }
    fn setMaxConnections(max) { self.max_connections = max; return 0; }
    fn getMaxConnections() { return self.max_connections; }
    fn getActiveConnections() { return self.active_connections; }
}


class DotNetRPCClient {
    let endpoint = "";
    let timeout_ms = 30000;
    let is_connected = false;
    let auth_token = "";
    let headers = {};
    let call_counter = 0;

    fn init_client(endpoint) {
        self.endpoint = endpoint;
        self.timeout_ms = 30000;
        self.is_connected = false;
        self.auth_token = "";
        self.headers = {};
        self.call_counter = 0;
        return 0;
    }

    fn setTimeout(ms) { self.timeout_ms = ms; return 0; }
    fn setAuthToken(token) { self.auth_token = token; return 0; }
    fn setHeader(key, value) { self.headers[key] = value; return 0; }

    fn connect() {
        self.is_connected = true;
        return 0;
    }

    fn disconnect() {
        self.is_connected = false;
        return 0;
    }

    fn isConnected() { return self.is_connected; }

    fn call(method, args) {
        self.call_counter = self.call_counter + 1;
        let result = new DotNetResult();
        result.init_result();
        result.setCallId(self.call_counter);
        result.setSuccess(nullptr);
        return result;
    }

    fn callAsync(method, args) {
        return self.call(method, args);
    }

    fn getEndpoint() { return self.endpoint; }
    fn getTimeout() { return self.timeout_ms; }
    fn getCallCount() { return self.call_counter; }
}


