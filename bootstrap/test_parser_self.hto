import "bootstrap/tokenize.hto";
import "bootstrap/parser.hto";
import "bootstrap/interpreter.hto";

let passed = 0;
let failed = 0;

fn check(name, condition) {
    if (condition) {
        passed = passed + 1;
        print("[PASS] " + name);
    } else {
        failed = failed + 1;
        print("[FAIL] " + name);
    }
}

print("========================================");
print("  H# Parser Self-Hosting Test");
print("========================================");
print("");

# ======== Test 1: IndexExpression ========
print("--- Test 1: IndexExpression ---");
let idx_src = "let arr = [10, 20, 30];\nlet val = arr[1];\nlet ch = src[i];";
let idx_tokens = tokenize(idx_src);
let idx_ast = parse(idx_tokens);
check("IndexExpr: Program", idx_ast[0] == "Program");
check("IndexExpr: 3 statements", len(idx_ast[1]) == 3);
check("IndexExpr: LetStatement[0] name", idx_ast[1][0][1] == "arr");
check("IndexExpr: arr[1] is IndexExpr", idx_ast[1][1][2][0] == "IndexExpression");
check("IndexExpr: index value", idx_ast[1][1][2][2][1] == "1");
check("IndexExpr: src[i] is IndexExpr", idx_ast[1][2][2][0] == "IndexExpression");
print("");

# ======== Test 2: ArrayLiteral ========
print("--- Test 2: ArrayLiteral ---");
let arr_src = "let a = [1, 2, 3];\nlet b = [];\nlet c = [x, y + 1];";
let arr_tokens = tokenize(arr_src);
let arr_ast = parse(arr_tokens);
check("ArrayLit: Program", arr_ast[0] == "Program");
check("ArrayLit: [1,2,3] is ArrayLiteral", arr_ast[1][0][2][0] == "ArrayLiteral");
check("ArrayLit: 3 elements", len(arr_ast[1][0][2][1]) == 3);
check("ArrayLit: empty array", arr_ast[1][1][2][0] == "ArrayLiteral");
check("ArrayLit: empty array 0 elems", len(arr_ast[1][1][2][1]) == 0);
check("ArrayLit: [x, y+1] is ArrayLiteral", arr_ast[1][2][2][0] == "ArrayLiteral");
check("ArrayLit: y+1 is BinaryOp", arr_ast[1][2][2][1][1][0] == "BinaryOp");
print("");

# ======== Test 3: DictLiteral ========
print("--- Test 3: DictLiteral ---");
let dict_src = "let d = {\"name\": \"Alice\", \"age\": 30};\nlet e = {};";
let dict_tokens = tokenize(dict_src);
let dict_ast = parse(dict_tokens);
check("DictLit: Program", dict_ast[0] == "Program");
check("DictLit: is DictLiteral", dict_ast[1][0][2][0] == "DictLiteral");
check("DictLit: 2 pairs", len(dict_ast[1][0][2][1]) == 2);
check("DictLit: first key is StringLiteral", dict_ast[1][0][2][1][0][0][0] == "StringLiteral");
check("DictLit: first key value 'name'", dict_ast[1][0][2][1][0][0][1] == "name");
check("DictLit: second key 'age'", dict_ast[1][0][2][1][1][0][1] == "age");
check("DictLit: empty dict", dict_ast[1][1][2][0] == "DictLiteral");
check("DictLit: empty dict 0 pairs", len(dict_ast[1][1][2][1]) == 0);
print("");

# ======== Test 4: Chained expressions ========
print("--- Test 4: Chained postfix ---");
let chain_src = "let v = obj.method()[0];\nlet w = arr[i][j];\nlet z = func(x)[1];";
let chain_tokens = tokenize(chain_src);
let chain_ast = parse(chain_tokens);
check("Chain: Program", chain_ast[0] == "Program");
check("Chain: 3 statements", len(chain_ast[1]) == 3);
check("Chain: obj.method()[0] is IndexExpression outer", chain_ast[1][0][2][0] == "IndexExpression");
check("Chain: inner is CallExpression", chain_ast[1][0][2][1][0] == "CallExpression");
check("Chain: arr[i][j] is IndexExpression outer", chain_ast[1][1][2][0] == "IndexExpression");
check("Chain: inner is IndexExpression", chain_ast[1][1][2][1][0] == "IndexExpression");
check("Chain: func(x)[1] is IndexExpression", chain_ast[1][2][2][0] == "IndexExpression");
print("");

# ======== Test 5: Complex H# tokenizer-like code ========
print("--- Test 5: Tokenizer-like code ---");
let tok_like_src = "let tokens = [];\nlet i = 0;\nlet n = len(src);\nwhile (i < n) {\n    let ch = src[i];\n    if (ch == \" \") {\n        i = i + 1;\n        continue;\n    }\n    push(tokens, {\"type\":\"LET\", \"value\":nullptr});\n    i = i + 1;\n}";
let tl_tokens = tokenize(tok_like_src);
let tl_ast = parse(tl_tokens);
check("TokLike: Program", tl_ast[0] == "Program");
check("TokLike: has WhileStatement", tl_ast[1][3][0] == "WhileStatement");
check("TokLike: while cond is BinaryOp", tl_ast[1][3][1][0] == "BinaryOp");
check("TokLike: has IndexExpression in while", tl_ast[1][3][2][0] == "BlockStatement");
check("TokLike: has push call", tl_ast[1][3][2][1][2][0] == "CallExpression");
check("TokLike: dict literal in push", tl_ast[1][3][2][1][2][2][1][0] == "DictLiteral");
check("TokLike: if inside while", tl_ast[1][3][2][1][1][0] == "IfStatement");
print("");

# ======== Test 6: Interpret complex code ========
print("--- Test 6: Interpret with Index/Array/Dict ---");
let eval_src = "let a = [10, 20, 30];\nlet idx1 = a[0];\nlet idx2 = a[1];\nlet idx3 = a[2];\nlet d = {\"x\": 100, \"y\": 200};\nlet sum = idx1 + idx2 + idx3;";
let eval_tokens = tokenize(eval_src);
let eval_ast = parse(eval_tokens);
let eval_env = [];
# use interpret from the interpreter module
let result = eval_node(eval_ast, eval_env);
check("Eval: idx1 = 10", _env_get(eval_env, "idx1") == 10);
check("Eval: idx2 = 20", _env_get(eval_env, "idx2") == 20);
check("Eval: idx3 = 30", _env_get(eval_env, "idx3") == 30);
check("Eval: sum = 60", _env_get(eval_env, "sum") == 60);
check("Eval: d exists", _env_get(eval_env, "d") != nullptr);
print("");

# ======== Summary ========
print("========================================");
print("  Results: " + passed + " passed, " + failed + " failed");
print("========================================");
if (failed > 0) {
    print("SOME TESTS FAILED!");
}
if (failed == 0) {
    print("ALL TESTS PASSED!");
}