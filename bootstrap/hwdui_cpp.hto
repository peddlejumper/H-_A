        self.method = method;
        self.params = [];
        self.id = 0;
        self.is_request = true;
        self.is_notification = false;
        self.correlation_id = "";
        self.timestamp = 0;
        return 0;
    }

    fn getMethod() { return self.method; }
    fn getParamCount() { return len(self.params); }

    fn getParam(index) {
        if (index >= 0 and index < len(self.params)) {
            return self.params[index];
        }
        return nullptr;
    }

    fn addParam(param) { push(self.params, param); return 0; }
    fn getId() { return self.id; }
    fn setId(v) { self.id = v; return 0; }
    fn isRequest() { return self.is_request; }
    fn isNotification() { return self.is_notification; }
    fn setNotification(v) { self.is_notification = v; return 0; }
    fn getCorrelationId() { return self.correlation_id; }
    fn setCorrelationId(v) { self.correlation_id = v; return 0; }
    fn getTimestamp() { return self.timestamp; }
    fn setTimestamp(v) { self.timestamp = v; return 0; }
    fn getParams() { return self.params; }
    fn setParams(p) { self.params = p; return 0; }

    fn dispose() {
        self.params = [];
        return 0;
    }
}


