class CppModule {
    let name = "";
    let projects = [];
    let build_config = "";
    let module_type = "library";

    fn init_module(name) {
        self.name = name;
        self.projects = [];
        self.build_config = "debug";
        self.module_type = "library";
        return 0;
    }

    fn getName() { return self.name; }
    fn getProjectCount() { return len(self.projects); }

    fn addProject(project) {
        push(self.projects, project);
        return 0;
    }

    fn getProject(name) {
        let i = 0;
        while (i < len(self.projects)) {
            if (self.projects[i].getName() == name) {
                return self.projects[i];
            }
            i = i + 1;
        }
        return nullptr;
    }

    fn setBuildConfig(c) { self.build_config = c; return 0; }
    fn getBuildConfig() { return self.build_config; }

    fn removeProject(name) {
        let new_projects = [];
        let i = 0;
        while (i < len(self.projects)) {
            if (self.projects[i].getName() != name) {
                push(new_projects, self.projects[i]);
            }
            i = i + 1;
        }
        self.projects = new_projects;
        return 0;
    }

    fn getProjects() { return self.projects; }
    fn setModuleType(t) { self.module_type = t; return 0; }
    fn getModuleType() { return self.module_type; }

    fn dispose() {
        self.projects = [];
        return 0;
    }
}


