# ═══════════════════════════════════════════════════════════════════════════
# Section 7: 序列化层 — 跨运行时类型转换
# ═══════════════════════════════════════════════════════════════════════════

class CppSerializer {
    let format = "json";
    let indent = false;
    let mapper = nullptr;
    let type_handlers = {};

    fn init_serializer(mapper) {
        self.format = "json";
        self.indent = false;
        self.mapper = mapper;
        self.type_handlers = {};
        return 0;
    }

    fn getFormat() { return self.format; }
    fn setFormat(f) { self.format = f; return 0; }
    fn setIndent(v) { self.indent = v; return 0; }
    fn getIndent() { return self.indent; }

    fn serialize(val) {
        if (val == nullptr) {
            return {"__type__": "nullptr", "value": nullptr};
        }
        return {"__type__": "auto", "value": val};
    }

    fn serializeObject(obj) {
        if (obj == nullptr) { return nullptr; }
        let result = {};
        for k in obj {
            result[k] = obj[k];
        }
        return result;
    }

    fn serializeList(lst) {
        if (lst == nullptr) { return []; }
        let result = [];
        let i = 0;
        while (i < len(lst)) {
            push(result, lst[i]);
            i = i + 1;
        }
        return result;
    }

    fn serializeListLength(lst) {
        if (lst == nullptr) { return 0; }
        return len(lst);
    }

    fn addTypeHandler(type_name, handler) {
        self.type_handlers[type_name] = handler;
        return 0;
    }

    fn getTypeHandler(type_name) {
        return self.type_handlers[type_name];
    }

    fn getMapper() { return self.mapper; }

    fn dispose() {
        self.type_handlers = {};
        self.mapper = nullptr;
        return 0;
    }
}


class CppDeserializer {
    let format = "json";
    let strict = false;
    let mapper = nullptr;
    let type_handlers = {};

    fn init_deserializer(mapper) {
        self.format = "json";
        self.strict = false;
        self.mapper = mapper;
        self.type_handlers = {};
        return 0;
    }

    fn getFormat() { return self.format; }
    fn setFormat(f) { self.format = f; return 0; }
    fn setStrict(v) { self.strict = v; return 0; }
    fn isStrict() { return self.strict; }

    fn deserialize(data) {
        if (data == nullptr) { return nullptr; }
        let ctype = data["__type__"];
        if (ctype == nullptr) { return data; }
        let handler = self.type_handlers[ctype];
        if (handler != nullptr) {
            return handler(data);
        }
        return data["value"];
    }

    fn deserializeObject(data) {
        return self.deserialize(data);
    }

    fn deserializeList(data) {
        if (data == nullptr) { return []; }
        return data;
    }

    fn addTypeHandler(type_name, handler) {
        self.type_handlers[type_name] = handler;
        return 0;
    }

    fn getTypeHandler(type_name) {
        return self.type_handlers[type_name];
    }

    fn getMapper() { return self.mapper; }

    fn dispose() {
        self.type_handlers = {};
        self.mapper = nullptr;
        return 0;
    }
}


class CppMessagePack {
    let packed = nullptr;
    let unpacked = nullptr;

    fn init_pack() {
        self.packed = nullptr;
        self.unpacked = nullptr;
        return 0;
    }

    fn pack(data) {
        self.packed = data;
        return self.packed;
    }

    fn unpack(data) {
        self.unpacked = data;
        return self.unpacked;
    }

    fn getPacked() { return self.packed; }
    fn getUnpacked() { return self.unpacked; }

    fn packSize() {
        if (self.packed == nullptr) { return 0; }
        return 1;
    }

    fn unpackedSize() {
        if (self.unpacked == nullptr) { return 0; }
        return 1;
    }

    fn dispose() {
        self.packed = nullptr;
        self.unpacked = nullptr;
        return 0;
    }
}


class CppJSON {
    let indent_level = 0;
    let escape_chars = true;
    let strict_mode = false;

    fn init_json() {
        self.indent_level = 0;
        self.escape_chars = true;
        self.strict_mode = false;
        return 0;
    }

    fn stringify(obj) {
        if (obj == nullptr) { return "null"; }
        if (obj == true) { return "true"; }
        if (obj == false) { return "false"; }
        return "\"" + str(obj) + "\"";
    }

    fn parse(json_str) {
        if (json_str == nullptr) { return nullptr; }
        return {};
    }

    fn setIndent(level) { self.indent_level = level; return 0; }
    fn setStrict(v) { self.strict_mode = v; return 0; }

    fn escape(str_val) {
        if (str_val == nullptr) { return ""; }
        return str_val;
    }

    fn unescape(str_val) {
        if (str_val == nullptr) { return ""; }
        return str_val;
    }

    fn dispose() {
        return 0;
    }
}


class CppTypeConverter {
    let converters = {};
    let conversion_cache = {};

    fn init_converter() {
        self.converters = {};
        self.conversion_cache = {};
        self._register_defaults();
        return 0;
    }

    fn _register_defaults() {
        self.converters["int->double"] = fn(val) { return val * 1.0; };
        self.converters["double->int"] = fn(val) { return val; };
        self.converters["int->string"] = fn(val) { return str(val); };
        self.converters["float->string"] = fn(val) { return str(val); };
        self.converters["bool->string"] = fn(val) { if (val) { return "true"; } return "false"; };
        self.converters["string->int"] = fn(val) { return val; };
        self.converters["string->float"] = fn(val) { return val; };
        self.converters["string->bool"] = fn(val) { if (val == "true") { return true; } return false; };
        self.converters["int->bool"] = fn(val) { if (val != 0) { return true; } return false; };
        self.converters["bool->int"] = fn(val) { if (val) { return 1; } return 0; };
        self.converters["string->list"] = fn(val) { return [val]; };
        self.converters["list->string"] = fn(val) { return str(val); };
        return 0;
    }

    fn register(from, to, converter_fn) {
        let key = from + "->" + to;
        self.converters[key] = converter_fn;
        return 0;
    }

    fn canConvert(from, to) {
        let key = from + "->" + to;
        return self.converters[key] != nullptr;
    }

    fn convert(val, from, to) {
        let key = from + "->" + to;
        let converter = self.converters[key];
        if (converter != nullptr) {
            return converter(val);
        }
        return val;
    }

    fn getConverter(from, to) {
        let key = from + "->" + to;
        return self.converters[key];
    }

    fn removeConverter(from, to) {
        let key = from + "->" + to;
        self.converters[key] = nullptr;
        return 0;
    }

    fn getConverterCount() {
        let count = 0;
        for k in self.converters {
            if (self.converters[k] != nullptr) {
                count = count + 1;
            }
        }
        return count;
    }

    fn clear() {
        self.converters = {};
        self.conversion_cache = {};
        return 0;
    }

    fn dispose() {
        self.converters = {};
        self.conversion_cache = {};
        return 0;
    }
}


# ═══════════════════════════════════════════════════════════════════════════
# Section 8: 异步任务桥接层
# ═══════════════════════════════════════════════════════════════════════════

class CppFuture {
    let id = 0;
    let status = "created";
    let result = nullptr;
    let exception = nullptr;
    let is_done = false;
    let is_faulted = false;
    let is_cancelled = false;
    let callbacks = [];

    fn init_future() {
        self.id = 0;
        self.status = "created";
        self.result = nullptr;
        self.exception = nullptr;
        self.is_done = false;
        self.is_faulted = false;
        self.is_cancelled = false;
        self.callbacks = [];
        return 0;
    }

    fn getId() { return self.id; }
    fn setId(v) { self.id = v; return 0; }
    fn getStatus() { return self.status; }
    fn isDone() { return self.is_done; }
    fn isFaulted() { return self.is_faulted; }
    fn isCancelled() { return self.is_cancelled; }

    fn complete(val) {
        self.result = val;
        self.is_done = true;
        self.status = "completed";
        self._runCallbacks();
        return 0;
    }

    fn fail(ex) {
        self.exception = ex;
        self.is_faulted = true;
        self.is_done = true;
        self.status = "faulted";
        self._runCallbacks();
        return 0;
    }

    fn cancel() {
        self.is_cancelled = true;
        self.is_done = true;
        self.status = "cancelled";
        return 0;
    }

    fn getResult() { return self.result; }
    fn getException() { return self.exception; }

    fn addCallback(cb) {
        if (self.is_done) {
            cb(self);
        } else {
            push(self.callbacks, cb);
        }
        return 0;
    }

    fn removeCallback(cb) {
        let new_callbacks = [];
        let i = 0;
        while (i < len(self.callbacks)) {
            if (self.callbacks[i] != cb) {
                push(new_callbacks, self.callbacks[i]);
            }
            i = i + 1;
        }
        self.callbacks = new_callbacks;
        return 0;
    }

    fn getCallbacks() { return self.callbacks; }

    fn _runCallbacks() {
        let i = 0;
        while (i < len(self.callbacks)) {
            self.callbacks[i](self);
            i = i + 1;
        }
        self.callbacks = [];
        return 0;
    }

    fn dispose() {
        self.result = nullptr;
        self.exception = nullptr;
        self.callbacks = [];
        return 0;
    }
}


class CppThreadPool {
    let core_pool_size = 2;
    let max_pool_size = 8;
    let is_running = false;
    let tasks = [];
    let futures = [];
    let queue_type = "fifo";

    fn init_pool() {
        self.core_pool_size = 2;
        self.max_pool_size = 8;
        self.is_running = false;
        self.tasks = [];
        self.futures = [];
        self.queue_type = "fifo";
        return 0;
    }

    fn getCorePoolSize() { return self.core_pool_size; }
    fn setCorePoolSize(sz) { self.core_pool_size = sz; return 0; }
    fn setMaxPoolSize(sz) { self.max_pool_size = sz; return 0; }
    fn getMaxPoolSize() { return self.max_pool_size; }
    fn isRunning() { return self.is_running; }

    fn execute(task_fn) {
        if (task_fn != nullptr) {
            task_fn();
        }
        return 0;
    }

    fn submit(task_fn) {
        let future = new CppFuture();
        future.init_future();
        future.setId(len(self.futures) + 1);
        push(self.futures, future);
        if (task_fn != nullptr) {
            let result = task_fn();
            future.complete(result);
        }
        return future;
    }

    fn getTaskCount() { return len(self.tasks); }
    fn getFutureCount() { return len(self.futures); }
    fn setQueueType(t) { self.queue_type = t; return 0; }
    fn getQueueType() { return self.queue_type; }

    fn cancelAll() {
        let i = 0;
        while (i < len(self.futures)) {
            self.futures[i].cancel();
            i = i + 1;
        }
        self.futures = [];
        return 0;
    }

    fn shutdown() {
        self.is_running = false;
        self.cancelAll();
        return 0;
    }

    fn dispose() {
        self.shutdown();
        return 0;
    }
}


class CppCancellationToken {
    let is_cancelled = false;
    let on_cancel_callbacks = [];
    let source = "";

    fn init_token() {
        self.is_cancelled = false;
        self.on_cancel_callbacks = [];
        self.source = "";
        return 0;
    }

    fn isCancelled() { return self.is_cancelled; }

    fn cancel() {
        self.is_cancelled = true;
        let i = 0;
        while (i < len(self.on_cancel_callbacks)) {
            self.on_cancel_callbacks[i]();
            i = i + 1;
        }
        return 0;
    }

    fn setOnCancel(cb) {
        push(self.on_cancel_callbacks, cb);
        return 0;
    }

    fn getOnCancel() { return self.on_cancel_callbacks; }

    fn reset() {
        self.is_cancelled = false;
        self.on_cancel_callbacks = [];
        return 0;
    }

    fn dispose() {
        self.on_cancel_callbacks = [];
        return 0;
    }
}


class CppAsyncResult {
    let future = nullptr;
    let is_completed = false;
    let async_state = nullptr;
    let result_id = 0;
    let wait_handle = nullptr;

    fn init_async() {
        self.future = nullptr;
