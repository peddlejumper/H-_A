class CppCMakeTarget {
    let name = "";
    let target_type = "";
    let version = "";
    let sources = [];
    let headers = [];
    let dependencies = [];
    let link_libs = [];
    let compile_defs = [];
    let compile_opts = [];
    let is_installed = false;
    let scope = "compile";

    fn init_target(name, ttype) {
        self.name = name;
        self.target_type = ttype;
        self.version = "1.0.0";
        self.sources = [];
        self.headers = [];
        self.dependencies = [];
        self.link_libs = [];
        self.compile_defs = [];
        self.compile_opts = [];
        self.is_installed = false;
        self.scope = "compile";
        return 0;
    }

    fn getName() { return self.name; }
    fn getType() { return self.target_type; }
    fn getVersion() { return self.version; }
    fn setVersion(v) { self.version = v; return 0; }

    fn addSource(src) { push(self.sources, src); return 0; }
    fn getSources() { return self.sources; }

    fn addHeader(hdr) { push(self.headers, hdr); return 0; }
    fn getHeaders() { return self.headers; }

    fn addDependency(dep) { push(self.dependencies, dep); return 0; }
    fn getDependencies() { return self.dependencies; }

    fn addLinkLib(lib) { push(self.link_libs, lib); return 0; }
    fn getLinkLibs() { return self.link_libs; }

    fn addCompileDef(def) { push(self.compile_defs, def); return 0; }
    fn getCompileDefs() { return self.compile_defs; }

    fn addCompileOpt(opt) { push(self.compile_opts, opt); return 0; }
    fn getCompileOpts() { return self.compile_opts; }

    fn isInstalled() { return self.is_installed; }
    fn setInstalled(v) { self.is_installed = v; return 0; }
    fn getScope() { return self.scope; }
    fn setScope(s) { self.scope = s; return 0; }

    fn getId() {
        return self.name + ":" + self.version;
    }

    fn dispose() {
        self.sources = [];
        self.headers = [];
        self.dependencies = [];
        self.link_libs = [];
        self.compile_defs = [];
        self.compile_opts = [];
        return 0;
    }
}


class CppCMakeManager {
    let repos = [];
    let installed_targets = {};
    let local_repo = "";

    fn init_cmake() {
        self.repos = [];
        self.installed_targets = {};
        self.local_repo = "";
        return 0;
    }

    fn addRepository(repo) {
        push(self.repos, repo);
        return 0;
    }

    fn getRepositories() { return self.repos; }

    fn install(target) {
        let key = target.getId();
        target.setInstalled(true);
        self.installed_targets[key] = target;
        return target;
    }

    fn getTarget(name) {
        for k in self.installed_targets {
            let t = self.installed_targets[k];
            if (t != nullptr and t.getName() == name) {
                return t;
            }
        }
        return nullptr;
    }

    fn getInstalledTargets() {
        let result = [];
        for k in self.installed_targets {
            if (self.installed_targets[k] != nullptr) {
                push(result, self.installed_targets[k]);
            }
        }
        return result;
    }

    fn getTargetCount() {
        let count = 0;
        for k in self.installed_targets {
            if (self.installed_targets[k] != nullptr) {
                count = count + 1;
            }
        }
        return count;
    }

    fn uninstall(name) {
        for k in self.installed_targets {
            let t = self.installed_targets[k];
            if (t != nullptr and t.getName() == name) {
                self.installed_targets[k] = nullptr;
            }
        }
        return 0;
    }

    fn setLocalRepo(path) { self.local_repo = path; return 0; }
    fn getLocalRepo() { return self.local_repo; }

    fn findPackage(name) {
        return self.getTarget(name);
    }

    fn resolve(name) {
        return self.getTarget(name);
    }

    fn dispose() {
        self.repos = [];
        self.installed_targets = {};
        return 0;
    }
}


