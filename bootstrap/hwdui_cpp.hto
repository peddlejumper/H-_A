class CppLogger {
    let level = 1;
    let log_file = "";
    let is_file_logging = false;
    let format_str = "[C++] {level} {message}";
    let max_level = 4;

    fn init_logger() {
        self.level = 1;
        self.log_file = "";
        self.is_file_logging = false;
        self.format_str = "[C++] {level} {message}";
        self.max_level = 4;
        return 0;
    }

    fn getLevel() { return self.level; }
    fn setLevel(v) { self.level = v; return 0; }
    fn setLogFile(path) { self.log_file = path; return 0; }
    fn getLogFile() { return self.log_file; }
    fn isFileLogging() { return self.is_file_logging; }
    fn setFormat(f) { self.format_str = f; return 0; }
    fn getFormat() { return self.format_str; }

    fn debug(msg) {
        if (self.level <= 0) { self._write("DEBUG", msg); }
        return 0;
    }

    fn info(msg) {
        if (self.level <= 1) { self._write("INFO", msg); }
        return 0;
    }

    fn warn(msg) {
        if (self.level <= 2) { self._write("WARN", msg); }
        return 0;
    }

    fn error(msg) {
        if (self.level <= 3) { self._write("ERROR", msg); }
        return 0;
    }

    fn fatal(msg) {
        self._write("FATAL", msg);
        return 0;
    }

    fn log(level, msg) {
        if (level >= self.level) {
            let names = ["DEBUG", "INFO", "WARN", "ERROR", "FATAL"];
            let lname = "UNKNOWN";
            if (level >= 0 and level < len(names)) {
                lname = names[level];
            }
            self._write(lname, msg);
        }
        return 0;
    }

    fn _write(level_name, msg) {
        print("[C++] [" + level_name + "] " + msg);
        return 0;
    }

    fn setMaxLevel(v) { self.max_level = v; return 0; }
    fn getMaxLevel() { return self.max_level; }

    fn dispose() {
        return 0;
    }
}


class CppProfiler {
    let measurements = {};
    let is_running = false;
    let start_time = 0;
    let total_measurements = 0;
    let category = "default";

    fn init_profiler() {
        self.measurements = {};
        self.is_running = false;
        self.start_time = 0;
        self.total_measurements = 0;
        self.category = "default";
        return 0;
    }

    fn start(name) {
        self.measurements[name] = {"start": 0, "end": 0, "elapsed": 0, "running": true};
        self.is_running = true;
        return 0;
    }

    fn stop(name) {
        let m = self.measurements[name];
        if (m != nullptr) {
            m["running"] = false;
            self.total_measurements = self.total_measurements + 1;
        }
        self.is_running = false;
        return 0;
    }

    fn measure(name) {
        self.start(name);
        self.stop(name);
        return 0;
    }

    fn getMeasurements() { return self.measurements; }
    fn getTotalMeasurements() { return self.total_measurements; }
    fn isRunning() { return self.is_running; }

    fn reset() {
        self.measurements = {};
        self.total_measurements = 0;
        self.is_running = false;
        return 0;
    }

    fn getAverageDuration(name) {
        let m = self.measurements[name];
        if (m != nullptr) {
            return m["elapsed"];
        }
        return 0;
    }

    fn getCategory() { return self.category; }
    fn setCategory(c) { self.category = c; return 0; }

    fn dispose() {
        self.measurements = {};
        return 0;
    }
}


class CppDebugger {
    let is_attached = false;
    let breakpoints = {};
    let current_file = "";
    let current_line = 0;
    let debug_port = 0;
    let step_mode = "none";
    let watch_vars = [];

    fn init_debugger() {
        self.is_attached = false;
        self.breakpoints = {};
        self.current_file = "";
        self.current_line = 0;
        self.debug_port = 0;
        self.step_mode = "none";
        self.watch_vars = [];
        return 0;
    }

    fn isAttached() { return self.is_attached; }

    fn attach() {
        self.is_attached = true;
        return 0;
    }

    fn detach() {
        self.is_attached = false;
        self.breakpoints = {};
        self.step_mode = "none";
        return 0;
    }

    fn setBreakpoint(file, line) {
        let key = file + ":" + str(line);
        self.breakpoints[key] = true;
        return 0;
    }

    fn removeBreakpoint(file, line) {
        let key = file + ":" + str(line);
        self.breakpoints[key] = nullptr;
        return 0;
    }

    fn getBreakpoints() { return self.breakpoints; }

    fn getBreakpointCount() {
        let count = 0;
        for k in self.breakpoints {
            if (self.breakpoints[k] != nullptr) {
                count = count + 1;
            }
        }
        return count;
    }

    fn clearBreakpoints() {
        self.breakpoints = {};
        return 0;
    }

    fn setDebugPort(port) { self.debug_port = port; return 0; }
    fn getDebugPort() { return self.debug_port; }
    fn setStepMode(mode) { self.step_mode = mode; return 0; }
    fn getStepMode() { return self.step_mode; }
    fn setCurrentFile(file) { self.current_file = file; return 0; }
    fn getCurrentFile() { return self.current_file; }
    fn setCurrentLine(line) { self.current_line = line; return 0; }
    fn getCurrentLine() { return self.current_line; }

    fn addWatch(var_name) {
        push(self.watch_vars, var_name);
        return 0;
    }

    fn removeWatch(var_name) {
        let new_watches = [];
        let i = 0;
        while (i < len(self.watch_vars)) {
            if (self.watch_vars[i] != var_name) {
                push(new_watches, self.watch_vars[i]);
            }
            i = i + 1;
        }
        self.watch_vars = new_watches;
        return 0;
    }

    fn getWatches() { return self.watch_vars; }

    fn dispose() {
        self.breakpoints = {};
        self.watch_vars = [];
        return 0;
    }
}


class CppConfig {
    let config_file = "";
    let values = {};
    let sections = {};
    let is_loaded = false;

    fn init_config() {
        self.config_file = "";
        self.values = {};
        self.sections = {};
        self.is_loaded = false;
        return 0;
    }

    fn load(file_path) {
        self.config_file = file_path;
        self.is_loaded = true;
        return 0;
    }

    fn save() {
        return 0;
    }

    fn getConfigFile() { return self.config_file; }
    fn setConfigFile(f) { self.config_file = f; return 0; }

    fn hasKey(key) {
        return self.values[key] != nullptr;
    }

    fn get(key, default_val) {
        let val = self.values[key];
        if (val == nullptr) {
            return default_val;
        }
        return val;
    }

    fn set(key, val) {
        self.values[key] = val;
        return 0;
    }

    fn setSection(name, section_data) {
        self.sections[name] = section_data;
        return 0;
    }

    fn getSection(name) {
        return self.sections[name];
    }

    fn getKeys() {
        let keys = [];
        for k in self.values {
            push(keys, k);
        }
        return keys;
    }

    fn remove(key) {
        self.values[key] = nullptr;
        return 0;
    }

    fn clear() {
        self.values = {};
        self.sections = {};
        return 0;
    }

    fn isLoaded() { return self.is_loaded; }

    fn dispose() {
        self.clear();
        return 0;
    }
}


