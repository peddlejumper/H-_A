    fn getAsyncState() { return self.async_state; }
    fn setAsyncState(state) { self.async_state = state; return 0; }
    fn getResultId() { return self.result_id; }
    fn setResultId(id) { self.result_id = id; return 0; }
    fn setWaitHandle(handle) { self.wait_handle = handle; return 0; }
    fn getWaitHandle() { return self.wait_handle; }

    fn dispose() {
        self.future = nullptr;
        self.async_state = nullptr;
        self.wait_handle = nullptr;
        return 0;
    }
}


