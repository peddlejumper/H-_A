# Section 13: 全局函数与初始化
# ═══════════════════════════════════════════════════════════════════════════

let _cpp_mapper = new CppTypeMapper();
let _cpp_cache = new CppObjectCache();
let _cpp_event_bus = new CppCrossEventBus();
let _cpp_binding_mgr = new CppBindingManager();
let _cpp_serializer = new CppSerializer(_cpp_mapper);
let _cpp_deserializer = new CppDeserializer(_cpp_mapper);
let _cpp_type_converter = new CppTypeConverter();
let _cpp_logger = new CppLogger();
let _cpp_profiler = new CppProfiler();
let _cpp_config = new CppConfig();
let _cpp_env = new CppEnvironment();
let _cpp_lib_loader = new CppLibLoader();
let _cpp_control_factory = new CppControlFactory();
let _cpp_style_bridge = new CppStyleBridge();
let _cpp_qml = new CppQML();
let _cpp_resource_bundle = new CppResourceBundle();
let _cpp_cmake = new CppCMakeManager();
let _cpp_thread_pool = new CppThreadPool();
let _cpp_is_initialized = false;

_cpp_mapper.init_mapper();
_cpp_cache.init_cache();
_cpp_event_bus.init_cross_bus();
_cpp_binding_mgr.init_binding_mgr();
_cpp_serializer.init_serializer(_cpp_mapper);
_cpp_deserializer.init_deserializer(_cpp_mapper);
_cpp_type_converter.init_converter();
_cpp_logger.init_logger();
_cpp_profiler.init_profiler();
_cpp_config.init_config();
_cpp_env.init_env();
_cpp_lib_loader.init_loader();
_cpp_control_factory.init_factory();
_cpp_style_bridge.init_style_bridge();
_cpp_qml.init_qml();
_cpp_resource_bundle.init_bundle();
_cpp_cmake.init_cmake();
_cpp_thread_pool.init_pool();

fn cpp_init() {
    _cpp_is_initialized = true;
    _cpp_logger.info("cpp_init: H# ↔ C++ interop initialized");
    _cpp_logger.info("cpp_init: " + "type mappings, object cache, event bus, bindings ready");
    return true;
}

fn cpp_shutdown() {
    _cpp_cache.clear();
    _cpp_event_bus.clear();
    _cpp_binding_mgr.clear();
    _cpp_config.clear();
    _cpp_thread_pool.cancelAll();
    _cpp_is_initialized = false;
    _cpp_logger.info("cpp_shutdown: H# ↔ C++ interop shut down");
    return 0;
}

fn cpp_is_ready() {
    return _cpp_is_initialized;
}

fn cpp_get_mapper() { return _cpp_mapper; }
fn cpp_get_cache() { return _cpp_cache; }
fn cpp_get_event_bus() { return _cpp_event_bus; }
fn cpp_get_binding_manager() { return _cpp_binding_mgr; }
fn cpp_get_serializer() { return _cpp_serializer; }
fn cpp_get_deserializer() { return _cpp_deserializer; }
fn cpp_get_type_converter() { return _cpp_type_converter; }
fn cpp_get_logger() { return _cpp_logger; }
fn cpp_get_profiler() { return _cpp_profiler; }
fn cpp_get_config() { return _cpp_config; }
fn cpp_get_env() { return _cpp_env; }
fn cpp_get_lib_loader() { return _cpp_lib_loader; }
fn cpp_get_control_factory() { return _cpp_control_factory; }
fn cpp_get_style_bridge() { return _cpp_style_bridge; }
fn cpp_get_qml() { return _cpp_qml; }
fn cpp_get_resource_bundle() { return _cpp_resource_bundle; }
fn cpp_get_cmake() { return _cpp_cmake; }
fn cpp_get_thread_pool() { return _cpp_thread_pool; }
fn cpp_get_version() { return "1.0.0"; }

