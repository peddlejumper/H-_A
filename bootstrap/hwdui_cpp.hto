class CppStyleBridge {
    let mappings = [];
    let reverse_mappings = {};

    fn init_style_bridge() {
        self.mappings = [];
        self.reverse_mappings = {};
        self._register_defaults();
        return 0;
    }

    fn _register_defaults() {
        self.addMapping("background", "background-color");
        self.addMapping("color", "color");
        self.addMapping("fontSize", "font-size");
        self.addMapping("fontFamily", "font-family");
        self.addMapping("fontWeight", "font-weight");
        self.addMapping("padding", "padding");
        self.addMapping("margin", "margin");
        self.addMapping("border", "border");
        self.addMapping("borderColor", "border-color");
        self.addMapping("borderRadius", "border-radius");
        self.addMapping("opacity", "opacity");
        self.addMapping("visibility", "visibility");
        return 0;
    }

    fn getMappingCount() { return len(self.mappings); }

    fn toQt(hwd_prop) {
        return self.reverse_mappings[hwd_prop];
    }

    fn toHwdUI(qt_prop) {
        let i = 0;
        while (i < len(self.mappings)) {
            if (self.mappings[i]["qt"] == qt_prop) {
                return self.mappings[i]["hwd"];
            }
            i = i + 1;
        }
        return nullptr;
    }

    fn addMapping(hwd_prop, qt_prop) {
        push(self.mappings, {"hwd": hwd_prop, "qt": qt_prop});
        self.reverse_mappings[hwd_prop] = qt_prop;
        return 0;
    }

    fn removeMapping(hwd_prop) {
        let new_mappings = [];
        let i = 0;
        while (i < len(self.mappings)) {
            if (self.mappings[i]["hwd"] != hwd_prop) {
                push(new_mappings, self.mappings[i]);
            }
            i = i + 1;
        }
        self.mappings = new_mappings;
        self.reverse_mappings[hwd_prop] = nullptr;
        return 0;
    }

    fn getMappings() { return self.mappings; }
    fn getReverseMappings() { return self.reverse_mappings; }

    fn clear() {
        self.mappings = [];
        self.reverse_mappings = {};
        return 0;
    }

    fn dispose() {
        self.clear();
        return 0;
    }
}


# ═══════════════════════════════════════════════════════════════════════════
# Section 12: 资源层
# ═══════════════════════════════════════════════════════════════════════════

class CppResourceBundle {
    let resources = {};
    let locale = "";
    let base_name = "";
    let fallback_locale = "";

    fn init_bundle() {
        self.resources = {};
        self.locale = "";
        self.base_name = "";
        self.fallback_locale = "";
        return 0;
    }

    fn setLocale(l) { self.locale = l; return 0; }
    fn getLocale() { return self.locale; }
    fn setBaseName(name) { self.base_name = name; return 0; }
    fn getBaseName() { return self.base_name; }

    fn getString(key) {
        let val = self.resources[key];
        if (val == nullptr) { return key; }
        return val;
    }

    fn getInteger(key) {
        let val = self.resources[key];
        if (val == nullptr) { return 0; }
        return val;
    }

    fn getBoolean(key) {
        let val = self.resources[key];
        if (val == nullptr) { return false; }
        return val;
    }

    fn hasResource(key) {
        return self.resources[key] != nullptr;
    }

    fn addResource(key, value) {
        self.resources[key] = value;
        return 0;
    }

    fn removeResource(key) {
        self.resources[key] = nullptr;
        return 0;
    }

    fn getResourceCount() {
        let count = 0;
        for k in self.resources {
            if (self.resources[k] != nullptr) {
                count = count + 1;
            }
        }
        return count;
    }

    fn clear() {
        self.resources = {};
        return 0;
    }

    fn setFallbackLocale(l) { self.fallback_locale = l; return 0; }
    fn getFallbackLocale() { return self.fallback_locale; }

    fn dispose() {
        self.resources = {};
        return 0;
    }
}


class CppFileWatcher {
    let path = "";
    let filter = "*";
    let is_watching = false;
    let include_subdirs = true;
    let change_callback = nullptr;
    let watch_interval = 1000;

    fn init_watcher(path, filter) {
        self.path = path;
        self.filter = filter;
        self.is_watching = false;
        self.include_subdirs = true;
        self.change_callback = nullptr;
        self.watch_interval = 1000;
        return 0;
    }

    fn getPath() { return self.path; }
    fn getFilter() { return self.filter; }
    fn isWatching() { return self.is_watching; }

    fn start() {
        self.is_watching = true;
        return 0;
    }

    fn stop() {
        self.is_watching = false;
        return 0;
    }

    fn setIncludeSubdirs(v) { self.include_subdirs = v; return 0; }
    fn getIncludeSubdirs() { return self.include_subdirs; }
    fn setCallback(cb) { self.change_callback = cb; return 0; }
    fn getCallback() { return self.change_callback; }
    fn setInterval(ms) { self.watch_interval = ms; return 0; }
    fn getInterval() { return self.watch_interval; }

    fn dispose() {
        self.stop();
        self.change_callback = nullptr;
        return 0;
    }
}


