# hwdui_cpp.hto — H# zzwUI ↔ C++ 协同开发库
# ═══════════════════════════════════════════════════════════════════════════
# 提供 H# 与 C++ Native 运行时之间的完整互操作基础设施：
# - 类型映射与值转换
# - 对象代理与调用代理
# - 跨运行时事件总线
# - zzwUI 控件 ↔ Qt/GTK 控件桥接
# - 双向数据绑定
# - RPC 远程过程调用
# - 序列化与反序列化
# - 异步任务桥接
# - 诊断与配置
# - CMake 项目层
# - Qt/QML 互操作
# - 资源管理
# ═══════════════════════════════════════════════════════════════════════════

import "bootstrap/hwdui.hto";

# ═══════════════════════════════════════════════════════════════════════════
# Section 1: 核心互操作层 — 类型映射、值包装、调用代理
# ═══════════════════════════════════════════════════════════════════════════

class CppTypeInfo {
    let type_name = "";
    let namespace = "";
    let shared_lib = "";
    let is_primitive = false;
    let is_template = false;
    let template_args = [];
    let base_class = "";
    let includes = [];
    let is_enum = false;
    let is_pod = false;
    let is_abstract = false;
    let modifiers = [];
    let full_name = "";
    let mangled_name = "";

    fn init_cpp_type(name, ns, lib) {
        self.type_name = name;
        self.namespace = ns;
        self.shared_lib = lib;
        self.is_primitive = false;
        self.is_template = false;
        self.template_args = [];
        self.base_class = "";
        self.includes = [];
        self.is_enum = false;
        self.is_pod = false;
        self.is_abstract = false;
        self.modifiers = [];
        if (ns == "") {
            self.full_name = name;
        } else {
            self.full_name = ns + "::" + name;
        }
        self.mangled_name = "";
        return 0;
    }

    fn setPrimitive(v) { self.is_primitive = v; return 0; }
    fn setTemplate(v) { self.is_template = v; return 0; }
    fn setEnum(v) { self.is_enum = v; return 0; }
    fn setPOD(v) { self.is_pod = v; return 0; }
    fn setAbstract(v) { self.is_abstract = v; return 0; }
    fn addTemplateArg(arg) { push(self.template_args, arg); return 0; }
    fn setBaseClass(cls) { self.base_class = cls; return 0; }
    fn addInclude(inc) { push(self.includes, inc); return 0; }
    fn addModifier(mod) { push(self.modifiers, mod); return 0; }
    fn setMangledName(name) { self.mangled_name = name; return 0; }

    fn getFullName() { return self.full_name; }
    fn getTypeName() { return self.type_name; }
    fn getNamespace() { return self.namespace; }
    fn getSharedLib() { return self.shared_lib; }
    fn isPrimitive() { return self.is_primitive; }
    fn isTemplate() { return self.is_template; }
    fn isEnum() { return self.is_enum; }
    fn isPOD() { return self.is_pod; }
    fn isAbstract() { return self.is_abstract; }
    fn getBaseClass() { return self.base_class; }
    fn getIncludes() { return self.includes; }
    fn getTemplateArgs() { return self.template_args; }
    fn getModifiers() { return self.modifiers; }
    fn getMangledName() { return self.mangled_name; }
}


class CppTypeMapper {
    let type_map = {};
    let reverse_map = {};
    let primitive_types = [];

    fn init_mapper() {
        self.type_map = {};
        self.reverse_map = {};
        self.primitive_types = [];
        self._register_defaults();
        return 0;
    }

    fn _register_defaults() {
        self.register("int", "int", true);
        self.register("float", "double", true);
        self.register("bool", "bool", true);
        self.register("string", "std::string", false);
        self.register("list", "std::vector", false);
        self.register("dict", "std::map", false);
        self.register("long", "long", true);
        self.register("short", "short", true);
        self.register("char", "char", true);
        self.register("void", "void", true);
        self.register("int64", "int64_t", true);
        self.register("uint64", "uint64_t", true);
        self.register("int32", "int32_t", true);
        self.register("float32", "float", true);
        self.register("size", "size_t", true);
        self.register("byte", "uint8_t", true);
        self.register("ptr", "void*", true);
        return 0;
    }

    fn register(htype, ctype, prim) {
        self.type_map[htype] = {"cpp": ctype, "primitive": prim};
        self.reverse_map[ctype] = htype;
        if (prim) {
            push(self.primitive_types, ctype);
        }
        return 0;
    }

    fn unregister(ctype) {
        let htype = self.reverse_map[ctype];
        if (htype != nullptr) {
            self.type_map[htype] = nullptr;
        }
        self.reverse_map[ctype] = nullptr;
        return 0;
    }

    fn toCpp(htype) {
        let info = self.type_map[htype];
        if (info != nullptr) {
            return info["cpp"];
        }
        return "void*";
    }

    fn toHSharp(ctype) {
        let htype = self.reverse_map[ctype];
        if (htype != nullptr) {
            return htype;
        }
        return "object";
    }

    fn isPrimitive(ctype) {
        let i = 0;
        while (i < len(self.primitive_types)) {
            if (self.primitive_types[i] == ctype) {
                return true;
            }
            i = i + 1;
        }
        return false;
    }

    fn getPrimitiveTypes() { return self.primitive_types; }

    fn getMappingCount() {
        let count = 0;
        for k in self.type_map {
            if (self.type_map[k] != nullptr) {
                count = count + 1;
            }
        }
        return count;
    }
}


class CppValue {
    let value = nullptr;
    let type_name = "void*";
    let is_null = true;
    let is_primitive = false;

    fn init_value(val, tn) {
        self.value = val;
        self.type_name = tn;
        self.is_null = (val == nullptr);
        self.is_primitive = false;
        return 0;
    }

    fn initFromValue(val) {
        self.value = val;
        self.type_name = "auto";
        self.is_null = (val == nullptr);
        self.is_primitive = false;
        return 0;
    }

    fn setPrimitive(p) { self.is_primitive = p; return 0; }
    fn setNull() { self.is_null = true; self.value = nullptr; return 0; }

    fn getValue() { return self.value; }
    fn getTypeName() { return self.type_name; }
    fn isNull() { return self.is_null; }

    fn asInt() {
        if (self.is_null) { return 0; }
        return self.value;
    }

    fn asFloat() {
        if (self.is_null) { return 0.0; }
        return self.value;
    }

    fn asString() {
        if (self.is_null) { return ""; }
        return self.value;
    }

    fn asBool() {
        if (self.is_null) { return false; }
        return self.value;
    }

    fn asList() {
        if (self.is_null) { return []; }
        return self.value;
    }

    fn asDict() {
        if (self.is_null) { return {}; }
        return self.value;
    }

    fn clone() {
        let cloned = new CppValue();
        cloned.init_value(self.value, self.type_name);
        cloned.is_primitive = self.is_primitive;
        return cloned;
    }
}


class CppInvoke {
    let method_name = "";
    let args = [];
    let is_static = false;
    let timeout = 30000;
    let is_getter = false;
    let is_setter = false;
    let property_name = "";
    let owner_object = nullptr;

    fn init_invoke(name) {
        self.method_name = name;
        self.args = [];
        self.is_static = false;
        self.timeout = 30000;
        self.is_getter = false;
        self.is_setter = false;
        self.property_name = "";
        self.owner_object = nullptr;
        return 0;
    }

    fn addArg(arg) { push(self.args, arg); return 0; }

    fn getMethodName() { return self.method_name; }
    fn getArgCount() { return len(self.args); }
    fn getArg(index) {
        if (index >= 0 and index < len(self.args)) {
            return self.args[index];
        }
        return nullptr;
    }
    fn isStatic() { return self.is_static; }
    fn setStatic(v) { self.is_static = v; return 0; }
    fn setTimeout(ms) { self.timeout = ms; return 0; }
    fn getTimeout() { return self.timeout; }
    fn setGetter(prop_name) {
        self.is_getter = true;
        self.property_name = prop_name;
        return 0;
    }
    fn getPropertyName() { return self.property_name; }
    fn setSetter(prop_name, value) {
        self.is_setter = true;
        self.property_name = prop_name;
        self.args = [value];
        return 0;
    }
    fn setSetterArgs(args) { self.args = args; return 0; }
    fn getOwnerObject() { return self.owner_object; }
    fn setOwnerObject(obj) { self.owner_object = obj; return 0; }
    fn setArgs(args) { self.args = args; return 0; }
    fn getArgs() { return self.args; }
}


class CppResult {
    let value = nullptr;
    let success = false;
    let error_message = "";
    let error_type = "";
    let stack_trace = "";
    let call_id = 0;
    let duration_ms = 0;
    let is_exception = false;

    fn init_result() {
        self.value = nullptr;
        self.success = false;
        self.error_message = "";
        self.error_type = "";
        self.stack_trace = "";
        self.call_id = 0;
        self.duration_ms = 0;
        self.is_exception = false;
        return 0;
    }

    fn setSuccess(val) {
        self.value = val;
        self.success = true;
        return 0;
    }

    fn setError(msg, etype) {
        self.error_message = msg;
        self.error_type = etype;
        self.success = false;
        self.is_exception = true;
        return 0;
    }

    fn setStackTrace(trace) { self.stack_trace = trace; return 0; }
    fn setCallId(id) { self.call_id = id; return 0; }
    fn setDuration(ms) { self.duration_ms = ms; return 0; }

    fn isSuccess() { return self.success; }
    fn isException() { return self.is_exception; }
    fn getValue() { return self.value; }
    fn getError() { return self.error_message; }
    fn getErrorType() { return self.error_type; }
    fn getCallId() { return self.call_id; }
    fn getStackTrace() { return self.stack_trace; }
    fn getDuration() { return self.duration_ms; }

    fn unwrap() {
        if (self.success == false) {
            print("CppError: " + self.error_message);
            return nullptr;
        }
        return self.value;
    }

    fn expect(msg) {
        if (self.success == false) {
            print("CppError: " + msg + " - " + self.error_message);
            return nullptr;
        }
        return self.value;
    }
}


# ═══════════════════════════════════════════════════════════════════════════
# Section 2: 对象桥接层 — 对象代理、类型描述、共享库
# ═══════════════════════════════════════════════════════════════════════════

class CppObject {
    let object_id = 0;
    let type_name = "";
    let is_disposed = false;
    let properties = {};
    let cached_methods = [];
    let cached_getters = [];
    let is_remote = false;
    let remote_endpoint = "";
    let metadata = {};

    fn init_object(obj_id, tn) {
        self.object_id = obj_id;
        self.type_name = tn;
        self.is_disposed = false;
        self.properties = {};
        self.cached_methods = [];
        self.cached_getters = [];
        self.is_remote = false;
        self.remote_endpoint = "";
        self.metadata = {};
        return 0;
    }

    fn setObjectId(id) { self.object_id = id; return 0; }
    fn getObjectId() { return self.object_id; }
    fn getTypeName() { return self.type_name; }
    fn isDisposed() { return self.is_disposed; }

    fn setProperty(name, value) {
        self.properties[name] = value;
        return 0;
    }

    fn getProperty(name) {
        return self.properties[name];
    }

    fn hasProperty(name) {
        return self.properties[name] != nullptr;
    }

    fn hasMethod(method_name) {
        let i = 0;
        while (i < len(self.cached_methods)) {
            if (self.cached_methods[i] == method_name) {
                return true;
            }
            i = i + 1;
        }
        return false;
    }

    fn isRemote() { return self.is_remote; }
    fn getRemoteEndpoint() { return self.remote_endpoint; }
    fn setRemoteEndpoint(endpoint) { self.remote_endpoint = endpoint; return 0; }

    fn dispose() {
        self.is_disposed = true;
        self.properties = {};
        self.cached_methods = [];
        self.cached_getters = [];
        return 0;
    }

    fn setMetadata(key, value) {
        self.metadata[key] = value;
        return 0;
    }

    fn getMetadata(key) {
        return self.metadata[key];
    }

    fn clearMetadata() {
        self.metadata = {};
        return 0;
    }

    fn addCachedMethod(method_name) {
        push(self.cached_methods, method_name);
        return 0;
    }

    fn addCachedGetter(prop_name) {
        push(self.cached_getters, prop_name);
        return 0;
    }

    fn getCachedMethods() { return self.cached_methods; }
    fn getCachedGetters() { return self.cached_getters; }
}


class CppObjectCache {
    let objects = {};
    let next_id = 0;

    fn init_cache() {
        self.objects = {};
        self.next_id = 0;
        return 0;
    }

    fn add(obj) {
        self.next_id = self.next_id + 1;
        obj.setObjectId(self.next_id);
        self.objects[self.next_id] = obj;
        return self.next_id;
    }

    fn get(id) {
        return self.objects[id];
    }

    fn getByType(type_name) {
        let result = [];
        for k in self.objects {
            let obj = self.objects[k];
            if (obj != nullptr and obj.getTypeName() == type_name) {
                push(result, obj);
            }
        }
        return result;
    }

    fn getCount() {
        let count = 0;
        for k in self.objects {
            if (self.objects[k] != nullptr) {
                count = count + 1;
            }
        }
        return count;
    }

    fn contains(id) {
        return self.objects[id] != nullptr;
    }

    fn remove(id) {
        let obj = self.objects[id];
        if (obj != nullptr) {
            obj.dispose();
        }
        self.objects[id] = nullptr;
        return 0;
    }

    fn clear() {
        for k in self.objects {
            let obj = self.objects[k];
            if (obj != nullptr) {
                obj.dispose();
            }
        }
        self.objects = {};
        self.next_id = 0;
        return 0;
    }

    fn getAll() {
        let result = [];
        for k in self.objects {
            if (self.objects[k] != nullptr) {
                push(result, self.objects[k]);
            }
        }
        return result;
    }

    fn getNextId() { return self.next_id; }
}


class CppSharedLib {
    let name = "";
    let version = "";
    let path = "";
    let is_loaded = false;
    let is_module = false;
    let module_name = "";
    let exported_types = [];
    let dependencies = [];

    fn init_lib(name, ver, path) {
        self.name = name;
        self.version = ver;
        self.path = path;
        self.is_loaded = false;
        self.is_module = false;
        self.module_name = "";
        self.exported_types = [];
        self.dependencies = [];
        return 0;
    }

    fn getName() { return self.name; }
    fn getVersion() { return self.version; }
    fn getPath() { return self.path; }
    fn isLoaded() { return self.is_loaded; }
    fn setLoaded(v) { self.is_loaded = v; return 0; }
    fn isModule() { return self.is_module; }
    fn getModuleName() { return self.module_name; }
    fn setModuleName(name) { self.module_name = name; return 0; }

    fn addType(type_info) {
        push(self.exported_types, type_info);
        return 0;
    }

    fn getType(type_name) {
        let i = 0;
        while (i < len(self.exported_types)) {
            let t = self.exported_types[i];
            if (t.getFullName() == type_name or t.getTypeName() == type_name) {
                return t;
            }
            i = i + 1;
        }
        return nullptr;
    }

    fn getTypeCount() { return len(self.exported_types); }

    fn addDependency(dep_name) {
        push(self.dependencies, dep_name);
        return 0;
    }

    fn getDependencies() { return self.dependencies; }
    fn getDependencyCount() { return len(self.dependencies); }

    fn removeType(type_name) {
        let new_types = [];
        let i = 0;
        while (i < len(self.exported_types)) {
            if (self.exported_types[i].getTypeName() != type_name) {
                push(new_types, self.exported_types[i]);
            }
            i = i + 1;
        }
        self.exported_types = new_types;
        return 0;
    }

    fn clear() {
        self.exported_types = [];
        self.dependencies = [];
        return 0;
    }
}


class CppLibLoader {
    let loaded_libs = {};
    let lib_count = 0;

    fn init_loader() {
        self.loaded_libs = {};
        self.lib_count = 0;
        return 0;
    }

    fn register(lib) {
        self.loaded_libs[lib.getName()] = lib;
        return 0;
    }

    fn load(name) {
        let lib = self.loaded_libs[name];
        if (lib != nullptr) {
            lib.setLoaded(true);
            self.lib_count = self.lib_count + 1;
        }
        return lib;
    }

    fn isLoaded(name) {
        let lib = self.loaded_libs[name];
        if (lib != nullptr) {
            return lib.isLoaded();
        }
        return false;
    }

    fn getLoadedCount() { return self.lib_count; }

    fn getLib(name) {
        return self.loaded_libs[name];
    }

    fn unload(name) {
        let lib = self.loaded_libs[name];
        if (lib != nullptr) {
            lib.setLoaded(false);
            self.lib_count = self.lib_count - 1;
        }
        return 0;
    }

    fn clear() {
        self.loaded_libs = {};
        self.lib_count = 0;
        return 0;
    }

    fn getAllLibs() {
        let result = [];
        for k in self.loaded_libs {
            if (self.loaded_libs[k] != nullptr) {
                push(result, self.loaded_libs[k]);
            }
        }
        return result;
    }

    fn getLibCount() {
        let count = 0;
        for k in self.loaded_libs {
            if (self.loaded_libs[k] != nullptr) {
                count = count + 1;
            }
        }
        return count;
    }
}


class CppConstructor {
    let param_types = [];
    let param_names = [];
    let is_default = false;
    let is_copy = false;
    let is_move = false;
    let is_explicit = false;

    fn init_ctor() {
        self.param_types = [];
        self.param_names = [];
        self.is_default = false;
        self.is_copy = false;
        self.is_move = false;
        self.is_explicit = false;
        return 0;
    }

    fn addParam(type, name) {
        push(self.param_types, type);
        push(self.param_names, name);
        return 0;
    }

    fn addParamType(type) { push(self.param_types, type); return 0; }
    fn addParamName(name) { push(self.param_names, name); return 0; }

    fn getParamType(index) {
        if (index >= 0 and index < len(self.param_types)) {
            return self.param_types[index];
        }
        return "";
    }

    fn getParamTypes() { return self.param_types; }
    fn getParamNames() { return self.param_names; }
    fn getParamCount() { return len(self.param_types); }

    fn isDefault() { return self.is_default; }
    fn setDefault(v) { self.is_default = v; return 0; }
    fn isCopy() { return self.is_copy; }
    fn setCopy(v) { self.is_copy = v; return 0; }
    fn isMove() { return self.is_move; }
    fn setMove(v) { self.is_move = v; return 0; }
    fn isExplicit() { return self.is_explicit; }
    fn setExplicit(v) { self.is_explicit = v; return 0; }
}


class CppMethod {
    let name = "";
    let return_type = "void";
    let param_types = [];
    let param_names = [];
    let is_static = false;
    let is_virtual = false;
    let is_const = false;
    let is_noexcept = false;
    let visibility = "public";
    let annotations = [];

    fn init_method(name, rtype) {
        self.name = name;
        self.return_type = rtype;
        self.param_types = [];
        self.param_names = [];
        self.is_static = false;
        self.is_virtual = false;
        self.is_const = false;
        self.is_noexcept = false;
        self.visibility = "public";
        self.annotations = [];
        return 0;
    }

    fn addParam(type, name) {
        push(self.param_types, type);
        push(self.param_names, name);
        return 0;
    }

    fn getName() { return self.name; }
    fn getReturnType() { return self.return_type; }
    fn getParamCount() { return len(self.param_types); }

    fn getParamType(index) {
        if (index >= 0 and index < len(self.param_types)) {
            return self.param_types[index];
        }
        return "";
    }

    fn getParamTypes() { return self.param_types; }
    fn getParamNames() { return self.param_names; }

    fn isStatic() { return self.is_static; }
    fn setStatic(v) { self.is_static = v; return 0; }
    fn isVirtual() { return self.is_virtual; }
    fn setVirtual(v) { self.is_virtual = v; return 0; }
    fn isConst() { return self.is_const; }
    fn setConst(v) { self.is_const = v; return 0; }
    fn isNoexcept() { return self.is_noexcept; }
    fn setNoexcept(v) { self.is_noexcept = v; return 0; }
    fn getVisibility() { return self.visibility; }
    fn setVisibility(v) { self.visibility = v; return 0; }

    fn addAnnotation(anno) { push(self.annotations, anno); return 0; }

    fn hasAnnotation(name) {
        let i = 0;
        while (i < len(self.annotations)) {
            if (self.annotations[i] == name) {
                return true;
            }
            i = i + 1;
        }
        return false;
    }

    fn getAnnotations() { return self.annotations; }
}


class CppField {
    let name = "";
    let type_name = "";
    let is_static = false;
    let is_const = false;
    let is_mutable = false;
    let is_volatile = false;
    let default_value = nullptr;
    let visibility = "public";
    let is_pointer = false;
    let is_reference = false;

    fn init_field(name, ftype) {
        self.name = name;
        self.type_name = ftype;
        self.is_static = false;
        self.is_const = false;
        self.is_mutable = false;
        self.is_volatile = false;
        self.default_value = nullptr;
        self.visibility = "public";
        self.is_pointer = false;
        self.is_reference = false;
        return 0;
    }

    fn getName() { return self.name; }
    fn getType() { return self.type_name; }
    fn isStatic() { return self.is_static; }
    fn setStatic(v) { self.is_static = v; return 0; }
    fn isConst() { return self.is_const; }
    fn setConst(v) { self.is_const = v; return 0; }
    fn isMutable() { return self.is_mutable; }
    fn setMutable(v) { self.is_mutable = v; return 0; }
    fn isVolatile() { return self.is_volatile; }
    fn setVolatile(v) { self.is_volatile = v; return 0; }
    fn getDefaultValue() { return self.default_value; }
    fn setDefaultValue(v) { self.default_value = v; return 0; }
    fn setVisibility(v) { self.visibility = v; return 0; }
    fn getVisibility() { return self.visibility; }
    fn isPointer() { return self.is_pointer; }
    fn setPointer(v) { self.is_pointer = v; return 0; }
    fn isReference() { return self.is_reference; }
    fn setReference(v) { self.is_reference = v; return 0; }
}


# ═══════════════════════════════════════════════════════════════════════════
# Section 3: 事件桥接层 — 跨运行时事件总线
# ═══════════════════════════════════════════════════════════════════════════

class CppEvent {
    let event_name = "";
    let listener_type = "";
    let listeners = [];
    let is_static = false;
    let is_remote = false;
    let remote_endpoint = "";
    let is_signal = false;

    fn init_event(name, ltype) {
        self.event_name = name;
        self.listener_type = ltype;
        self.listeners = [];
        self.is_static = false;
        self.is_remote = false;
        self.remote_endpoint = "";
        self.is_signal = false;
        return 0;
    }

    fn getName() { return self.event_name; }
    fn getListenerType() { return self.listener_type; }
    fn getListenerCount() { return len(self.listeners); }
    fn isStatic() { return self.is_static; }
    fn setStatic(v) { self.is_static = v; return 0; }
    fn isRemote() { return self.is_remote; }
    fn setRemote(v) { self.is_remote = v; return 0; }
    fn getRemoteEndpoint() { return self.remote_endpoint; }
    fn setRemoteEndpoint(endpoint) { self.remote_endpoint = endpoint; return 0; }

    fn addListener(listener) {
        push(self.listeners, listener);
        return 0;
    }

    fn removeListener(listener) {
        let new_listeners = [];
        let i = 0;
        while (i < len(self.listeners)) {
            if (self.listeners[i] != listener) {
                push(new_listeners, self.listeners[i]);
            }
            i = i + 1;
        }
        self.listeners = new_listeners;
        return 0;
    }

    fn getListeners() { return self.listeners; }

    fn clearListeners() {
        self.listeners = [];
        return 0;
    }

    fn isSignal() { return self.is_signal; }
    fn setSignal(v) { self.is_signal = v; return 0; }
}


class CppEventListener {
    let listener_id = 0;
    let event_name = "";
    let callback = nullptr;
    let is_oneshot = false;
    let filter_fn = nullptr;
    let is_active = true;

    fn init_listener(event_name, cb) {
        self.event_name = event_name;
        self.callback = cb;
        self.is_oneshot = false;
        self.filter_fn = nullptr;
        self.is_active = true;
        self.listener_id = 0;
        return 0;
    }

    fn setOneShot(v) { self.is_oneshot = v; return 0; }
    fn setFilter(filter_fn) { self.filter_fn = filter_fn; return 0; }
    fn setActive(v) { self.is_active = v; return 0; }
    fn setId(id) { self.listener_id = id; return 0; }

    fn getId() { return self.listener_id; }
    fn getEventName() { return self.event_name; }
    fn isActive() { return self.is_active; }
    fn isOneShot() { return self.is_oneshot; }

    fn onEvent(sender, args) {
        if (self.is_active == false) { return 0; }
        if (self.filter_fn != nullptr) {
            if (self.filter_fn(sender, args) == false) {
                return 0;
            }
        }
        if (self.callback != nullptr) {
            self.callback(sender, args);
        }
        if (self.is_oneshot) {
            self.is_active = false;
        }
        return 0;
    }
}


class CppCrossEventBus {
    let events = {};
    let remote_events = {};
    let listener_counter = 0;
    let bridge_enabled = false;

    fn init_cross_bus() {
        self.events = {};
        self.remote_events = {};
        self.listener_counter = 0;
        self.bridge_enabled = false;
        return 0;
    }

    fn subscribe(event_name, callback) {
        let evt = self.events[event_name];
        if (evt == nullptr) {
            evt = new CppEvent();
            evt.init_event(event_name, "CppEventListener");
            self.events[event_name] = evt;
        }
        let listener = new CppEventListener();
        listener.init_listener(event_name, callback);
        self.listener_counter = self.listener_counter + 1;
        listener.setId(self.listener_counter);
        evt.addListener(listener);
        return listener;
    }

    fn unsubscribe(event_name, listener) {
        let evt = self.events[event_name];
        if (evt != nullptr) {
            evt.removeListener(listener);
        }
        return 0;
    }

    fn publish(event_name, sender, args) {
        let evt = self.events[event_name];
        if (evt == nullptr) { return 0; }
        let listeners = evt.getListeners();
        let i = 0;
        while (i < len(listeners)) {
            listeners[i].onEvent(sender, args);
            i = i + 1;
        }
        return 0;
    }

    fn getEventCount() {
        let count = 0;
        for k in self.events {
            count = count + 1;
        }
        for k in self.remote_events {
            count = count + 1;
        }
        return count;
    }

    fn clearEvent(event_name) {
        let new_events = {};
        for k in self.events {
            if (k != event_name) {
                new_events[k] = self.events[k];
            }
        }
        self.events = new_events;
        let new_remote = {};
        for k in self.remote_events {
            if (k != event_name) {
                new_remote[k] = self.remote_events[k];
            }
        }
        self.remote_events = new_remote;
        return 0;
    }

    fn clear() {
        self.events = {};
        self.remote_events = {};
        self.listener_counter = 0;
        return 0;
    }

    fn enableBridge() {
        self.bridge_enabled = true;
        return 0;
    }

    fn disableBridge() {
        self.bridge_enabled = false;
        return 0;
    }

    fn isBridgeEnabled() { return self.bridge_enabled; }

    fn getListenerCount() { return self.listener_counter; }

    fn getEvent(event_name) {
        return self.events[event_name];
    }
}


class CppUIDispatcher {
    let invoke_queue = [];
    let is_processing = false;
    let main_thread_id = 0;
    let sync_context = nullptr;

    fn init_dispatcher() {
        self.invoke_queue = [];
        self.is_processing = false;
        self.main_thread_id = 0;
        self.sync_context = nullptr;
        return 0;
    }

    fn invoke(action) {
        push(self.invoke_queue, {"action": action, "sync": true, "result": nullptr, "done": false});
        return 0;
    }

    fn invokeLater(action) {
        push(self.invoke_queue, {"action": action, "sync": false, "result": nullptr, "done": false});
        return 0;
    }

    fn processQueue() {
        if (self.is_processing) { return 0; }
        self.is_processing = true;
        let i = 0;
        while (i < len(self.invoke_queue)) {
            let item = self.invoke_queue[i];
            if (item["done"] == false and item["action"] != nullptr) {
                item["action"]();
                item["done"] = true;
            }
            i = i + 1;
        }
        let new_q = [];
        i = 0;
        while (i < len(self.invoke_queue)) {
            if (self.invoke_queue[i]["done"] == false) {
                push(new_q, self.invoke_queue[i]);
            }
            i = i + 1;
        }
        self.invoke_queue = new_q;
        self.is_processing = false;
        return 0;
    }

    fn getQueueSize() { return len(self.invoke_queue); }
    fn clear() { self.invoke_queue = []; return 0; }
    fn setMainThread(id) { self.main_thread_id = id; return 0; }
    fn getMainThread() { return self.main_thread_id; }
    fn isProcessing() { return self.is_processing; }
}


# ═══════════════════════════════════════════════════════════════════════════
# Section 4: UI 桥接层 — zzwUI 控件 ↔ Qt/GTK 控件
# ═══════════════════════════════════════════════════════════════════════════

class ZzwUICppControlBridge {
    let hwidget = nullptr;
    let cpp_control = nullptr;
    let property_bindings = [];
    let event_bindings = [];
    let enabled = true;
    let sync_direction = "both";
    let is_syncing = false;

    fn init_bridge(hw, cc) {
        self.hwidget = hw;
        self.cpp_control = cc;
        self.property_bindings = [];
        self.event_bindings = [];
        self.enabled = true;
        self.sync_direction = "both";
        self.is_syncing = false;
        return 0;
    }

    fn bindProperty(hprop, cprop) {
        push(self.property_bindings, {"hsharp": hprop, "cpp": cprop});
        return 0;
    }

    fn bindEvent(hevent, cevent) {
        push(self.event_bindings, {"hsharp": hevent, "cpp": cevent});
        return 0;
    }

    fn getHWidget() { return self.hwidget; }
    fn getCppControl() { return self.cpp_control; }
    fn getPropertyBindings() { return self.property_bindings; }
    fn getEventBindings() { return self.event_bindings; }

    fn syncToCpp() {
        if (self.enabled == false) { return 0; }
        if (self.sync_direction == "hsharp_to_cpp" or self.sync_direction == "both") {
            self.is_syncing = true;
            let i = 0;
            while (i < len(self.property_bindings)) {
                let binding = self.property_bindings[i];
                let hprop = binding["hsharp"];
                let cprop = binding["cpp"];
                let val = self.hwidget[hprop];
                if (val != nullptr) {
                    self.cpp_control[cprop] = val;
                }
                i = i + 1;
            }
            self.is_syncing = false;
        }
        return 0;
    }

    fn syncToHSharp() {
        if (self.enabled == false) { return 0; }
        if (self.sync_direction == "cpp_to_hsharp" or self.sync_direction == "both") {
            self.is_syncing = true;
            let i = 0;
            while (i < len(self.property_bindings)) {
                let binding = self.property_bindings[i];
                let hprop = binding["hsharp"];
                let cprop = binding["cpp"];
                let val = self.cpp_control[cprop];
                if (val != nullptr) {
                    self.hwidget[hprop] = val;
                }
                i = i + 1;
            }
            self.is_syncing = false;
        }
        return 0;
    }

    fn syncBoth() {
        self.syncToCpp();
        self.syncToHSharp();
        return 0;
    }

    fn unbindProperty(hprop) {
        let new_bindings = [];
        let i = 0;
        while (i < len(self.property_bindings)) {
            if (self.property_bindings[i]["hsharp"] != hprop) {
                push(new_bindings, self.property_bindings[i]);
            }
            i = i + 1;
        }
        self.property_bindings = new_bindings;
        return 0;
    }

    fn unbindEvent(hevent) {
        let new_bindings = [];
        let i = 0;
        while (i < len(self.event_bindings)) {
            if (self.event_bindings[i]["hsharp"] != hevent) {
                push(new_bindings, self.event_bindings[i]);
            }
            i = i + 1;
        }
        self.event_bindings = new_bindings;
        return 0;
    }

    fn unbindAll() {
        self.property_bindings = [];
        self.event_bindings = [];
        return 0;
    }

    fn isEnabled() { return self.enabled; }
    fn setEnabled(v) { self.enabled = v; return 0; }
    fn setSyncDirection(dir) { self.sync_direction = dir; return 0; }
    fn getSyncDirection() { return self.sync_direction; }

    fn dispose() {
        self.unbindAll();
        self.hwidget = nullptr;
        self.cpp_control = nullptr;
        self.enabled = false;
        return 0;
    }
}


class CppWindowBridge {
    let hwindow = nullptr;
    let cpp_window = nullptr;
    let title_binding = false;
    let size_binding = false;
    let position_binding = false;
    let visibility_binding = false;
    let state_binding = false;

    fn init_win_bridge(hw, cw) {
        self.hwindow = hw;
        self.cpp_window = cw;
        self.title_binding = false;
        self.size_binding = false;
        self.position_binding = false;
        self.visibility_binding = false;
        self.state_binding = false;
        return 0;
    }

    fn bindTitle() {
        self.title_binding = true;
        return 0;
    }

    fn bindSize() {
        self.size_binding = true;
        return 0;
    }

    fn bindPosition() {
        self.position_binding = true;
        return 0;
    }

    fn bindVisibility() {
        self.visibility_binding = true;
        return 0;
    }

    fn bindState() {
        self.state_binding = true;
        return 0;
    }

    fn syncTitle() {
        if (self.title_binding and self.hwindow != nullptr and self.cpp_window != nullptr) {
            self.hwindow["title"] = self.cpp_window["title"];
        }
        return 0;
    }

    fn syncSize() {
        if (self.size_binding and self.hwindow != nullptr and self.cpp_window != nullptr) {
            self.hwindow["width"] = self.cpp_window["width"];
            self.hwindow["height"] = self.cpp_window["height"];
        }
        return 0;
    }

    fn syncPosition() {
        if (self.position_binding and self.hwindow != nullptr and self.cpp_window != nullptr) {
            self.hwindow["x"] = self.cpp_window["x"];
            self.hwindow["y"] = self.cpp_window["y"];
        }
        return 0;
    }

    fn syncAll() {
        self.syncTitle();
        self.syncSize();
        self.syncPosition();
        return 0;
    }

    fn getHWindow() { return self.hwindow; }
    fn getCppWindow() { return self.cpp_window; }
    fn isTitleBound() { return self.title_binding; }
    fn isSizeBound() { return self.size_binding; }
    fn isPositionBound() { return self.position_binding; }
    fn isVisibilityBound() { return self.visibility_binding; }
    fn isStateBound() { return self.state_binding; }

    fn unbindAll() {
        self.title_binding = false;
        self.size_binding = false;
        self.position_binding = false;
        self.visibility_binding = false;
        self.state_binding = false;
        return 0;
    }

    fn dispose() {
        self.unbindAll();
        self.hwindow = nullptr;
        self.cpp_window = nullptr;
        return 0;
    }
}


class CppUIHost {
    let parent = nullptr;
    let widgets = [];
    let is_active = false;
    let layout_engine = "zzwUI";
    let renderer = "default";

    fn init_host(parent) {
        self.parent = parent;
        self.widgets = [];
        self.is_active = false;
        self.layout_engine = "zzwUI";
        self.renderer = "default";
        return 0;
    }

    fn hostWidget(widget, wtype) {
        push(self.widgets, {"widget": widget, "type": wtype});
        return 0;
    }

    fn removeWidget(widget) {
        let new_widgets = [];
        let i = 0;
        while (i < len(self.widgets)) {
            if (self.widgets[i]["widget"] != widget) {
                push(new_widgets, self.widgets[i]);
            }
            i = i + 1;
        }
        self.widgets = new_widgets;
        return 0;
    }

    fn getWidgets() { return self.widgets; }
    fn getWidgetCount() { return len(self.widgets); }
    fn activate() { self.is_active = true; return 0; }
    fn deactivate() { self.is_active = false; return 0; }
    fn isActive() { return self.is_active; }
    fn setLayoutEngine(engine) { self.layout_engine = engine; return 0; }
    fn getLayoutEngine() { return self.layout_engine; }
    fn setRenderer(renderer) { self.renderer = renderer; return 0; }
    fn getRenderer() { return self.renderer; }

    fn clear() {
        self.widgets = [];
        return 0;
    }

    fn dispose() {
        self.clear();
        self.parent = nullptr;
        self.is_active = false;
        return 0;
    }
}


class CppControlFactory {
    let type_map = {};
    let widget_types = {};

    fn init_factory() {
        self.type_map = {};
        self.widget_types = {};
        self._register_defaults();
        return 0;
    }

    fn _register_defaults() {
        self.register("Button", "QPushButton", "Qt");
        self.register("Label", "QLabel", "Qt");
        self.register("TextBox", "QLineEdit", "Qt");
        self.register("TextArea", "QTextEdit", "Qt");
        self.register("CheckBox", "QCheckBox", "Qt");
        self.register("RadioButton", "QRadioButton", "Qt");
        self.register("Slider", "QSlider", "Qt");
        self.register("ProgressBar", "QProgressBar", "Qt");
        self.register("ListView", "QListView", "Qt");
        self.register("ComboBox", "QComboBox", "Qt");
        self.register("ScrollView", "QScrollArea", "Qt");
        self.register("TabControl", "QTabWidget", "Qt");
        self.register("TreeView", "QTreeView", "Qt");
        self.register("Menu", "QMenuBar", "Qt");
        self.register("ImageView", "QLabel", "Qt");
        self.register("Pane", "QWidget", "Qt");
        self.register("Grid", "QGridLayout", "Qt");
        self.register("HBox", "QHBoxLayout", "Qt");
        self.register("VBox", "QVBoxLayout", "Qt");
        self.register("SplitPane", "QSplitter", "Qt");
        self.register("ToggleButton", "QPushButton", "Qt");
        self.register("PasswordField", "QLineEdit", "Qt");
        return 0;
    }

    fn register(hwtype, cpptype, framework) {
        self.type_map[hwtype] = {"cpp": cpptype, "framework": framework};
        self.widget_types[hwtype] = framework;
        return 0;
    }

    fn getCppType(hwtype) {
        let info = self.type_map[hwtype];
        if (info != nullptr) {
            return info["cpp"];
        }
        return nullptr;
    }

    fn getFramework(hwtype) {
        return self.widget_types[hwtype];
    }

    fn hasType(hwtype) {
        return self.type_map[hwtype] != nullptr;
    }

    fn getSupportedTypes() {
        let types = [];
        for k in self.type_map {
            push(types, k);
        }
        return types;
    }

    fn getSupportedFrameworks() {
        let frameworks = [];
        for k in self.widget_types {
            let fw = self.widget_types[k];
            let found = false;
            let i = 0;
            while (i < len(frameworks)) {
                if (frameworks[i] == fw) {
                    found = true;
                }
                i = i + 1;
            }
            if (found == false) {
                push(frameworks, fw);
            }
        }
        return frameworks;
    }

    fn createControl(hwtype) {
        let cpptype = self.getCppType(hwtype);
        if (cpptype == nullptr) {
            return nullptr;
        }
        return {"__type__": cpptype, "widget_type": hwtype};
    }

    fn removeType(hwtype) {
        self.type_map[hwtype] = nullptr;
        self.widget_types[hwtype] = nullptr;
        return 0;
    }

    fn getTypeCount() {
        let count = 0;
        for k in self.type_map {
            if (self.type_map[k] != nullptr) {
                count = count + 1;
            }
        }
        return count;
    }

    fn clear() {
        self.type_map = {};
        self.widget_types = {};
        return 0;
    }
}


# ═══════════════════════════════════════════════════════════════════════════
# Section 5: 数据绑定层 — 双向绑定
# ═══════════════════════════════════════════════════════════════════════════

class CppBinding {
    let source = nullptr;
    let source_path = "";
    let target = nullptr;
    let target_path = "";
    let mode = "twoWay";
    let converter = nullptr;
    let converter_param = nullptr;
    let fallback_value = nullptr;
    let is_active = true;
    let property_notifier = nullptr;

    fn init_binding(src, spath, tgt, tpath) {
        self.source = src;
        self.source_path = spath;
        self.target = tgt;
        self.target_path = tpath;
        self.mode = "twoWay";
        self.converter = nullptr;
        self.converter_param = nullptr;
        self.fallback_value = nullptr;
        self.is_active = true;
        self.property_notifier = nullptr;
        return 0;
    }

    fn getSource() { return self.source; }
    fn getSourcePath() { return self.source_path; }
    fn getTarget() { return self.target; }
    fn getTargetPath() { return self.target_path; }
    fn getMode() { return self.mode; }
    fn setMode(m) { self.mode = m; return 0; }

    fn updateTarget() {
        if (self.is_active == false) { return 0; }
        if (self.mode == "oneWayToSource") { return 0; }
        let val = self.source[self.source_path];
        if (val == nullptr) {
            val = self.fallback_value;
        }
        if (self.converter != nullptr) {
            val = self.converter(val, self.converter_param);
        }
        self.target[self.target_path] = val;
        return 0;
    }

    fn updateSource() {
        if (self.is_active == false) { return 0; }
        if (self.mode == "oneWay") { return 0; }
        let val = self.target[self.target_path];
        if (self.converter != nullptr) {
            val = self.converter(val, self.converter_param);
        }
        self.source[self.source_path] = val;
        return 0;
    }

    fn setConverter(c) { self.converter = c; return 0; }
    fn getConverter() { return self.converter; }
    fn setConverterParam(p) { self.converter_param = p; return 0; }
    fn setFallbackValue(v) { self.fallback_value = v; return 0; }
    fn getFallbackValue() { return self.fallback_value; }
    fn isActive() { return self.is_active; }
    fn setActive(v) { self.is_active = v; return 0; }
    fn setPropertyNotifier(notifier) { self.property_notifier = notifier; return 0; }
    fn getPropertyNotifier() { return self.property_notifier; }

    fn dispose() {
        self.source = nullptr;
        self.target = nullptr;
        self.converter = nullptr;
        self.is_active = false;
        return 0;
    }
}


class CppMultiBinding {
    let target = nullptr;
    let target_path = "";
    let bindings = [];
    let converter = nullptr;
    let values = [];

    fn init_multi(target, tpath) {
        self.target = target;
        self.target_path = tpath;
        self.bindings = [];
        self.converter = nullptr;
        self.values = [];
        return 0;
    }

    fn addBinding(binding) {
        push(self.bindings, binding);
        return 0;
    }

    fn removeBinding(binding) {
        let new_bindings = [];
        let i = 0;
        while (i < len(self.bindings)) {
            if (self.bindings[i] != binding) {
                push(new_bindings, self.bindings[i]);
            }
            i = i + 1;
        }
        self.bindings = new_bindings;
        return 0;
    }

    fn getBindings() { return self.bindings; }
    fn getBindingCount() { return len(self.bindings); }
    fn setConverter(c) { self.converter = c; return 0; }
    fn getConverter() { return self.converter; }
    fn getTarget() { return self.target; }
    fn getTargetPath() { return self.target_path; }

    fn updateTarget() {
        self.values = [];
        let i = 0;
        while (i < len(self.bindings)) {
            let b = self.bindings[i];
            let val = b.getSource()[b.getSourcePath()];
            push(self.values, val);
            i = i + 1;
        }
        if (self.converter != nullptr) {
            let result = self.converter(self.values);
            self.target[self.target_path] = result;
        }
        return 0;
    }

    fn getValues() { return self.values; }

    fn dispose() {
        self.bindings = [];
        self.target = nullptr;
        self.converter = nullptr;
        self.values = [];
        return 0;
    }
}


class CppBindingManager {
    let bindings = [];
    let deferred_updates = [];
    let is_deferred = false;
    let update_count = 0;

    fn init_binding_mgr() {
        self.bindings = [];
        self.deferred_updates = [];
        self.is_deferred = false;
        self.update_count = 0;
        return 0;
    }

    fn addBinding(binding) {
        push(self.bindings, binding);
        return 0;
    }

    fn removeBinding(binding) {
        let new_bindings = [];
        let i = 0;
        while (i < len(self.bindings)) {
            if (self.bindings[i] != binding) {
                push(new_bindings, self.bindings[i]);
            }
            i = i + 1;
        }
        self.bindings = new_bindings;
        return 0;
    }

    fn updateAll() {
        if (self.is_deferred) { return 0; }
        self.update_count = self.update_count + 1;
        let i = 0;
        while (i < len(self.bindings)) {
            self.bindings[i].updateTarget();
            i = i + 1;
        }
        return 0;
    }

    fn getBindingsForSource(src) {
        let result = [];
        let i = 0;
        while (i < len(self.bindings)) {
            if (self.bindings[i].getSource() == src) {
                push(result, self.bindings[i]);
            }
            i = i + 1;
        }
        return result;
    }

    fn getBindingsForTarget(tgt) {
        let result = [];
        let i = 0;
        while (i < len(self.bindings)) {
            if (self.bindings[i].getTarget() == tgt) {
                push(result, self.bindings[i]);
            }
            i = i + 1;
        }
        return result;
    }

    fn getBindingCount() { return len(self.bindings); }

    fn deferUpdates() {
        self.is_deferred = true;
        return 0;
    }

    fn flushDeferred() {
        self.is_deferred = false;
        self.updateAll();
        return 0;
    }

    fn isDeferred() { return self.is_deferred; }

    fn clear() {
        self.bindings = [];
        self.deferred_updates = [];
        self.update_count = 0;
        return 0;
    }

    fn dispose() {
        self.clear();
        return 0;
    }
}


class CppBindingExpression {
    let binding = nullptr;
    let target = nullptr;
    let target_property = "";
    let is_dirty = false;
    let expression_str = "";
    let last_value = nullptr;

    fn init_expr(binding, tgt, tprop) {
        self.binding = binding;
        self.target = tgt;
        self.target_property = tprop;
        self.is_dirty = false;
        self.expression_str = "";
        self.last_value = nullptr;
        return 0;
    }

    fn getBinding() { return self.binding; }
    fn getTarget() { return self.target; }
    fn getTargetProperty() { return self.target_property; }
    fn isDirty() { return self.is_dirty; }

    fn markDirty() {
        self.is_dirty = true;
        return 0;
    }

    fn refresh() {
        if (self.binding != nullptr) {
            self.binding.updateTarget();
        }
        self.is_dirty = false;
        return 0;
    }

    fn getLastValue() { return self.last_value; }
    fn setExpression(expr) { self.expression_str = expr; return 0; }
    fn getExpression() { return self.expression_str; }

    fn dispose() {
        self.binding = nullptr;
        self.target = nullptr;
        self.last_value = nullptr;
        return 0;
    }
}


