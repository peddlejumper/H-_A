class CppServiceHost {
    let host_name = "";
    let port = 0;
    let services = {};
    let endpoints = [];
    let is_running = false;
    let max_connections = 100;
    let protocol = "tcp";

    fn init_host(name, port) {
        self.host_name = name;
        self.port = port;
        self.services = {};
        self.endpoints = [];
        self.is_running = false;
        self.max_connections = 100;
        self.protocol = "tcp";
        return 0;
    }

    fn getHostName() { return self.host_name; }
    fn getPort() { return self.port; }
    fn isRunning() { return self.is_running; }

    fn start() {
        self.is_running = true;
        return 0;
    }

    fn stop() {
        self.is_running = false;
        return 0;
    }

    fn registerService(name, svc) {
        self.services[name] = svc;
        return 0;
    }

    fn hasService(name) {
        return self.services[name] != nullptr;
    }

    fn getService(name) {
        return self.services[name];
    }

    fn unregisterService(name) {
        self.services[name] = nullptr;
        return 0;
    }

    fn getServiceCount() {
        let count = 0;
        for k in self.services {
            if (self.services[k] != nullptr) {
                count = count + 1;
            }
        }
        return count;
    }

    fn setMaxConnections(max) { self.max_connections = max; return 0; }
    fn getMaxConnections() { return self.max_connections; }
    fn addEndpoint(endpoint) { push(self.endpoints, endpoint); return 0; }
    fn getEndpoints() { return self.endpoints; }
    fn setProtocol(proto) { self.protocol = proto; return 0; }
    fn getProtocol() { return self.protocol; }

    fn dispose() {
        self.services = {};
        self.endpoints = [];
        self.is_running = false;
        return 0;
    }
}


class CppRPCClient {
    let endpoint = "";
    let timeout = 30000;
    let is_connected = false;
    let auth_token = "";
    let call_count = 0;
    let serializer = nullptr;

    fn init_client(endpoint) {
        self.endpoint = endpoint;
        self.timeout = 30000;
        self.is_connected = false;
        self.auth_token = "";
        self.call_count = 0;
        self.serializer = nullptr;
        return 0;
    }

    fn getEndpoint() { return self.endpoint; }
    fn setTimeout(ms) { self.timeout = ms; return 0; }
    fn getTimeout() { return self.timeout; }
    fn setAuthToken(token) { self.auth_token = token; return 0; }
    fn getAuthToken() { return self.auth_token; }
    fn isConnected() { return self.is_connected; }

    fn connect() {
        self.is_connected = true;
        return 0;
    }

    fn disconnect() {
        self.is_connected = false;
        return 0;
    }

    fn call(method, args) {
        self.call_count = self.call_count + 1;
        let result = new CppResult();
        result.init_result();
        result.setCallId(self.call_count);
        result.setSuccess(nullptr);
        return result;
    }

    fn getCallCount() { return self.call_count; }
    fn setSerializer(s) { self.serializer = s; return 0; }
    fn getSerializer() { return self.serializer; }

    fn dispose() {
        self.disconnect();
        self.serializer = nullptr;
        return 0;
    }
}


