# Section 13: Global Functions & Init Tests
# ═══════════════════════════════════════════════════════════════════════════

fn test_global_init() {
    dotnet_init();
    let ready = dotnet_is_ready();
    assert(ready == true, "dotnet_is_ready after init");
    return 0;
}

fn test_global_getters() {
    let m = dotnet_get_mapper();
    assert(m != nullptr, "dotnet_get_mapper");
    let c = dotnet_get_cache();
    assert(c != nullptr, "dotnet_get_cache");
    let eb = dotnet_get_event_bus();
    assert(eb != nullptr, "dotnet_get_event_bus");
    let bm = dotnet_get_binding_manager();
    assert(bm != nullptr, "dotnet_get_binding_manager");
    let s = dotnet_get_serializer();
    assert(s != nullptr, "dotnet_get_serializer");
    let d = dotnet_get_deserializer();
    assert(d != nullptr, "dotnet_get_deserializer");
    let tc = dotnet_get_type_converter();
    assert(tc != nullptr, "dotnet_get_type_converter");
    let log = dotnet_get_logger();
    assert(log != nullptr, "dotnet_get_logger");
    let prof = dotnet_get_profiler();
    assert(prof != nullptr, "dotnet_get_profiler");
    let cfg = dotnet_get_config();
    assert(cfg != nullptr, "dotnet_get_config");
    let env = dotnet_get_env();
    assert(env != nullptr, "dotnet_get_env");
    let al = dotnet_get_assembly_loader();
    assert(al != nullptr, "dotnet_get_assembly_loader");
    let cf = dotnet_get_control_factory();
    assert(cf != nullptr, "dotnet_get_control_factory");
    let sb = dotnet_get_style_bridge();
    assert(sb != nullptr, "dotnet_get_style_bridge");
    let xm = dotnet_get_xaml();
    assert(xm != nullptr, "dotnet_get_xaml");
    let rm = dotnet_get_resource_manager();
    assert(rm != nullptr, "dotnet_get_resource_manager");
    let ng = dotnet_get_nuget();
    assert(ng != nullptr, "dotnet_get_nuget");
    let ts = dotnet_get_task_scheduler();
    assert(ts != nullptr, "dotnet_get_task_scheduler");
    let ver = dotnet_get_version();
    assert(ver == "1.0.0", "dotnet_get_version");
    return 0;
}

fn test_global_shutdown() {
    dotnet_shutdown();
    let ready = dotnet_is_ready();
    assert(ready == false, "dotnet_is_ready after shutdown");
    return 0;
}

