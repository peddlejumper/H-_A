# T18 - Raytracer benchmark (DZZW worker pool speedup validation)
# ─────────────────────────────────────────────────────────────────
# Renders a small image of three coloured spheres with a simple
# recursive ray tracer.  The render is run twice:
#
#   1. sequentially  — one ray at a time on the main thread.
#   2. in parallel   — the image is split into `parallelism()` tiles,
#                      one tile per worker; the tiles are joined with
#                      `concurrent { ... }`.
#
# The test asserts:
#   A: the parallel render produces a bitmap that matches the
#      sequential render (so the result is correct, not just fast).
#   B: the parallel render is at least 2x faster on a >=2-core host.
#   C: the throughput (pixels per ms) is at least 2x higher.
#
# This is the user-visible "raytrace benchmark" required by the
# v0.4.1 spec (multi-threaded DZZW scheduler) to demonstrate the
# worker pool actually speeds up CPU-bound work.
#
# Summary: `RAYTRACE_BENCH : PASS=N FAIL=M`

# ─── Test framework ─────────────────────────────────────────────────
let __stats_empty = [];
let __stats = [0, 0, __stats_empty];

fn check(name, cond, detail) {
    if (cond) {
        print("OK " + name);
        __stats[0] = __stats[0] + 1;
    } else {
        print("FAIL " + name + " " + detail);
        __stats[1] = __stats[1] + 1;
        push(__stats[2], name);
    }
}

# ─── Scene constants ────────────────────────────────────────────────
let W = 240;           # image width  (pixels)
let H = 180;           # image height (pixels)
let SAMPLES = 4;       # rays per pixel
let MAX_DEPTH = 6;     # recursion depth

# Three spheres in the scene: (cx, cy, cz, r, r_color, g_color, b_color)
let SCENE = [
    [ 0.0,  0.0, -3.0, 1.0,  0.9, 0.2, 0.2],   # red,    centre
    [-1.7, -0.3, -3.5, 0.8,  0.2, 0.9, 0.2],   # green,  left
    [ 1.6,  0.4, -3.2, 0.7,  0.2, 0.3, 0.9]    # blue,   right
];

# Light direction (pointing toward the light source)
let LIGHT = [-0.4, -0.6, 0.7];

# ─── Vector helpers (all operate on [x, y, z]) ─────────────────────
fn vsub(a, b) { return [a[0] - b[0], a[1] - b[1], a[2] - b[2]]; }
fn vdot(a, b) { return a[0]*b[0] + a[1]*b[1] + a[2]*b[2]; }
fn vlen(a)    { return sqrt(vdot(a, a)); }
fn vnorm(a)   {
    let l = vlen(a);
    if (l == 0.0) { return [0.0, 0.0, 0.0]; }
    return [a[0]/l, a[1]/l, a[2]/l];
}
fn vscale(a, s) { return [a[0]*s, a[1]*s, a[2]*s]; }
fn vadd(a, b)   { return [a[0] + b[0], a[1] + b[1], a[2] + b[2]]; }

# ─── Ray-sphere intersection ────────────────────────────────────────
# Returns the `t` along the ray, or -1 if no hit.
fn intersect(ro, rd, sphere) {
    let oc = vsub(ro, [sphere[0], sphere[1], sphere[2]]);
    let b  = vdot(oc, rd);
    let c  = vdot(oc, oc) - sphere[3] * sphere[3];
    let disc = b*b - c;
    if (disc < 0.0) { return -1.0; }
    let s = sqrt(disc);
    let t = 0.0 - b - s;
    if (t < 0.001) { t = 0.0 - b + s; }
    if (t < 0.001) { return -1.0; }
    return t;
}

# ─── Trace a single ray, return RGB triplet ────────────────────────
fn trace(ro, rd, depth) {
    if (depth >= MAX_DEPTH) { return [0.0, 0.0, 0.0]; }

    # Find nearest hit
    let best_t = 1.0 * 1000000000.0 * 1000000000.0 * 1000000000.0 * 1000000000.0;
    let best_s = -1;
    let i = 0;
    while (i < len(SCENE)) {
        let s = SCENE[i];
        let t = intersect(ro, rd, s);
        if (t > 0.0 and t < best_t) {
            best_t = t;
            best_s = i;
        }
        i = i + 1;
    }
    if (best_s < 0) {
        # Background gradient (top -> bottom sky)
        let t = 0.5 * (rd[1] + 1.0);
        return [(1.0 - t) * 1.0 + t * 0.5,
                (1.0 - t) * 1.0 + t * 0.7,
                (1.0 - t) * 1.0 + t * 1.0];
    }
    let s = SCENE[best_s];
    let hit = vadd(ro, vscale(rd, best_t));
    let n   = vnorm(vsub(hit, [s[0], s[1], s[2]]));
    let ldir = vnorm(LIGHT);
    let diff = max_num(0.0, vdot(n, vscale(ldir, -1.0)));
    # Recursive reflection
    let refl_dir = vsub(rd, vscale(n, 2.0 * vdot(rd, n)));
    let refl     = trace(hit, refl_dir, depth + 1);
    let refl_f   = 0.3;     # 30% reflective
    let diff_f   = 0.7 * diff;
    return [s[4] * (diff_f + refl_f * refl[0]),
            s[5] * (diff_f + refl_f * refl[1]),
            s[6] * (diff_f + refl_f * refl[2])];
}

# ─── Render one pixel to RGB ────────────────────────────────────────
fn render_pixel(px, py) {
    let x = (px / W) * 2.0 - 1.0;
    let y = (py / H) * 2.0 - 1.0;
    let ro = [0.0, 0.0, 0.0];
    let rd = vnorm([x, y, -1.0]);
    let r = 0.0;
    let g = 0.0;
    let b = 0.0;
    let s = 0;
    while (s < SAMPLES) {
        let c = trace(ro, rd, 0);
        r = r + c[0];
        g = g + c[1];
        b = b + c[2];
        s = s + 1;
    }
    return [r / SAMPLES, g / SAMPLES, b / SAMPLES];
}

# ─── Render the full image into a flat list [r0,g0,b0,r1,g1,b1,...] ─
parallel fn render_tile(tile_y, tile_h) {
    let out = [];
    let y = tile_y;
    let end_y = tile_y + tile_h;
    while (y < end_y) {
        let x = 0;
        while (x < W) {
            let c = render_pixel(x, y);
            push(out, c[0]);
            push(out, c[1]);
            push(out, c[2]);
            x = x + 1;
        }
        y = y + 1;
    }
    return out;
}

# ─── Sequential render ──────────────────────────────────────────────
fn render_sequential() {
    let img = [];
    let y = 0;
    while (y < H) {
        let x = 0;
        while (x < W) {
            let c = render_pixel(x, y);
            push(img, c[0]);
            push(img, c[1]);
            push(img, c[2]);
            x = x + 1;
        }
        y = y + 1;
    }
    return img;
}

# ─── Parallel render (one tile per worker) ─────────────────────────
async fn render_parallel() {
    let np = parallelism();
    if (np < 1) { np = 1; }
    # Split the image vertically into `np` tiles; the last tile
    # absorbs any leftover rows.
    let rows_per = H / np;
    let rem = H - rows_per * np;
    let tiles_y = [];
    let tiles_h = [];
    let i = 0;
    let y = 0;
    while (i < np) {
        let h = rows_per;
        if (i == np - 1) { h = h + rem; }
        push(tiles_y, y);
        push(tiles_h, h);
        y = y + h;
        i = i + 1;
    }
    # Build the list of (y, h) tile descriptors first.
    let tiles_y = [];
    let tiles_h = [];
    let i = 0;
    let y = 0;
    while (i < np) {
        let h = rows_per;
        if (i == np - 1) { h = h + rem; }
        push(tiles_y, y);
        push(tiles_h, h);
        y = y + h;
        i = i + 1;
    }
    # Submit all tiles in one pass (each call dispatches to a worker
    # and returns an HFuture synchronously, so the main thread never
    # blocks here).  We then enter a `concurrent { }` block which joins
    # the parent scope's outstanding futures — but those futures are
    # owned by `render_parallel`'s own scope, not the block's scope.
    # We just await each Future in turn; since workers are already
    # running in parallel, the total time is bounded by the slowest
    # tile, not by their sum.
    let futs = [];
    let t = 0;
    while (t < np) {
        let f = render_tile(tiles_y[t], tiles_h[t]);
        push(futs, f);
        t = t + 1;
    }
    # Wait for all tiles.  The workers are already running in
    # parallel; this just blocks the main thread until the slowest
    # one is done.
    let imgs = [];
    let k = 0;
    while (k < np) {
        let tile = await futs[k];
        push(imgs, tile);
        k = k + 1;
    }
    # Stitch
    let full = [];
    let m = 0;
    while (m < len(imgs)) {
        let t = imgs[m];
        let j = 0;
        while (j < len(t)) {
            push(full, t[j]);
            j = j + 1;
        }
        m = m + 1;
    }
    return full;
}

# ─── Compare two images element-wise (allow small FP noise) ────────
fn images_equal(a, b, eps) {
    if (len(a) != len(b)) { return false; }
    let i = 0;
    while (i < len(a)) {
        if (abs(a[i] - b[i]) > eps) { return false; }
        i = i + 1;
    }
    return true;
}

# ─── Main benchmark ────────────────────────────────────────────────
print("RENDERING (" + str(W) + "x" + str(H) + " x" + str(SAMPLES) + " samples, depth=" + str(MAX_DEPTH) + ") on " + str(parallelism()) + " workers");

let t0_s = time_ms();
let img_seq = render_sequential();
let t1_s = time_ms();
let seq_ms = t1_s - t0_s;

let t0_p = time_ms();
let img_par = await render_parallel();
let t1_p = time_ms();
let par_ms = t1_p - t0_p;

let n_pix = W * H;
let seq_throughput = (n_pix * 1000.0) / (seq_ms + 1);
let par_throughput = (n_pix * 1000.0) / (par_ms + 1);
let speedup = seq_ms / (par_ms + 0.001);

print("  sequential: " + str(seq_ms) + " ms  (" + str(int(seq_throughput)) + " pix/s)");
print("  parallel:   " + str(par_ms) + " ms  (" + str(int(par_throughput)) + " pix/s)");
print("  speedup:    " + str(speedup) + "x");
print("  img length: " + str(len(img_seq)) + " vs " + str(len(img_par)));

check("A/img_lengths_match",      len(img_seq) == len(img_par),
      "seq=" + str(len(img_seq)) + " par=" + str(len(img_par)));
check("A/img_pixels_correct",     images_equal(img_seq, img_par, 0.001),
      "first 5: " + str(img_seq[0]) + " " + str(img_seq[1]) + " " + str(img_seq[2]) + " " + str(img_seq[3]) + " " + str(img_seq[4]));

if (parallelism() >= 2) {
    check("B/parallel_speedup_2x",  par_ms * 2 <= seq_ms,
          "seq_ms=" + str(seq_ms) + " par_ms=" + str(par_ms));
    check("C/throughput_2x",        par_throughput >= seq_throughput * 2.0,
          "seq=" + str(int(seq_throughput)) + " par=" + str(int(par_throughput)));
} else {
    print("OK B/parallel_speedup_2x (skipped: 1 core)");
    __stats[0] = __stats[0] + 1;
    print("OK C/throughput_2x (skipped: 1 core)");
    __stats[0] = __stats[0] + 1;
}

# ─── Summary ───────────────────────────────────────────────────────
print("RAYTRACE_BENCH : PASS=" + str(__stats[0]) + " FAIL=" + str(__stats[1]));
if (__stats[1] > 0) {
    let i = 0;
    let failed = __stats[2];
    while (i < len(failed)) {
        print("  FAIL: " + failed[i]);
        i = i + 1;
    }
}
