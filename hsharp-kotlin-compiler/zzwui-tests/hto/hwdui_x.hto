class SideBar extends zzwUI {
    let items = [];
    let selected_index = -1;
    let collapsed = false;
    let collapsed_width = 40;
    let expanded_width = 200;
    let logo = "";
    let onItemSelected = nullptr;
    let onCollapseChanged = nullptr;

    fn init_sb() {
        self.init("");
        self.widget_type = "SideBar";
        self.items = [];
        self.selected_index = -1;
        self.collapsed = false;
        self.collapsed_width = 40;
        self.expanded_width = 200;
        self.logo = "";
        self.width = self.expanded_width;
        return 0;
    }

    fn addItem(text, icon, callback) {
        push(self.items, {"text": text, "icon": icon, "callback": callback, "enabled": true});
        return len(self.items) - 1;
    }

    fn removeItem(index) {
        let new_items = [];
        let i = 0;
        while (i < len(self.items)) {
            if (i != index) { push(new_items, self.items[i]); }
            i = i + 1;
        }
        self.items = new_items;
        return 0;
    }

    fn selectItem(index) {
        if (index >= 0 and index < len(self.items)) {
            self.selected_index = index;
            if (self.onItemSelected != nullptr) { self.onItemSelected(self, index); }
        }
        return 0;
    }

    fn getSelectedIndex() { return self.selected_index; }

    fn getItemCount() { return len(self.items); }

    fn toggleCollapse() {
        self.collapsed = not self.collapsed;
        if (self.collapsed) { self.width = self.collapsed_width; }
        else { self.width = self.expanded_width; }
        if (self.onCollapseChanged != nullptr) { self.onCollapseChanged(self, self.collapsed); }
        return 0;
    }

    fn collapse() {
        if (self.collapsed == false) {
            self.collapsed = true;
            self.width = self.collapsed_width;
            if (self.onCollapseChanged != nullptr) { self.onCollapseChanged(self, true); }
        }
        return 0;
    }

    fn expand() {
        if (self.collapsed) {
            self.collapsed = false;
            self.width = self.expanded_width;
            if (self.onCollapseChanged != nullptr) { self.onCollapseChanged(self, false); }
        }
        return 0;
    }

    fn setLogo(l) { self.logo = l; return 0; }

    fn getLogo() { return self.logo; }

    fn setCollapsedWidth(w) { self.collapsed_width = w; return 0; }

    fn setExpandedWidth(w) { self.expanded_width = w; return 0; }

    fn setOnItemSelected(callback) { self.onItemSelected = callback; return 0; }

    fn setOnCollapseChanged(callback) { self.onCollapseChanged = callback; return 0; }

    fn setItemEnabled(index, enabled) {
        if (index >= 0 and index < len(self.items)) {
            self.items[index]["enabled"] = enabled;
        }
        return 0;
    }

    fn isItemEnabled(index) {
        if (index >= 0 and index < len(self.items)) {
            return self.items[index]["enabled"];
        }
        return false;
    }
}

