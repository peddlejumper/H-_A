        }
        return 0;
    }

    fn getTargetFPS() {
        return self._target_fps;
    }

    fn shouldFrame(current_time) {
        if (not self._throttle_enabled) { return true; }
        if (current_time - self._last_frame_time >= self._min_frame_time) {
            return true;
        }
        return false;
    }

    fn recordFrame(current_time) {
