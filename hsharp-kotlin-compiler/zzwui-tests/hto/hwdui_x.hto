    let multi_select = false;
    let show_header = true;
    let sort_column = -1;
    let sort_ascending = true;
    let onItemSelect = nullptr;
    let onItemDoubleClick = nullptr;

    fn init_lv() {
        self.init("");
        self.widget_type = "ListView";
        self.items = [];
        self.columns = [];
        self.view_mode = "details";
        self.selected_index = -1;
        return 0;
    }

    fn addColumn(title, width) {
        push(self.columns, {"title": title, "width": width});
        return 0;
    }

    fn addItem(item_data) { push(self.items, item_data); return 0; }

    fn addItems(data_list) {
        let i = 0;
        while (i < len(data_list)) {
            push(self.items, data_list[i]);
            i = i + 1;
        }
        return 0;
    }

    fn removeItem(index) {
        let new_items = [];
        let i = 0;
        while (i < len(self.items)) {
            if (i != index) { push(new_items, self.items[i]); }
            i = i + 1;
        }
        self.items = new_items;
        return 0;
    }

    fn clearItems() { self.items = []; self.selected_index = -1; return 0; }

    fn getItem(index) {
        if (index >= 0 and index < len(self.items)) { return self.items[index]; }
        return nullptr;
    }

    fn getItemCount() { return len(self.items); }

    fn getItems() { return self.items; }

    fn setItems(item_list) { self.items = item_list; return 0; }

    fn selectItem(index) {
        if (index >= 0 and index < len(self.items)) {
            self.selected_index = index;
            if (self.onItemSelect != nullptr) { self.onItemSelect(self, index); }
        }
        return 0;
    }

    fn getSelectedItem() {
        if (self.selected_index >= 0 and self.selected_index < len(self.items)) {
            return self.items[self.selected_index];
        }
        return nullptr;
    }

    fn getSelectedIndex() { return self.selected_index; }

    fn setViewMode(mode) { self.view_mode = mode; return 0; }

    fn setMultiSelect(ms) { self.multi_select = ms; return 0; }

    fn sortByColumn(col) { self.sort_column = col; self.sort_ascending = true; return 0; }

    fn setOnItemSelect(callback) { self.onItemSelect = callback; return 0; }

    fn setOnItemDoubleClick(callback) { self.onItemDoubleClick = callback; return 0; }

    fn scrollToItem(index) { return 0; }

    fn ensureVisible(index) { return 0; }
}

