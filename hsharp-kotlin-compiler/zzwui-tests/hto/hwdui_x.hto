class CreditCardInput extends zzwUI {
    let _number = "";
    let _masked = true;
    let _card_type = "";
    let _expiry = "";
    let _cvv = "";

    fn init_cci() {
        self.init(str(hwdui_next_id()));
        self.widget_type = "CreditCardInput";
        self.width = 250;
        self.height = 30;
        self._number = "";
        self._masked = true;
        self._card_type = "";
        self._expiry = "";
        self._cvv = "";
        return 0;
    }

    fn setNumber(num) { self._number = num; self._detectCardType(); return 0; }
    fn getNumber() { return self._number; }
    fn getMaskedNumber() { if (not self._masked) { return self._number; } if (len(self._number) < 4) { return "****"; } let masked = "****-****-****-"; let i = len(self._number) - 4; while (i < len(self._number)) { masked = masked + self._number[i]; i = i + 1; } return masked; }
    fn _detectCardType() { if (len(self._number) == 0) { self._card_type = ""; return 0; } if (self._number[0] == "4") { self._card_type = "Visa"; } else if (self._number[0] == "5") { self._card_type = "MasterCard"; } else if (self._number[0] == "3") { self._card_type = "Amex"; } else if (self._number[0] == "6") { self._card_type = "Discover"; } else { self._card_type = "Unknown"; } return 0; }
    fn getCardType() { return self._card_type; }
    fn setExpiry(expiry) { self._expiry = expiry; return 0; }
    fn getExpiry() { return self._expiry; }
    fn setCVV(cvv) { self._cvv = cvv; return 0; }
    fn getCVV() { return self._cvv; }
    fn setMasked(masked) { self._masked = masked; return 0; }
    fn isValid() { let digits = ""; let i = 0; while (i < len(self._number)) { let c = self._number[i]; if (c >= "0" and c <= "9") { digits = digits + c; } i = i + 1; } return len(digits) >= 13 and len(digits) <= 19; }
    fn clear() { self._number = ""; self._card_type = ""; self._expiry = ""; self._cvv = ""; return 0; }
}

