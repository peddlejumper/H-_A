            self._action(param);
        }
        return 0;
    }

    fn canExecute(param) {
        if (self._predicate != nullptr) {
            return self._predicate(param);
        }
        return true;
    }

    fn raiseCanExecuteChanged() {
        return 0;
    }
}

class DelegateCommand {
    let _delegate = nullptr;
    let _context = nullptr;

    fn init_dc(delegate_fn, context) {
        self._delegate = delegate_fn;
        self._context = context;
        return 0;
    }

    fn invoke(args) {
        if (self._delegate != nullptr) {
            return self._delegate(args);
        }
        return nullptr;
    }

    fn invokeWith(args) {
        let combined = {"args": args, "context": self._context};
        return self.invoke(combined);
    }

    fn bind(target) {
        self._context = target;
        return 0;
    }

    fn isBound() {
        return self._context != nullptr;
    }
}

class AsyncCommand {
    let _task = nullptr;
    let _is_running = false;
    let _on_complete = nullptr;
    let _on_error = nullptr;

    fn init_ac(task_fn, on_complete, on_error) {
        self._task = task_fn;
        self._on_complete = on_complete;
        self._on_error = on_error;
        self._is_running = false;
        return 0;
    }

    fn execute() {
        self._is_running = true;
        if (self._task != nullptr) {
            self._task();
        }
        return 0;
    }

    fn complete(result) {
        self._is_running = false;
        if (self._on_complete != nullptr) {
            self._on_complete(result);
        }
        return 0;
