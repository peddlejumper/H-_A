class PhoneNumberInput extends zzwUI {
    let _value = "";
    let _placeholder = "";
    let _format = "+X (XXX) XXX-XXXX";
    let _country_code = "+1";
    let _region = "US";
    let _max_length = 15;

    fn init_pni() {
        self.init(str(hwdui_next_id()));
        self.widget_type = "PhoneNumberInput";
        self.width = 200;
        self.height = 30;
        self._value = "";
        self._placeholder = "+1 (555) 000-0000";
        self._format = "+X (XXX) XXX-XXXX";
        self._country_code = "+1";
        self._region = "US";
        self._max_length = 15;
        return 0;
    }

    fn setValue(val) { self._value = val; return 0; }
    fn getValue() { return self._value; }
    fn setCountryCode(code) { self._country_code = code; return 0; }
    fn getCountryCode() { return self._country_code; }
    fn setRegion(reg) { self._region = reg; return 0; }
    fn getRegion() { return self._region; }

    fn getDigitsOnly() {
        let digits = "";
        let i = 0;
        while (i < len(self._value)) {
            let c = self._value[i];
            if (c >= "0" and c <= "9") { digits = digits + c; }
            i = i + 1;
        }
        return digits;
    }

    fn isValid() { let digits = self.getDigitsOnly(); return len(digits) >= 7 and len(digits) <= self._max_length; }
    fn clear() { self._value = ""; return 0; }
    fn setMaxLength(len_val) { self._max_length = len_val; return 0; }
}

