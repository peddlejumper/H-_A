# CircularProgress — 环形进度条
# ═══════════════════════════════════════════════════════════════════════════
class CircularProgress extends zzwUI {
    let value = 0;
    let max_value = 100;
    let show_text = true;

    fn init_circular() {
        self.init("");
        self.widget_type = "CircularProgress";
        self.value = 0;
        self.max_value = 100;
        self.show_text = true;
        return 0;
    }

    fn setValue(v) {
        if (v < 0) { v = 0; }
        if (v > self.max_value) { v = self.max_value; }
        self.value = v;
        return 0;
    }

    fn getValue() { return self.value; }

    fn setMaxValue(m) {
        self.max_value = m;
        return 0;
    }

    fn setShowText(show) {
        self.show_text = show;
        return 0;
    }

    fn getPercentage() {
        if (self.max_value <= 0) { return 0; }
        return (self.value * 100.0) / self.max_value;
    }
}

