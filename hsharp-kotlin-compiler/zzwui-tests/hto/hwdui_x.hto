class InputValidator {
    let _validators = [];
    let _error_message = "";
    let _is_valid = true;
    let _input_widget = nullptr;

    fn init_iv() {
        self._validators = [];
        self._error_message = "";
        self._is_valid = true;
        self._input_widget = nullptr;
        return 0;
    }

    fn addValidator(validator) {
        push(self._validators, validator);
        return 0;
    }

    fn removeValidator(validator) {
        let new_validators = [];
        let __iter86 = self._validators;
        let __i86 = 0;
        while (__i86 < len(__iter86)) {
            let v = __iter86[__i86];
            if (v != validator) { push(new_validators, v); }
            __i86 = __i86 + 1;
        }
        self._validators = new_validators;
        return 0;
    }

    fn validate(value) {
        self._is_valid = true;
        self._error_message = "";
        let i = 0;
        while (i < len(self._validators)) {
            let result = self._validators[i].validate(value);
            if (not result) {
                self._is_valid = false;
                self._error_message = self._validators[i].getErrorMessage();
                break;
            }
            i = i + 1;
        }
        return self._is_valid;
    }

    fn isValid() {
        return self._is_valid;
    }

    fn getErrorMessage() {
        return self._error_message;
    }

    fn setInputWidget(widget) {
        self._input_widget = widget;
        return 0;
    }

    fn getInputWidget() {
        return self._input_widget;
    }

    fn clearValidators() {
        self._validators = [];
        return 0;
    }

    fn getValidatorCount() {
        return len(self._validators);
    }
}

