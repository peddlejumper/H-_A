        }
        self.popups = new_popups;
        if (self.active_popup == popup) { self.active_popup = nullptr; }
        return 0;
    }

    fn showPopup(popup) {
        if (self.active_popup != nullptr and self.active_popup != popup) {
            self.active_popup.close();
        }
        self.active_popup = popup;
        popup.open();
        return 0;
    }

    fn closePopup(popup) {
        popup.close();
        if (self.active_popup == popup) { self.active_popup = nullptr; }
        return 0;
    }

    fn closeAll() {
        let i = 0;
        while (i < len(self.popups)) {
            self.popups[i].close();
            i = i + 1;
        }
        self.active_popup = nullptr;
        return 0;
    }

    fn getActivePopup() { return self.active_popup; }

    fn getPopupCount() { return len(self.popups); }

    fn setCloseOnOutsideClick(coc) { self.close_on_outside_click = coc; return 0; }

    fn isPopupOpen() {
        if (self.active_popup != nullptr and self.active_popup.is_open) { return true; }
        return false;
    }
}

class ScreenManager {
    let screen_width = 1024;
    let screen_height = 768;
    let dpi = 96;
    let color_depth = 24;
    let refresh_rate = 60;
    let is_high_dpi = false;

    fn init_scm() {
        self.screen_width = 1024;
        self.screen_height = 768;
        self.dpi = 96;
        self.color_depth = 24;
        self.refresh_rate = 60;
        self.is_high_dpi = false;
        return 0;
    }

    fn getScreenSize() {
        return {"width": self.screen_width, "height": self.screen_height};
    }

    fn getScreenWidth() { return self.screen_width; }

    fn getScreenHeight() { return self.screen_height; }

    fn getDpi() { return self.dpi; }

    fn getDpiScale() { return self.dpi * 100 / 96; }

    fn setDpi(d) { self.dpi = d; return 0; }

    fn getColorDepth() { return self.color_depth; }

    fn getRefreshRate() { return self.refresh_rate; }

    fn isHighDpi() { return self.is_high_dpi; }

    fn getWorkArea() {
        return {"x": 0, "y": 0, "width": self.screen_width, "height": self.screen_height - 40};
    }

    fn scalePixels(px) {
        return px * self.dpi / 96;
    }

    fn unscalePixels(px) {
        return px * 96 / self.dpi;
    }
}

