# ═══════════════════════════════════════════════════════════════════════════
# LinkLabel — 超链接标签
# ═══════════════════════════════════════════════════════════════════════════
class LinkLabel extends Label {
    let url = "";
    let visited = false;
    let onLinkClicked = nullptr;
    let underline = true;

    fn init_link(text, url) {
        self.init_label(text);
        self.widget_type = "LinkLabel";
        self.url = url;
        self.visited = false;
        self.underline = true;
        return 0;
    }

    fn setUrl(u) {
        self.url = u;
        return 0;
    }

    fn getUrl() { return self.url; }

    fn setVisited(v) {
        self.visited = v;
        return 0;
    }

    fn isVisited() { return self.visited; }

    fn setOnLinkClicked(callback) {
        self.onLinkClicked = callback;
        return 0;
    }

    fn click() {
        self.visited = true;
        if (self.onLinkClicked != nullptr) {
            self.onLinkClicked(self, self.url);
        }
        return 0;
    }

    fn setUnderline(u) {
        self.underline = u;
        return 0;
    }
}

# ═══════════════════════════════════════════════════════════════════════════
# Badge — 徽章/角标
# ═══════════════════════════════════════════════════════════════════════════
class Badge extends zzwUI {
    let count = 0;
    let max_count = 99;
    let show_zero = false;
    let badge_color = "#FF4444";

    fn init_badge() {
        self.init("");
        self.widget_type = "Badge";
        self.count = 0;
        self.max_count = 99;
        self.show_zero = false;
        self.width = 22;
        self.height = 22;
        return 0;
    }

    fn setCount(c) {
        if (c < 0) { c = 0; }
        self.count = c;
        return 0;
    }

    fn getCount() { return self.count; }

    fn increment() {
        self.count = self.count + 1;
        return 0;
    }

    fn decrement() {
        if (self.count > 0) {
            self.count = self.count - 1;
        }
        return 0;
    }

    fn getDisplayText() {
        if (self.count == 0) {
            if (self.show_zero) { return "0"; }
            return "";
        }
        if (self.count > self.max_count) {
            return self.max_count + "+";
        }
        return self.count;
    }

    fn setMaxCount(m) {
        self.max_count = m;
        return 0;
    }

    fn setShowZero(show) {
        self.show_zero = show;
        return 0;
    }

    fn setBadgeColor(color) {
        self.badge_color = color;
        return 0;
    }

    fn isVisible() {
        if (self.count == 0 and self.show_zero == false) { return false; }
        return true;
    }
}

# ═══════════════════════════════════════════════════════════════════════════
# DateTimePicker — 日期时间选择器
# ═══════════════════════════════════════════════════════════════════════════
class DateTimePicker extends zzwUI {
    let selected_date = "";
    let selected_time = "00:00";
    let use_24h = false;
    let onDateTimeChanged = nullptr;

    fn init_dtp() {
        self.init("");
        self.widget_type = "DateTimePicker";
        self.selected_date = "";
        self.selected_time = "00:00";
        self.use_24h = false;
        return 0;
    }

    fn setDate(date) {
        self.selected_date = date;
        self._notify();
        return 0;
    }

    fn setTime(time) {
        self.selected_time = time;
        self._notify();
        return 0;
    }

    fn setDateTime(date, time) {
        self.selected_date = date;
        self.selected_time = time;
        self._notify();
        return 0;
    }

    fn getDateTime() {
        return self.selected_date + " " + self.selected_time;
    }

    fn getDate() { return self.selected_date; }

    fn getTime() { return self.selected_time; }

    fn setUse24Hour(use) {
        self.use_24h = use;
        return 0;
    }

    fn is24Hour() { return self.use_24h; }

    fn setOnDateTimeChanged(callback) {
        self.onDateTimeChanged = callback;
        return 0;
    }

    fn _notify() {
        if (self.onDateTimeChanged != nullptr) {
            self.onDateTimeChanged(self, self.selected_date, self.selected_time);
        }
        return 0;
    }
}

# ═══════════════════════════════════════════════════════════════════════════
# TagInput — 标签输入
# ═══════════════════════════════════════════════════════════════════════════
class TagInput extends zzwUI {
    let tags = [];
    let max_tags = 0;
    let allow_duplicates = false;
    let onTagsChanged = nullptr;
    let onTagAdded = nullptr;
    let onTagRemoved = nullptr;

    fn init_taginput() {
        self.init("");
        self.widget_type = "TagInput";
        self.tags = [];
        self.max_tags = 0;
        self.allow_duplicates = false;
        return 0;
    }

    fn addTag(tag) {
        if (self.allow_duplicates == false) {
            let i = 0;
            while (i < len(self.tags)) {
                if (self.tags[i] == tag) { return 0; }
                i = i + 1;
            }
        }
        if (self.max_tags > 0 and len(self.tags) >= self.max_tags) { return 0; }
        push(self.tags, tag);
        if (self.onTagAdded != nullptr) {
            self.onTagAdded(self, tag);
        }
        if (self.onTagsChanged != nullptr) {
            self.onTagsChanged(self, self.tags);
        }
        return 0;
    }

    fn removeTag(tag) {
        let new_tags = [];
        let i = 0;
        while (i < len(self.tags)) {
            if (self.tags[i] != tag) {
                push(new_tags, self.tags[i]);
            }
            i = i + 1;
        }
        self.tags = new_tags;
        if (self.onTagRemoved != nullptr) {
            self.onTagRemoved(self, tag);
        }
        if (self.onTagsChanged != nullptr) {
            self.onTagsChanged(self, self.tags);
        }
        return 0;
    }

    fn removeTagAt(index) {
        if (index < 0 or index >= len(self.tags)) { return 0; }
        let tag = self.tags[index];
        let new_tags = [];
        let i = 0;
        while (i < len(self.tags)) {
            if (i != index) {
                push(new_tags, self.tags[i]);
            }
            i = i + 1;
        }
        self.tags = new_tags;
        if (self.onTagRemoved != nullptr) {
            self.onTagRemoved(self, tag);
        }
        if (self.onTagsChanged != nullptr) {
            self.onTagsChanged(self, self.tags);
        }
        return 0;
    }

    fn getTags() { return self.tags; }

    fn getTagCount() { return len(self.tags); }

    fn hasTag(tag) {
        let i = 0;
        while (i < len(self.tags)) {
            if (self.tags[i] == tag) { return true; }
            i = i + 1;
        }
        return false;
    }

    fn clearTags() {
        self.tags = [];
        if (self.onTagsChanged != nullptr) {
            self.onTagsChanged(self, self.tags);
        }
        return 0;
    }

    fn setMaxTags(max) {
        self.max_tags = max;
        return 0;
    }

    fn setAllowDuplicates(allow) {
        self.allow_duplicates = allow;
        return 0;
    }

    fn setOnTagsChanged(callback) {
        self.onTagsChanged = callback;
        return 0;
    }

    fn setOnTagAdded(callback) {
        self.onTagAdded = callback;
        return 0;
    }

    fn setOnTagRemoved(callback) {
        self.onTagRemoved = callback;
        return 0;
    }
}

# ═══════════════════════════════════════════════════════════════════════════
# BreadcrumbItem — 面包屑项
# ═══════════════════════════════════════════════════════════════════════════
class BreadcrumbItem {
    let text = "";
    let data = nullptr;
    let is_last = false;

    fn init_bcitem(text, data) {
        self.text = text;
        self.data = data;
        self.is_last = false;
        return 0;
    }
}

# ═══════════════════════════════════════════════════════════════════════════
# Breadcrumb — 面包屑导航
# ═══════════════════════════════════════════════════════════════════════════
class Breadcrumb extends zzwUI {
    let items = [];
    let separator = ">";
    let onItemClicked = nullptr;

    fn init_breadcrumb() {
        self.init("");
        self.widget_type = "Breadcrumb";
        self.items = [];
        self.separator = ">";
        self.height = 30;
        return 0;
    }

    fn addItem(text, data) {
        let item = new BreadcrumbItem();
        item.init_bcitem(text, data);
        push(self.items, item);
        self._updateLast();
        return 0;
    }

    fn removeLast() {
        if (len(self.items) > 0) {
            let new_items = [];
            let i = 0;
            while (i < len(self.items) - 1) {
                push(new_items, self.items[i]);
                i = i + 1;
            }
            self.items = new_items;
        }
        self._updateLast();
        return 0;
    }

    fn clear() {
        self.items = [];
        return 0;
    }

    fn setPath(path_parts) {
        self.items = [];
        let i = 0;
        while (i < len(path_parts)) {
            let item = new BreadcrumbItem();
            item.init_bcitem(path_parts[i], nullptr);
            push(self.items, item);
            i = i + 1;
        }
        self._updateLast();
        return 0;
    }

    fn getItemCount() { return len(self.items); }

    fn getItem(index) {
        if (index < 0 or index >= len(self.items)) { return nullptr; }
        return self.items[index];
    }

    fn setSeparator(sep) {
        self.separator = sep;
        return 0;
    }

    fn setOnItemClicked(callback) {
        self.onItemClicked = callback;
        return 0;
    }

    fn clickItem(index) {
        if (index < 0 or index >= len(self.items)) { return 0; }
        if (self.onItemClicked != nullptr) {
            self.onItemClicked(self, index, self.items[index]);
        }
        return 0;
    }

    fn _updateLast() {
        let i = 0;
        while (i < len(self.items)) {
            self.items[i].is_last = false;
            i = i + 1;
        }
        if (len(self.items) > 0) {
            self.items[len(self.items) - 1].is_last = true;
        }
        return 0;
    }
}

# ═══════════════════════════════════════════════════════════════════════════
# RichLabel — 富文本标签
# ═══════════════════════════════════════════════════════════════════════════
class RichLabel extends Label {
    let markup = "";
    let segments = [];

    fn init_rich(text) {
        self.init_label(text);
        self.widget_type = "RichLabel";
        self.markup = "";
        self.segments = [];
        return 0;
    }

    fn setMarkup(m) {
        self.markup = m;
        self._parseMarkup();
        return 0;
    }

    fn getMarkup() { return self.markup; }

    fn getSegments() { return self.segments; }

    fn getSegmentCount() { return len(self.segments); }

    fn getPlainText() {
        let result = "";
        let i = 0;
        while (i < len(self.segments)) {
            result = result + self.segments[i]["text"];
            i = i + 1;
        }
        return result;
    }

    fn _parseMarkup() {
        self.segments = [];
        let i = 0;
        let current_text = "";
        let current_style = {"bold": false, "italic": false, "color": "", "size": 0};
        let tag_stack = [];
        while (i < len(self.markup)) {
            let ch = self.markup[i];
            if (ch == "<") {
                if (current_text != "") {
                    let seg = {"text": current_text, "bold": current_style["bold"], "italic": current_style["italic"], "color": current_style["color"], "size": current_style["size"]};
                    push(self.segments, seg);
                    current_text = "";
                }
                let tag_end = self._findTagEnd(i);
                if (tag_end < 0) {
                    current_text = current_text + ch;
                    i = i + 1;
                } else {
                    let tag = "";
                    let ti = i + 1;
                    while (ti < tag_end) {
                        tag = tag + self.markup[ti];
                        ti = ti + 1;
                    }
                    let close = false;
                    if (tag[0] == "/") {
                        close = true;
                        let new_tag = "";
                        ti = 1;
                        while (ti < len(tag)) {
                            new_tag = new_tag + tag[ti];
                            ti = ti + 1;
                        }
                        tag = new_tag;
                    }
                    if (close) {
                        if (tag == "b") { current_style["bold"] = false; }
                        if (tag == "i") { current_style["italic"] = false; }
                        if (tag == "color") { current_style["color"] = ""; }
                        if (tag == "size") { current_style["size"] = 0; }
                        if (len(tag_stack) > 0) {
                            let new_stack = [];
                            ti = 0;
                            while (ti < len(tag_stack) - 1) {
                                push(new_stack, tag_stack[ti]);
                                ti = ti + 1;
                            }
                            tag_stack = new_stack;
                        }
                    } else {
                        push(tag_stack, tag);
                        if (tag == "b") { current_style["bold"] = true; }
                        if (tag == "i") { current_style["italic"] = true; }
                        if (tag == "color") {
                            let eq = self._findAttr(tag, "color");
                            if (eq != "") { current_style["color"] = eq; }
                        }
                        if (tag == "size") {
                            let eq = self._findAttr(tag, "size");
                            if (eq != "") { current_style["size"] = eq; }
                        }
                    }
                    i = tag_end + 1;
                }
            } else {
                current_text = current_text + ch;
                i = i + 1;
            }
        }
        if (current_text != "") {
            let seg = {"text": current_text, "bold": current_style["bold"], "italic": current_style["italic"], "color": current_style["color"], "size": current_style["size"]};
            push(self.segments, seg);
        }
        return 0;
    }

    fn _findTagEnd(start) {
        let j = start + 1;
        while (j < len(self.markup)) {
            if (self.markup[j] == ">") { return j; }
            j = j + 1;
        }
        return -1;
    }

    fn _findAttr(tag, attr_name) {
        let prefix = attr_name + "=";
        # manual find of __contains(tag, prefix)
        let idx = -1;
        let i = 0;
        while (i < len(tag)) {
            let j = 0;
            while (j < len(prefix) and i + j < len(tag) and tag[i + j] == prefix[j]) {
                j = j + 1;
            }
            if (j == len(prefix)) {
                idx = i;
                break;
            }
            i = i + 1;
        }
        if (idx < 0) { return ""; }
        let start = idx + len(prefix);
        if (tag[start] == "\"") {
            start = start + 1;
            # manual find of " from start
            let end = -1;
            i = start;
            while (i < len(tag)) {
                if (tag[i] == "\"") {
                    end = i;
                    break;
                }
                i = i + 1;
            }
            if (end < 0) { return ""; }
            # manual substring tag[start:end]
            let result = "";
            i = start;
            while (i < end) {
                result = result + tag[i];
                i = i + 1;
            }
            return result;
        }
        if (tag[start] == "'") {
            start = start + 1;
            # manual find of ' from start
            let end = -1;
            i = start;
            while (i < len(tag)) {
                if (tag[i] == "'") {
                    end = i;
                    break;
                }
                i = i + 1;
            }
            if (end < 0) { return ""; }
            # manual substring tag[start:end]
            let result = "";
            i = start;
            while (i < end) {
                result = result + tag[i];
                i = i + 1;
            }
            return result;
        }
        # manual find of " " from start
        let end = -1;
        i = start;
        while (i < len(tag)) {
            if (tag[i] == " ") {
                end = i;
                break;
            }
            i = i + 1;
        }
        if (end < 0) { end = len(tag); }
        # manual substring tag[start:end]
        let result = "";
        i = start;
        while (i < end) {
            result = result + tag[i];
            i = i + 1;
        }
        return result;
    }
}

# ═══════════════════════════════════════════════════════════════════════════
# EventBus — 事件总线（发布/订阅）
# ═══════════════════════════════════════════════════════════════════════════
class EventBus {
    let listeners = {};

    fn init_bus() {
        self.listeners = {};
        return 0;
    }

    fn on(event, callback) {
        let arr = self.listeners[event];
        if (arr == nullptr) {
            arr = [];
            self.listeners[event] = arr;
        }
        let wrapper = {"_cb": callback, "_once": false};
        push(arr, wrapper);
        return 0;
    }

    fn off(event, callback) {
        let arr = self.listeners[event];
        if (arr == nullptr) { return 0; }
        let new_arr = [];
        let i = 0;
        while (i < len(arr)) {
            if (arr[i]["_cb"] != callback) {
                push(new_arr, arr[i]);
            }
            i = i + 1;
        }
        self.listeners[event] = new_arr;
        return 0;
    }

    fn emit(event, data) {
        let arr = self.listeners[event];
        if (arr == nullptr) { return 0; }
        let i = 0;
        let to_remove = [];
        while (i < len(arr)) {
            let wrapper = arr[i];
            let cb = wrapper["_cb"];
            cb(event, data);
            if (wrapper["_once"] == true) {
                push(to_remove, i);
            }
            i = i + 1;
        }
        if (len(to_remove) > 0) {
            let new_arr = [];
            i = 0;
            while (i < len(arr)) {
                let keep = true;
                let j = 0;
                while (j < len(to_remove)) {
                    if (i == to_remove[j]) {
                        keep = false;
                        break;
                    }
                    j = j + 1;
                }
                if (keep) {
                    push(new_arr, arr[i]);
                }
                i = i + 1;
            }
            self.listeners[event] = new_arr;
        }
        return 0;
    }

    fn once(event, callback) {
        let arr = self.listeners[event];
        if (arr == nullptr) {
            arr = [];
            self.listeners[event] = arr;
        }
        let wrapper = {"_cb": callback, "_once": true};
        push(arr, wrapper);
        return 0;
    }

    fn clear() {
        self.listeners = {};
        return 0;
    }

    fn clearEvent(event) {
        self.listeners[event] = [];
        return 0;
    }

    fn hasListeners(event) {
        let arr = self.listeners[event];
        if (arr == nullptr) { return false; }
        return len(arr) > 0;
    }
}

# ═══════════════════════════════════════════════════════════════════════════
# Clipboard — 剪贴板
# ═══════════════════════════════════════════════════════════════════════════
class Clipboard {
    let content = "";
    let content_type = "text";
    let history = [];

    fn init_clipboard() {
        self.content = "";
        self.content_type = "text";
        self.history = [];
        return 0;
    }

    fn copy(text) {
        if (self.content != "") {
            push(self.history, {"content": self.content, "type": self.content_type});
        }
        self.content = text;
        self.content_type = "text";
        return 0;
    }

    fn copyWithType(text, ctype) {
        if (self.content != "") {
            push(self.history, {"content": self.content, "type": self.content_type});
        }
        self.content = text;
        self.content_type = ctype;
        return 0;
    }

    fn paste() { return self.content; }

    fn pasteWithType() {
        return {"content": self.content, "type": self.content_type};
    }

    fn getType() { return self.content_type; }

    fn clear() {
        self.content = "";
        self.content_type = "text";
        return 0;
    }

    fn hasContent() {
        return self.content != "";
    }

    fn getHistory() { return self.history; }

    fn getHistoryCount() { return len(self.history); }

    fn clearHistory() {
        self.history = [];
        return 0;
    }
}

# ═══════════════════════════════════════════════════════════════════════════
# UndoCommand — 撤销命令
# ═══════════════════════════════════════════════════════════════════════════
class UndoCommand {
    let description = "";
    let undo_fn = nullptr;
    let redo_fn = nullptr;
    let timestamp = 0;

    fn init_ucmd(desc, undo_fn, redo_fn) {
        self.description = desc;
        self.undo_fn = undo_fn;
        self.redo_fn = redo_fn;
        self.timestamp = 0;
        return 0;
    }
}

# ═══════════════════════════════════════════════════════════════════════════
# UndoRedo — 撤销/重做管理器
# ═══════════════════════════════════════════════════════════════════════════
class UndoRedo {
    let undo_stack = [];
    let redo_stack = [];
    let max_history = 50;
    let onStateChanged = nullptr;

    fn init_ur() {
        self.undo_stack = [];
        self.redo_stack = [];
        self.max_history = 50;
        return 0;
    }

    fn execute(description, undo_fn, redo_fn) {
        let cmd = new UndoCommand();
        cmd.init_ucmd(description, undo_fn, redo_fn);
        push(self.undo_stack, cmd);
        self.redo_stack = [];
        if (len(self.undo_stack) > self.max_history) {
            let new_stack = [];
            let i = 1;
            while (i < len(self.undo_stack)) {
                push(new_stack, self.undo_stack[i]);
                i = i + 1;
            }
            self.undo_stack = new_stack;
        }
        if (self.onStateChanged != nullptr) {
            self.onStateChanged(self);
        }
        return 0;
    }

    fn undo() {
        if (len(self.undo_stack) == 0) { return false; }
        let cmd = self.undo_stack[len(self.undo_stack) - 1];
        let new_stack = [];
        let i = 0;
        while (i < len(self.undo_stack) - 1) {
            push(new_stack, self.undo_stack[i]);
            i = i + 1;
        }
        self.undo_stack = new_stack;
        if (cmd.undo_fn != nullptr) {
            cmd.undo_fn();
        }
        push(self.redo_stack, cmd);
        if (self.onStateChanged != nullptr) {
            self.onStateChanged(self);
        }
        return true;
    }

    fn redo() {
        if (len(self.redo_stack) == 0) { return false; }
        let cmd = self.redo_stack[len(self.redo_stack) - 1];
        let new_stack = [];
        let i = 0;
        while (i < len(self.redo_stack) - 1) {
            push(new_stack, self.redo_stack[i]);
            i = i + 1;
        }
        self.redo_stack = new_stack;
        if (cmd.redo_fn != nullptr) {
            cmd.redo_fn();
        }
        push(self.undo_stack, cmd);
        if (self.onStateChanged != nullptr) {
            self.onStateChanged(self);
        }
        return true;
    }

    fn canUndo() { return len(self.undo_stack) > 0; }

    fn canRedo() { return len(self.redo_stack) > 0; }

    fn getUndoCount() { return len(self.undo_stack); }

    fn getRedoCount() { return len(self.redo_stack); }

    fn getUndoDescription() {
        if (len(self.undo_stack) == 0) { return ""; }
        return self.undo_stack[len(self.undo_stack) - 1].description;
    }

    fn getRedoDescription() {
        if (len(self.redo_stack) == 0) { return ""; }
        return self.redo_stack[len(self.redo_stack) - 1].description;
    }

    fn clear() {
        self.undo_stack = [];
        self.redo_stack = [];
        if (self.onStateChanged != nullptr) {
            self.onStateChanged(self);
        }
        return 0;
    }

    fn setMaxHistory(max) {
        self.max_history = max;
        return 0;
    }

    fn setOnStateChanged(callback) {
        self.onStateChanged = callback;
        return 0;
    }
}

