    }

    fn setErrorMessage(msg) {
        self._error_message = msg;
        return 0;
    }

    fn getErrorMessage() {
        return self._error_message;
    }

    fn isValid() {
        return self._is_valid;
    }
}

class EmailValidator {
    let _error_message = "Invalid email address";
    let _is_valid = true;
    let _allow_empty = false;

    fn init_ev() {
        self._error_message = "Invalid email address";
        self._is_valid = true;
        self._allow_empty = false;
        return 0;
    }

    fn validate(value) {
        if (value == nullptr or value == "") {
            if (self._allow_empty) {
                self._is_valid = true;
                return true;
            }
            self._is_valid = false;
            return false;
        }
        let str_val = str(value);
        let at_pos = -1;
        let dot_pos = -1;
        let i = 0;
        while (i < len(str_val)) {
            if (str_val[i] == "@") { at_pos = i; }
            i = i + 1;
        }
        if (at_pos <= 0 or at_pos >= len(str_val) - 1) {
            self._is_valid = false;
            return false;
        }
        let j = at_pos + 1;
        while (j < len(str_val)) {
            if (str_val[j] == ".") { dot_pos = j; }
            j = j + 1;
        }
        if (dot_pos <= at_pos + 1 or dot_pos >= len(str_val) - 1) {
            self._is_valid = false;
            return false;
        }
        self._is_valid = true;
        return true;
    }

    fn setErrorMessage(msg) {
        self._error_message = msg;
        return 0;
    }

    fn getErrorMessage() {
        return self._error_message;
    }

    fn setAllowEmpty(allow) {
        self._allow_empty = allow;
        return 0;
    }

    fn isValid() {
        return self._is_valid;
    }
}

class NumberValidator {
    let _error_message = "Not a valid number";
    let _is_valid = true;
    let _allow_decimal = true;
    let _allow_negative = true;
    let _decimal_places = -1;

    fn init_nv() {
        self._error_message = "Not a valid number";
        self._is_valid = true;
        self._allow_decimal = true;
        self._allow_negative = true;
        self._decimal_places = -1;
        return 0;
    }

    fn validate(value) {
        if (value == nullptr or value == "") {
            self._is_valid = false;
            return false;
        }
        let str_val = str(value);
        let has_dot = false;
        let has_digit = false;
        let i = 0;
        if (len(str_val) > 0 and str_val[0] == "-") {
            if (not self._allow_negative) {
                self._is_valid = false;
                return false;
            }
            i = 1;
        }
        while (i < len(str_val)) {
            let c = str_val[i];
            if (c == ".") {
                if (not self._allow_decimal or has_dot) {
                    self._is_valid = false;
                    return false;
                }
                has_dot = true;
            } else if (c >= "0" and c <= "9") {
                has_digit = true;
            } else {
                self._is_valid = false;
                return false;
            }
            i = i + 1;
        }
        if (not has_digit) {
            self._is_valid = false;
            return false;
        }
        if (self._decimal_places >= 0 and has_dot) {
            let dot_idx = 0;
            let k = 0;
            while (k < len(str_val)) {
                if (str_val[k] == ".") { dot_idx = k; }
                k = k + 1;
            }
            let decimals = len(str_val) - dot_idx - 1;
            if (decimals > self._decimal_places) {
                self._is_valid = false;
                return false;
            }
        }
        self._is_valid = true;
        return true;
    }

    fn setAllowDecimal(allow) {
        self._allow_decimal = allow;
        return 0;
    }

    fn setAllowNegative(allow) {
        self._allow_negative = allow;
        return 0;
    }

    fn setDecimalPlaces(places) {
        self._decimal_places = places;
        return 0;
    }

    fn setErrorMessage(msg) {
        self._error_message = msg;
        return 0;
    }

    fn getErrorMessage() {
        return self._error_message;
    }

    fn isValid() {
        return self._is_valid;
    }
}

