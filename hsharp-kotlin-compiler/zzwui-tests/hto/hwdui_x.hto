        self.widget_type = "DurationPicker";
        self.days = 0;
        self.hours = 0;
        self.minutes = 0;
        self.seconds = 0;
        return 0;
    }

    fn setDuration(d, h, m, s) {
        self.days = d;
        self.hours = h;
        self.minutes = m;
        self.seconds = s;
        if (self.onDurationChanged != nullptr) { self.onDurationChanged(self); }
        return 0;
    }

    fn getTotalSeconds() {
        return self.days * 86400 + self.hours * 3600 + self.minutes * 60 + self.seconds;
    }

    fn getTotalMinutes() { return self.days * 1440 + self.hours * 60 + self.minutes; }

    fn getTotalHours() { return self.days * 24 + self.hours; }

    fn setShowDays(show) { self.show_days = show; return 0; }

    fn setShowSeconds(show) { self.show_seconds = show; return 0; }

    fn setOnDurationChanged(callback) { self.onDurationChanged = callback; return 0; }

    fn getDisplayText() {
        return self.days + "d " + self.hours + "h " + self.minutes + "m";
    }
}

