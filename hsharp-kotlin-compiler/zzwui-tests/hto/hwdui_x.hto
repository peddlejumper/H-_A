    fn removeTag(tag) { let new_tags = []; for __contains(self._tags, t) { if (t != tag) { push(new_tags, t); } } self._tags = new_tags; return 0; }
    fn removeTagAt(index) { if (index < 0 or index >= len(self._tags)) { return 0; } let new_tags = []; let i = 0; while (i < len(self._tags)) { if (i != index) { push(new_tags, self._tags[i]); } i = i + 1; } self._tags = new_tags; return 0; }
    fn getTags() { return self._tags; }
