            else { total_main = total_main + child.height + self.gap; }
            __i33 = __i33 + 1;
        }
        if (total_main > self.gap) { total_main = total_main - self.gap; }
        let main_start = cur_main;
        if (self.justify_content == "center") {
            if (is_row) { main_start = self._hwdui_pad_left + (avail_w - total_main) / 2; }
            else { main_start = self._hwdui_pad_top + (avail_h - total_main) / 2; }
        }
        if (self.justify_content == "flex-end") {
            if (is_row) { main_start = self._hwdui_pad_left + avail_w - total_main; }
            else { main_start = self._hwdui_pad_top + avail_h - total_main; }
        }
        if (self.justify_content == "space-between" and len(self.children) > 1) {
            let visible_count = 0;
