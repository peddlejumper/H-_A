class PrintDocument {
    let _title = "";
    let _pages = [];
    let _page_size = "A4";
    let _orientation = "portrait";
    let _margins = {};

    fn init_pd() {
        self._title = "";
        self._pages = [];
        self._page_size = "A4";
        self._orientation = "portrait";
        self._margins = {"top": 20, "right": 20, "bottom": 20, "left": 20};
        return 0;
    }

    fn setTitle(title) { self._title = title; return 0; }
    fn getTitle() { return self._title; }
    fn addPage(content) { push(self._pages, content); return 0; }
    fn removePage(index) { if (index < 0 or index >= len(self._pages)) { return 0; } let new_pages = []; let i = 0; while (i < len(self._pages)) { if (i != index) { push(new_pages, self._pages[i]); } i = i + 1; } self._pages = new_pages; return 0; }
    fn getPage(index) { if (index >= 0 and index < len(self._pages)) { return self._pages[index]; } return nullptr; }
    fn getPageCount() { return len(self._pages); }
    fn setPageSize(size) { self._page_size = size; return 0; }
    fn getPageSize() { return self._page_size; }
    fn setOrientation(orientation) { self._orientation = orientation; return 0; }
    fn getOrientation() { return self._orientation; }
    fn setMargins(top, right, bottom, left) { self._margins["top"] = top; self._margins["right"] = right; self._margins["bottom"] = bottom; self._margins["left"] = left; return 0; }
    fn getMargins() { return self._margins; }
    fn printDoc(printer_name) { return hwdui_print_document(self, printer_name); }
    fn clear() { self._pages = []; return 0; }
}

class PrintPreview extends zzwUI {
    let _document = nullptr;
    let _current_page = 0;
    let _zoom = 1.0;

    fn init_pprev() {
        self.init(str(hwdui_next_id()));
        self.widget_type = "PrintPreview";
        self.width = 800;
        self.height = 600;
        self._document = nullptr;
        self._current_page = 0;
        self._zoom = 1.0;
        return 0;
    }

    fn setDocument(doc) { self._document = doc; self._current_page = 0; return 0; }
    fn getDocument() { return self._document; }
    fn setZoom(zoom) { if (zoom < 0.1) { zoom = 0.1; } if (zoom > 5.0) { zoom = 5.0; } self._zoom = zoom; return 0; }
    fn getZoom() { return self._zoom; }
    fn zoomIn() { self.setZoom(self._zoom * 1.25); return 0; }
    fn zoomOut() { self.setZoom(self._zoom * 0.8); return 0; }
    fn nextPage() { if (self._document != nullptr and self._current_page + 1 < self._document.getPageCount()) { self._current_page = self._current_page + 1; } return 0; }
    fn prevPage() { if (self._current_page > 0) { self._current_page = self._current_page - 1; } return 0; }
    fn getCurrentPage() { return self._current_page; }
    fn doPrint() { if (self._document != nullptr) { return self._document.printDoc(""); } return 0; }
}

