    }
}

class RangeValidator {
    let _min_value = 0;
    let _max_value = 100;
    let _error_message = "Value out of range";
    let _is_valid = true;
    let _inclusive = true;

    fn init_rangev(min_val, max_val) {
        self._min_value = min_val;
        self._max_value = max_val;
        self._error_message = "Value out of range";
        self._is_valid = true;
        self._inclusive = true;
        return 0;
    }

    fn validate(value) {
        let num = 0;
        num = hwdui_parse_number(value);
        if (self._inclusive) {
            if (num < self._min_value or num > self._max_value) {
                self._is_valid = false;
                return false;
            }
        } else {
            if (num <= self._min_value or num >= self._max_value) {
                self._is_valid = false;
                return false;
            }
        }
        self._is_valid = true;
        return true;
    }

    fn setRange(min_val, max_val) {
        self._min_value = min_val;
        self._max_value = max_val;
        return 0;
    }

    fn getMin() {
        return self._min_value;
    }

    fn getMax() {
        return self._max_value;
    }

    fn setInclusive(inclusive) {
        self._inclusive = inclusive;
        return 0;
    }

    fn setErrorMessage(msg) {
        self._error_message = msg;
        return 0;
    }

    fn getErrorMessage() {
        return self._error_message;
    }

    fn isValid() {
        return self._is_valid;
    }
}

class RegexValidator {
    let _pattern = "";
    let _error_message = "Invalid format";
    let _is_valid = true;
    let _case_sensitive = true;

    fn init_regv(pattern, message) {
        self._pattern = pattern;
        self._error_message = message;
        self._is_valid = true;
        self._case_sensitive = true;
        return 0;
    }

    fn validate(value) {
        if (value == nullptr or value == "") {
            self._is_valid = false;
            return false;
        }
        let test_value = str(value);
        if (not self._case_sensitive) {
            test_value = hwdui_string_lower(test_value);
        }
        let matched = hwdui_regex_match(test_value, self._pattern);
        if (not matched) {
            self._is_valid = false;
            return false;
        }
        self._is_valid = true;
        return true;
    }

    fn setPattern(pattern) {
        self._pattern = pattern;
        return 0;
    }

    fn getPattern() {
        return self._pattern;
    }

    fn setErrorMessage(msg) {
        self._error_message = msg;
        return 0;
    }

    fn getErrorMessage() {
        return self._error_message;
    }

    fn setCaseSensitive(sensitive) {
        self._case_sensitive = sensitive;
        return 0;
    }

    fn isValid() {
        return self._is_valid;
    }
}

class LengthValidator {
    let _min_length = 0;
    let _max_length = 999;
    let _error_message = "Invalid length";
    let _is_valid = true;

    fn init_lv(min_len, max_len) {
        self._min_length = min_len;
        self._max_length = max_len;
        self._error_message = "Invalid length";
        self._is_valid = true;
        return 0;
    }

    fn validate(value) {
        let str_val = str(value);
        let len_val = len(str_val);
        if (len_val < self._min_length or len_val > self._max_length) {
            self._is_valid = false;
            return false;
        }
        self._is_valid = true;
        return true;
    }

    fn setMinLength(min_len) {
        self._min_length = min_len;
        return 0;
    }

    fn getMinLength() {
        return self._min_length;
    }

    fn setMaxLength(max_len) {
        self._max_length = max_len;
        return 0;
    }

    fn getMaxLength() {
