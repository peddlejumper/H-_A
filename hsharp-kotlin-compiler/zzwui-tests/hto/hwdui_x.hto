# --- Window extensions ---

fn hwdui_win_set_icon(win, icon_path) {
    win.setInlineStyle("window-icon", icon_path);
    return 0;
}

fn hwdui_win_set_topmost(win, topmost) {
    if (topmost) {
        win.setInlineStyle("window-topmost", "true");
    } else {
        win.setInlineStyle("window-topmost", "false");
    }
    return 0;
}

fn hwdui_win_set_opacity(win, opacity) {
    if (opacity < 0) { opacity = 0; }
    if (opacity > 1) { opacity = 1; }
    win.setInlineStyle("window-opacity", str(opacity));
    return 0;
}

fn hwdui_win_flash(win, count) {
    let flash_count = count;
    if (flash_count <= 0) { flash_count = 3; }
    let i = 0;
    while (i < flash_count) {
        win.setInlineStyle("window-flash", "active");
        win.setInlineStyle("window-flash", "inactive");
        i = i + 1;
    }
    return 0;
}

fn hwdui_win_set_always_on_top(win, on_top) {
    if (on_top) {
        win.setInlineStyle("window-zorder", "topmost");
    } else {
        win.setInlineStyle("window-zorder", "normal");
    }
    return 0;
}

fn hwdui_win_bring_to_front(win) {
    win.setInlineStyle("window-zorder", "topmost");
    win.setInlineStyle("window-focus", "true");
    let new_windows = [];
    push(new_windows, win);
    let __iter44 = _hwdui_active_windows;
    let __i44 = 0;
    while (__i44 < len(__iter44)) {
        let w = __iter44[__i44];
        if (w != win) {
            push(new_windows, w);
        }
        __i44 = __i44 + 1;
    }
    _hwdui_active_windows = new_windows;
    return 0;
}

fn hwdui_win_send_to_back(win) {
    win.setInlineStyle("window-zorder", "bottom");
    let new_windows = [];
    let __iter45 = _hwdui_active_windows;
    let __i45 = 0;
    while (__i45 < len(__iter45)) {
        let w = __iter45[__i45];
        if (w != win) {
            push(new_windows, w);
        }
        __i45 = __i45 + 1;
    }
    push(new_windows, win);
    _hwdui_active_windows = new_windows;
    return 0;
}

fn hwdui_win_set_fullscreen(win, fs) {
    if (fs) {
        win.restore_x = win.x;
        win.restore_y = win.y;
        win.restore_w = win.width;
        win.restore_h = win.height;
        win.x = 0;
        win.y = 0;
        win.width = 1920;
        win.height = 1080;
        win.setInlineStyle("window-fullscreen", "true");
    } else {
        win.x = win.restore_x;
        win.y = win.restore_y;
        win.width = win.restore_w;
        win.height = win.restore_h;
        win.setInlineStyle("window-fullscreen", "false");
    }
    return 0;
}

fn hwdui_win_toggle_fullscreen(win) {
    let current = win.getInlineStyle("window-fullscreen");
    if (current == "true") {
        hwdui_win_set_fullscreen(win, false);
    } else {
        hwdui_win_set_fullscreen(win, true);
    }
    return 0;
}

fn hwdui_win_set_min_size(win, w, h) {
    win._hwdui_min_w = w;
    win._hwdui_min_h = h;
    if (win.width < w) { win.width = w; }
    if (win.height < h) { win.height = h; }
    return 0;
}

fn hwdui_win_set_max_size(win, w, h) {
    win._hwdui_max_w = w;
    win._hwdui_max_h = h;
    if (win.width > w) { win.width = w; }
    if (win.height > h) { win.height = h; }
    return 0;
}

fn hwdui_win_dock_to_screen_edge(win, edge) {
    let scm = new ScreenManager();
    scm.init_scm();
    let scr = scm.getScreenSize();
    let sw = scr["width"];
    let sh = scr["height"];
    if (edge == "left") {
        win.x = 0;
        win.y = 0;
        win.height = sh;
    } else if (edge == "right") {
        win.x = sw - win.width;
        win.y = 0;
        win.height = sh;
    } else if (edge == "top") {
        win.x = 0;
        win.y = 0;
        win.width = sw;
    } else if (edge == "bottom") {
        win.x = 0;
        win.y = sh - win.height;
        win.width = sw;
    }
    return 0;
}

fn hwdui_win_snap_to_grid(win) {
    let grid_size = 20;
    let snapped_x = (win.x / grid_size) * grid_size;
    let snapped_y = (win.y / grid_size) * grid_size;
    let snapped_w = ((win.width + grid_size - 1) / grid_size) * grid_size;
    let snapped_h = ((win.height + grid_size - 1) / grid_size) * grid_size;
    win.x = snapped_x;
    win.y = snapped_y;
    win.width = snapped_w;
    win.height = snapped_h;
    return 0;
}

fn hwdui_win_get_state(win) {
    if (win.is_minimized) {
        return "minimized";
    }
    if (win.is_maximized) {
        return "maximized";
    }
    return "normal";
}

# --- Panel extensions ---

fn hwdui_panel_set_child_alignment(panel, child, align) {
    let align_key = "child-align-" + child.id;
    panel.setInlineStyle(align_key, align);
    child.setInlineStyle("self-alignment", align);
    return 0;
}

fn hwdui_panel_get_child_alignment(panel, child) {
    let align_key = "child-align-" + child.id;
    let val = panel.getInlineStyle(align_key);
    if (val == nullptr) { return "fill"; }
    return val;
}

fn hwdui_panel_swap_children(panel, idx1, idx2) {
    let cnt = len(panel.children);
    if (idx1 < 0 or idx1 >= cnt) { return -1; }
    if (idx2 < 0 or idx2 >= cnt) { return -1; }
    let temp = panel.children[idx1];
    panel.children[idx1] = panel.children[idx2];
    panel.children[idx2] = temp;
    return 0;
}

fn hwdui_panel_reorder_child(panel, child, new_idx) {
    let cnt = len(panel.children);
    if (new_idx < 0 or new_idx >= cnt) { return -1; }
    let old_idx = -1;
    let i = 0;
    while (i < cnt) {
        if (panel.children[i] == child) {
            old_idx = i;
            break;
        }
        i = i + 1;
    }
    if (old_idx == -1) { return -1; }
    let tmp = panel.children[old_idx];
    let new_children = [];
    let j = 0;
    while (j < cnt) {
        if (j == old_idx) {
            j = j + 1;
            continue;
        }
        if (j == new_idx) {
            push(new_children, tmp);
        }
        push(new_children, panel.children[j]);
        j = j + 1;
    }
    if (new_idx == cnt - 1) {
        push(new_children, tmp);
    }
    panel.children = new_children;
    return 0;
}

