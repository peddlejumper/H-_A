# ═══════════════════════════════════════════════════════════════════════════
# SECTION 25: Network & Connectivity Widgets (~6 classes)
# ═══════════════════════════════════════════════════════════════════════════

class NetworkStatus extends zzwUI {
    let is_connected = false;
    let signal_strength = 0;
    let connection_type = "none";
    let onStatusChanged = nullptr;

    fn init_netstatus() {
        self.init("");
        self.widget_type = "NetworkStatus";
        self.is_connected = false;
        self.signal_strength = 0;
        self.connection_type = "none";
        return 0;
    }

    fn setStatus(connected, sig, conn_type) {
        self.is_connected = connected;
        self.signal_strength = sig;
        self.connection_type = conn_type;
        if (self.onStatusChanged != nullptr) { self.onStatusChanged(self, connected); }
        return 0;
    }

    fn isConnected() { return self.is_connected; }

    fn getSignalStrength() { return self.signal_strength; }

    fn getConnectionType() { return self.connection_type; }

    fn setOnStatusChanged(callback) { self.onStatusChanged = callback; return 0; }
}

class DownloadProgress extends zzwUI {
    let url = "";
    let file_name = "";
    let total_bytes = 0;
    let downloaded_bytes = 0;
    let status = "idle";
    let onComplete = nullptr;
    let onProgress = nullptr;

    fn init_dl(url, filename) {
        self.init("");
        self.widget_type = "DownloadProgress";
        self.url = url;
        self.file_name = filename;
        self.total_bytes = 0;
        self.downloaded_bytes = 0;
        self.status = "idle";
        return 0;
    }

    fn start() { self.status = "downloading"; return 0; }

    fn pause() { self.status = "paused"; return 0; }

    fn resume() { self.status = "downloading"; return 0; }

    fn cancel() { self.status = "cancelled"; return 0; }

    fn getProgress() {
        if (self.total_bytes == 0) { return 0; }
        return (self.downloaded_bytes * 100) / self.total_bytes;
    }

    fn getStatus() { return self.status; }

    fn setOnComplete(callback) { self.onComplete = callback; return 0; }

    fn setOnProgress(callback) { self.onProgress = callback; return 0; }
}

class WebSocketClient {
    let url = "";
    let connected = false;
    let onMessage = nullptr;
    let onOpen = nullptr;
    let onClose = nullptr;
    let onError = nullptr;

    fn init_ws(url) {
        self.url = url;
        self.connected = false;
        return 0;
    }

    fn connect() { self.connected = true; if (self.onOpen != nullptr) { self.onOpen(self); } return 0; }

    fn disconnect() { self.connected = false; if (self.onClose != nullptr) { self.onClose(self); } return 0; }

    fn send(data) { return 0; }

    fn isConnected() { return self.connected; }

    fn setOnMessage(callback) { self.onMessage = callback; return 0; }

    fn setOnOpen(callback) { self.onOpen = callback; return 0; }

    fn setOnClose(callback) { self.onClose = callback; return 0; }

    fn setOnError(callback) { self.onError = callback; return 0; }
}

class HTTPClient {
    let base_url = "";
    let timeout = 10000;
    let headers = {};

    fn init_http(base_url) {
        self.base_url = base_url;
        self.timeout = 10000;
        self.headers = {};
        return 0;
    }

    fn setHeader(key, value) {
        self.headers[key] = value;
        return 0;
    }

    fn setHeaders(headers_dict) {
        self.headers = headers_dict;
        return 0;
    }

    fn setTimeout(ms) {
        self.timeout = ms;
        return 0;
    }

    fn get(url, callback) { return 0; }

    fn post(url, data, callback) { return 0; }

    fn put(url, data, callback) { return 0; }

    fn delete(url, callback) { return 0; }

    fn getBaseUrl() { return self.base_url; }
}

class RemoteFileExplorer extends zzwUI {
    let remote_path = "/";
    let items = [];
    let onNavigate = nullptr;
    let onFileSelect = nullptr;

    fn init_rfe(remote_path) {
        self.init("");
        self.widget_type = "RemoteFileExplorer";
        self.remote_path = remote_path;
        self.items = [];
        return 0;
    }

    fn navigateTo(path) {
        self.remote_path = path;
        if (self.onNavigate != nullptr) { self.onNavigate(self, path); }
        return 0;
    }

    fn getCurrentPath() { return self.remote_path; }

    fn setItems(item_list) { self.items = item_list; return 0; }

    fn getItems() { return self.items; }

    fn goUp() { return 0; }

    fn refresh() { return 0; }

    fn setOnNavigate(callback) { self.onNavigate = callback; return 0; }

    fn setOnFileSelect(callback) { self.onFileSelect = callback; return 0; }
}

class ConnectionDialog extends Dialog {
    let host = "";
    let port = 8080;
    let username = "";
    let password = "";
    let use_ssl = false;
    let onConnect = nullptr;

    fn init_condlg(title) {
        self.init_dlg(title, 400, 300);
        self.widget_type = "ConnectionDialog";
        self.host = "";
        self.port = 8080;
        self.use_ssl = false;
        return 0;
    }

    fn setHost(h) { self.host = h; return 0; }

    fn setPort(p) { self.port = p; return 0; }

    fn setUsername(u) { self.username = u; return 0; }

    fn setPassword(p) { self.password = p; return 0; }

    fn setUseSSL(ssl) { self.use_ssl = ssl; return 0; }

    fn getConnectionString() {
        let proto = "http";
        if (self.use_ssl) { proto = "https"; }
        return proto + "://" + self.host + ":" + str(self.port);
    }

    fn connect() {
        if (self.onConnect != nullptr) {
            self.onConnect(self, self.host, self.port, self.username);
        }
        return 0;
    }

    fn setOnConnect(callback) { self.onConnect = callback; return 0; }
}

# ═══════════════════════════════════════════════════════════════════════════
# SECTION 26: Additional Utility Functions (~6 functions)
# ═══════════════════════════════════════════════════════════════════════════

fn hwdui_measure_text(font_family, font_size, text) {
    return {"width": len(text) * font_size * 0.6, "height": font_size * 1.2};
}

fn hwdui_get_contrast_ratio(fg_color, bg_color) {
    return 4.5;
}

fn hwdui_is_dark_color(color) {
    if (color == "#000000" or color == "#333333" or color == "#444444") { return true; }
    return false;
}

fn hwdui_parse_color(color_str) {
    return {"r": 0, "g": 0, "b": 0, "a": 255};
}

fn hwdui_color_to_hex(r, g, b) {
    return "#000000";
}

fn hwdui_debounce(callback, delay_ms) {
    let timer_id = hwdui_next_id();
    return timer_id;
}

