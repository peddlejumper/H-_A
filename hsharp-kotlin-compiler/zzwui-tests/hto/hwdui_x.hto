    let _current_y = 0;
    let _row_height = 0;
    let _padding = 2;

    fn init_ta() {
        self._textures = {};
        self._total_width = 512;
        self._total_height = 512;
        self._current_x = 0;
        self._current_y = 0;
        self._row_height = 0;
        self._padding = 2;
        return 0;
    }

    fn addTexture(name, width, height) {
        if (self._current_x + width + self._padding > self._total_width) {
            self._current_x = 0;
            self._current_y = self._current_y + self._row_height + self._padding;
            self._row_height = 0;
        }
        if (self._current_y + height > self._total_height) {
            return false;
        }
        self._textures[name] = {"x": self._current_x, "y": self._current_y, "width": width, "height": height};
        self._current_x = self._current_x + width + self._padding;
        if (height > self._row_height) { self._row_height = height; }
        return true;
    }

    fn getTextureRect(name) {
        if (self._textures[name] != nullptr) {
            return self._textures[name];
        }
        return nullptr;
    }

    fn removeTexture(name) {
        let new_textures = {};
        let __iter101 = self._textures;
        let __i101 = 0;
        while (__i101 < len(__iter101)) {
            let key = __iter101[__i101];
            if (key != name) { new_textures[key] = self._textures[key]; }
            __i101 = __i101 + 1;
        }
        self._textures = new_textures;
        return 0;
    }

    fn hasTexture(name) {
        return self._textures[name] != nullptr;
    }

    fn getTextureCount() {
        let count = 0;
        let __iter102 = self._textures;
        let __i102 = 0;
        while (__i102 < len(__iter102)) {
            let key = __iter102[__i102];
            count = count + 1;
            __i102 = __i102 + 1;
        }
        return count;
    }

    fn setAtlasSize(w, h) {
        self._total_width = w;
        self._total_height = h;
        return 0;
    }

    fn getUtilization() {
        let used = 0;
        let __iter103 = self._textures;
        let __i103 = 0;
        while (__i103 < len(__iter103)) {
            let key = __iter103[__i103];
            let t = self._textures[key];
            used = used + t["width"] * t["height"];
            __i103 = __i103 + 1;
        }
        return used / (self._total_width * self._total_height);
    }

    fn clear() {
        self._textures = {};
        self._current_x = 0;
        self._current_y = 0;
        self._row_height = 0;
        return 0;
    }
}

class ResourcePool {
    let _pool = {};
    let _factory = nullptr;
    let _max_size = 50;
    let _active_count = 0;

    fn init_rp() {
        self._pool = {};
        self._factory = nullptr;
        self._max_size = 50;
        self._active_count = 0;
        return 0;
    }

    fn setFactory(factory_func) {
        self._factory = factory_func;
        return 0;
    }

    fn acquire() {
        let __iter104 = self._pool;
        let __i104 = 0;
        while (__i104 < len(__iter104)) {
            let key = __iter104[__i104];
            if (len(self._pool[key]) > 0) {
                let obj = self._pool[key][len(self._pool[key]) - 1];
                let new_list = [];
                let i = 0;
                while (i < len(self._pool[key]) - 1) {
                    push(new_list, self._pool[key][i]);
                    i = i + 1;
                }
                self._pool[key] = new_list;
                self._active_count = self._active_count + 1;
                return obj;
            }
            __i104 = __i104 + 1;
        }
        if (self._factory != nullptr) {
            let obj = self._factory();
            self._active_count = self._active_count + 1;
            return obj;
        }
        return nullptr;
    }

    fn release(obj) {
        if (obj == nullptr) { return 0; }
        let type_key = obj["__type__"];
        if (type_key == nullptr) { type_key = "object"; }
        if (self._pool[type_key] == nullptr) {
            self._pool[type_key] = [];
        }
        let total_count = 0;
        let __iter105 = self._pool;
        let __i105 = 0;
        while (__i105 < len(__iter105)) {
            let k = __iter105[__i105];
            total_count = total_count + len(self._pool[k]);
            __i105 = __i105 + 1;
        }
        if (total_count < self._max_size) {
            push(self._pool[type_key], obj);
        }
        self._active_count = self._active_count - 1;
        return 0;
    }

    fn getActiveCount() {
        return self._active_count;
    }

    fn getPoolSize() {
        let total = 0;
        let __iter106 = self._pool;
        let __i106 = 0;
        while (__i106 < len(__iter106)) {
            let key = __iter106[__i106];
            total = total + len(self._pool[key]);
            __i106 = __i106 + 1;
        }
        return total;
    }

    fn setMaxSize(size) {
        self._max_size = size;
        return 0;
    }

    fn clear() {
        self._pool = {};
        self._active_count = 0;
        return 0;
    }
}

