class InkCanvas extends zzwUI {
    let _strokes = [];
    let _ink_color = "#000000";
    let _ink_width = 3;
    let _eraser_mode = false;
    let _undo_stack = [];

    fn init_ic() {
        self.init(str(hwdui_next_id()));
        self.widget_type = "InkCanvas";
        self.width = 400;
        self.height = 300;
        self._strokes = [];
        self._ink_color = "#000000";
        self._ink_width = 3;
        self._eraser_mode = false;
        self._undo_stack = [];
        return 0;
    }

    fn drawStroke(points) {
        push(self._undo_stack, {"action": "draw", "stroke": points, "color": self._ink_color, "width": self._ink_width});
        push(self._strokes, {"points": points, "color": self._ink_color, "width": self._ink_width});
        return 0;
    }

    fn undo() {
        if (len(self._undo_stack) > 0) {
            let last_idx = len(self._undo_stack) - 1;
            self._undo_stack[last_idx] = nullptr;
            let new_stack = [];
            let i = 0;
            while (i < last_idx) {
                push(new_stack, self._undo_stack[i]);
                i = i + 1;
            }
            self._undo_stack = new_stack;
            if (len(self._strokes) > 0) {
                let new_strokes = [];
                let j = 0;
                while (j < len(self._strokes) - 1) {
                    push(new_strokes, self._strokes[j]);
                    j = j + 1;
                }
                self._strokes = new_strokes;
            }
        }
        return 0;
    }

