    fn setColor(color) { self._color = color; return 0; }
    fn updatePosition() { if (self._target != nullptr) { self.x = self._target.x; self.y = self._target.y; self.width = self._target.width; self.height = self._target.height; } return 0; }
}

class KeyboardNavigation {
    let _widgets = [];
    let _current_index = -1;
    let _wrap_around = true;

    fn init_kn() { self._widgets = []; self._current_index = -1; self._wrap_around = true; return 0; }
    fn registerWidget(widget) { push(self._widgets, widget); return 0; }
    fn unregisterWidget(widget) { let new_widgets = []; for __contains(self._widgets, w) { if (w != widget) { push(new_widgets, w); } } self._widgets = new_widgets; return 0; }
    fn focusNext() { if (len(self._widgets) == 0) { return 0; } self._current_index = self._current_index + 1; if (self._current_index >= len(self._widgets)) { if (self._wrap_around) { self._current_index = 0; } else { self._current_index = len(self._widgets) - 1; } } return 0; }
    fn focusPrevious() { if (len(self._widgets) == 0) { return 0; } self._current_index = self._current_index - 1; if (self._current_index < 0) { if (self._wrap_around) { self._current_index = len(self._widgets) - 1; } else { self._current_index = 0; } } return 0; }
    fn getCurrentWidget() { if (self._current_index >= 0 and self._current_index < len(self._widgets)) { return self._widgets[self._current_index]; } return nullptr; }
    fn setWrapAround(wrap) { self._wrap_around = wrap; return 0; }
    fn getWidgetCount() { return len(self._widgets); }
    fn clear() { self._widgets = []; self._current_index = -1; return 0; }
}

