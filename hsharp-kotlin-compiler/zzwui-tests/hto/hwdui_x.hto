class BlinkAnimation extends Animation {
    let blink_count = 3;
    let blink_speed = 200;
    let on_state = true;
    let blink_timer = 0;

    fn init_ba(target_widget, count, speed) {
        self.init_anim(target_widget, "visible", 0, speed * count);
        self.blink_count = count;
        self.blink_speed = speed;
        self.on_state = true;
        self.blink_timer = 0;
        return 0;
    }

    fn setBlinkCount(count) { self.blink_count = count; return 0; }

    fn getBlinkCount() { return self.blink_count; }

    fn setBlinkSpeed(speed) { self.blink_speed = speed; return 0; }

    fn getBlinkSpeed() { return self.blink_speed; }

    fn start() {
        self.running = true;
        self.elapsed = 0;
        self.blink_timer = 0;
        self.on_state = true;
        return 0;
    }

    fn update(delta_ms) {
        if (self.running == false) { return 0; }
        self.blink_timer = self.blink_timer + delta_ms;
        if (self.blink_timer >= self.blink_speed) {
            self.blink_timer = 0;
            self.on_state = not self.on_state;
            self.blink_count = self.blink_count - 1;
            if (self.blink_count <= 0) {
                self.running = false;
                if (self.target != nullptr) { self.target.visible = true; }
                if (self.onComplete != nullptr) { self.onComplete(self); }
                return 0;
            }
        }
        if (self.target != nullptr) { self.target.visible = self.on_state; }
        self.elapsed = self.elapsed + delta_ms;
        return 0;
    }
}

