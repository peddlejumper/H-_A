    let restore_h = 300;
    let title_height = 28;
    let _hwdui_win_id = 0;
    let _hwdui_saved_x = 0;
    let _hwdui_saved_y = 0;
    let _hwdui_saved_w = 0;
    let _hwdui_saved_h = 0;

    fn init_win(win_title) {
        self.init(str(hwdui_next_id()));
        self.widget_type = "Window";
        self.title = win_title;
        self._hwdui_win_id = hwdui_next_id();
        return 0;
    }

    fn set_title(new_title) {
        self.title = new_title;
        return 0;
    }

    fn center_on_screen(screen_w, screen_h) {
        self.x = (screen_w - self.width) / 2;
        self.y = (screen_h - self.height) / 2;
        self.centered = true;
        return 0;
    }

    fn open() {
        self.visible = true;
        return 0;
    }

    fn close() {
        let new_windows = [];
