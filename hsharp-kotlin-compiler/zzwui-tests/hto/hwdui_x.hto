class WindowManager {
    let windows = [];
    let active_window = nullptr;
    let onWindowActivated = nullptr;
    let onWindowClosed = nullptr;

    fn init_wm() {
        self.windows = [];
        self.active_window = nullptr;
        return 0;
    }

    fn addWindow(window) {
        push(self.windows, window);
        return 0;
    }

    fn removeWindow(window) {
        let new_windows = [];
        let i = 0;
        while (i < len(self.windows)) {
            if (self.windows[i] != window) { push(new_windows, self.windows[i]); }
            i = i + 1;
        }
        self.windows = new_windows;
        if (self.active_window == window) {
            self.active_window = nullptr;
            if (len(self.windows) > 0) { self.activateWindow(self.windows[0]); }
        }
        return 0;
    }

    fn activateWindow(window) {
        self.active_window = window;
        if (self.onWindowActivated != nullptr) { self.onWindowActivated(window); }
        return 0;
    }

    fn getActiveWindow() { return self.active_window; }

    fn getWindow(index) {
        if (index >= 0 and index < len(self.windows)) { return self.windows[index]; }
        return nullptr;
    }

    fn getWindowCount() { return len(self.windows); }

    fn closeAll() {
        let i = 0;
        while (i < len(self.windows)) {
            self.windows[i].close();
            i = i + 1;
        }
        self.windows = [];
        self.active_window = nullptr;
        return 0;
    }

    fn cascadeWindows(offset) {
        let i = 0;
        while (i < len(self.windows)) {
            self.windows[i].x = i * offset;
            self.windows[i].y = i * offset;
            i = i + 1;
        }
        return 0;
    }

    fn tileWindows() {
        let count = len(self.windows);
        if (count == 0) { return 0; }
        let cols = 2;
        let rows = (count + 1) / 2;
        let tile_w = 1024 / cols;
        let tile_h = 768 / rows;
        let i = 0;
        while (i < count) {
            let col = i % cols;
            let row = i / cols;
            self.windows[i].x = col * tile_w;
            self.windows[i].y = row * tile_h;
            self.windows[i].width = tile_w;
            self.windows[i].height = tile_h;
            i = i + 1;
        }
        return 0;
    }

    fn setOnWindowActivated(callback) { self.onWindowActivated = callback; return 0; }

    fn setOnWindowClosed(callback) { self.onWindowClosed = callback; return 0; }
}

class DragDropManager {
    let source_widget = nullptr;
    let current_data = nullptr;
    let is_dragging = false;
    let drag_cursor_x = 0;
    let drag_cursor_y = 0;
    let drop_target = nullptr;
    let onDragStart = nullptr;
    let onDragOver = nullptr;
    let onDrop = nullptr;
    let onDragEnd = nullptr;

    fn init_ddm() {
        self.source_widget = nullptr;
        self.current_data = nullptr;
        self.is_dragging = false;
        self.drag_cursor_x = 0;
        self.drag_cursor_y = 0;
        self.drop_target = nullptr;
        return 0;
    }

    fn startDrag(widget, data, x, y) {
        self.source_widget = widget;
        self.current_data = data;
        self.is_dragging = true;
        self.drag_cursor_x = x;
        self.drag_cursor_y = y;
        if (self.onDragStart != nullptr) { self.onDragStart(widget, data, x, y); }
        return 0;
    }

    fn updateDrag(x, y) {
        self.drag_cursor_x = x;
        self.drag_cursor_y = y;
        if (self.onDragOver != nullptr) { self.onDragOver(x, y); }
        return 0;
    }

    fn endDrag(target_widget) {
        self.drop_target = target_widget;
        self.is_dragging = false;
        if (self.onDrop != nullptr) { self.onDrop(self.source_widget, target_widget, self.current_data); }
        if (self.onDragEnd != nullptr) { self.onDragEnd(self.source_widget); }
        return 0;
    }

    fn cancelDrag() {
        self.is_dragging = false;
        if (self.onDragEnd != nullptr) { self.onDragEnd(self.source_widget); }
        return 0;
    }

    fn isDragging() { return self.is_dragging; }

    fn getSource() { return self.source_widget; }

    fn getData() { return self.current_data; }

    fn getCursorPosition() { return {"x": self.drag_cursor_x, "y": self.drag_cursor_y}; }

    fn setOnDragStart(callback) { self.onDragStart = callback; return 0; }

    fn setOnDragOver(callback) { self.onDragOver = callback; return 0; }

    fn setOnDrop(callback) { self.onDrop = callback; return 0; }

    fn setOnDragEnd(callback) { self.onDragEnd = callback; return 0; }
}

