    fn setDetail(panel) { self._detail_panel = panel; self.add_child(panel); self._layout(); return 0; }
    fn getDetail() { return self._detail_panel; }
    fn _layout() { if (self._master_panel != nullptr) { self._master_panel.x = 0; self._master_panel.y = 0; self._master_panel.width = self._master_width; self._master_panel.height = self.height; } if (self._detail_panel != nullptr) { self._detail_panel.x = self._master_width; self._detail_panel.y = 0; self._detail_panel.width = self.width - self._master_width; self._detail_panel.height = self.height; } return 0; }
    fn setMasterWidth(w) { self._master_width = w; self._layout(); return 0; }
}

