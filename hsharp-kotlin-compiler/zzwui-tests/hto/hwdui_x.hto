        self.height = 30;
        self._octets = [0, 0, 0, 0];
        self._version = "ipv4";
        self._current_octet = 0;
        return 0;
    }

    fn setOctet(index, value) { if (index < 0 or index > 3) { return 0; } if (value < 0) { value = 0; } if (value > 255) { value = 255; } self._octets[index] = value; return 0; }
    fn getOctet(index) { if (index < 0 or index > 3) { return 0; } return self._octets[index]; }
    fn setAddress(addr) { let parts = hwdui_string_split(addr, "."); if (len(parts) == 4) { let i = 0; while (i < 4) { self._octets[i] = hwdui_parse_number(parts[i]); i = i + 1; } } return 0; }
    fn getAddress() { return str(self._octets[0]) + "." + str(self._octets[1]) + "." + str(self._octets[2]) + "." + str(self._octets[3]); }
    fn isValid() { let i = 0; while (i < 4) { if (self._octets[i] < 0 or self._octets[i] > 255) { return false; } i = i + 1; } return true; }
    fn setVersion(version) { self._version = version; return 0; }
    fn getVersion() { return self._version; }
    fn focusNextOctet() { if (self._current_octet < 3) { self._current_octet = self._current_octet + 1; } return 0; }
    fn focusPrevOctet() { if (self._current_octet > 0) { self._current_octet = self._current_octet - 1; } return 0; }
    fn clear() { self._octets = [0, 0, 0, 0]; self._current_octet = 0; return 0; }
}

