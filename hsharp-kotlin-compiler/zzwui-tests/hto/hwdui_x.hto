class ViewModel {
    let _properties = {};
    let _commands = {};
    let _is_dirty = false;

    fn init_vm() {
        self._properties = {};
        self._commands = {};
        self._is_dirty = false;
        return 0;
    }

    fn setProperty(key, value) {
        let old_val = self._properties[key];
        self._properties[key] = value;
        self._is_dirty = true;
        if (self.onPropertyChanged != nullptr) {
            self.onPropertyChanged(self, key, old_val, value);
        }
        return 0;
    }

    fn getProperty(key) {
        return self._properties[key];
    }

    fn hasProperty(key) {
        return self._properties[key] != nullptr;
    }

    fn isDirty() {
        return self._is_dirty;
    }

    fn markClean() {
        self._is_dirty = false;
        return 0;
    }

    fn registerCommand(name, cmd) {
        self._commands[name] = cmd;
        return 0;
    }

    fn executeCommand(name) {
        let cmd = self._commands[name];
        if (cmd != nullptr) {
            cmd.execute();
        }
        return 0;
    }

    fn canExecuteCommand(name) {
        let cmd = self._commands[name];
        if (cmd != nullptr) {
            return cmd.canExecute();
        }
        return false;
    }
}

class ObservableProperty {
    let _value = nullptr;
    let _subscribers = [];
    let _name = "";

    fn init_obp(name, initial_value) {
        self._name = name;
        self._value = initial_value;
        self._subscribers = [];
        return 0;
    }

    fn get() {
        return self._value;
    }

    fn set(new_value) {
        let old = self._value;
        self._value = new_value;
        self._notify(old, new_value);
        return 0;
    }

    fn _notify(old_val, new_val) {
        let __iter46 = self._subscribers;
        let __i46 = 0;
        while (__i46 < len(__iter46)) {
            let callback = __iter46[__i46];
            if (callback != nullptr) {
                callback(old_val, new_val);
            }
            __i46 = __i46 + 1;
        }
        return 0;
    }

    fn subscribe(callback) {
        push(self._subscribers, callback);
        return 0;
    }

    fn unsubscribe(callback) {
        let new_subs = [];
        let __iter47 = self._subscribers;
        let __i47 = 0;
        while (__i47 < len(__iter47)) {
            let sub = __iter47[__i47];
            if (sub != callback) {
                push(new_subs, sub);
            }
            __i47 = __i47 + 1;
        }
        self._subscribers = new_subs;
        return 0;
    }

    fn getSubscriberCount() {
        return len(self._subscribers);
    }

    fn getName() {
        return self._name;
    }
}

class Command {
    let _execute_fn = nullptr;
    let _can_execute_fn = nullptr;
    let _is_executing = false;

    fn init_cmd(exec_fn, can_exec_fn) {
        self._execute_fn = exec_fn;
        self._can_execute_fn = can_exec_fn;
        self._is_executing = false;
        return 0;
    }

    fn execute() {
        if (self._can_execute_fn != nullptr) {
            if (not self._can_execute_fn()) {
                return -1;
            }
        }
        self._is_executing = true;
        if (self._execute_fn != nullptr) {
            self._execute_fn();
        }
        self._is_executing = false;
        return 0;
    }

    fn canExecute() {
        if (self._can_execute_fn != nullptr) {
            return self._can_execute_fn();
        }
        return true;
    }

    fn isExecuting() {
        return self._is_executing;
    }

    fn setExecute(fn_exec) {
        self._execute_fn = fn_exec;
        return 0;
    }

    fn setCanExecute(fn_can) {
        self._can_execute_fn = fn_can;
        return 0;
    }
}

class RelayCommand {
    let _action = nullptr;
    let _predicate = nullptr;

    fn init_rc(action, predicate) {
        self._action = action;
        self._predicate = predicate;
        return 0;
    }

    fn execute(param) {
