class DatePicker extends zzwUI {
    let selected_date = "";
    let min_date = "";
    let max_date = "";
    let show_week_numbers = false;
    let first_day = 0;
    let onDateSelected = nullptr;
    let current_month = 1;
    let current_year = 2024;

    fn init_dp() {
        self.init("");
        self.widget_type = "DatePicker";
        self.selected_date = "";
        self.current_month = 1;
        self.current_year = 2024;
        return 0;
    }

    fn setDate(date) {
        self.selected_date = date;
        if (self.onDateSelected != nullptr) { self.onDateSelected(self, date); }
        return 0;
    }

    fn getDate() { return self.selected_date; }

    fn setMinDate(date) { self.min_date = date; return 0; }

    fn setMaxDate(date) { self.max_date = date; return 0; }

    fn setShowWeekNumbers(show) { self.show_week_numbers = show; return 0; }

    fn setFirstDay(day) { self.first_day = day; return 0; }

    fn setOnDateSelected(callback) {
        self.onDateSelected = callback;
        return 0;
    }

    fn prevMonth() {
        if (self.current_month == 1) {
            self.current_month = 12;
            self.current_year = self.current_year - 1;
        } else {
            self.current_month = self.current_month - 1;
        }
        return 0;
    }

    fn nextMonth() {
        if (self.current_month == 12) {
            self.current_month = 1;
            self.current_year = self.current_year + 1;
        } else {
            self.current_month = self.current_month + 1;
        }
        return 0;
    }

    fn today() { return 0; }

    fn clear() { self.selected_date = ""; return 0; }
}

