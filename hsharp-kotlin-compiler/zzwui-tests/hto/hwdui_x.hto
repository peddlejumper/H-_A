# Rating — 评分组件
# ═══════════════════════════════════════════════════════════════════════════
class Rating extends zzwUI {
    let value = 0;
    let max_stars = 5;
    let allow_half = false;
    let onRatingChanged = nullptr;

    fn init_rating() {
        self.init("");
        self.widget_type = "Rating";
        self.value = 0;
        self.max_stars = 5;
        self.allow_half = false;
        return 0;
    }

    fn setMaxStars(count) {
        self.max_stars = count;
        return 0;
    }

    fn setAllowHalf(allow) {
        self.allow_half = allow;
        return 0;
    }

    fn setRating(rating) {
        if (rating < 0) { rating = 0; }
        if (rating > self.max_stars) { rating = self.max_stars; }
        self.value = rating;
        if (self.onRatingChanged != nullptr) {
            self.onRatingChanged(self, self.value);
        }
        return 0;
    }

    fn getRating() { return self.value; }

    fn setOnRatingChanged(callback) {
        self.onRatingChanged = callback;
        return 0;
    }
}

