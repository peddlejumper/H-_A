        btn.enabled = false;
    } else {
        btn.setInlineStyle("button-loading", "false");
        btn.setInlineStyle("button-disabled", "false");
        btn.enabled = true;
    }
    return 0;
}

fn hwdui_btn_set_size_mode(btn, mode) {
    if (mode == "large") {
        btn.setInlineStyle("button-size", "large");
        btn.width = 160;
        btn.height = 48;
    } else if (mode == "small") {
        btn.setInlineStyle("button-size", "small");
        btn.width = 64;
        btn.height = 24;
    } else {
        btn.setInlineStyle("button-size", "normal");
        btn.width = 100;
        btn.height = 30;
    }
    return 0;
}

