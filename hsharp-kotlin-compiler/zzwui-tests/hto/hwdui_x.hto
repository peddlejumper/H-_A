class DocumentPane extends zzwUI {
    let _tabs = [];
    let _active_tab_index = 0;
    let _tab_height = 32;
    let _closeable = true;
    let _reorderable = true;
    let _overflow_mode = "scroll";
    let _scroll_offset = 0;

    fn init_docpane() {
        self.init(str(hwdui_next_id()));
        self.widget_type = "DocumentPane";
        self.width = 600;
        self.height = 400;
        self._tabs = [];
        self._active_tab_index = 0;
        self._tab_height = 32;
        self._closeable = true;
        self._reorderable = true;
        self._overflow_mode = "scroll";
        self._scroll_offset = 0;
        return 0;
    }

    fn addTab(tab) {
        push(self._tabs, tab);
        tab.setPane(self);
        if (len(self._tabs) == 1) {
            self._active_tab_index = 0;
            tab.setActive(true);
        }
        return 0;
    }

    fn removeTab(tab) {
        let new_tabs = [];
        let removed_idx = -1;
        let i = 0;
        while (i < len(self._tabs)) {
            if (self._tabs[i] == tab) {
                removed_idx = i;
            } else {
                push(new_tabs, self._tabs[i]);
            }
            i = i + 1;
        }
        self._tabs = new_tabs;
        tab.setPane(nullptr);
        if (self._active_tab_index >= len(self._tabs)) {
            self._active_tab_index = len(self._tabs) - 1;
        }
        if (self._active_tab_index < 0) { self._active_tab_index = 0; }
        if (len(self._tabs) > 0) {
            self._tabs[self._active_tab_index].setActive(true);
        }
        return 0;
    }

    fn removeTabAt(index) {
        if (index < 0 or index >= len(self._tabs)) { return 0; }
        self.removeTab(self._tabs[index]);
        return 0;
    }

    fn setActiveTab(index) {
        if (index < 0 or index >= len(self._tabs)) { return 0; }
        if (self._active_tab_index < len(self._tabs)) {
            self._tabs[self._active_tab_index].setActive(false);
        }
        self._active_tab_index = index;
        self._tabs[index].setActive(true);
        return 0;
    }

    fn getActiveTab() {
        if (self._active_tab_index >= 0 and self._active_tab_index < len(self._tabs)) {
            return self._tabs[self._active_tab_index];
        }
        return nullptr;
    }

    fn getActiveTabIndex() {
        return self._active_tab_index;
    }

    fn getTabs() {
        return self._tabs;
    }

    fn getTabCount() {
        return len(self._tabs);
    }

    fn setCloseable(closeable) {
        self._closeable = closeable;
        return 0;
    }

    fn isCloseable() {
        return self._closeable;
    }

    fn moveTab(from_idx, to_idx) {
        if (not self._reorderable) { return 0; }
        if (from_idx < 0 or from_idx >= len(self._tabs)) { return 0; }
        if (to_idx < 0 or to_idx >= len(self._tabs)) { return 0; }
        let tab = self._tabs[from_idx];
        let new_tabs = [];
        let i = 0;
        while (i < len(self._tabs)) {
            if (i != from_idx) {
                if (len(new_tabs) == to_idx) {
                    push(new_tabs, tab);
                }
                push(new_tabs, self._tabs[i]);
            }
            i = i + 1;
        }
        if (len(new_tabs) == to_idx) {
            push(new_tabs, tab);
        }
        self._tabs = new_tabs;
        if (self._active_tab_index == from_idx) {
            self._active_tab_index = to_idx;
        }
        return 0;
    }

    fn setReorderable(reorderable) {
        self._reorderable = reorderable;
        return 0;
    }

    fn scrollTabs(delta) {
        self._scroll_offset = self._scroll_offset + delta;
        if (self._scroll_offset < 0) { self._scroll_offset = 0; }
        return 0;
    }
}

