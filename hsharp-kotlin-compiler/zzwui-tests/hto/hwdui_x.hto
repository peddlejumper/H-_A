# ═══════════════════════════════════════════════════════════════════════════
# SplitPane — 可拖动分隔面板
# ═══════════════════════════════════════════════════════════════════════════
class SplitPane extends zzwUI {
    let orientation = "horizontal";
    let divider_position = 0.5;
    let first_panel = nullptr;
    let second_panel = nullptr;
    let onDragging = nullptr;

    fn init_split(orient) {
        self.init("");
        self.widget_type = "SplitPane";
        self.orientation = orient;
        self.divider_position = 0.5;
        return 0;
    }

    fn setFirstPanel(panel) {
        self.first_panel = panel;
        self.add_child(panel);
        return 0;
    }

    fn setSecondPanel(panel) {
        self.second_panel = panel;
        self.add_child(panel);
        return 0;
    }

    fn setDividerPosition(pos) {
        if (pos < 0.0) { pos = 0.0; }
        if (pos > 1.0) { pos = 1.0; }
        self.divider_position = pos;
        return 0;
    }

    fn getDividerPosition() { return self.divider_position; }

    fn do_layout() {
        let pad_left = self._hwdui_pad_left;
        let pad_top = self._hwdui_pad_top;
        let avail_w = self.width - pad_left - self._hwdui_pad_right;
        let avail_h = self.height - pad_top - self._hwdui_pad_bottom;
        if (self.orientation == "horizontal") {
            let divider_size = 4;
            let left_w = (avail_w - divider_size) * self.divider_position;
            let right_w = avail_w - left_w - divider_size;
            if (self.first_panel != nullptr and self.first_panel.visible) {
                self.first_panel.x = self.x + pad_left;
                self.first_panel.y = self.y + pad_top;
                self.first_panel.width = left_w;
                self.first_panel.height = avail_h;
                self.first_panel.do_layout();
            }
            if (self.second_panel != nullptr and self.second_panel.visible) {
                self.second_panel.x = self.x + pad_left + left_w + divider_size;
                self.second_panel.y = self.y + pad_top;
                self.second_panel.width = right_w;
                self.second_panel.height = avail_h;
                self.second_panel.do_layout();
            }
        } else {
            let divider_size = 4;
            let top_h = (avail_h - divider_size) * self.divider_position;
            let bottom_h = avail_h - top_h - divider_size;
            if (self.first_panel != nullptr and self.first_panel.visible) {
                self.first_panel.x = self.x + pad_left;
                self.first_panel.y = self.y + pad_top;
                self.first_panel.width = avail_w;
                self.first_panel.height = top_h;
                self.first_panel.do_layout();
            }
            if (self.second_panel != nullptr and self.second_panel.visible) {
                self.second_panel.x = self.x + pad_left;
                self.second_panel.y = self.y + pad_top + top_h + divider_size;
                self.second_panel.width = avail_w;
                self.second_panel.height = bottom_h;
                self.second_panel.do_layout();
            }
        }
        return 0;
    }

    fn setOnDragging(callback) {
        self.onDragging = callback;
        return 0;
    }
}

# ═══════════════════════════════════════════════════════════════════════════
# DataBinding — 数据绑定
# ═══════════════════════════════════════════════════════════════════════════
class Binding {
    let source = nullptr;
    let source_path = "";
    let target = nullptr;
    let target_prop = "";
    let converter = nullptr;

    fn init_binding(src, src_path, tgt, tgt_prop) {
        self.source = src;
        self.source_path = src_path;
        self.target = tgt;
        self.target_prop = tgt_prop;
        return 0;
    }

    fn setConverter(func) {
        self.converter = func;
        return 0;
    }

    fn update() {
        let value = self.source[self.source_path];
        if (self.converter != nullptr) { value = self.converter(value); }
        self.target[self.target_prop] = value;
        return 0;
    }
}

class DataContext {
    let data = nullptr;
    let bindings = [];

    fn init_context(data_obj) {
        self.data = data_obj;
        self.bindings = [];
        return 0;
    }

    fn add_binding(binding) {
        push(self.bindings, binding);
        return 0;
    }

    fn update_all() {
        let i = 0;
        while (i < len(self.bindings)) {
            let b = self.bindings[i];
            b.update();
            i = i + 1;
        }
        return 0;
    }

    fn set_data(data_obj) {
        self.data = data_obj;
        self.update_all();
        return 0;
    }

    fn get_data() { return self.data; }
}

# ═══════════════════════════════════════════════════════════════════════════
# Accordion — 折叠面板
# ═══════════════════════════════════════════════════════════════════════════
class AccordionItem {
    let title = "";
    let content = nullptr;
    let expanded = false;

    fn init_item(t, widget) {
        self.title = t;
        self.content = widget;
        self.expanded = false;
        return 0;
    }
}

class Accordion extends zzwUI {
    let items = [];
    let allow_multiple = false;
    let padding = 4;

    fn init_accordion() {
        self.init("");
        self.widget_type = "Accordion";
        self.items = [];
        self.allow_multiple = false;
        return 0;
    }

    fn setAllowMultiple(value) {
        self.allow_multiple = value;
        return 0;
    }

    fn addItem(title, content_widget) {
        let item = new AccordionItem();
        item.init_item(title, content_widget);
        push(self.items, item);
        content_widget.visible = item.expanded;
        self.add_child(content_widget);
        return 0;
    }

    fn toggleItem(index) {
        if (index < 0 or index >= len(self.items)) { return 0; }
        let item = self.items[index];
        if (self.allow_multiple == false and item.expanded == false) {
            let i = 0;
            while (i < len(self.items)) {
                let other = self.items[i];
                if (i != index) {
                    other.expanded = false;
                    other.content.visible = false;
                }
                i = i + 1;
            }
        }
        item.expanded = not item.expanded;
        item.content.visible = item.expanded;
        self.do_layout();
        return 1;
    }

    fn expandItem(index) {
        if (index < 0 or index >= len(self.items)) { return 0; }
        if (self.allow_multiple == false) {
            let i = 0;
            while (i < len(self.items)) {
                let other = self.items[i];
                other.expanded = false;
                other.content.visible = false;
                i = i + 1;
            }
        }
        let item = self.items[index];
        item.expanded = true;
        item.content.visible = true;
        self.do_layout();
        return 1;
    }

    fn do_layout() {
        let pad_left = self._hwdui_pad_left;
        let pad_top = self._hwdui_pad_top;
        let avail_w = self.width - pad_left - self._hwdui_pad_right;
        let current_y = pad_top;
        let item_height = 24;
        let i = 0;
        while (i < len(self.items)) {
            let item = self.items[i];
            current_y = current_y + item_height + self.padding;
            if (item.expanded and item.content.visible) {
                item.content.x = self.x + pad_left + self.padding;
                item.content.y = self.y + current_y;
                item.content.width = avail_w - self.padding * 2;
                item.content.do_layout();
                current_y = current_y + item.content.height + self.padding;
            }
            i = i + 1;
        }
        return 0;
    }
}

# ═══════════════════════════════════════════════════════════════════════════
# Stepper — 步进器
# ═══════════════════════════════════════════════════════════════════════════
class Stepper extends zzwUI {
    let value = 0;
    let min_value = 0;
    let max_value = 100;
    let step = 1;
    let onValueChanged = nullptr;

    fn init_stepper(initial_val) {
        self.init("");
        self.widget_type = "Stepper";
        self.value = initial_val;
        self.min_value = 0;
        self.max_value = 100;
        self.step = 1;
        return 0;
    }

    fn setRange(min_val, max_val) {
        self.min_value = min_val;
        self.max_value = max_val;
        return 0;
    }

    fn setStep(step_size) {
        self.step = step_size;
        return 0;
    }

    fn setValue(new_val) {
        if (new_val < self.min_value) { new_val = self.min_value; }
        if (new_val > self.max_value) { new_val = self.max_value; }
        self.value = new_val;
        if (self.onValueChanged != nullptr) {
            self.onValueChanged(self, self.value);
        }
        return 0;
    }

    fn getValue() { return self.value; }

    fn increment() {
        self.setValue(self.value + self.step);
        return 0;
    }

    fn decrement() {
        self.setValue(self.value - self.step);
        return 0;
    }

    fn setOnValueChanged(callback) {
        self.onValueChanged = callback;
        return 0;
    }
}

