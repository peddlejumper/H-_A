    }

    fn addItem(item) { push(self._items, item); item.setNavView(self); return 0; }
    fn removeItem(item) { let new_items = []; for __contains(self._items, it) { if (it != item) { push(new_items, it); } } self._items = new_items; item.setNavView(nullptr); return 0; }
    fn selectItem(index) { if (index < 0 or index >= len(self._items)) { return 0; } if (self._selected_index >= 0 and self._selected_index < len(self._items)) { self._items[self._selected_index].setSelected(false); } self._selected_index = index; self._items[index].setSelected(true); return 0; }
    fn getSelectedIndex() { return self._selected_index; }
    fn getItems() { return self._items; }
    fn getItemCount() { return len(self._items); }
    fn setMode(mode) { self._mode = mode; return 0; }
    fn togglePane() { self._is_open = not self._is_open; return 0; }
    fn isOpen() { return self._is_open; }
    fn setHeaderText(text) { self._header_text = text; return 0; }
    fn clear() { self._items = []; self._selected_index = -1; return 0; }
}

