    let _target_fps = 60;
    let _last_frame_time = 0;
    let _frame_count = 0;
    let _elapsed_time = 0;
    let _current_fps = 0;
    let _throttle_enabled = true;
    let _min_frame_time = 1.0 / 60;

    fn init_frc() {
        self._target_fps = 60;
        self._last_frame_time = 0;
        self._frame_count = 0;
