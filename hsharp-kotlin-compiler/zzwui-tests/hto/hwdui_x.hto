                if (child.visible) { visible_count = visible_count + 1; }
                __i34 = __i34 + 1;
            }
            if (is_row) { self.gap = (avail_w - total_main) / (visible_count - 1); }
            else { self.gap = (avail_h - total_main) / (visible_count - 1); }
        }
        cur_main = main_start;
        let __iter35 = self.children;
        let __i35 = 0;
        while (__i35 < len(__iter35)) {
            let child = __iter35[__i35];
            if (child.visible == false) { continue; }
            if (is_row) {
