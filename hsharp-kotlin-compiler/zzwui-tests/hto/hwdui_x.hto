class ToastNotification extends Notification {
    let toast_id = 0;
    let action_text = "";
    let onAction = nullptr;
    let onDismissed = nullptr;
    let progress = -1;

    fn init_toast(t, m, ntype) {
        self.init_notify(t, m, ntype);
        self.widget_type = "ToastNotification";
        self.toast_id = 0;
        self.action_text = "";
        self.progress = -1;
        return 0;
    }

    fn setToastId(id) { self.toast_id = id; return 0; }

    fn getToastId() { return self.toast_id; }

    fn setActionText(text) { self.action_text = text; return 0; }

    fn getActionText() { return self.action_text; }

    fn setOnAction(callback) { self.onAction = callback; return 0; }

    fn setOnDismissed(callback) { self.onDismissed = callback; return 0; }

    fn setProgress(p) {
        if (p < -1) { p = -1; }
        if (p > 100) { p = 100; }
        self.progress = p;
        return 0;
    }

    fn getProgress() { return self.progress; }

    fn toast() {
        self.visible = true;
        return 0;
    }

    fn dismiss() {
        self.visible = false;
        if (self.onDismissed != nullptr) { self.onDismissed(self); }
        return 0;
    }
}

