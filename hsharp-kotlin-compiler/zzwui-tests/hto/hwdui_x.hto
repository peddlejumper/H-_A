    fn init_fw(pane) {
        self._pane = pane;
        self._x = 100;
        self._y = 100;
        self._width = 300;
        self._height = 200;
        if (pane != nullptr) {
            self._title = pane.getTitle();
        }
        self._is_visible = true;
        self._is_resizable = true;
        self._is_movable = true;
        self._min_width = 150;
        self._min_height = 100;
        return 0;
    }

    fn getPane() {
        return self._pane;
    }

    fn setPosition(x, y) {
        self._x = x;
        self._y = y;
        return 0;
    }

    fn getX() {
        return self._x;
    }

    fn getY() {
        return self._y;
    }

    fn setSize(w, h) {
        if (w >= self._min_width) { self._width = w; }
        if (h >= self._min_height) { self._height = h; }
        return 0;
    }

    fn getWidth() {
        return self._width;
    }

    fn getHeight() {
        return self._height;
    }

    fn setTitle(title) {
        self._title = title;
        return 0;
    }

    fn getTitle() {
        return self._title;
    }

    fn show() {
        self._is_visible = true;
        return 0;
    }

    fn hide() {
        self._is_visible = false;
        return 0;
    }

    fn isVisible() {
        return self._is_visible;
    }

    fn close() {
        self._is_visible = false;
        return 0;
    }

    fn setResizable(resizable) {
        self._is_resizable = resizable;
        return 0;
    }

    fn isResizable() {
        return self._is_resizable;
    }

    fn moveBy(dx, dy) {
        self._x = self._x + dx;
        self._y = self._y + dy;
        return 0;
    }

    fn containsPoint(px, py) {
        return px >= self._x and px <= self._x + self._width and
               py >= self._y and py <= self._y + self._height;
    }
}

