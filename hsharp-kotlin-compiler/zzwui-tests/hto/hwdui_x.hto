        self.widget_type = "Flyout";
        self.content = nullptr;
        self.is_open = false;
        self.flyout_side = "right";
        self.overlay = true;
        self.width_size = 300;
        self.visible = false;
        return 0;
    }

    fn setContent(widget) {
        self.content = widget;
        self.remove_all_children();
        if (widget != nullptr) { self.add_child(widget); }
        return 0;
    }

    fn getContent() { return self.content; }

    fn show() {
        self.is_open = true;
        self.visible = true;
        if (self.onOpened != nullptr) { self.onOpened(self); }
        return 0;
    }

    fn hide() {
        self.is_open = false;
        self.visible = false;
        if (self.onClosed != nullptr) { self.onClosed(self); }
        return 0;
    }

    fn toggle() {
        if (self.is_open) { self.hide(); }
        else { self.show(); }
        return 0;
    }

    fn isOpen() { return self.is_open; }

    fn setSide(side) { self.flyout_side = side; return 0; }

    fn getSide() { return self.flyout_side; }

    fn setOverlay(ov) { self.overlay = ov; return 0; }

    fn setWidth(w) { self.width_size = w; self.width = w; return 0; }

    fn setOnOpened(callback) { self.onOpened = callback; return 0; }

    fn setOnClosed(callback) { self.onClosed = callback; return 0; }
}

class Callout extends zzwUI {
    let target = nullptr;
    let message = "";
    let callout_position = "auto";
    let arrow_size = 8;
    let auto_close_delay = 0;
    let is_visible = false;

    fn init_call(msg) {
        self.init("");
        self.widget_type = "Callout";
        self.target = nullptr;
        self.message = msg;
        self.callout_position = "auto";
        self.arrow_size = 8;
        self.auto_close_delay = 0;
        self.is_visible = false;
        self.visible = false;
        return 0;
    }

    fn setTarget(widget) { self.target = widget; return 0; }

    fn getTarget() { return self.target; }

    fn setMessage(msg) { self.message = msg; return 0; }

    fn getMessage() { return self.message; }

    fn setPosition(pos) { self.callout_position = pos; return 0; }

    fn getPosition() { return self.callout_position; }

    fn setArrowSize(size) { self.arrow_size = size; return 0; }

    fn setAutoCloseDelay(ms) { self.auto_close_delay = ms; return 0; }

    fn show() {
        if (self.target != nullptr) {
            self.x = self.target.x + self.target.width / 2;
            self.y = self.target.y + self.target.height;
        }
        self.is_visible = true;
        self.visible = true;
        return 0;
    }

    fn hide() {
        self.is_visible = false;
        self.visible = false;
        return 0;
    }

    fn isVisible() { return self.is_visible; }
}

