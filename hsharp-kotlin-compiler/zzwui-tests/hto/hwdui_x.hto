}

class ShakeAnimation extends Animation {
    let amplitude = 10;
    let frequency = 4;
    let shake_duration = 500;
    let shake_origin_x = 0;
    let shake_origin_y = 0;

    fn init_shake(target_widget, amp, dur) {
        self.init_anim(target_widget, "x", 0, dur);
        self.amplitude = amp;
        self.frequency = 4;
        self.shake_duration = dur;
        self.shake_origin_x = 0;
        self.shake_origin_y = 0;
        return 0;
    }

    fn setAmplitude(amp) { self.amplitude = amp; return 0; }

    fn getAmplitude() { return self.amplitude; }

    fn setFrequency(freq) { self.frequency = freq; return 0; }

    fn getFrequency() { return self.frequency; }

    fn setShakeDuration(dur) { self.shake_duration = dur; return 0; }

    fn getShakeDuration() { return self.shake_duration; }

    fn start() {
        if (self.target != nullptr) {
            self.shake_origin_x = self.target.x;
            self.shake_origin_y = self.target.y;
        }
        self.running = true;
        self.elapsed = 0;
        return 0;
    }

    fn update(delta_ms) {
        if (self.running == false) { return 0; }
        self.elapsed = self.elapsed + delta_ms;
        if (self.elapsed >= self.shake_duration) {
            self.elapsed = self.shake_duration;
            self.running = false;
            if (self.target != nullptr) {
                self.target.x = self.shake_origin_x;
            }
            if (self.onComplete != nullptr) { self.onComplete(self); }
            return 0;
        }
        let progress = self.elapsed * 100 / self.shake_duration;
        let decay = 1 - (progress / 100);
        let offset = self.amplitude * decay;
        if (self.target != nullptr) {
            self.target.x = self.shake_origin_x + offset;
        }
        return 0;
    }
}

class MorphAnimation extends Animation {
