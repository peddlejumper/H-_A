    fn init_tooltip(t) {
        self.init("");
        self.widget_type = "Tooltip";
        self.text = t;
        self.visible = false;
        self.delay = 500;
        return 0;
    }

    fn setText(t) {
        self.text = t;
        return 0;
    }

    fn setDelay(ms) {
        self.delay = ms;
        return 0;
    }

    fn showAt(px, py) {
        self.x = px + 10;
        self.y = py + 10;
        self.visible = true;
        hwdui_tooltip_set(self);
        return 0;
    }

    fn hide() {
        self.visible = false;
        hwdui_tooltip_set(nullptr);
        return 0;
    }
}

class KeyboardHandler {
    let tab_order = [];
    let current_index = -1;
    let enabled = true;

    fn init_kh() {
        self.tab_order = [];
        self.current_index = -1;
        self.enabled = true;
        return 0;
    }

    fn addWidget(widget) {
        push(self.tab_order, widget);
        return 0;
    }

    fn removeWidget(widget) {
        let new_order = [];
        let __iter29 = self.tab_order;
        let __i29 = 0;
        while (__i29 < len(__iter29)) {
            let w = __iter29[__i29];
            if (w != widget) {
                push(new_order, w);
            }
            __i29 = __i29 + 1;
        }
        self.tab_order = new_order;
        return 0;
    }

    fn setCurrent(widget) {
        let idx = 0;
        while (idx < len(self.tab_order)) {
            if (self.tab_order[idx] == widget) {
                self.current_index = idx;
                return 0;
            }
            idx = idx + 1;
        }
        return 0;
    }

    fn getCurrent() {
        if (self.current_index >= 0 and self.current_index < len(self.tab_order)) {
            return self.tab_order[self.current_index];
        }
        return nullptr;
    }

    fn next() {
        if (len(self.tab_order) == 0) { return nullptr; }
        let start = self.current_index;
        let idx = start;
        while (true) {
            idx = idx + 1;
            if (idx >= len(self.tab_order)) { idx = 0; }
            if (self.tab_order[idx].enabled) {
                self.current_index = idx;
                return self.tab_order[idx];
            }
            if (idx == start) { return nullptr; }
        }
        return nullptr;
    }

    fn prev() {
        if (len(self.tab_order) == 0) { return nullptr; }
        let start = self.current_index;
        let idx = start;
        while (true) {
            idx = idx - 1;
            if (idx < 0) { idx = len(self.tab_order) - 1; }
            if (self.tab_order[idx].enabled) {
                self.current_index = idx;
                return self.tab_order[idx];
            }
            if (idx == start) { return nullptr; }
        }
        return nullptr;
    }

    fn clear() {
        self.tab_order = [];
        self.current_index = -1;
        return 0;
    }
}

# ═══════════════════════════════════════════════════════════════════════════
# Serializer — Widget 序列化
# ═══════════════════════════════════════════════════════════════════════════
class Serializer {
    let data = {};
    let widget_map = {};

    fn init_serializer() {
        self.data = {};
        self.widget_map = {};
        return 0;
    }

    fn serialize(widget) {
        let wdata = {};
        wdata["widget_type"] = widget.widget_type;
        wdata["x"] = widget.x;
        wdata["y"] = widget.y;
        wdata["width"] = widget.width;
        wdata["height"] = widget.height;
        wdata["visible"] = widget.visible;
        wdata["enabled"] = widget.enabled;
        wdata["styles"] = widget.styles;
        wdata["id"] = widget.id;
        wdata["classes"] = widget._css_classes;
        let children_data = [];
        let i = 0;
        while (i < len(widget.children)) {
            let child = widget.children[i];
            push(children_data, self.serialize(child));
            i = i + 1;
        }
        wdata["children"] = children_data;
        return wdata;
    }

    fn serialize_root(root_widget) {
        self.data = self.serialize(root_widget);
        return self.data;
    }

    fn get_data() { return self.data; }
}

# ═══════════════════════════════════════════════════════════════════════════
# Deserializer — Widget 反序列化
# ═══════════════════════════════════════════════════════════════════════════
class Deserializer {
    let data = {};
    let widget_map = {};
    let factory = {};

    fn init_deserializer() {
        self.data = {};
        self.widget_map = {};
        self.factory = {};
        self.register_builtin_factories();
        return 0;
    }

    fn register_factory(widget_type, ctor) {
        self.factory[widget_type] = ctor;
        return 0;
    }

    fn register_builtin_factories() {
        self.register_factory("zzwUI", fn() { return new zzwUI(); });
        self.register_factory("Window", fn() { return new Window(); });
        self.register_factory("Panel", fn() { return new Panel(); });
        self.register_factory("Button", fn() { return new Button(); });
        self.register_factory("Label", fn() { return new Label(); });
        self.register_factory("TextBox", fn() { return new TextBox(); });
        self.register_factory("CheckBox", fn() { return new CheckBox(); });
        self.register_factory("RadioButton", fn() { return new RadioButton(); });
        self.register_factory("Slider", fn() { return new Slider(); });
        self.register_factory("ProgressBar", fn() { return new ProgressBar(); });
        self.register_factory("Image", fn() { return new Image(); });
        self.register_factory("ListBox", fn() { return new ListBox(); });
        self.register_factory("ComboBox", fn() { return new ComboBox(); });
        self.register_factory("ScrollView", fn() { return new ScrollView(); });
        self.register_factory("TabControl", fn() { return new TabControl(); });
        self.register_factory("Separator", fn() { return new Separator(); });
        self.register_factory("Canvas", fn() { return new Canvas(); });
        self.register_factory("GridPanel", fn() { return new GridPanel(); });
        return 0;
    }

    fn deserialize(wdata) {
        let widget_type = wdata["widget_type"];
        let ctor = self.factory[widget_type];
        if (ctor == nullptr) { return nullptr; }
        let widget = ctor();
        widget.widget_type = widget_type;
        if (wdata["x"] != nullptr) { widget.x = wdata["x"]; }
        if (wdata["y"] != nullptr) { widget.y = wdata["y"]; }
        if (wdata["width"] != nullptr) { widget.width = wdata["width"]; }
        if (wdata["height"] != nullptr) { widget.height = wdata["height"]; }
        if (wdata["visible"] != nullptr) { widget.visible = wdata["visible"]; }
        if (wdata["enabled"] != nullptr) { widget.enabled = wdata["enabled"]; }
        if (wdata["styles"] != nullptr) { widget.styles = wdata["styles"]; }
        if (wdata["id"] != nullptr) { widget.id = wdata["id"]; }
        if (wdata["classes"] != nullptr) { widget._css_classes = wdata["classes"]; }
        if (wdata["children"] != nullptr) {
            let children_data = wdata["children"];
            let i = 0;
            while (i < len(children_data)) {
                let child_data = children_data[i];
                let child = self.deserialize(child_data);
                if (child != nullptr) { widget.add_child(child); }
                i = i + 1;
            }
        }
        return widget;
    }

    fn deserialize_from_data(data) {
        self.data = data;
        return self.deserialize(data);
    }

    fn get_widget_map() { return self.widget_map; }
}

