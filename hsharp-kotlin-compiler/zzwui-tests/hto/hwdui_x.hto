}

class KeySequenceInput extends zzwUI {
    let _keys = [];
    let _recording = false;
    let _modifiers = {"ctrl": false, "shift": false, "alt": false, "meta": false};

    fn init_ksi() {
        self.init(str(hwdui_next_id()));
        self.widget_type = "KeySequenceInput";
        self.width = 200;
        self.height = 30;
        self._keys = [];
        self._recording = false;
        self._modifiers = {"ctrl": false, "shift": false, "alt": false, "meta": false};
