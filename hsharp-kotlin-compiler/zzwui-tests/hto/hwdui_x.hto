}

class OverlayPanel extends Panel {
    let _hwdui_layers = [];

    fn init_op() {
        self.init_panel("absolute");
        self.widget_type = "OverlayPanel";
        self._hwdui_layers = [];
        return 0;
    }

    fn addLayer(widget) {
        widget.z_index = len(self.children);
        self.add_child(widget);
        push(self._hwdui_layers, widget);
        return 0;
    }

    fn removeLayer(index) {
        if (index >= 0 and index < len(self._hwdui_layers)) {
            self.remove_child(self._hwdui_layers[index]);
            let new_layers = [];
            let i = 0;
            while (i < len(self._hwdui_layers)) {
                if (i != index) { push(new_layers, self._hwdui_layers[i]); }
                i = i + 1;
            }
            self._hwdui_layers = new_layers;
        }
        return 0;
    }

    fn getLayer(index) {
        if (index >= 0 and index < len(self._hwdui_layers)) {
            return self._hwdui_layers[index];
        }
        return nullptr;
    }

    fn getLayerCount() { return len(self._hwdui_layers); }

    fn bringLayerToTop(index) {
        if (index >= 0 and index < len(self._hwdui_layers)) {
            self._hwdui_layers[index].bring_to_front();
        }
        return 0;
    }

    fn do_layout() {
        let i = 0;
        while (i < len(self._hwdui_layers)) {
            self._hwdui_layers[i].x = self._hwdui_pad_left;
            self._hwdui_layers[i].y = self._hwdui_pad_top;
            self._hwdui_layers[i].width = self.width - self._hwdui_pad_left - self._hwdui_pad_right;
            self._hwdui_layers[i].height = self.height - self._hwdui_pad_top - self._hwdui_pad_bottom;
            i = i + 1;
        }
        return 0;
    }
}

