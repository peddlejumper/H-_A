class DockPanel extends Panel {
    let last_fill = nullptr;

    fn init_dp() {
        self.init_panel("absolute");
        self.widget_type = "DockPanel";
        return 0;
    }

    fn dockTop(widget, height) {
        widget.x = 0;
        widget.y = 0;
        widget.width = self.width;
        widget.height = height;
        self.add_child(widget);
        return 0;
    }

    fn dockBottom(widget, height) {
        widget.x = 0;
        widget.y = self.height - height;
        widget.width = self.width;
        widget.height = height;
        self.add_child(widget);
        return 0;
    }

    fn dockLeft(widget, width) {
        widget.x = 0;
        widget.y = 0;
        widget.width = width;
        widget.height = self.height;
        self.add_child(widget);
        return 0;
    }

    fn dockRight(widget, width) {
        widget.x = self.width - width;
        widget.y = 0;
        widget.width = width;
        widget.height = self.height;
        self.add_child(widget);
        return 0;
    }

    fn dockFill(widget) {
        self.last_fill = widget;
        self.add_child(widget);
        return 0;
    }

    fn do_layout() {
        if (self.last_fill != nullptr) {
            self.last_fill.width = self.width;
            self.last_fill.height = self.height;
        }
        return 0;
    }

}

