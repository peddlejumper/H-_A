    }

    fn setTickCount(count) {
        self._tick_count = count;
        return 0;
    }

    fn getTickCount() {
        return self._tick_count;
    }

    fn getTicks() {
        let ticks = [];
        if (self._tick_count <= 0) { return ticks; }
        let step = (self._max_value - self._min_value) / self._tick_count;
        let i = 0;
        while (i <= self._tick_count) {
            push(ticks, self._min_value + i * step);
            i = i + 1;
        }
        return ticks;
    }

    fn setShowGrid(show) {
        self._show_grid = show;
        return 0;
    }

    fn setGridColor(color) {
        self._grid_color = color;
        return 0;
    }

    fn getGridColor() {
        return self._grid_color;
    }

    fn setLogarithmic(log) {
        self._logarithmic = log;
        return 0;
    }
}

