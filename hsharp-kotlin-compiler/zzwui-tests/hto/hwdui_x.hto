class GaugeControl extends zzwUI {
    let _value = 0;
    let _min_value = 0;
    let _max_value = 100;
    let _title = "";
    let _needle_color = "#E74C3C";
    let _arc_color = "#4A90D9";
    let _background_color = "#E0E0E0";
    let _start_angle = 135;
    let _end_angle = 405;
    let _show_value_label = true;
    let _zones = [];

    fn init_gc() {
        self.init(str(hwdui_next_id()));
        self.widget_type = "GaugeControl";
        self.width = 200;
        self.height = 200;
        self._value = 0;
        self._min_value = 0;
        self._max_value = 100;
        self._title = "";
        self._needle_color = "#E74C3C";
        self._arc_color = "#4A90D9";
        self._background_color = "#E0E0E0";
        self._start_angle = 135;
        self._end_angle = 405;
        self._show_value_label = true;
        self._zones = [];
        return 0;
    }

    fn setValue(val) {
        if (val < self._min_value) { val = self._min_value; }
        if (val > self._max_value) { val = self._max_value; }
        self._value = val;
        return 0;
    }

    fn getValue() {
        return self._value;
    }

    fn setRange(min_val, max_val) {
        self._min_value = min_val;
        self._max_value = max_val;
        return 0;
    }

    fn getMin() {
        return self._min_value;
    }

    fn getMax() {
        return self._max_value;
    }

    fn setTitle(title) {
        self._title = title;
        return 0;
    }

    fn getTitle() {
        return self._title;
    }

    fn setNeedleColor(color) {
        self._needle_color = color;
        return 0;
    }

    fn setArcColor(color) {
        self._arc_color = color;
        return 0;
    }

    fn getPercent() {
        if (self._max_value == self._min_value) { return 0; }
        return (self._value - self._min_value) / (self._max_value - self._min_value) * 100;
    }

    fn addZone(from_val, to_val, color) {
        push(self._zones, {"from": from_val, "to": to_val, "color": color});
        return 0;
    }

    fn clearZones() {
        self._zones = [];
        return 0;
    }

    fn getZones() {
        return self._zones;
    }
}

