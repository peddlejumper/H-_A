    fn togglePin() {
        self._is_pinned = not self._is_pinned;
        return 0;
    }

    fn isPinned() {
        return self._is_pinned;
    }

    fn setPinned(pinned) {
        self._is_pinned = pinned;
        return 0;
    }

    fn toggleCollapse() {
        if (self._can_collapse) {
            self._collapsed = not self._collapsed;
        }
        return 0;
    }

    fn isCollapsed() {
        return self._collapsed;
    }

    fn setCollapsible(can) {
        self._can_collapse = can;
        return 0;
    }
}

class ResizeGrip extends zzwUI {
    let _direction = "se";
    let _grip_size = 12;
    let _grip_color = "#999999";
    let _target = nullptr;
    let _is_dragging = false;
    let _drag_start_x = 0;
    let _drag_start_y = 0;
    let _drag_start_w = 0;
    let _drag_start_h = 0;
    let _min_width = 50;
    let _min_height = 50;

    fn init_rg(direction, target) {
        self.init(str(hwdui_next_id()));
        self.widget_type = "ResizeGrip";
        self.width = 12;
        self.height = 12;
        self._direction = direction;
        self._grip_size = 12;
        self._grip_color = "#999999";
        self._target = target;
        self._is_dragging = false;
        self._drag_start_x = 0;
        self._drag_start_y = 0;
        self._drag_start_w = 0;
        self._drag_start_h = 0;
        self._min_width = 50;
        self._min_height = 50;
        return 0;
    }

    fn setDirection(dir) {
        self._direction = dir;
        return 0;
    }

    fn getDirection() {
        return self._direction;
    }

    fn setTarget(target) {
        self._target = target;
        return 0;
    }

    fn getTarget() {
        return self._target;
    }

    fn startDrag(mx, my) {
        if (self._target == nullptr) { return 0; }
        self._is_dragging = true;
        self._drag_start_x = mx;
        self._drag_start_y = my;
        self._drag_start_w = self._target.width;
        self._drag_start_h = self._target.height;
        return 0;
    }

    fn drag(mx, my) {
        if (not self._is_dragging or self._target == nullptr) { return 0; }
        let dx = mx - self._drag_start_x;
        let dy = my - self._drag_start_y;
        let new_w = self._drag_start_w;
        let new_h = self._drag_start_h;
        if (self._direction == "se" or self._direction == "e" or self._direction == "ne") {
            new_w = self._drag_start_w + dx;
        }
        if (self._direction == "sw" or self._direction == "w" or self._direction == "nw") {
            new_w = self._drag_start_w - dx;
        }
        if (self._direction == "se" or self._direction == "s" or self._direction == "sw") {
            new_h = self._drag_start_h + dy;
        }
        if (self._direction == "ne" or self._direction == "n" or self._direction == "nw") {
            new_h = self._drag_start_h - dy;
        }
        if (new_w < self._min_width) { new_w = self._min_width; }
        if (new_h < self._min_height) { new_h = self._min_height; }
        self._target.width = new_w;
        self._target.height = new_h;
        return 0;
    }

    fn endDrag() {
        self._is_dragging = false;
        return 0;
    }

    fn isDragging() {
        return self._is_dragging;
    }

    fn setMinSize(w, h) {
        self._min_width = w;
        self._min_height = h;
        return 0;
    }

    fn setGripColor(color) {
        self._grip_color = color;
        return 0;
    }
}

class SplitContainer extends zzwUI {
    let _panel_a = nullptr;
    let _panel_b = nullptr;
    let _split_ratio = 0.5;
    let _split_position = 0;
    let _orientation = "horizontal";
    let _splitter_width = 6;
    let _splitter_dragging = false;
    let _splitter_color = "#AAAAAA";
    let _min_panel_size = 40;

    fn init_sc() {
        self.init(str(hwdui_next_id()));
        self.widget_type = "SplitContainer";
        self.width = 600;
        self.height = 400;
        self._panel_a = nullptr;
        self._panel_b = nullptr;
        self._split_ratio = 0.5;
        self._split_position = 0;
        self._orientation = "horizontal";
        self._splitter_width = 6;
        self._splitter_dragging = false;
        self._splitter_color = "#AAAAAA";
        self._min_panel_size = 40;
        return 0;
    }

    fn setPanelA(panel) {
        self._panel_a = panel;
        self.add_child(panel);
        self._layout();
        return 0;
    }

    fn getPanelA() {
        return self._panel_a;
    }

    fn setPanelB(panel) {
        self._panel_b = panel;
        self.add_child(panel);
        self._layout();
        return 0;
    }

    fn getPanelB() {
        return self._panel_b;
    }

    fn setOrientation(orientation) {
        self._orientation = orientation;
        self._layout();
        return 0;
    }

    fn getOrientation() {
        return self._orientation;
    }

    fn setSplitRatio(ratio) {
        if (ratio < 0.1) { ratio = 0.1; }
        if (ratio > 0.9) { ratio = 0.9; }
        self._split_ratio = ratio;
        self._layout();
        return 0;
    }

    fn getSplitRatio() {
        return self._split_ratio;
    }

    fn _layout() {
        if (self._orientation == "horizontal") {
            let a_w = (self.width - self._splitter_width) * self._split_ratio;
            if (a_w < self._min_panel_size) { a_w = self._min_panel_size; }
            let b_w = self.width - a_w - self._splitter_width;
            if (b_w < self._min_panel_size) { b_w = self._min_panel_size; }
            a_w = self.width - b_w - self._splitter_width;
            if (self._panel_a != nullptr) {
                self._panel_a.width = a_w;
                self._panel_a.height = self.height;
                self._panel_a.x = 0;
                self._panel_a.y = 0;
            }
            if (self._panel_b != nullptr) {
                self._panel_b.width = b_w;
                self._panel_b.height = self.height;
                self._panel_b.x = a_w + self._splitter_width;
                self._panel_b.y = 0;
            }
            self._split_position = a_w;
        } else {
            let a_h = (self.height - self._splitter_width) * self._split_ratio;
            if (a_h < self._min_panel_size) { a_h = self._min_panel_size; }
            let b_h = self.height - a_h - self._splitter_width;
            if (b_h < self._min_panel_size) { b_h = self._min_panel_size; }
            a_h = self.height - b_h - self._splitter_width;
            if (self._panel_a != nullptr) {
                self._panel_a.width = self.width;
                self._panel_a.height = a_h;
                self._panel_a.x = 0;
                self._panel_a.y = 0;
            }
            if (self._panel_b != nullptr) {
                self._panel_b.width = self.width;
                self._panel_b.height = b_h;
                self._panel_b.x = 0;
                self._panel_b.y = a_h + self._splitter_width;
            }
            self._split_position = a_h;
        }
        return 0;
    }

    fn startDrag() {
        self._splitter_dragging = true;
        return 0;
    }

    fn dragTo(value) {
        if (not self._splitter_dragging) { return 0; }
        if (self._orientation == "horizontal") {
            self._split_position = value;
            self._split_ratio = value / (self.width - self._splitter_width);
        } else {
            self._split_position = value;
            self._split_ratio = value / (self.height - self._splitter_width);
        }
        self.setSplitRatio(self._split_ratio);
        return 0;
    }

    fn endDrag() {
        self._splitter_dragging = false;
        return 0;
    }

    fn isDragging() {
        return self._splitter_dragging;
    }

    fn getSplitPosition() {
        return self._split_position;
    }

    fn setSplitterColor(color) {
        self._splitter_color = color;
        return 0;
    }
}

class CollapsibleSplitContainer extends SplitContainer {
    let _panel_a_collapsed = false;
    let _panel_b_collapsed = false;
    let _collapse_button_size = 16;
    let _show_collapse_buttons = true;
    let _collapsed_size = 30;

    fn init_csc() {
        self.init_sc();
        self.widget_type = "CollapsibleSplitContainer";
        self._panel_a_collapsed = false;
        self._panel_b_collapsed = false;
        self._collapse_button_size = 16;
        self._show_collapse_buttons = true;
        self._collapsed_size = 30;
        return 0;
    }

    fn collapsePanelA() {
        self._panel_a_collapsed = true;
        self._panel_b_collapsed = false;
        if (self._orientation == "horizontal") {
            self._split_position = self._collapsed_size;
            if (self._panel_a != nullptr) {
                self._panel_a.width = self._collapsed_size;
            }
            if (self._panel_b != nullptr) {
                self._panel_b.x = self._collapsed_size + self._splitter_width;
                self._panel_b.width = self.width - self._collapsed_size - self._splitter_width;
            }
        } else {
            self._split_position = self._collapsed_size;
            if (self._panel_a != nullptr) {
                self._panel_a.height = self._collapsed_size;
            }
            if (self._panel_b != nullptr) {
                self._panel_b.y = self._collapsed_size + self._splitter_width;
                self._panel_b.height = self.height - self._collapsed_size - self._splitter_width;
            }
        }
        return 0;
    }

    fn collapsePanelB() {
        self._panel_b_collapsed = true;
        self._panel_a_collapsed = false;
        let total = 0;
        if (self._orientation == "horizontal") { total = self.width; }
        else { total = self.height; }
        self._split_position = total - self._collapsed_size - self._splitter_width;
        if (self._orientation == "horizontal") {
            if (self._panel_a != nullptr) {
                self._panel_a.width = self.width - self._collapsed_size - self._splitter_width;
            }
            if (self._panel_b != nullptr) {
                self._panel_b.x = self.width - self._collapsed_size;
                self._panel_b.width = self._collapsed_size;
            }
        } else {
            if (self._panel_a != nullptr) {
                self._panel_a.height = self.height - self._collapsed_size - self._splitter_width;
            }
            if (self._panel_b != nullptr) {
                self._panel_b.y = self.height - self._collapsed_size;
                self._panel_b.height = self._collapsed_size;
            }
        }
        return 0;
    }

    fn expandAll() {
        self._panel_a_collapsed = false;
        self._panel_b_collapsed = false;
        self._layout();
        return 0;
    }

    fn isPanelACollapsed() {
        return self._panel_a_collapsed;
    }

    fn isPanelBCollapsed() {
        return self._panel_b_collapsed;
    }

    fn togglePanelA() {
        if (self._panel_a_collapsed) {
            self.expandAll();
        } else {
            self.collapsePanelA();
        }
        return 0;
    }

    fn togglePanelB() {
        if (self._panel_b_collapsed) {
            self.expandAll();
        } else {
            self.collapsePanelB();
        }
        return 0;
    }

    fn setCollapsedSize(size) {
        self._collapsed_size = size;
        return 0;
    }

    fn getCollapsedSize() {
        return self._collapsed_size;
    }
}

class TabbedPanel extends zzwUI {
    let _tabs = [];
    let _active_index = 0;
    let _tab_position = "top";
    let _tab_height = 32;
    let _tab_width = 120;
    let _scrollable = false;
    let _tab_offset = 0;

    fn init_tp() {
        self.init(str(hwdui_next_id()));
        self.widget_type = "TabbedPanel";
        self.width = 500;
        self.height = 400;
        self._tabs = [];
        self._active_index = 0;
        self._tab_position = "top";
        self._tab_height = 32;
        self._tab_width = 120;
        self._scrollable = false;
        self._tab_offset = 0;
        return 0;
    }

    fn addTab(title, widget) {
        let tab = {"title": title, "widget": widget, "closable": false, "tooltip": ""};
        push(self._tabs, tab);
        if (len(self._tabs) == 1) {
            self._active_index = 0;
            if (widget != nullptr) {
                self.add_child(widget);
            }
        }
        return 0;
    }

    fn removeTab(index) {
        if (index < 0 or index >= len(self._tabs)) { return 0; }
        if (self._tabs[index]["widget"] != nullptr) {
            self.remove_child(self._tabs[index]["widget"]);
        }
        let new_tabs = [];
        let i = 0;
        while (i < len(self._tabs)) {
            if (i != index) { push(new_tabs, self._tabs[i]); }
            i = i + 1;
        }
        self._tabs = new_tabs;
        if (self._active_index >= len(self._tabs)) {
            self._active_index = len(self._tabs) - 1;
        }
        return 0;
    }

    fn selectTab(index) {
        if (index < 0 or index >= len(self._tabs)) { return 0; }
        if (self._active_index < len(self._tabs) and self._tabs[self._active_index]["widget"] != nullptr) {
            self._tabs[self._active_index]["widget"].visible = false;
        }
        self._active_index = index;
        if (self._tabs[index]["widget"] != nullptr) {
            self._tabs[index]["widget"].visible = true;
        }
        return 0;
    }

    fn getActiveIndex() {
        return self._active_index;
    }

    fn getActiveWidget() {
        if (self._active_index >= 0 and self._active_index < len(self._tabs)) {
            return self._tabs[self._active_index]["widget"];
        }
        return nullptr;
    }

    fn getTabCount() {
        return len(self._tabs);
    }

    fn setTabPosition(pos) {
        self._tab_position = pos;
        return 0;
    }

    fn getTabPosition() {
        return self._tab_position;
    }

    fn setScrollable(scrollable) {
        self._scrollable = scrollable;
        return 0;
    }

    fn scrollTabs(offset) {
        self._tab_offset = self._tab_offset + offset;
        if (self._tab_offset < 0) { self._tab_offset = 0; }
        return 0;
    }
}

class StackedPanel extends zzwUI {
    let _panels = [];
    let _active_index = 0;
    let _transition_type = "slide";
    let _transition_duration = 300;
    let _auto_size = true;
    let _clip_content = true;

    fn init_stp() {
        self.init(str(hwdui_next_id()));
        self.widget_type = "StackedPanel";
        self.width = 500;
        self.height = 400;
        self._panels = [];
        self._active_index = 0;
        self._transition_type = "slide";
        self._transition_duration = 300;
        self._auto_size = true;
        self._clip_content = true;
        return 0;
    }

    fn addPanel(widget) {
        widget.visible = false;
        push(self._panels, widget);
        self.add_child(widget);
        if (len(self._panels) == 1) {
            widget.visible = true;
        }
        return 0;
    }

    fn removePanel(widget) {
        let new_panels = [];
        let removed_idx = -1;
        let i = 0;
        while (i < len(self._panels)) {
            if (self._panels[i] == widget) {
                removed_idx = i;
                self.remove_child(widget);
            } else {
                push(new_panels, self._panels[i]);
            }
            i = i + 1;
        }
        self._panels = new_panels;
        if (self._active_index >= len(self._panels)) {
            self._active_index = len(self._panels) - 1;
        }
        if (self._active_index < 0) { self._active_index = 0; }
        return 0;
    }

    fn setActiveIndex(index) {
        if (index < 0 or index >= len(self._panels)) { return 0; }
        if (self._active_index < len(self._panels)) {
            self._panels[self._active_index].visible = false;
        }
        self._active_index = index;
        self._panels[index].visible = true;
        return 0;
    }

    fn getActiveIndex() {
        return self._active_index;
    }

    fn getActivePanel() {
        if (self._active_index >= 0 and self._active_index < len(self._panels)) {
            return self._panels[self._active_index];
        }
        return nullptr;
    }

    fn getPanelCount() {
        return len(self._panels);
    }

    fn setTransition(type) {
        self._transition_type = type;
        return 0;
    }

    fn getTransition() {
        return self._transition_type;
    }

    fn next() {
        if (self._active_index + 1 < len(self._panels)) {
            self.setActiveIndex(self._active_index + 1);
        }
        return 0;
    }

    fn previous() {
        if (self._active_index - 1 >= 0) {
            self.setActiveIndex(self._active_index - 1);
        }
        return 0;
    }

    fn setAutoSize(auto_size) {
        self._auto_size = auto_size;
        return 0;
    }
}

class DragThumb extends zzwUI {
    let _target = nullptr;
    let _drag_data = nullptr;
    let _is_dragging = false;
    let _drag_offset_x = 0;
    let _drag_offset_y = 0;
    let _thumb_color = "#888888";
    let _thumb_size = 20;
    let _allowed_directions = "xy";

    fn init_dthumb(target) {
        self.init(str(hwdui_next_id()));
        self.widget_type = "DragThumb";
        self.width = 20;
        self.height = 20;
        self._target = target;
        self._drag_data = nullptr;
        self._is_dragging = false;
        self._drag_offset_x = 0;
        self._drag_offset_y = 0;
        self._thumb_color = "#888888";
        self._thumb_size = 20;
        self._allowed_directions = "xy";
        return 0;
    }

    fn setTarget(target) {
        self._target = target;
        return 0;
    }

    fn getTarget() {
        return self._target;
    }

    fn setDragData(data) {
        self._drag_data = data;
        return 0;
    }

    fn getDragData() {
        return self._drag_data;
    }

    fn startDrag(mx, my) {
        self._is_dragging = true;
        if (self._target != nullptr) {
            self._drag_offset_x = mx - self._target.x;
            self._drag_offset_y = my - self._target.y;
        }
        return 0;
    }

    fn drag(mx, my) {
        if (not self._is_dragging or self._target == nullptr) { return 0; }
        if (self._allowed_directions == "xy" or self._allowed_directions == "x") {
            self._target.x = mx - self._drag_offset_x;
        }
        if (self._allowed_directions == "xy" or self._allowed_directions == "y") {
            self._target.y = my - self._drag_offset_y;
        }
        return 0;
    }

    fn endDrag() {
        self._is_dragging = false;
        return 0;
    }

    fn isDragging() {
        return self._is_dragging;
    }

    fn setAllowedDirections(dirs) {
        self._allowed_directions = dirs;
        return 0;
    }

    fn setThumbSize(size) {
        self._thumb_size = size;
        self.width = size;
        self.height = size;
        return 0;
    }

    fn setThumbColor(color) {
        self._thumb_color = color;
        return 0;
    }
}

