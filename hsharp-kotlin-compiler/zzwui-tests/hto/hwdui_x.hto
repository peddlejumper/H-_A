class StackPanel extends Panel {
    let orientation = "vertical";
    let item_alignment = "stretch";
    let reverse = false;

    fn init_sp() {
        self.init_panel("vbox");
        self.widget_type = "StackPanel";
        self.orientation = "vertical";
        self.item_alignment = "stretch";
        self.reverse = false;
        return 0;
    }

    fn setOrientation(orient) {
        self.orientation = orient;
        if (orient == "horizontal") {
            self.layout_type = "hbox";
        } else {
            self.layout_type = "vbox";
        }
        return 0;
    }

    fn getOrientation() { return self.orientation; }

    fn setItemAlignment(align) { self.item_alignment = align; return 0; }

    fn getItemAlignment() { return self.item_alignment; }

    fn setReverse(rev) { self.reverse = rev; return 0; }

    fn getReverse() { return self.reverse; }

    fn stackChildren() {
        self.do_layout();
        return 0;
    }
}

class WrapPanel extends Panel {
    let orientation = "horizontal";
    let item_width = 0;
    let item_height = 0;
    let spacing_x = 4;
    let spacing_y = 4;

    fn init_wp() {
        self.init_panel("absolute");
        self.widget_type = "WrapPanel";
        self.orientation = "horizontal";
        self.item_width = 0;
        self.item_height = 0;
        self.spacing_x = 4;
        self.spacing_y = 4;
        return 0;
    }

    fn setOrientation(orient) { self.orientation = orient; return 0; }

    fn getOrientation() { return self.orientation; }

    fn setItemSize(w, h) {
        self.item_width = w;
        self.item_height = h;
        return 0;
    }

    fn getItemSize() { return {"width": self.item_width, "height": self.item_height}; }

    fn setSpacingX(sx) { self.spacing_x = sx; return 0; }

    fn setSpacingY(sy) { self.spacing_y = sy; return 0; }

    fn do_layout() {
        let cur_x = self._hwdui_pad_left;
        let cur_y = self._hwdui_pad_top;
        let __iter30 = self.children;
        let __i30 = 0;
        while (__i30 < len(__iter30)) {
            let child = __iter30[__i30];
            if (child.visible == false) { continue; }
            if (self.orientation == "horizontal") {
                if (cur_x + child.width > self.width - self._hwdui_pad_right) {
                    cur_x = self._hwdui_pad_left;
                    cur_y = cur_y + child.height + self.spacing_y;
                }
                child.x = cur_x;
                child.y = cur_y;
                cur_x = cur_x + child.width + self.spacing_x;
            } else {
                if (cur_y + child.height > self.height - self._hwdui_pad_bottom) {
                    cur_y = self._hwdui_pad_top;
                    cur_x = cur_x + child.width + self.spacing_x;
                }
                child.x = cur_x;
                child.y = cur_y;
                cur_y = cur_y + child.height + self.spacing_y;
            }
            __i30 = __i30 + 1;
        }
        return 0;
    }
}

class UniformGrid extends zzwUI {
    let rows = 2;
    let columns = 2;
    let cell_width = 100;
    let cell_height = 100;
    let spacing_x = 4;
    let spacing_y = 4;

    fn init_ug(rows, cols) {
        self.init("");
        self.widget_type = "UniformGrid";
        self.rows = rows;
        self.columns = cols;
        self.cell_width = 100;
        self.cell_height = 100;
        self.spacing_x = 4;
        self.spacing_y = 4;
        return 0;
    }

    fn setRows(r) { self.rows = r; return 0; }

    fn getRows() { return self.rows; }

    fn setColumns(c) { self.columns = c; return 0; }

    fn getColumns() { return self.columns; }

    fn setCellSize(w, h) {
        self.cell_width = w;
        self.cell_height = h;
        return 0;
    }

    fn getCellSize() { return {"width": self.cell_width, "height": self.cell_height}; }

    fn setSpacing(sx, sy) {
        self.spacing_x = sx;
        self.spacing_y = sy;
        return 0;
    }

    fn getSpacing() { return {"x": self.spacing_x, "y": self.spacing_y}; }

    fn layout() {
        let idx = 0;
        let r = 0;
        while (r < self.rows) {
            let c = 0;
            while (c < self.columns) {
                if (idx < len(self.children)) {
                    let child = self.children[idx];
                    child.x = self._hwdui_pad_left + c * (self.cell_width + self.spacing_x);
                    child.y = self._hwdui_pad_top + r * (self.cell_height + self.spacing_y);
                    child.width = self.cell_width;
                    child.height = self.cell_height;
                }
                idx = idx + 1;
                c = c + 1;
            }
            r = r + 1;
        }
        return 0;
    }
}

class ViewBox extends zzwUI {
    let content = nullptr;
    let stretch = "uniform";
    let stretch_direction = "both";

    fn init_vb() {
        self.init("");
        self.widget_type = "ViewBox";
        self.content = nullptr;
        self.stretch = "uniform";
        self.stretch_direction = "both";
        return 0;
    }

    fn setContent(widget) {
        self.content = widget;
        if (widget != nullptr) {
            self.add_child(widget);
        }
        return 0;
    }

    fn getContent() { return self.content; }

    fn setStretch(s) { self.stretch = s; return 0; }

    fn getStretch() { return self.stretch; }

    fn setStretchDirection(d) { self.stretch_direction = d; return 0; }

    fn getStretchDirection() { return self.stretch_direction; }

    fn do_layout() {
        if (self.content == nullptr) { return 0; }
        let scale_x = self.width * 100 / self.content.width;
        let scale_y = self.height * 100 / self.content.height;
        if (self.stretch == "uniform") {
            let s = scale_x;
            if (scale_y < scale_x) { s = scale_y; }
            scale_x = s;
            scale_y = s;
        }
        if (self.stretch == "uniformToFill") {
            let s = scale_x;
            if (scale_y > scale_x) { s = scale_y; }
            scale_x = s;
            scale_y = s;
        }
        self.content.x = self.x;
        self.content.y = self.y;
        self.content.width = self.content.width * scale_x / 100;
        self.content.height = self.content.height * scale_y / 100;
        return 0;
    }
}

