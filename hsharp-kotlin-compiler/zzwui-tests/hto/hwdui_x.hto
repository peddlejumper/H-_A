    }

    fn startRecording() { self._recording = true; self._keys = []; return 0; }
    fn stopRecording() { self._recording = false; return 0; }
    fn isRecording() { return self._recording; }
    fn recordKey(key_name) { if (not self._recording) { return 0; } push(self._keys, key_name); return 0; }
    fn getSequence() { let seq = ""; if (self._modifiers["ctrl"]) { seq = seq + "Ctrl+"; } if (self._modifiers["shift"]) { seq = seq + "Shift+"; } if (self._modifiers["alt"]) { seq = seq + "Alt+"; } let i = 0; while (i < len(self._keys)) { if (i > 0) { seq = seq + "+"; } seq = seq + self._keys[i]; i = i + 1; } return seq; }
    fn getKeys() { return self._keys; }
    fn getKeyCount() { return len(self._keys); }
    fn setModifier(name, pressed) { if (self._modifiers[name] != nullptr) { self._modifiers[name] = pressed; } return 0; }
    fn clear() { self._keys = []; self._modifiers = {"ctrl": false, "shift": false, "alt": false, "meta": false}; return 0; }
}

class ExpressionInput extends zzwUI {
    let _expression = "";
    let _result = "";
    let _variables = {};

    fn init_ei() {
        self.init(str(hwdui_next_id()));
        self.widget_type = "ExpressionInput";
        self.width = 250;
        self.height = 30;
        self._expression = "";
        self._result = "";
        self._variables = {};
        return 0;
    }

    fn setExpression(expr) { self._expression = expr; return 0; }
    fn getExpression() { return self._expression; }
    fn evaluate() { self._result = hwdui_eval_expression(self._expression, self._variables); return self._result; }
    fn getResult() { return self._result; }
    fn setVariable(name, value) { self._variables[name] = value; return 0; }
    fn getVariable(name) { if (self._variables[name] != nullptr) { return self._variables[name]; } return 0; }
    fn clear() { self._expression = ""; self._result = ""; return 0; }
}

class RegexInput extends zzwUI {
    let _pattern = "";
    let _test_string = "";
    let _match_result = false;
    let _matches = [];

    fn init_regi() {
        self.init(str(hwdui_next_id()));
        self.widget_type = "RegexInput";
        self.width = 250;
        self.height = 30;
        self._pattern = "";
        self._test_string = "";
        self._match_result = false;
        self._matches = [];
        return 0;
    }

    fn setPattern(pattern) { self._pattern = pattern; return 0; }
    fn getPattern() { return self._pattern; }
    fn setTestString(str_val) { self._test_string = str_val; return 0; }
    fn getTestString() { return self._test_string; }
    fn test() { self._match_result = hwdui_regex_match(self._test_string, self._pattern); return self._match_result; }
    fn getMatches() { if (self._match_result) { self._matches = hwdui_regex_find_all(self._test_string, self._pattern); } else { self._matches = []; } return self._matches; }
    fn getMatchCount() { return len(self._matches); }
    fn replace(replacement) { return hwdui_regex_replace(self._test_string, self._pattern, replacement); }
    fn clear() { self._pattern = ""; self._test_string = ""; self._match_result = false; self._matches = []; return 0; }
}

