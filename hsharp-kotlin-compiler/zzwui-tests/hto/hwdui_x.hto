class NumericUpDown extends zzwUI {
    let val = 0;
    let min_val = 0;
    let max_val = 100;
    let step = 1;
    let decimals = 0;
    let thousands_sep = false;
    let hex_mode = false;
    let onValueChanged = nullptr;

    fn init_nud(minv, maxv, initv) {
        self.init("");
        self.widget_type = "NumericUpDown";
        self.min_val = minv;
        self.max_val = maxv;
        self.val = initv;
        self.step = 1;
        self.decimals = 0;
        self.thousands_sep = false;
        self.hex_mode = false;
        return 0;
    }

    fn setValue(v) {
        if (v < self.min_val) { v = self.min_val; }
        if (v > self.max_val) { v = self.max_val; }
        self.val = v;
        if (self.onValueChanged != nullptr) { self.onValueChanged(self, self.val); }
        return 0;
    }

    fn getValue() { return self.val; }

    fn setRange(minv, maxv) {
        self.min_val = minv;
        self.max_val = maxv;
        if (self.val < minv) { self.val = minv; }
        if (self.val > maxv) { self.val = maxv; }
        return 0;
    }

    fn setStep(st) {
        self.step = st;
        return 0;
    }

    fn setDecimals(d) {
        self.decimals = d;
        return 0;
    }

    fn increment() {
        self.setValue(self.val + self.step);
        return 0;
    }

    fn decrement() {
        self.setValue(self.val - self.step);
        return 0;
    }

    fn setThousandsSeparator(use) {
        self.thousands_sep = use;
        return 0;
    }

    fn setHexMode(use) {
        self.hex_mode = use;
        return 0;
    }

    fn setOnValueChanged(callback) {
        self.onValueChanged = callback;
        return 0;
    }

    fn getText() {
        if (self.hex_mode) { return "0x" + str(self.val); }
        return str(self.val);
    }
}

class MaskedTextBox extends TextBox {
    let mask = "";
    let prompt_char = "_";
    let include_literals = true;
    let ascii_only = false;

    fn init_mtb(mask_pattern) {
        self.init_tb("");
        self.widget_type = "MaskedTextBox";
        self.mask = mask_pattern;
        self.prompt_char = "_";
        self.include_literals = true;
        return 0;
    }

    fn setMask(m) {
        self.mask = m;
        self.clear();
        return 0;
    }

    fn getMask() { return self.mask; }

    fn setPromptChar(ch) {
        self.prompt_char = ch;
        return 0;
    }

    fn getPromptChar() { return self.prompt_char; }

    fn setIncludeLiterals(include) {
        self.include_literals = include;
        return 0;
    }

    fn setAsciiOnly(ascii) {
        self.ascii_only = ascii;
        return 0;
    }

    fn getRawText() {
        let result = "";
        let i = 0;
        while (i < len(self.text)) {
            let ch = self.text[i];
            if (ch != self.prompt_char and ch != " " and ch != "-" and ch != "(" and ch != ")") {
                result = result + ch;
            }
            i = i + 1;
        }
        return result;
    }

    fn isComplete() {
        let i = 0;
        while (i < len(self.text)) {
            if (self.text[i] == self.prompt_char) { return false; }
            i = i + 1;
        }
        return true;
    }
}

class AutoCompleteBox extends TextBox {
    let items = [];
    let filtered_items = [];
    let is_open = false;
    let max_drop_height = 200;
    let min_chars = 1;
    let filter_mode = "starts_with";
    let onSelectionChanged = nullptr;
    let onFilter = nullptr;

    fn init_acb() {
        self.init_tb("");
        self.widget_type = "AutoCompleteBox";
        self.items = [];
        self.filtered_items = [];
        self.is_open = false;
        self.min_chars = 1;
        return 0;
    }

    fn setItems(item_list) {
        self.items = item_list;
        return 0;
    }

    fn addItem(item) {
        push(self.items, item);
        return 0;
    }

    fn addItems(item_list) {
        let i = 0;
        while (i < len(item_list)) {
            push(self.items, item_list[i]);
            i = i + 1;
        }
        return 0;
    }

    fn removeItem(index) {
        let new_items = [];
        let i = 0;
        while (i < len(self.items)) {
            if (i != index) { push(new_items, self.items[i]); }
            i = i + 1;
        }
        self.items = new_items;
        return 0;
    }

    fn clearItems() {
        self.items = [];
        self.filtered_items = [];
        return 0;
    }

    fn getItems() { return self.items; }

    fn getItemCount() { return len(self.items); }

    fn setFilterMode(mode) {
        self.filter_mode = mode;
        return 0;
    }

    fn setMinChars(n) {
        self.min_chars = n;
        return 0;
    }

    fn filter(text) {
        if (len(text) < self.min_chars) {
            self.filtered_items = [];
            self.is_open = false;
            return 0;
        }
        if (self.onFilter != nullptr) {
            self.onFilter(self, text);
            return 0;
        }
        let filtered = [];
        let i = 0;
        while (i < len(self.items)) {
            let item = self.items[i];
            let match = false;
            if (self.filter_mode == "starts_with") {
                let j = 0;
                while (j < len(text) and j < len(item)) {
                    if (text[j] != item[j]) { break; }
                    j = j + 1;
                }
                if (j == len(text)) { match = true; }
            } else if (self.filter_mode == "contains") {
                let j = 0;
                while (j < len(item)) {
                    let k = 0;
                    while (k < len(text) and j + k < len(item) and item[j+k] == text[k]) {
                        k = k + 1;
                    }
                    if (k == len(text)) { match = true; break; }
                    j = j + 1;
                }
            }
            if (match) { push(filtered, item); }
            i = i + 1;
        }
        self.filtered_items = filtered;
        self.is_open = len(filtered) > 0;
        return 0;
    }

    fn getFilteredItems() { return self.filtered_items; }

    fn getFilteredCount() { return len(self.filtered_items); }

    fn selectItem(index) {
        if (index >= 0 and index < len(self.filtered_items)) {
            self.set_text(self.filtered_items[index]);
            self.is_open = false;
            if (self.onSelectionChanged != nullptr) {
                self.onSelectionChanged(self, self.filtered_items[index]);
            }
        }
        return 0;
    }

    fn isOpen() { return self.is_open; }

    fn closePopup() {
        self.is_open = false;
        return 0;
    }

    fn setOnSelectionChanged(callback) {
        self.onSelectionChanged = callback;
        return 0;
    }

    fn setOnFilter(callback) {
        self.onFilter = callback;
        return 0;
    }
}

class RichTextBox extends zzwUI {
    let text = "";
    let readonly = false;
    let word_wrap = true;
    let show_line_numbers = false;
    let line_count = 0;
    let scroll_x = 0;
    let scroll_y = 0;
    let cursor_line = 0;
    let cursor_col = 0;
    let selection_start_line = 0;
    let selection_start_col = 0;
    let selection_end_line = 0;
    let selection_end_col = 0;
    let onTextChanged = nullptr;
    let onSelectionChanged = nullptr;

    fn init_rtb() {
        self.init("");
        self.widget_type = "RichTextBox";
        self.text = "";
        self.readonly = false;
        self.word_wrap = true;
        self.show_line_numbers = false;
        self.line_count = 1;
        return 0;
    }

    fn setText(t) {
        self.text = t;
        if (self.onTextChanged != nullptr) { self.onTextChanged(self, t); }
        return 0;
    }

    fn getText() { return self.text; }

    fn appendText(t) {
        self.text = self.text + t;
        if (self.onTextChanged != nullptr) { self.onTextChanged(self, self.text); }
        return 0;
    }

    fn insertText(t, line, col) { return 0; }

    fn clear() {
        self.text = "";
        self.line_count = 1;
        return 0;
    }

    fn getLineCount() { return self.line_count; }

    fn getLine(index) { return "TODO"; }

    fn setReadonly(ro) {
        self.readonly = ro;
        return 0;
    }

    fn isReadonly() { return self.readonly; }

    fn setWordWrap(wrap) {
        self.word_wrap = wrap;
        return 0;
    }

    fn setShowLineNumbers(show) {
        self.show_line_numbers = show;
        return 0;
    }

    fn selectAll() {
        self.selection_start_line = 0;
        self.selection_start_col = 0;
        self.selection_end_line = self.line_count - 1;
        return 0;
    }

    fn getSelectedText() { return "TODO"; }

    fn copy() { return self.getSelectedText(); }

    fn cut() { return self.getSelectedText(); }

    fn paste(txt) { return 0; }

    fn undo() { return 0; }

    fn redo() { return 0; }

    fn canUndo() { return false; }

    fn canRedo() { return false; }

    fn getCursorPosition() {
        return {"line": self.cursor_line, "column": self.cursor_col};
    }

    fn setCursorPosition(line, col) {
        self.cursor_line = line;
        self.cursor_col = col;
        return 0;
    }

    fn findText(search_text) { return -1; }

    fn replaceText(search_text, replace_text) { return 0; }

    fn replaceAll(search_text, replace_text) { return 0; }

    fn getTextLength() { return len(self.text); }

    fn scrollTo(line) {
        self.scroll_y = line;
        return 0;
    }

    fn setOnTextChanged(callback) {
        self.onTextChanged = callback;
        return 0;
    }

    fn setOnSelectionChanged(callback) {
        self.onSelectionChanged = callback;
        return 0;
    }
}

