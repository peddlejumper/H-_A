class ProgressDialog extends Dialog {
    let progress = 0;
    let message = "";
    let cancellable = true;
    let is_cancelled = false;
    let onCancel = nullptr;
    let title_text = "";

    fn init_pdlg(dlg_title, msg) {
        self.init_dlg(dlg_title, 400, 140);
        self.widget_type = "ProgressDialog";
        self.progress = 0;
        self.message = msg;
        self.cancellable = true;
        self.is_cancelled = false;
        self.title_text = dlg_title;
        return 0;
    }

    fn setProgress(p) {
        self.progress = p;
        if (p < 0) { self.progress = 0; }
        if (p > 100) { self.progress = 100; }
        return 0;
    }

    fn getProgress() { return self.progress; }

    fn setMessage(msg) { self.message = msg; return 0; }

    fn getMessage() { return self.message; }

    fn setCancellable(c) { self.cancellable = c; return 0; }

    fn isCancellable() { return self.cancellable; }

    fn cancel() {
        self.is_cancelled = true;
        if (self.onCancel != nullptr) { self.onCancel(self); }
        return 0;
    }

    fn isCancelled() { return self.is_cancelled; }

    fn setOnCancel(callback) { self.onCancel = callback; return 0; }

    fn incrementProgress(amount) {
        self.progress = self.progress + amount;
        if (self.progress > 100) { self.progress = 100; }
        return 0;
    }
}

