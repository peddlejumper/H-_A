class VirtualizingStackPanel extends zzwUI {
    let _items = [];
    let _item_height = 30;
    let _visible_start = 0;
    let _visible_end = 0;
    let _scroll_offset = 0;
    let _cache = {};
    let _total_height = 0;
    let _recycling = true;

    fn init_vsp() {
        self.init(str(hwdui_next_id()));
        self.widget_type = "VirtualizingStackPanel";
        self.width = 300;
        self.height = 400;
        self._items = [];
        self._item_height = 30;
        self._visible_start = 0;
        self._visible_end = 0;
        self._scroll_offset = 0;
        self._cache = {};
        self._total_height = 0;
        self._recycling = true;
        return 0;
    }

    fn setItems(items) {
        self._items = items;
        self._total_height = len(items) * self._item_height;
        self._updateVisibleRange();
        return 0;
    }

    fn setItemHeight(h) {
        self._item_height = h;
        self._total_height = len(self._items) * h;
        self._updateVisibleRange();
        return 0;
    }

    fn getItemHeight() {
        return self._item_height;
    }

    fn scrollTo(offset) {
        self._scroll_offset = offset;
        if (self._scroll_offset < 0) { self._scroll_offset = 0; }
        let max_offset = self._total_height - self.height;
        if (max_offset < 0) { max_offset = 0; }
        if (self._scroll_offset > max_offset) { self._scroll_offset = max_offset; }
        self._updateVisibleRange();
        return 0;
    }

    fn _updateVisibleRange() {
        self._visible_start = self._scroll_offset / self._item_height;
        self._visible_end = (self._scroll_offset + self.height) / self._item_height + 1;
        if (self._visible_end > len(self._items)) {
            self._visible_end = len(self._items);
        }
        return 0;
    }

    fn getVisibleRange() {
        return {"start": self._visible_start, "end": self._visible_end};
    }

    fn getItemAt(index) {
        if (index < 0 or index >= len(self._items)) { return nullptr; }
        return self._items[index];
    }

    fn getTotalHeight() {
        return self._total_height;
    }

    fn getItemY(index) {
        return index * self._item_height - self._scroll_offset;
    }

    fn isItemVisible(index) {
        return index >= self._visible_start and index < self._visible_end;
    }

    fn setRecyclingEnabled(enabled) {
        self._recycling = enabled;
        return 0;
    }

    fn getItemCount() {
        return len(self._items);
    }
}

