class Canvas extends zzwUI {
    let x = 0;
    let y = 0;
    let width = 0;
    let height = 0;
    let visible = true;
    let enabled = true;
    let parent = nullptr;
    let widget_type = "Canvas";
    let lines = [];
    let rects = [];
    let circles = [];
    let texts = [];
    let images = [];

    fn init_canvas(w, h) {
        self.init("");
        self.widget_type = "Canvas";
        self.width = w;
        self.height = h;
        self.lines = [];
        self.rects = [];
        self.circles = [];
        self.texts = [];
        self.images = [];
        return 0;
    }

    fn drawLine(x1, y1, x2, y2, color, line_width) {
        push(self.lines, {"x1": x1, "y1": y1, "x2": x2, "y2": y2, "color": color, "width": line_width});
        return 0;
    }

    fn drawRect(x, y, w, h, color, fill, line_width) {
        push(self.rects, {"x": x, "y": y, "width": w, "height": h, "color": color, "fill": fill, "width": line_width});
        return 0;
    }

    fn fillRect(x, y, w, h, color) {
        push(self.rects, {"x": x, "y": y, "width": w, "height": h, "color": color, "fill": true, "width": 0});
        return 0;
    }

    fn drawCircle(cx, cy, r, color, fill, line_width) {
        push(self.circles, {"cx": cx, "cy": cy, "radius": r, "color": color, "fill": fill, "width": line_width});
        return 0;
    }

    fn fillCircle(cx, cy, r, color) {
        push(self.circles, {"cx": cx, "cy": cy, "radius": r, "color": color, "fill": true, "width": 0});
        return 0;
    }

    fn drawText(x, y, text, color, size) {
        push(self.texts, {"x": x, "y": y, "text": text, "color": color, "size": size});
        return 0;
    }

    fn drawImage(x, y, w, h, path) {
        push(self.images, {"x": x, "y": y, "width": w, "height": h, "path": path});
        return 0;
    }

    fn clear() {
        self.lines = [];
        self.rects = [];
        self.circles = [];
        self.texts = [];
        self.images = [];
        return 0;
    }
}

class GridPanel extends zzwUI {
    let x = 0;
    let y = 0;
    let width = 0;
    let height = 0;
    let visible = true;
    let enabled = true;
    let parent = nullptr;
    let widget_type = "GridPanel";
    let rows = 0;
    let cols = 0;
    let row_heights = [];
    let col_widths = [];
    let row_spacing = 0;
    let col_spacing = 0;
    let grid_children = [];

    fn init_grid(r, c) {
        self.init("");
        self.widget_type = "GridPanel";
        self.rows = r;
        self.cols = c;
        self.row_heights = [];
        self.col_widths = [];
        self.row_spacing = 0;
        self.col_spacing = 0;
        self.grid_children = [];
        let ri = 0;
        while (ri < r) {
            push(self.row_heights, 0);
            ri = ri + 1;
        }
        let ci = 0;
        while (ci < c) {
            push(self.col_widths, 0);
            ci = ci + 1;
        }
        return 0;
    }

    fn setRowHeight(row, h) {
        if (row >= 0 and row < len(self.row_heights)) {
            self.row_heights[row] = h;
        }
        return 0;
    }

    fn setColWidth(col, w) {
        if (col >= 0 and col < len(self.col_widths)) {
            self.col_widths[col] = w;
        }
        return 0;
    }

    fn setSpacing(rs, cs) {
        self.row_spacing = rs;
        self.col_spacing = cs;
        return 0;
    }

    fn addChildAt(child, row, col) {
        push(self.grid_children, {"widget": child, "row": row, "col": col});
        self.add_child(child);
        return 0;
    }

    fn do_layout() {
        let __iter28 = self.grid_children;
        let __i28 = 0;
        while (__i28 < len(__iter28)) {
            let gc = __iter28[__i28];
            let r = gc["row"];
            let c = gc["col"];
            let widget = gc["widget"];
            let col_x = self._hwdui_pad_left;
            let ci = 0;
            while (ci < c) {
                col_x = col_x + self.col_widths[ci] + self.col_spacing;
                ci = ci + 1;
            }
            widget.x = col_x;
            let row_y = self._hwdui_pad_top;
            let ri = 0;
            while (ri < r) {
                row_y = row_y + self.row_heights[ri] + self.row_spacing;
                ri = ri + 1;
            }
            widget.y = row_y;
            __i28 = __i28 + 1;
        }
        return 0;
    }
}

class Timer {
    let interval_ms = 0;
    let callback = nullptr;
    let running = false;
    let elapsed = 0;
    let repeats = true;

    fn init_timer(ms, fn_ref) {
        self.interval_ms = ms;
        self.callback = fn_ref;
        self.running = false;
        self.elapsed = 0;
        self.repeats = true;
        push(_hwdui_all_timers, self);
        return 0;
    }

    fn start() {
        self.running = true;
        self.elapsed = 0;
        return 0;
    }

    fn stop() {
        self.running = false;
        return 0;
    }

    fn restart() {
        self.elapsed = 0;
        self.running = true;
        return 0;
    }

    fn isRunning() {
        return self.running;
    }

    fn setInterval(ms) {
        self.interval_ms = ms;
        return 0;
    }

    fn setRepeats(r) {
        self.repeats = r;
        return 0;
    }

    fn _tick(delta_ms) {
        if (self.running == false) { return 0; }
        self.elapsed = self.elapsed + delta_ms;
        if (self.elapsed >= self.interval_ms) {
            if (self.callback != nullptr) {
                self.callback(self);
            }
            if (self.repeats == false) {
                self.running = false;
            } else {
                self.elapsed = 0;
            }
        }
        return 0;
    }
}

