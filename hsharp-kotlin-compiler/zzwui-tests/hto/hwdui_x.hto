class CaptchaInput extends zzwUI {
    let _value = "";
    let _captcha_text = "";
    let _captcha_length = 6;
    let _character_set = "ABCDEFGHJKLMNPQRSTUVWXYZ23456789";
    let _case_sensitive = false;

    fn init_capti() {
        self.init(str(hwdui_next_id()));
        self.widget_type = "CaptchaInput";
        self.width = 180;
        self.height = 30;
        self._value = "";
        self._captcha_text = "";
        self._captcha_length = 6;
        self._character_set = "ABCDEFGHJKLMNPQRSTUVWXYZ23456789";
        self._case_sensitive = false;
        self._generateCaptcha();
        return 0;
    }

    fn _generateCaptcha() { self._captcha_text = ""; let i = 0; while (i < self._captcha_length) { let idx = hwdui_random_int(0, len(self._character_set) - 1); self._captcha_text = self._captcha_text + self._character_set[idx]; i = i + 1; } return 0; }
    fn setValue(val) { self._value = val; return 0; }
    fn getValue() { return self._value; }
    fn refreshCaptcha() { self._generateCaptcha(); self._value = ""; return 0; }
    fn getCaptchaText() { return self._captcha_text; }
    fn verify() { let user_val = self._value; let expected = self._captcha_text; if (not self._case_sensitive) { user_val = hwdui_string_upper(user_val); expected = hwdui_string_upper(expected); } return user_val == expected; }
    fn clear() { self._value = ""; self._generateCaptcha(); return 0; }
}

class OTPInput extends zzwUI {
    let _digits = [];
    let _otp_length = 6;
    let _current_index = 0;
    let _masked = true;

    fn init_otpi() {
        self.init(str(hwdui_next_id()));
        self.widget_type = "OTPInput";
        self.width = 300;
        self.height = 40;
        self._digits = [];
        self._otp_length = 6;
        self._current_index = 0;
        self._masked = true;
        let i = 0;
        while (i < self._otp_length) { push(self._digits, ""); i = i + 1; }
        return 0;
    }

    fn setDigit(index, digit) { if (index < 0 or index >= self._otp_length) { return 0; } if (len(digit) > 1) { digit = digit[0]; } self._digits[index] = digit; if (digit != "") { self._current_index = index + 1; if (self._current_index >= self._otp_length) { self._current_index = self._otp_length; } } return 0; }
    fn getOTP() { let otp = ""; for __contains(self._digits, d) { otp = otp + d; } return otp; }
    fn isComplete() { for __contains(self._digits, d) { if (d == "") { return false; } } return true; }
    fn setLength(len_val) { self._otp_length = len_val; self._digits = []; let i = 0; while (i < len_val) { push(self._digits, ""); i = i + 1; } return 0; }
    fn clear() { let i = 0; while (i < len(self._digits)) { self._digits[i] = ""; i = i + 1; } self._current_index = 0; return 0; }
}

class PinInput extends zzwUI {
    let _digits = [];
    let _pin_length = 4;
    let _masked = true;
    let _max_attempts = 3;
    let _attempts = 0;
    let _locked = false;

    fn init_pini() {
        self.init(str(hwdui_next_id()));
        self.widget_type = "PinInput";
        self.width = 200;
        self.height = 40;
        self._digits = [];
        self._pin_length = 4;
        self._masked = true;
        self._max_attempts = 3;
        self._attempts = 0;
        self._locked = false;
        let i = 0;
        while (i < self._pin_length) { push(self._digits, ""); i = i + 1; }
        return 0;
    }

    fn addDigit(digit) { if (self._locked) { return 0; } let i = 0; while (i < len(self._digits)) { if (self._digits[i] == "") { if (len(digit) > 1) { digit = digit[0]; } self._digits[i] = digit; break; } i = i + 1; } return 0; }
    fn removeLastDigit() { let i = len(self._digits) - 1; while (i >= 0) { if (self._digits[i] != "") { self._digits[i] = ""; break; } i = i - 1; } return 0; }
    fn getPIN() { let pin = ""; for __contains(self._digits, d) { pin = pin + d; } return pin; }
    fn verifyPIN(expected_pin) { if (self._locked) { return false; } if (self.getPIN() == expected_pin) { self._attempts = 0; return true; } self._attempts = self._attempts + 1; if (self._attempts >= self._max_attempts) { self._locked = true; } return false; }
    fn isComplete() { for __contains(self._digits, d) { if (d == "") { return false; } } return true; }
    fn isLocked() { return self._locked; }
    fn unlock() { self._locked = false; self._attempts = 0; return 0; }
    fn clear() { let i = 0; while (i < len(self._digits)) { self._digits[i] = ""; i = i + 1; } self._attempts = 0; return 0; }
}

