class ExportManager {
    let _exporters = {};
    let _default_format = "pdf";

    fn init_em() { self._exporters = {}; self._default_format = "pdf"; return 0; }
    fn registerExporter(format, exporter) { self._exporters[format] = exporter; return 0; }
    fn unregisterExporter(format) { let new_exporters = {}; for __contains(self._exporters, key) { if (key != format) { new_exporters[key] = self._exporters[key]; } } self._exporters = new_exporters; return 0; }
    fn export(data, format, file_path) { if (self._exporters[format] != nullptr) { return self._exporters[format].export(data, file_path); } if (self._exporters[self._default_format] != nullptr) { return self._exporters[self._default_format].export(data, file_path); } return false; }
    fn getSupportedFormats() { let formats = []; for __contains(self._exporters, key) { push(formats, key); } return formats; }
    fn setDefaultFormat(format) { self._default_format = format; return 0; }
    fn clear() { self._exporters = {}; return 0; }
}

