# ═══════════════════════════════════════════════════════════════════════════
# PasswordBox — 密码输入框
# ═══════════════════════════════════════════════════════════════════════════
class PasswordBox extends TextBox {
    let echo_char = "*";
    let real_text = "";

    fn init_pw() {
        self.init_tb("");
        self.widget_type = "PasswordBox";
        self.echo_char = "*";
        self.real_text = "";
        return 0;
    }

    fn setText(t) {
        self.real_text = t;
        let masked = "";
        let i = 0;
        while (i < len(t)) {
            masked = masked + self.echo_char;
            i = i + 1;
        }
        self.text = masked;
        return 0;
    }

    fn getRealText() { return self.real_text; }

    fn getMaskedText() { return self.text; }

    fn setEchoChar(ch) {
        self.echo_char = ch;
        self.setText(self.real_text);
        return 0;
    }

    fn appendChar(ch) {
        self.setText(self.real_text + ch);
        return 0;
    }

    fn deleteLast() {
        if (len(self.real_text) > 0) {
            self.setText(substring(self.real_text, 0, len(self.real_text) - 1));
        }
        return 0;
    }

    fn clear() {
        self.real_text = "";
        self.text = "";
        return 0;
    }
}

