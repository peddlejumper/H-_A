class ToggleButton extends Button {
    let toggle_group = "";
    let exclusive = true;

    fn init_tbtn(text) {
        self.init_btn(text);
        self.widget_type = "ToggleButton";
        self.is_toggle = true;
        self.toggle_group = "";
        self.exclusive = true;
        return 0;
    }

    fn setGroup(grp) {
        self.toggle_group = grp;
        return 0;
    }

    fn getGroup() { return self.toggle_group; }

    fn setExclusive(ex) {
        self.exclusive = ex;
        return 0;
    }

    fn isExclusive() { return self.exclusive; }

    fn setState(state) {
        self.set_checked(state);
        return 0;
    }

    fn getState() { return self.is_checked; }
}

