    fn getAnchor() { return self.anchor_widget; }

    fn setMaxHeight(h) { self.max_height = h; return 0; }

    fn getMaxHeight() { return self.max_height; }

    fn open() {
        if (self.anchor_widget != nullptr) {
            self.x = self.anchor_widget.x;
            self.y = self.anchor_widget.y + self.anchor_widget.height;
            self.width = self.anchor_widget.width;
        }
        self.is_open = true;
        self.visible = true;
        if (self.onOpened != nullptr) { self.onOpened(self); }
        return 0;
    }

    fn close() {
        self.is_open = false;
        self.visible = false;
        if (self.onClosed != nullptr) { self.onClosed(self); }
        return 0;
    }

    fn toggle() {
        if (self.is_open) { self.close(); }
        else { self.open(); }
        return 0;
    }

    fn setOnOpened(callback) { self.onOpened = callback; return 0; }

    fn setOnClosed(callback) { self.onClosed = callback; return 0; }
}

class ContextPopup extends zzwUI {
    let menu_items = [];
    let is_open = false;
    let x_pos = 0;
    let y_pos = 0;
    let onMenuSelected = nullptr;

    fn init_ctxp() {
        self.init("");
        self.widget_type = "ContextPopup";
        self.menu_items = [];
        self.is_open = false;
        self.x_pos = 0;
        self.y_pos = 0;
        self.visible = false;
        return 0;
    }

    fn addItem(text, callback) {
        push(self.menu_items, {"text": text, "callback": callback, "enabled": true});
        return 0;
    }

    fn addSeparator() {
        push(self.menu_items, {"text": "", "callback": nullptr, "enabled": false, "separator": true});
        return 0;
    }

    fn removeItem(index) {
        let new_items = [];
        let i = 0;
        while (i < len(self.menu_items)) {
            if (i != index) { push(new_items, self.menu_items[i]); }
            i = i + 1;
        }
        self.menu_items = new_items;
        return 0;
    }

    fn clearItems() { self.menu_items = []; return 0; }

    fn getItemCount() { return len(self.menu_items); }

    fn showAt(x, y) {
        self.x_pos = x;
        self.y_pos = y;
        self.x = x;
        self.y = y;
        self.is_open = true;
        self.visible = true;
        return 0;
    }

    fn close() {
        self.is_open = false;
        self.visible = false;
        return 0;
    }

    fn isOpen() { return self.is_open; }

    fn setOnMenuSelected(callback) { self.onMenuSelected = callback; return 0; }

    fn setItemEnabled(index, enabled) {
        if (index >= 0 and index < len(self.menu_items)) {
            self.menu_items[index]["enabled"] = enabled;
        }
        return 0;
    }
}

