    let bytes_per_line = 16;
    let show_ascii = true;
    let show_offset = true;
    let readonly = false;
    let cursor_pos = 0;

    fn init_hex() {
        self.init("");
        self.widget_type = "HexEditor";
        self.data = [];
        self.bytes_per_line = 16;
        self.show_ascii = true;
        self.show_offset = true;
        self.readonly = false;
        return 0;
    }

    fn setData(data_array) {
        self.data = data_array;
        return 0;
    }

    fn getData() { return self.data; }

    fn setBytesPerLine(n) {
        self.bytes_per_line = n;
        return 0;
    }

    fn setShowAscii(show) {
        self.show_ascii = show;
        return 0;
    }

    fn setShowOffset(show) {
        self.show_offset = show;
        return 0;
    }

    fn setReadonly(ro) {
        self.readonly = ro;
        return 0;
    }

    fn getByte(offset) {
        if (offset >= 0 and offset < len(self.data)) { return self.data[offset]; }
        return 0;
    }

    fn setByte(offset, value) {
        if (self.readonly == false and offset >= 0 and offset < len(self.data)) {
            self.data[offset] = value;
        }
        return 0;
    }

    fn getSize() { return len(self.data); }

    fn clear() {
        self.data = [];
        self.cursor_pos = 0;
        return 0;
    }
}

