        self.init("");
        self.widget_type = "Expander";
        self.header = header_text;
        self.content = nullptr;
        self.is_expanded = false;
        self.expand_direction = "down";
        self.animation_duration = 200;
        return 0;
    }

    fn setHeader(text) { self.header = text; return 0; }

    fn getHeader() { return self.header; }

    fn setContent(widget) {
        self.content = widget;
        if (widget != nullptr) { self.add_child(widget); }
        return 0;
    }

    fn getContent() { return self.content; }

    fn expand() {
        self.is_expanded = true;
        if (self.onExpanded != nullptr) { self.onExpanded(self); }
        return 0;
    }

    fn collapse() {
        self.is_expanded = false;
        if (self.onCollapsed != nullptr) { self.onCollapsed(self); }
        return 0;
    }

    fn toggle() {
        if (self.is_expanded) { self.collapse(); }
        else { self.expand(); }
        return 0;
    }

    fn isExpanded() { return self.is_expanded; }

    fn setExpandDirection(dir) { self.expand_direction = dir; return 0; }

    fn getExpandDirection() { return self.expand_direction; }

    fn setOnExpanded(callback) { self.onExpanded = callback; return 0; }

    fn setOnCollapsed(callback) { self.onCollapsed = callback; return 0; }
}

class Frame extends zzwUI {
    let source = "";
    let content = nullptr;
    let navigation_enabled = false;
    let history = [];
    let history_index = -1;

    fn init_frame() {
        self.init("");
        self.widget_type = "Frame";
        self.source = "";
        self.content = nullptr;
        self.navigation_enabled = false;
        self.history = [];
        self.history_index = -1;
        return 0;
    }

    fn setContent(widget) {
        if (self.content != nullptr and self.navigation_enabled) {
            push(self.history, self.content);
            self.history_index = len(self.history) - 1;
        }
        self.remove_all_children();
        self.content = widget;
        if (widget != nullptr) { self.add_child(widget); }
        return 0;
    }

    fn getContent() { return self.content; }

    fn setSource(src) { self.source = src; return 0; }

    fn getSource() { return self.source; }

    fn setNavigationEnabled(en) { self.navigation_enabled = en; return 0; }

    fn canGoBack() {
        if (self.history_index >= 0) { return true; }
        return false;
    }

    fn canGoForward() {
        if (self.history_index < len(self.history) - 1) { return true; }
        return false;
    }

    fn goBack() {
        if (self.canGoBack() == false) { return 0; }
        self.content = self.history[self.history_index];
        self.history_index = self.history_index - 1;
        self.remove_all_children();
        self.add_child(self.content);
        return 0;
    }

    fn goForward() {
        if (self.canGoForward() == false) { return 0; }
        self.history_index = self.history_index + 1;
        self.content = self.history[self.history_index];
        self.remove_all_children();
        self.add_child(self.content);
        return 0;
    }

    fn refresh() { return 0; }
}

class ContentPresenter extends zzwUI {
    let content = nullptr;
    let content_template = "";
    let content_source = "";

    fn init_cp() {
        self.init("");
        self.widget_type = "ContentPresenter";
        self.content = nullptr;
        self.content_template = "";
        self.content_source = "";
        return 0;
    }

    fn setContent(widget) {
        self.content = widget;
        self.remove_all_children();
        if (widget != nullptr) { self.add_child(widget); }
        return 0;
    }

    fn getContent() { return self.content; }

    fn setContentTemplate(tpl) { self.content_template = tpl; return 0; }

    fn getContentTemplate() { return self.content_template; }

    fn setContentSource(src) { self.content_source = src; return 0; }

    fn getContentSource() { return self.content_source; }

    fn present() {
