                self._current_fps = self._frame_count / self._elapsed_time;
                self._frame_count = 0;
                self._elapsed_time = 0;
            }
        }
        self._last_frame_time = current_time;
        return 0;
    }

    fn getCurrentFPS() {
        return self._current_fps;
    }

    fn setThrottleEnabled(enabled) {
        self._throttle_enabled = enabled;
        return 0;
    }

    fn reset() {
        self._last_frame_time = 0;
        self._frame_count = 0;
        self._elapsed_time = 0;
        self._current_fps = 0;
        return 0;
    }
}

class BackgroundRenderer {
    let _render_queue = [];
    let _is_rendering = false;
    let _current_item = 0;
    let _on_complete = nullptr;
    let _batch_size = 10;

    fn init_bgr() {
        self._render_queue = [];
        self._is_rendering = false;
        self._current_item = 0;
        self._on_complete = nullptr;
        self._batch_size = 10;
        return 0;
    }

    fn addTask(task_func, data) {
        push(self._render_queue, {"func": task_func, "data": data});
        return 0;
    }

    fn start() {
        self._is_rendering = true;
        self._current_item = 0;
        return 0;
    }

    fn processBatch() {
        if (not self._is_rendering) { return false; }
        let processed = 0;
        while (self._current_item < len(self._render_queue) and processed < self._batch_size) {
            let task = self._render_queue[self._current_item];
            task["func"](task["data"]);
            self._current_item = self._current_item + 1;
            processed = processed + 1;
        }
        if (self._current_item >= len(self._render_queue)) {
            self._is_rendering = false;
            if (self._on_complete != nullptr) {
                self._on_complete();
            }
            return false;
        }
        return true;
    }

    fn isRendering() {
        return self._is_rendering;
    }

    fn getProgress() {
        if (len(self._render_queue) == 0) { return 1.0; }
        return self._current_item / len(self._render_queue);
    }

    fn setOnComplete(callback) {
        self._on_complete = callback;
        return 0;
    }

    fn cancel() {
        self._is_rendering = false;
        return 0;
    }

    fn clear() {
