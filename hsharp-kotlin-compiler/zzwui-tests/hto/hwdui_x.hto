            } else {
                self.first.height = self.split_pos;
                self.first.width = self.width;
                self.second.y = self.split_pos + 4;
                self.second.height = self.height - self.split_pos - 4;
                self.second.width = self.width;
            }
        }
        return 0;
    }

}

