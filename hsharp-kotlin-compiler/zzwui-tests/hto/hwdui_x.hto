class MonthCalendar extends zzwUI {
    let selected_dates = [];
    let min_date = "";
    let max_date = "";
    let show_today = true;
    let bold_dates = [];
    let multi_select = false;
    let max_selection = 7;
    let onDateClicked = nullptr;

