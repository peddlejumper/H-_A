# ═══════════════════════════════════════════════════════════════════════════
# SECTION 10: Additional Standalone Functions
# ═══════════════════════════════════════════════════════════════════════════

fn hwdui_create_button(text, callback) {
    let btn = new Button();
    btn.init_btn(text);
    if (callback != nullptr) { btn.onClick = callback; }
    return btn;
}

fn hwdui_create_label(text) {
    let lbl = new Label();
    lbl.init_label(text);
    return lbl;
}

fn hwdui_create_textbox(text) {
    let tb = new TextBox();
    tb.init_tb(text);
    return tb;
}

fn hwdui_create_checkbox(text) {
    let cb = new CheckBox();
    cb.init_cb(text);
    return cb;
}

fn hwdui_create_radiobutton(text, group) {
    let rb = new RadioButton();
    rb.init_rb(text, group);
    return rb;
}

fn hwdui_show_message(title, message, mtype) {
    return hwdui_messagebox(title, message, mtype);
}

fn hwdui_get_screen_size() {
    let scm = new ScreenManager();
    scm.init_scm();
    return scm.getScreenSize();
}

fn hwdui_get_cursor_position() {
    return {"x": 0, "y": 0};
}

fn hwdui_set_cursor(cursor_type) {
    return 0;
}

