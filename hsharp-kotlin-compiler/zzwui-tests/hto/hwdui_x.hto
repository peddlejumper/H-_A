class Popup extends zzwUI {
    let content = nullptr;
    let placement = "bottom";
    let is_open = false;
    let auto_close = true;
    let close_on_escape = true;
    let stay_open = false;
    let onOpened = nullptr;
    let onClosed = nullptr;

    fn init_pop() {
        self.init("");
        self.widget_type = "Popup";
        self.content = nullptr;
        self.placement = "bottom";
        self.is_open = false;
        self.auto_close = true;
        self.close_on_escape = true;
        self.stay_open = false;
        self.visible = false;
        return 0;
    }

    fn setContent(widget) {
        self.content = widget;
        self.remove_all_children();
        if (widget != nullptr) { self.add_child(widget); }
        return 0;
    }

    fn getContent() { return self.content; }

    fn open() {
        self.is_open = true;
        self.visible = true;
        if (self.onOpened != nullptr) { self.onOpened(self); }
        return 0;
    }

    fn close() {
        self.is_open = false;
        self.visible = false;
        if (self.onClosed != nullptr) { self.onClosed(self); }
        return 0;
    }

    fn toggle() {
        if (self.is_open) { self.close(); }
        else { self.open(); }
        return 0;
    }

    fn isOpen() { return self.is_open; }

    fn setPlacement(p) { self.placement = p; return 0; }

    fn getPlacement() { return self.placement; }

    fn setAutoClose(ac) { self.auto_close = ac; return 0; }

    fn setStayOpen(so) { self.stay_open = so; return 0; }

    fn setOnOpened(callback) { self.onOpened = callback; return 0; }

    fn setOnClosed(callback) { self.onClosed = callback; return 0; }
}

class Flyout extends zzwUI {
    let content = nullptr;
    let is_open = false;
    let flyout_side = "right";
    let overlay = true;
    let width_size = 300;
