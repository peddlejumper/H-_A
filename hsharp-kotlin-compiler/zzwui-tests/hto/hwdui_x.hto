    let _speed = 50;
    let _is_playing = false;
    let _cursor_visible = true;

    fn init_twt() {
        self.init(str(hwdui_next_id()));
        self.widget_type = "TypewriterText";
        self.width = 200;
        self.height = 24;
        self._full_text = "";
        self._visible_text = "";
        self._char_index = 0;
        self._speed = 50;
        self._is_playing = false;
        self._cursor_visible = true;
        return 0;
    }

    fn setText(text) {
        self._full_text = text;
        self._visible_text = "";
        self._char_index = 0;
        return 0;
    }

    fn play() {
        self._is_playing = true;
        return 0;
    }

    fn pause() {
        self._is_playing = false;
        return 0;
    }

    fn update(dt) {
        if (not self._is_playing) { return 0; }
        if (self._char_index < len(self._full_text)) {
            self._char_index = self._char_index + 1;
            self._visible_text = "";
            let i = 0;
            while (i < self._char_index) {
                self._visible_text = self._visible_text + self._full_text[i];
                i = i + 1;
            }
        } else {
            self._is_playing = false;
        }
        return 0;
    }

    fn setSpeed(speed) {
        self._speed = speed;
        return 0;
    }

    fn isFinished() {
        return self._char_index >= len(self._full_text);
    }

    fn getVisibleText() {
        return self._visible_text;
    }
}

