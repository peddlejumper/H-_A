fn hwdui_pair_get(pairs, key, default_val) {
    let i = 0;
    while (i < len(pairs)) {
        let pair = pairs[i];
        if (pair[0] == key) {
            return pair[1];
        }
        i = i + 1;
    }
    return default_val;
}
fn hwdui_pair_set(pairs, key, value) {
    let i = 0;
    while (i < len(pairs)) {
        let pair = pairs[i];
        if (pair[0] == key) {
            pair[1] = value;
            return pairs;
        }
        i = i + 1;
    }
    push(pairs, [key, value]);
    return pairs;
}
fn hwdui_copy_style_props(pairs, target_dict) {
    let i = 0;
    while (i < len(pairs)) {
        let pair = pairs[i];
        target_dict[pair[0]] = pair[1];
        i = i + 1;
    }
    return 0;
}
