fn hwdui_collect_matched_rules(widget) {
    let all_rules = [];
    let i = 0;
    while (i < len(_hwdui_all_stylesheets)) {
        let matched = _hwdui_all_stylesheets[i].matchRules(widget);
        let j = 0;
        while (j < len(matched)) {
            push(all_rules, matched[j]);
            j = j + 1;
        }
        i = i + 1;
    }
    return all_rules;
}
fn hwdui_compute_style(widget) {
    let computed = hwdui_empty_style();
    hwdui_copy_style_props(_hwdui_css_defaults, computed);
    let rules = hwdui_collect_matched_rules(widget);
    let i = 0;
    while (i < len(rules)) {
        let rule = rules[i];
        hwdui_copy_style_props(rule.declarations, computed);
        i = i + 1;
    }
    let legacy_keys = ["bg_color", "fg_color", "border_color", "border_width", "border_radius", "font_size", "font_family", "padding"];
    let j = 0;
    while (j < len(legacy_keys)) {
        let lk = legacy_keys[j];
        let sv = widget.styles[lk];
        if (sv != "" and sv != nullptr) {
            computed[lk] = sv;
        }
        j = j + 1;
    }
    hwdui_copy_style_props(widget._inline_styles, computed);
    return computed;
}
