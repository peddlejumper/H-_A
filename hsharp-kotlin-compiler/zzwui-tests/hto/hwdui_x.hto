class MediaTransportControls extends zzwUI {
    let _player = nullptr;
    let _is_playing = false;

    fn init_mtc() {
        self.init(str(hwdui_next_id()));
        self.widget_type = "MediaTransportControls";
        self.width = 300;
        self.height = 40;
        self._player = nullptr;
        self._is_playing = false;
        return 0;
    }

    fn setPlayer(player) { self._player = player; return 0; }
    fn getPlayer() { return self._player; }
    fn playPause() { if (self._player == nullptr) { return 0; } if (self._is_playing) { self._player.pause(); } else { self._player.play(); } self._is_playing = not self._is_playing; return 0; }
    fn stop() { if (self._player == nullptr) { return 0; } self._player.stop(); self._is_playing = false; return 0; }
    fn skipForward() { if (self._player == nullptr) { return 0; } self._player.seek(self._player.getCurrentTime() + 10); return 0; }
    fn skipBackward() { if (self._player == nullptr) { return 0; } self._player.seek(self._player.getCurrentTime() - 10); return 0; }
    fn isPlaying() { return self._is_playing; }
}

class VolumeControl extends zzwUI {
    let _volume = 1.0;
    let _is_muted = false;
    let _previous_volume = 1.0;
    let _step = 0.05;

    fn init_vc() {
        self.init(str(hwdui_next_id()));
        self.widget_type = "VolumeControl";
        self.width = 120;
        self.height = 24;
        self._volume = 1.0;
        self._is_muted = false;
        self._previous_volume = 1.0;
        self._step = 0.05;
        return 0;
    }

    fn setVolume(vol) { if (vol < 0) { vol = 0; } if (vol > 1.0) { vol = 1.0; } self._volume = vol; if (vol > 0) { self._is_muted = false; } return 0; }
    fn getVolume() { return self._volume; }
    fn toggleMute() { if (self._is_muted) { self._volume = self._previous_volume; self._is_muted = false; } else { self._previous_volume = self._volume; self._volume = 0; self._is_muted = true; } return 0; }
    fn isMuted() { return self._is_muted; }
    fn volumeUp() { self.setVolume(self._volume + self._step); return 0; }
    fn volumeDown() { self.setVolume(self._volume - self._step); return 0; }
    fn getVolumePercent() { return self._volume * 100; }
    fn setStep(step) { self._step = step; return 0; }
}

class SeekBar extends zzwUI {
    let _min_value = 0;
    let _max_value = 100;
    let _current_value = 0;
    let _is_seeking = false;

    fn init_sb2() {
        self.init(str(hwdui_next_id()));
        self.widget_type = "SeekBar";
        self.width = 300;
        self.height = 20;
        self._min_value = 0;
        self._max_value = 100;
        self._current_value = 0;
        self._is_seeking = false;
        return 0;
    }

    fn setRange(min_val, max_val) { self._min_value = min_val; self._max_value = max_val; return 0; }
    fn setValue(val) { if (val < self._min_value) { val = self._min_value; } if (val > self._max_value) { val = self._max_value; } self._current_value = val; return 0; }
    fn getValue() { return self._current_value; }
    fn getPercent() { if (self._max_value == self._min_value) { return 0; } return (self._current_value - self._min_value) / (self._max_value - self._min_value) * 100; }
    fn startSeek() { self._is_seeking = true; return 0; }
    fn seekToPercent(percent) { if (percent < 0) { percent = 0; } if (percent > 100) { percent = 100; } self._current_value = self._min_value + (self._max_value - self._min_value) * percent / 100; return 0; }
    fn endSeek() { self._is_seeking = false; return 0; }
    fn isSeeking() { return self._is_seeking; }
}

