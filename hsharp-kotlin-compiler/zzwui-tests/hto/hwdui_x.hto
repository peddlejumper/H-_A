class StepProgress extends zzwUI {
    let _steps = [];
    let _current_step = 0;
    let _orientation = "horizontal";
    let _show_labels = true;

    fn init_sprog() {
        self.init(str(hwdui_next_id()));
        self.widget_type = "StepProgress";
        self.width = 500;
        self.height = 60;
        self._steps = [];
        self._current_step = 0;
        self._orientation = "horizontal";
        self._show_labels = true;
        return 0;
    }

    fn setSteps(steps) { self._steps = steps; return 0; }
    fn addStep(label) { push(self._steps, label); return 0; }
    fn getSteps() { return self._steps; }
    fn getStepCount() { return len(self._steps); }
    fn setCurrentStep(step) { if (step < 0) { step = 0; } if (step >= len(self._steps)) { step = len(self._steps) - 1; } self._current_step = step; return 0; }
    fn getCurrentStep() { return self._current_step; }
    fn next() { if (self._current_step + 1 < len(self._steps)) { self._current_step = self._current_step + 1; } return 0; }
    fn previous() { if (self._current_step - 1 >= 0) { self._current_step = self._current_step - 1; } return 0; }
    fn isFirstStep() { return self._current_step == 0; }
    fn isLastStep() { return self._current_step >= len(self._steps) - 1; }
    fn setOrientation(orientation) { self._orientation = orientation; return 0; }
}

class Wizard {
    let _pages = [];
    let _current_page = 0;
    let _on_finish = nullptr;
    let _on_cancel = nullptr;

    fn init_wiz() {
        self._pages = [];
        self._current_page = 0;
        self._on_finish = nullptr;
        self._on_cancel = nullptr;
        return 0;
    }

    fn addPage(page) { push(self._pages, page); page.setWizard(self); page.visible = false; if (len(self._pages) == 1) { page.visible = true; } return 0; }
    fn removePage(page) { let new_pages = []; for __contains(self._pages, p) { if (p != page) { push(new_pages, p); } } self._pages = new_pages; page.setWizard(nullptr); return 0; }
    fn next() { if (self._current_page + 1 < len(self._pages)) { self._pages[self._current_page].visible = false; self._current_page = self._current_page + 1; self._pages[self._current_page].visible = true; } return 0; }
    fn previous() { if (self._current_page - 1 >= 0) { self._pages[self._current_page].visible = false; self._current_page = self._current_page - 1; self._pages[self._current_page].visible = true; } return 0; }
    fn goToPage(index) { if (index < 0 or index >= len(self._pages)) { return 0; } self._pages[self._current_page].visible = false; self._current_page = index; self._pages[self._current_page].visible = true; return 0; }
    fn finish() { if (self._on_finish != nullptr) { self._on_finish(); } return 0; }
    fn cancel() { if (self._on_cancel != nullptr) { self._on_cancel(); } return 0; }
    fn getCurrentPage() { if (self._current_page < len(self._pages)) { return self._pages[self._current_page]; } return nullptr; }
    fn getCurrentIndex() { return self._current_page; }
    fn getPageCount() { return len(self._pages); }
    fn canGoNext() { return self._current_page + 1 < len(self._pages); }
    fn canGoPrevious() { return self._current_page > 0; }
    fn setOnFinish(callback) { self._on_finish = callback; return 0; }
    fn setOnCancel(callback) { self._on_cancel = callback; return 0; }
}

