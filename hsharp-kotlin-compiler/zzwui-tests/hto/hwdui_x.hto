class ScreenReader {
    let _enabled = false;
    let _speech_rate = 1.0;
    let _volume = 1.0;

    fn init_sr() { self._enabled = false; self._speech_rate = 1.0; self._volume = 1.0; return 0; }
    fn enable() { self._enabled = true; return 0; }
    fn disable() { self._enabled = false; return 0; }
    fn isEnabled() { return self._enabled; }
    fn speak(text) { if (self._enabled) { hwdui_tts_speak(text, self._speech_rate, self._volume); } return 0; }
    fn announceFocus(widget) { if (self._enabled and widget != nullptr) { self.speak(widget.widget_type + " " + widget.id); } return 0; }
    fn setSpeechRate(rate) { self._speech_rate = rate; return 0; }
    fn getSpeechRate() { return self._speech_rate; }
    fn setVolume(vol) { if (vol < 0) { vol = 0; } if (vol > 1) { vol = 1; } self._volume = vol; return 0; }
    fn stop() { hwdui_tts_stop(); return 0; }
}

class HighContrastTheme {
    let _enabled = false;
    let _mode = "dark";
    let _foreground = "#FFFFFF";
    let _background = "#000000";

    fn init_hct() { self._enabled = false; self._mode = "dark"; self._foreground = "#FFFFFF"; self._background = "#000000"; return 0; }
    fn enable() { self._enabled = true; return 0; }
    fn disable() { self._enabled = false; return 0; }
    fn isEnabled() { return self._enabled; }
    fn setMode(mode) { self._mode = mode; if (mode == "dark") { self._foreground = "#FFFFFF"; self._background = "#000000"; } else if (mode == "light") { self._foreground = "#000000"; self._background = "#FFFFFF"; } return 0; }
    fn getMode() { return self._mode; }
    fn getForeground() { return self._foreground; }
    fn getBackground() { return self._background; }
    fn apply() { hwdui_apply_theme({"bg_color": self._background, "fg_color": self._foreground}); return 0; }
}

