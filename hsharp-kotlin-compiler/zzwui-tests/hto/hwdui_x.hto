class FocusManager {
    let focus_chain = [];
    let current_focus = nullptr;
    let focus_policy = "tab";

    fn init_fm() {
        self.focus_chain = [];
        self.current_focus = nullptr;
        self.focus_policy = "tab";
        return 0;
    }

    fn setFocus(widget) {
        if (self.current_focus != nullptr) {
            self.current_focus.trigger_blur();
        }
        self.current_focus = widget;
        if (widget != nullptr) {
            widget.trigger_focus();
        }
        return 0;
    }

    fn getFocus() { return self.current_focus; }

    fn addToChain(widget) {
        push(self.focus_chain, widget);
        return 0;
    }

    fn removeFromChain(widget) {
        let new_chain = [];
        let i = 0;
        while (i < len(self.focus_chain)) {
            if (self.focus_chain[i] != widget) { push(new_chain, self.focus_chain[i]); }
            i = i + 1;
        }
        self.focus_chain = new_chain;
        return 0;
    }

    fn focusNext() {
