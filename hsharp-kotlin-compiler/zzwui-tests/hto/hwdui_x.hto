class CarouselPanel extends zzwUI {
    let items = [];
    let current_index = 0;
    let auto_play = false;
    let interval = 3000;
    let loop_enabled = true;
    let onPageChanged = nullptr;
    let onAnimationEnd = nullptr;

    fn init_cp() {
        self.init("");
        self.widget_type = "CarouselPanel";
        self.items = [];
        self.current_index = 0;
        self.auto_play = false;
        self.interval = 3000;
        self.loop_enabled = true;
        return 0;
    }

    fn addItem(widget) {
        push(self.items, widget);
        self.add_child(widget);
        widget.visible = false;
        if (len(self.items) == 1) { widget.visible = true; }
        return 0;
    }

    fn removeItem(index) {
        if (index >= 0 and index < len(self.items)) {
            self.remove_child(self.items[index]);
            let new_items = [];
            let i = 0;
            while (i < len(self.items)) {
                if (i != index) { push(new_items, self.items[i]); }
                i = i + 1;
            }
            self.items = new_items;
        }
        return 0;
    }

    fn next() {
        if (len(self.items) == 0) { return 0; }
        self.items[self.current_index].visible = false;
        self.current_index = self.current_index + 1;
        if (self.current_index >= len(self.items)) {
            if (self.loop_enabled) { self.current_index = 0; }
            else { self.current_index = len(self.items) - 1; }
        }
        self.items[self.current_index].visible = true;
        if (self.onPageChanged != nullptr) { self.onPageChanged(self, self.current_index); }
        return 0;
    }

    fn previous() {
        if (len(self.items) == 0) { return 0; }
        self.items[self.current_index].visible = false;
        self.current_index = self.current_index - 1;
        if (self.current_index < 0) {
            if (self.loop_enabled) { self.current_index = len(self.items) - 1; }
            else { self.current_index = 0; }
        }
        self.items[self.current_index].visible = true;
        if (self.onPageChanged != nullptr) { self.onPageChanged(self, self.current_index); }
        return 0;
    }

    fn goTo(index) {
        if (index >= 0 and index < len(self.items)) {
            self.items[self.current_index].visible = false;
            self.current_index = index;
            self.items[self.current_index].visible = true;
            if (self.onPageChanged != nullptr) { self.onPageChanged(self, self.current_index); }
        }
        return 0;
    }

    fn setAutoPlay(ap) { self.auto_play = ap; return 0; }

    fn setInterval(ms) { self.interval = ms; return 0; }

    fn setLoop(enabled) { self.loop_enabled = enabled; return 0; }

    fn getCurrentIndex() { return self.current_index; }

    fn getItemCount() { return len(self.items); }

    fn setOnPageChanged(callback) { self.onPageChanged = callback; return 0; }

    fn setOnAnimationEnd(callback) { self.onAnimationEnd = callback; return 0; }
}

