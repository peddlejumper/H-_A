fn hwdui_tbl_set_column_width(tbl, col, width) {
    if (col >= 0 and col < len(tbl.columns)) {
        tbl.columns[col]["width"] = width;
    }
    return 0;
}

fn hwdui_tbl_set_row_height(tbl, row, height) {
    tbl.row_height = height;
    tbl.setInlineStyle("row-height", str(height));
    return 0;
}

fn hwdui_tbl_auto_size_columns(tbl) {
    let col_count = len(tbl.columns);
    let avail_w = tbl.width;
    if (col_count > 0) {
        let col_w = avail_w / col_count;
        let c = 0;
        while (c < col_count) {
            tbl.columns[c]["width"] = col_w;
            c = c + 1;
        }
    }
    return 0;
}

fn hwdui_tbl_auto_size_rows(tbl) {
    let row_count = len(tbl.rows);
    let avail_h = tbl.height - tbl.header_height;
    if (row_count > 0) {
        let row_h = avail_h / row_count;
        tbl.row_height = row_h;
    }
    return 0;
}

fn hwdui_tbl_freeze_column(tbl, col) {
    if (col >= 0 and col < len(tbl.columns)) {
        tbl.setInlineStyle("frozen-column", str(col));
    }
    return 0;
}

fn hwdui_tbl_freeze_row(tbl, row) {
    if (row >= 0 and row < len(tbl.rows)) {
        tbl.setInlineStyle("frozen-row", str(row));
    }
    return 0;
}

# --- ScrollView extensions ---

fn hwdui_sv_scroll_to_top(sv) {
    sv.scroll_to(sv.scroll_x, 0);
    return 0;
}

fn hwdui_sv_scroll_to_bottom(sv) {
    let max_y = sv.content_height - sv.height;
    if (max_y < 0) { max_y = 0; }
    sv.scroll_to(sv.scroll_x, max_y);
    return 0;
}

fn hwdui_sv_scroll_to_left(sv) {
    sv.scroll_to(0, sv.scroll_y);
    return 0;
}

fn hwdui_sv_scroll_to_right(sv) {
    let max_x = sv.content_width - sv.width;
    if (max_x < 0) { max_x = 0; }
    sv.scroll_to(max_x, sv.scroll_y);
    return 0;
}

fn hwdui_sv_set_scroll_speed(sv, speed) {
    sv.setInlineStyle("scroll-speed", str(speed));
    return 0;
}

