    fn removeItem(index) { if (index < 0 or index >= len(self._items)) { return 0; } let new_items = []; let i = 0; while (i < len(self._items)) { if (i != index) { push(new_items, self._items[i]); } i = i + 1; } self._items = new_items; if (self._current_index >= len(self._items)) { self._current_index = len(self._items) - 1; } return 0; }
    fn getItems() { return self._items; }
    fn getItemCount() { return len(self._items); }
    fn setCurrentIndex(index) { if (index < 0 or index >= len(self._items)) { return 0; } self._current_index = index; return 0; }
    fn getCurrentIndex() { return self._current_index; }
    fn next() { if (len(self._items) == 0) { return 0; } self._current_index = self._current_index + 1; if (self._current_index >= len(self._items)) { if (self._loop_mode == "all") { self._current_index = 0; } else { self._current_index = len(self._items) - 1; } } return 0; }
    fn previous() { if (len(self._items) == 0) { return 0; } self._current_index = self._current_index - 1; if (self._current_index < 0) { if (self._loop_mode == "all") { self._current_index = len(self._items) - 1; } else { self._current_index = 0; } } return 0; }
    fn setLoopMode(mode) { self._loop_mode = mode; return 0; }
    fn clear() { self._items = []; self._current_index = -1; return 0; }
}

class MediaInfo extends zzwUI {
    let _title = "";
    let _artist = "";
    let _album = "";
    let _duration = 0;

    fn init_mi() {
        self.init(str(hwdui_next_id()));
        self.widget_type = "MediaInfo";
        self.width = 300;
        self.height = 200;
        self._title = "";
        self._artist = "";
        self._album = "";
        self._duration = 0;
        return 0;
    }

