            }
            __i12 = __i12 + 1;
        }
        _hwdui_active_windows = new_windows;
        self.visible = false;
        return 0;
    }

    fn minimize() {
        self._hwdui_saved_x = self.x;
        self._hwdui_saved_y = self.y;
        self._hwdui_saved_w = self.width;
        self._hwdui_saved_h = self.height;
        self.is_minimized = true;
        return 0;
    }

    fn maximize() {
        self._hwdui_saved_x = self.x;
        self._hwdui_saved_y = self.y;
        self._hwdui_saved_w = self.width;
        self._hwdui_saved_h = self.height;
        self.is_maximized = true;
        return 0;
    }

    fn restore() {
        self.x = self._hwdui_saved_x;
        self.y = self._hwdui_saved_y;
        self.width = self._hwdui_saved_w;
        self.height = self._hwdui_saved_h;
        self.is_minimized = false;
        self.is_maximized = false;
        return 0;
    }

    fn get_client_area() {
        return {"x": self._hwdui_pad_left, "y": self.title_height, "width": self.width - self._hwdui_pad_left - self._hwdui_pad_right, "height": self.height - self.title_height - self._hwdui_pad_bottom};
    }

    fn get_active_child() {
        let __iter13 = self.children;
        let __i13 = 0;
        while (__i13 < len(__iter13)) {
            let child = __iter13[__i13];
            if (child.visible and child.enabled) {
                return child;
            }
            __i13 = __i13 + 1;
        }
        return nullptr;
    }

    fn layout_children() {
        self.do_layout();
        return 0;
    }

}

class Panel extends zzwUI {
    let layout_type = "absolute";
    let spacing = 4;
    let auto_size = false;

    fn init_panel(ltype) {
        self.init("");
        self.widget_type = "Panel";
        self.layout_type = ltype;
        return 0;
    }

    fn set_layout_type(ltype) {
        self.layout_type = ltype;
        return 0;
    }

    fn set_spacing(s) {
        self.spacing = s;
        return 0;
    }

    fn do_layout() {
        if (self.layout_type == "vbox") {
            self._do_vbox_layout();
        } else if (self.layout_type == "hbox") {
            self._do_hbox_layout();
        } else if (self.layout_type == "grid") {
            self._do_grid_layout();
        }
        return 0;
    }

    fn _do_vbox_layout() {
        let cur_y = self._hwdui_pad_top;
        let __iter14 = self.children;
        let __i14 = 0;
        while (__i14 < len(__iter14)) {
            let child = __iter14[__i14];
            if (child.visible == false) {
                continue;
            }
            child.x = self._hwdui_pad_left;
            child.y = cur_y;
            cur_y = cur_y + child.height + self.spacing;
            __i14 = __i14 + 1;
        }
        return 0;
    }

    fn _do_hbox_layout() {
        let cur_x = self._hwdui_pad_left;
        let __iter15 = self.children;
        let __i15 = 0;
        while (__i15 < len(__iter15)) {
            let child = __iter15[__i15];
            if (child.visible == false) {
                continue;
            }
            child.x = cur_x;
            child.y = self._hwdui_pad_top;
            cur_x = cur_x + child.width + self.spacing;
            __i15 = __i15 + 1;
        }
        return 0;
    }

    fn _do_grid_layout() {
        let cur_x = self._hwdui_pad_left;
        let cur_y = self._hwdui_pad_top;
        let __iter16 = self.children;
        let __i16 = 0;
        while (__i16 < len(__iter16)) {
            let child = __iter16[__i16];
            if (child.visible == false) {
                continue;
            }
            child.x = cur_x;
            child.y = cur_y;
            cur_x = cur_x + child.width + self.spacing;
            if (cur_x + child.width > self.width) {
                cur_x = self._hwdui_pad_left;
                cur_y = cur_y + child.height + self.spacing;
            }
            __i16 = __i16 + 1;
        }
        return 0;
    }

}

class Button extends zzwUI {
