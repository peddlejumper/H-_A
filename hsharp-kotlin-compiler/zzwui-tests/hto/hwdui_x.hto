class TransitionManager {
    let transitions = [];
    let running = false;
    let onAllComplete = nullptr;

    fn init_tm() {
        self.transitions = [];
        self.running = false;
        self.onAllComplete = nullptr;
        return 0;
    }

    fn addTransition(transition) {
        push(self.transitions, transition);
        return 0;
    }

    fn removeTransition(index) {
        let new_trans = [];
        let i = 0;
        while (i < len(self.transitions)) {
            if (i != index) { push(new_trans, self.transitions[i]); }
            i = i + 1;
        }
        self.transitions = new_trans;
        return 0;
    }

    fn startAll() {
        self.running = true;
        let i = 0;
        while (i < len(self.transitions)) {
            self.transitions[i].start();
            i = i + 1;
        }
        return 0;
    }

    fn stopAll() {
        self.running = false;
        let i = 0;
        while (i < len(self.transitions)) {
            self.transitions[i].stop();
            i = i + 1;
        }
        if (self.onAllComplete != nullptr) { self.onAllComplete(self); }
        return 0;
    }

    fn getCount() { return len(self.transitions); }

    fn setOnAllComplete(callback) { self.onAllComplete = callback; return 0; }

    fn update(delta_ms) {
        if (self.running == false) { return 0; }
        let all_done = true;
        let i = 0;
        while (i < len(self.transitions)) {
            self.transitions[i].update(delta_ms);
            if (self.transitions[i].running) { all_done = false; }
            i = i + 1;
        }
        if (all_done) {
            self.running = false;
            if (self.onAllComplete != nullptr) { self.onAllComplete(self); }
        }
        return 0;
    }
}

class KeyframeAnimation extends Animation {
    let keyframes = [];
    let current_keyframe_index = 0;
    let iterations = 1;
    let current_iteration = 0;

    fn init_kfa(target_widget, prop, dur) {
        self.init_anim(target_widget, prop, 0, dur);
        self.keyframes = [];
        self.current_keyframe_index = 0;
        self.iterations = 1;
        self.current_iteration = 0;
        return 0;
    }

    fn addKeyframe(progress, value, easing) {
        push(self.keyframes, {"progress": progress, "value": value, "easing": easing});
        return len(self.keyframes) - 1;
    }

    fn removeKeyframe(index) {
        let new_kf = [];
        let i = 0;
        while (i < len(self.keyframes)) {
            if (i != index) { push(new_kf, self.keyframes[i]); }
            i = i + 1;
        }
        self.keyframes = new_kf;
        return 0;
    }

    fn clearKeyframes() { self.keyframes = []; return 0; }

    fn getKeyframeCount() { return len(self.keyframes); }

    fn setIterations(n) { self.iterations = n; return 0; }

    fn getIterations() { return self.iterations; }

    fn getCurrentIteration() { return self.current_iteration; }
}

class ParallelAnimation extends Animation {
    let animations = [];
    let completed_count = 0;

    fn init_pa() {
        self.init_anim(nullptr, "", 0, 0);
        self.animations = [];
        self.completed_count = 0;
        return 0;
    }

    fn addAnimation(anim) {
        push(self.animations, anim);
        return 0;
    }

    fn removeAnimation(index) {
        let new_anims = [];
        let i = 0;
        while (i < len(self.animations)) {
            if (i != index) { push(new_anims, self.animations[i]); }
            i = i + 1;
        }
        self.animations = new_anims;
        return 0;
    }

    fn start() {
        self.running = true;
        self.completed_count = 0;
        let i = 0;
        while (i < len(self.animations)) {
            self.animations[i].start();
            i = i + 1;
        }
        return 0;
    }

    fn stop() {
        let i = 0;
        while (i < len(self.animations)) {
            self.animations[i].stop();
            i = i + 1;
        }
        self.running = false;
        return 0;
    }

    fn update(delta_ms) {
        if (self.running == false) { return 0; }
        let all_done = true;
        let i = 0;
        while (i < len(self.animations)) {
            self.animations[i].update(delta_ms);
            if (self.animations[i].running) { all_done = false; }
            i = i + 1;
        }
        if (all_done) {
            self.running = false;
            if (self.onComplete != nullptr) { self.onComplete(self); }
            if (self.loop) { self.start(); }
        }
        return 0;
    }

    fn getAnimationCount() { return len(self.animations); }
}

class SequentialAnimation extends Animation {
    let animations = [];
    let current_index = 0;

    fn init_sa() {
        self.init_anim(nullptr, "", 0, 0);
        self.animations = [];
        self.current_index = 0;
        return 0;
    }

    fn addAnimation(anim) {
        push(self.animations, anim);
        return 0;
    }

    fn removeAnimation(index) {
        let new_anims = [];
        let i = 0;
        while (i < len(self.animations)) {
            if (i != index) { push(new_anims, self.animations[i]); }
            i = i + 1;
        }
        self.animations = new_anims;
        return 0;
    }

    fn start() {
        self.running = true;
        self.current_index = 0;
        if (len(self.animations) > 0) {
            self.animations[0].start();
        }
        return 0;
    }

    fn stop() {
        let i = 0;
        while (i < len(self.animations)) {
            self.animations[i].stop();
            i = i + 1;
        }
        self.running = false;
        self.current_index = 0;
        return 0;
    }

    fn update(delta_ms) {
        if (self.running == false) { return 0; }
        if (self.current_index >= len(self.animations)) {
            self.running = false;
            if (self.onComplete != nullptr) { self.onComplete(self); }
            if (self.loop) { self.start(); }
            return 0;
        }
        let current_anim = self.animations[self.current_index];
        current_anim.update(delta_ms);
        if (current_anim.running == false) {
            self.current_index = self.current_index + 1;
            if (self.current_index < len(self.animations)) {
                self.animations[self.current_index].start();
            } else {
                self.running = false;
                if (self.onComplete != nullptr) { self.onComplete(self); }
                if (self.loop) { self.start(); }
            }
        }
        return 0;
    }

    fn getAnimationCount() { return len(self.animations); }
}

class SpringAnimation extends Animation {
    let stiffness = 100;
    let damping = 10;
    let mass = 1;
    let velocity = 0;
    let rest_threshold = 0.01;

    fn init_spra(target_widget, prop, to_value, dur) {
        self.init_anim(target_widget, prop, to_value, dur);
        self.stiffness = 100;
        self.damping = 10;
        self.mass = 1;
        self.velocity = 0;
        self.rest_threshold = 0.01;
        return 0;
    }

    fn setStiffness(s) { self.stiffness = s; return 0; }

    fn getStiffness() { return self.stiffness; }

    fn setDamping(d) { self.damping = d; return 0; }

    fn getDamping() { return self.damping; }

    fn setMass(m) { self.mass = m; return 0; }

    fn getMass() { return self.mass; }

    fn setRestThreshold(t) { self.rest_threshold = t; return 0; }

    fn getRestThreshold() { return self.rest_threshold; }

    fn update(delta_ms) {
        if (self.running == false) { return 0; }
        let dt = delta_ms / 1000;
        let displacement = self.to_val - self._currentSpringValue();
        let spring_force = self.stiffness * displacement;
        let damping_force = self.damping * self.velocity;
        let force = spring_force - damping_force;
        let acceleration = force / self.mass;
        self.velocity = self.velocity + acceleration * dt;
        let new_val = self._currentSpringValue() + self.velocity * dt;
        self._applySpringValue(new_val);
        let abs_dis = displacement;
        if (abs_dis < 0) { abs_dis = -abs_dis; }
        if (abs_dis < self.rest_threshold and self.velocity < self.rest_threshold) {
            if (self.velocity < 0) { self.velocity = -self.velocity; }
            self.running = false;
            self._applyValue(self.to_val);
            if (self.onComplete != nullptr) { self.onComplete(self); }
        }
        self.elapsed = self.elapsed + delta_ms;
        return 0;
    }

    fn _currentSpringValue() {
        if (self.target == nullptr) { return 0; }
        return self.from_val;
    }

    fn _applySpringValue(val) {
        if (self.target != nullptr) {
            self._applyValue(val);
        }
    }
}

