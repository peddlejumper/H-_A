class ZOrderManager {
    let z_order_map = {};
    let next_z = 0;

    fn init_zom() {
        self.z_order_map = {};
        self.next_z = 0;
        return 0;
    }

    fn assignZ(widget) {
        widget.z_index = self.next_z;
        self.next_z = self.next_z + 1;
        return 0;
    }

    fn bringToFront(widget) {
        widget.z_index = self.next_z;
        self.next_z = self.next_z + 1;
        return 0;
    }

    fn sendToBack(widget) {
        widget.z_index = -1;
        return 0;
    }

    fn setZIndex(widget, z) {
        widget.z_index = z;
        if (z >= self.next_z) { self.next_z = z + 1; }
        return 0;
    }

    fn getZIndex(widget) { return widget.z_index; }

    fn sortByZ(widget_list) {
        let i = 0;
        while (i < len(widget_list) - 1) {
            let j = 0;
            while (j < len(widget_list) - i - 1) {
                if (widget_list[j].z_index > widget_list[j + 1].z_index) {
                    let tmp = widget_list[j];
                    widget_list[j] = widget_list[j + 1];
                    widget_list[j + 1] = tmp;
                }
                j = j + 1;
            }
            i = i + 1;
        }
        return widget_list;
    }

    fn getTopWidget(widget_list) {
        let top = widget_list[0];
        let i = 1;
        while (i < len(widget_list)) {
            if (widget_list[i].z_index > top.z_index) { top = widget_list[i]; }
            i = i + 1;
        }
        return top;
    }
}

