class ButtonGroup extends zzwUI {
    let buttons = [];
    let exclusive = true;
    let selected_index = -1;
    let orientation = "horizontal";

    fn init_btngroup() {
        self.init("");
        self.widget_type = "ButtonGroup";
        self.buttons = [];
        self.exclusive = true;
        self.selected_index = -1;
        return 0;
    }

    fn addButton(button) {
        push(self.buttons, button);
        self.add_child(button);
        return 0;
    }

    fn removeButton(index) {
        let new_btns = [];
        let i = 0;
        while (i < len(self.buttons)) {
            if (i != index) { push(new_btns, self.buttons[i]); }
            i = i + 1;
        }
        self.buttons = new_btns;
        return 0;
    }

    fn getButton(index) {
        if (index >= 0 and index < len(self.buttons)) { return self.buttons[index]; }
        return nullptr;
    }

    fn getButtonCount() { return len(self.buttons); }

    fn setExclusive(ex) {
        self.exclusive = ex;
        return 0;
    }

    fn setOrientation(orient) {
        self.orientation = orient;
        return 0;
    }

    fn selectButton(index) {
        if (index < 0 or index >= len(self.buttons)) { return 0; }
        if (self.exclusive) {
            let i = 0;
            while (i < len(self.buttons)) {
                self.buttons[i].is_checked = false;
                i = i + 1;
            }
        }
        self.buttons[index].is_checked = true;
        self.selected_index = index;
        return 0;
    }

    fn getSelectedButton() {
        if (self.selected_index >= 0 and self.selected_index < len(self.buttons)) {
            return self.buttons[self.selected_index];
        }
        return nullptr;
    }

    fn getSelectedIndex() { return self.selected_index; }

    fn clearSelection() {
        let i = 0;
        while (i < len(self.buttons)) {
            self.buttons[i].is_checked = false;
            i = i + 1;
        }
        self.selected_index = -1;
        return 0;
    }
}

