class SpinBox extends zzwUI {
    let val = 0;
    let min_val = 0;
    let max_val = 100;
    let step = 1;
    let decimals = 0;
    let prefix = "";
    let suffix = "";
    let wrap = false;

    fn init_sp(minv, maxv, initv) {
        self.init("");
        self.widget_type = "SpinBox";
        self.min_val = minv;
        self.max_val = maxv;
        self.val = initv;
        self.step = 1;
        self.decimals = 0;
        self.prefix = "";
        self.suffix = "";
        return 0;
    }

    fn setValue(v) {
        if (v < self.min_val) { v = self.min_val; }
        if (v > self.max_val) { v = self.max_val; }
        self.val = v;
        return 0;
    }

    fn getValue() {
        return self.val;
    }

    fn setRange(minv, maxv) {
        self.min_val = minv;
        self.max_val = maxv;
        if (self.val < minv) { self.val = minv; }
        if (self.val > maxv) { self.val = maxv; }
        return 0;
    }

    fn setStep(st) {
        self.step = st;
        return 0;
    }

    fn setDecimals(d) {
        self.decimals = d;
        return 0;
    }

    fn setPrefix(p) {
        self.prefix = p;
        return 0;
    }

    fn setSuffix(s) {
        self.suffix = s;
        return 0;
    }

    fn setWrap(w) {
        self.wrap = w;
        return 0;
    }

    fn increment() {
        self.val = self.val + self.step;
        if (self.val > self.max_val) { self.val = self.max_val; }
        return 0;
    }

    fn decrement() {
        self.val = self.val - self.step;
        if (self.val < self.min_val) { self.val = self.min_val; }
        return 0;
    }

    fn getText() {
        return self.prefix + str(self.val) + self.suffix;
    }

}

