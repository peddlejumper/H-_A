class AudioPlayer extends zzwUI {
    let _source = "";
    let _is_playing = false;
    let _volume = 1.0;
    let _current_time = 0;
    let _duration = 0;
    let _is_muted = false;
    let _title = "";

    fn init_ap() {
        self.init(str(hwdui_next_id()));
        self.widget_type = "AudioPlayer";
        self.width = 400;
        self.height = 80;
        self._source = "";
        self._is_playing = false;
        self._volume = 1.0;
        self._current_time = 0;
        self._duration = 0;
        self._is_muted = false;
        self._title = "";
        return 0;
    }

    fn setSource(source) { self._source = source; self._duration = hwdui_audio_get_duration(source); return 0; }
    fn getSource() { return self._source; }
    fn play() { if (self._source != "") { self._is_playing = true; } return 0; }
    fn pause() { self._is_playing = false; return 0; }
    fn stop() { self._is_playing = false; self._current_time = 0; return 0; }
    fn isPlaying() { return self._is_playing; }
    fn setVolume(vol) { if (vol < 0) { vol = 0; } if (vol > 1.0) { vol = 1.0; } self._volume = vol; return 0; }
    fn getVolume() { return self._volume; }
    fn toggleMute() { self._is_muted = not self._is_muted; return 0; }
    fn seek(time) { if (time < 0) { time = 0; } if (time > self._duration) { time = self._duration; } self._current_time = time; return 0; }
    fn getCurrentTime() { return self._current_time; }
    fn getDuration() { return self._duration; }
    fn setTitle(title) { self._title = title; return 0; }
    fn getTitle() { return self._title; }
}

