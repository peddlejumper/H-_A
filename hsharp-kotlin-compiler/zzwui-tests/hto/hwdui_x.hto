class DockSite extends zzwUI {
    let _manager = nullptr;
    let _splitters = [];
    let _active_splitter = -1;
    let _splitter_dragging = false;
    let _splitter_width = 4;
    let _splitter_color = "#CCCCCC";

    fn init_ds() {
        self.init(str(hwdui_next_id()));
        self.widget_type = "DockSite";
        self.width = 800;
        self.height = 600;
        self._manager = new DockManager();
        self._manager.init_dm();
        self._splitters = [];
        self._active_splitter = -1;
        self._splitter_dragging = false;
        self._splitter_width = 4;
        self._splitter_color = "#CCCCCC";
        return 0;
    }

    fn setManager(mgr) {
        self._manager = mgr;
        return 0;
    }

    fn getManager() {
        return self._manager;
    }

    fn addPane(pane) {
        self._manager.addPane(pane);
        self.layoutPanes();
        return 0;
    }

    fn layoutPanes() {
        self._manager.layoutPanes(self.width, self.height);
        self._rebuildSplitters();
        return 0;
    }

    fn _rebuildSplitters() {
        self._splitters = [];
        let panes = self._manager.getPanes();
        if (self._manager.getLayout() == "horizontal") {
            let i = 1;
            while (i < len(panes)) {
                let r = panes[i - 1].getRect();
                push(self._splitters, {"x": r["x"] + r["width"] - self._splitter_width / 2, "y": 0, "width": self._splitter_width, "height": self.height, "index": i});
                i = i + 1;
            }
        } else {
            let i = 1;
            while (i < len(panes)) {
                let r = panes[i - 1].getRect();
                push(self._splitters, {"x": 0, "y": r["y"] + r["height"] - self._splitter_width / 2, "width": self.width, "height": self._splitter_width, "index": i});
                i = i + 1;
            }
        }
        return 0;
    }

    fn startSplitterDrag(index) {
        self._active_splitter = index;
        self._splitter_dragging = true;
        return 0;
    }

    fn dragSplitter(x, y) {
        if (not self._splitter_dragging) { return 0; }
        if (self._active_splitter < 0) { return 0; }
        let panes = self._manager.getPanes();
        if (self._active_splitter >= len(panes)) { return 0; }
        let left = panes[self._active_splitter - 1];
        let right = panes[self._active_splitter];
        let lr = left.getRect();
        let rr = right.getRect();
        if (self._manager.getLayout() == "horizontal") {
            let new_lw = x - lr["x"];
            if (new_lw < self._manager.getMinPaneSize()) { new_lw = self._manager.getMinPaneSize(); }
            if (new_lw > (lr["width"] + rr["width"]) - self._manager.getMinPaneSize()) {
                new_lw = (lr["width"] + rr["width"]) - self._manager.getMinPaneSize();
            }
            let new_rw = (lr["width"] + rr["width"]) - new_lw;
            left.setRect(lr["x"], lr["y"], new_lw, lr["height"]);
            right.setRect(new_lw, rr["y"], new_rw, rr["height"]);
        } else {
            let new_th = y - lr["y"];
            if (new_th < self._manager.getMinPaneSize()) { new_th = self._manager.getMinPaneSize(); }
            if (new_th > (lr["height"] + rr["height"]) - self._manager.getMinPaneSize()) {
                new_th = (lr["height"] + rr["height"]) - self._manager.getMinPaneSize();
            }
            let new_bh = (lr["height"] + rr["height"]) - new_th;
            left.setRect(lr["x"], lr["y"], lr["width"], new_th);
            right.setRect(rr["x"], new_th, rr["width"], new_bh);
        }
        self._rebuildSplitters();
        return 0;
    }

    fn endSplitterDrag() {
        self._splitter_dragging = false;
        self._active_splitter = -1;
        return 0;
    }

    fn isSplitterDragging() {
        return self._splitter_dragging;
    }

    fn findSplitterAt(x, y) {
        let i = 0;
        while (i < len(self._splitters)) {
            let s = self._splitters[i];
            if (x >= s["x"] and x <= s["x"] + s["width"] and
                y >= s["y"] and y <= s["y"] + s["height"]) {
                return i;
            }
            i = i + 1;
        }
        return -1;
    }

    fn getSplitterColor() {
        return self._splitter_color;
    }

    fn setSplitterColor(color) {
        self._splitter_color = color;
        return 0;
    }
}

