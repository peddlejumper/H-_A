        self._placeholder = nullptr;
        self._loading = false;
        return 0;
    }

    fn setLoadFunc(func) {
        self._load_func = func;
        return 0;
    }

    fn triggerLoad() {
        if (self._is_loaded or self._loading) { return 0; }
        self._loading = true;
        if (self._load_func != nullptr) {
            self._content = self._load_func();
        }
        self._is_loaded = true;
        self._loading = false;
        if (self._content != nullptr) {
            self.add_child(self._content);
        }
        return 0;
    }

    fn isLoaded() {
        return self._is_loaded;
    }

    fn setPlaceholder(widget) {
        self._placeholder = widget;
        if (not self._is_loaded) {
            self.add_child(widget);
        }
        return 0;
    }

    fn getContent() {
        return self._content;
    }

    fn setTrigger(trigger) {
        self._load_trigger = trigger;
        return 0;
    }

    fn unload() {
        if (self._content != nullptr) {
            self.remove_child(self._content);
        }
        self._content = nullptr;
        self._is_loaded = false;
        return 0;
    }

    fn reload() {
        self.unload();
        self.triggerLoad();
        return 0;
    }
}

