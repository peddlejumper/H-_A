    fn getTitle() { return self._title; }
    fn setArtist(artist) { self._artist = artist; return 0; }
    fn getArtist() { return self._artist; }
    fn setAlbum(album) { self._album = album; return 0; }
    fn getAlbum() { return self._album; }
    fn setDuration(duration) { self._duration = duration; return 0; }
    fn getDuration() { return self._duration; }
    fn getDurationFormatted() { let mins = self._duration / 60; let secs = self._duration % 60; let sec_str = str(secs); if (secs < 10) { sec_str = "0" + sec_str; } return str(mins) + ":" + sec_str; }
}

class SubtitleDisplay extends zzwUI {
    let _subtitles = [];
    let _current_index = -1;
    let _font_size = 16;

    fn init_sd() {
        self.init(str(hwdui_next_id()));
        self.widget_type = "SubtitleDisplay";
        self.width = 600;
        self.height = 40;
        self._subtitles = [];
        self._current_index = -1;
        self._font_size = 16;
        return 0;
    }

    fn addSubtitle(start_time, end_time, text) { push(self._subtitles, {"start": start_time, "end": end_time, "text": text}); return 0; }
    fn getSubtitles() { return self._subtitles; }
    fn updateForTime(current_time) { let i = 0; while (i < len(self._subtitles)) { if (current_time >= self._subtitles[i]["start"] and current_time <= self._subtitles[i]["end"]) { self._current_index = i; return i; } i = i + 1; } self._current_index = -1; return -1; }
    fn getCurrentText() { if (self._current_index >= 0 and self._current_index < len(self._subtitles)) { return self._subtitles[self._current_index]["text"]; } return ""; }
    fn setFontSize(size) { self._font_size = size; return 0; }
    fn clear() { self._subtitles = []; self._current_index = -1; return 0; }
}

class EqualizerControl extends zzwUI {
    let _bands = [];
    let _num_bands = 10;
    let _band_values = [];
    let _presets = {};

    fn init_ec() {
        self.init(str(hwdui_next_id()));
        self.widget_type = "EqualizerControl";
        self.width = 400;
        self.height = 200;
        self._bands = [];
        self._num_bands = 10;
        self._band_values = [];
        self._presets = {};
        let i = 0;
        while (i < self._num_bands) {
            push(self._band_values, 0);
            push(self._bands, 32 * (i + 1));
            i = i + 1;
        }
        return 0;
    }

    fn setBand(index, value) { if (index < 0 or index >= self._num_bands) { return 0; } if (value < -12) { value = -12; } if (value > 12) { value = 12; } self._band_values[index] = value; return 0; }
    fn getBand(index) { if (index < 0 or index >= self._num_bands) { return 0; } return self._band_values[index]; }
    fn getBandCount() { return self._num_bands; }
    fn addPreset(name, values) { self._presets[name] = values; return 0; }
    fn applyPreset(name) { if (self._presets[name] != nullptr) { self._band_values = self._presets[name]; } return 0; }
    fn reset() { let i = 0; while (i < self._num_bands) { self._band_values[i] = 0; i = i + 1; } return 0; }
}

class WaveFormDisplay extends zzwUI {
    let _samples = [];
    let _wave_color = "#4A90D9";
    let _progress = 0;

    fn init_wfd() {
        self.init(str(hwdui_next_id()));
        self.widget_type = "WaveFormDisplay";
        self.width = 400;
        self.height = 80;
        self._samples = [];
        self._wave_color = "#4A90D9";
        self._progress = 0;
        return 0;
    }

    fn setSamples(samples) { self._samples = samples; return 0; }
    fn getSamples() { return self._samples; }
    fn getSampleCount() { return len(self._samples); }
    fn setProgress(progress) { if (progress < 0) { progress = 0; } if (progress > 1) { progress = 1; } self._progress = progress; return 0; }
    fn getProgress() { return self._progress; }
    fn clear() { self._samples = []; self._progress = 0; return 0; }
}

