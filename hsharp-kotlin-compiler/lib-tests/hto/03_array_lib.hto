# H# Library Test 03 — Array Library
# Self-contained array/sequence operations.

let __stats = [0, 0, []];   # [passed, failed, failed_names]

fn check(name, cond) {
    if (cond) {
        __stats[0] = __stats[0] + 1;
    } else {
        __stats[1] = __stats[1] + 1;
        push(__stats[2], name);
    }
}

# =====================================================
# arr_sum / arr_product / arr_min / arr_max / arr_average
# =====================================================
fn arr_sum(a) {
    let s = 0;
    let i = 0;
    while (i < len(a)) { s = s + a[i]; i = i + 1; }
    return s;
}
fn arr_product(a) {
    let p = 1;
    let i = 0;
    while (i < len(a)) { p = p * a[i]; i = i + 1; }
    return p;
}
fn arr_min(a) {
    let m = a[0];
    let i = 1;
    while (i < len(a)) { if (a[i] < m) { m = a[i]; } i = i + 1; }
    return m;
}
fn arr_max(a) {
    let m = a[0];
    let i = 1;
    while (i < len(a)) { if (a[i] > m) { m = a[i]; } i = i + 1; }
    return m;
}
fn arr_average(a) { return arr_sum(a) / len(a); }
fn arr_contains(a, v) {
    let i = 0;
    while (i < len(a)) { if (a[i] == v) { return true; } i = i + 1; }
    return false;
}
fn arr_index_of(a, v) {
    let i = 0;
    while (i < len(a)) { if (a[i] == v) { return i; } i = i + 1; }
    return -1;
}
fn arr_count(a, v) {
    let n = 0;
    let i = 0;
    while (i < len(a)) { if (a[i] == v) { n = n + 1; } i = i + 1; }
    return n;
}
fn arr_reverse(a) {
    let r = [];
    let i = len(a) - 1;
    while (i >= 0) { push(r, a[i]); i = i - 1; }
    return r;
}
fn arr_unique(a) {
    let r = [];
    let i = 0;
    while (i < len(a)) {
        if (not arr_contains(r, a[i])) { push(r, a[i]); }
        i = i + 1;
    }
    return r;
}
fn arr_range(lo, hi, step) {
    let r = [];
    let i = lo;
    while (i < hi) {
        push(r, i);
        i = i + step;
    }
    return r;
}

check("sum/empty",     arr_sum([]) == 0);
check("sum/basic",     arr_sum([1, 2, 3, 4, 5]) == 15);
check("sum/neg",       arr_sum([-1, 1, -2, 2]) == 0);
check("sum/big",       arr_sum([100, 200, 300]) == 600);
check("prod/empty",    arr_product([]) == 1);
check("prod/basic",    arr_product([1, 2, 3, 4]) == 24);
check("prod/zero",     arr_product([1, 2, 0, 4]) == 0);
check("min/1",         arr_min([3, 1, 4, 1, 5, 9, 2, 6]) == 1);
check("min/single",    arr_min([42]) == 42);
check("min/neg",       arr_min([-1, -5, -3]) == -5);
check("max/1",         arr_max([3, 1, 4, 1, 5, 9, 2, 6]) == 9);
check("max/single",    arr_max([42]) == 42);
check("avg/3",         arr_average([10, 20, 30]) == 20);
check("contains/yes",  arr_contains([1, 2, 3], 2) == true);
check("contains/no",   arr_contains([1, 2, 3], 5) == false);
check("index/yes",     arr_index_of([1, 2, 3], 2) == 1);
check("index/no",      arr_index_of([1, 2, 3], 5) == -1);
check("count/3x2",     arr_count([1, 2, 1, 3, 1], 1) == 3);
check("count/zero",    arr_count([1, 2, 3], 5) == 0);
check("reverse/1",     arr_reverse([1, 2, 3])[0] == 3 and arr_reverse([1, 2, 3])[2] == 1);
check("reverse/empty", len(arr_reverse([])) == 0);
check("unique/1",      len(arr_unique([1, 2, 2, 3, 3, 3])) == 3);
check("unique/all",    len(arr_unique([1, 1, 1])) == 1);
check("range/1-5",     len(arr_range(1, 6, 1)) == 5);
check("range/0-10/2",  len(arr_range(0, 10, 2)) == 5);

# =====================================================
# arr_map / arr_filter / arr_reduce
# =====================================================
fn arr_map(a, f) {
    let r = [];
    let i = 0;
    while (i < len(a)) { push(r, f(a[i])); i = i + 1; }
    return r;
}
fn arr_filter(a, f) {
    let r = [];
    let i = 0;
    while (i < len(a)) {
        if (f(a[i])) { push(r, a[i]); }
        i = i + 1;
    }
    return r;
}
fn arr_reduce(a, init, f) {
    let acc = init;
    let i = 0;
    while (i < len(a)) {
        acc = f(acc, a[i]);
        i = i + 1;
    }
    return acc;
}
fn arr_any(a, f) {
    let i = 0;
    while (i < len(a)) {
        if (f(a[i])) { return true; }
        i = i + 1;
    }
    return false;
}
fn arr_all(a, f) {
    let i = 0;
    while (i < len(a)) {
        if (not f(a[i])) { return false; }
        i = i + 1;
    }
    return true;
}
fn arr_take(a, n) {
    let r = [];
    let i = 0;
    while (i < n and i < len(a)) { push(r, a[i]); i = i + 1; }
    return r;
}
fn arr_drop(a, n) {
    let r = [];
    let i = n;
    while (i < len(a)) { push(r, a[i]); i = i + 1; }
    return r;
}
fn arr_concat(a, b) {
    let r = [];
    let i = 0;
    while (i < len(a)) { push(r, a[i]); i = i + 1; }
    let j = 0;
    while (j < len(b)) { push(r, b[j]); j = j + 1; }
    return r;
}

# map
let doubled = arr_map([1, 2, 3], fn(x) { return x * 2; });
check("map/double",     doubled[0] == 2 and doubled[1] == 4 and doubled[2] == 6);
let sq = arr_map([1, 2, 3, 4], fn(x) { return x * x; });
check("map/sq",         sq[0] == 1 and sq[3] == 16);
# filter
let gt2 = arr_filter([1, 2, 3, 4, 5], fn(x) { return x > 2; });
check("filter/gt2",     len(gt2) == 3 and gt2[0] == 3);
let evens = arr_filter([1, 2, 3, 4, 5, 6], fn(x) { return x - int(x/2)*2 == 0; });
check("filter/even",    len(evens) == 3 and evens[0] == 2 and evens[2] == 6);
# reduce
let sum_reduce = arr_reduce([1, 2, 3, 4, 5], 0, fn(a, b) { return a + b; });
check("reduce/sum",     sum_reduce == 15);
let prod_reduce = arr_reduce([1, 2, 3, 4], 1, fn(a, b) { return a * b; });
check("reduce/prod",    prod_reduce == 24);
# any / all
check("any/yes",        arr_any([1, 2, 3], fn(x) { return x == 2; }) == true);
check("any/no",         arr_any([1, 2, 3], fn(x) { return x > 5; }) == false);
check("all/yes",        arr_all([2, 4, 6], fn(x) { return x - int(x/2)*2 == 0; }) == true);
check("all/no",         arr_all([2, 4, 5], fn(x) { return x - int(x/2)*2 == 0; }) == false);
# take / drop
check("take/2",         len(arr_take([1, 2, 3, 4], 2)) == 2);
check("take/many",      len(arr_take([1, 2], 10)) == 2);
check("drop/2",         arr_drop([1, 2, 3, 4], 2)[0] == 3);
# concat
let c = arr_concat([1, 2, 3], [4, 5]);
check("concat/basic",   len(c) == 5 and c[3] == 4 and c[4] == 5);

# =====================================================
# Sorting algorithms
# =====================================================
fn arr_bubble_sort(a) {
    let n = len(a);
    let swapped = true;
    while (swapped) {
        swapped = false;
        let i = 0;
        while (i < n - 1) {
            if (a[i] > a[i + 1]) {
                let t = a[i];
                a[i] = a[i + 1];
                a[i + 1] = t;
                swapped = true;
            }
            i = i + 1;
        }
        n = n - 1;
    }
    return a;
}
fn arr_insertion_sort(a) {
    let i = 1;
    while (i < len(a)) {
        let key = a[i];
        let j = i - 1;
        while (j >= 0 and a[j] > key) {
            a[j + 1] = a[j];
            j = j - 1;
        }
        a[j + 1] = key;
        i = i + 1;
    }
    return a;
}
fn arr_selection_sort(a) {
    let i = 0;
    while (i < len(a)) {
        let mn = i;
        let j = i + 1;
        while (j < len(a)) {
            if (a[j] < a[mn]) { mn = j; }
            j = j + 1;
        }
        let t = a[i];
        a[i] = a[mn];
        a[mn] = t;
        i = i + 1;
    }
    return a;
}
fn arr_quick_sort(a, lo, hi) {
    if (lo >= hi) { return a; }
    let pivot = a[hi];
    let i = lo - 1;
    let j = lo;
    while (j < hi) {
        if (a[j] <= pivot) {
            i = i + 1;
            let t = a[i];
            a[i] = a[j];
            a[j] = t;
        }
        j = j + 1;
    }
    let t = a[i + 1];
    a[i + 1] = a[hi];
    a[hi] = t;
    let p = i + 1;
    arr_quick_sort(a, lo, p - 1);
    arr_quick_sort(a, p + 1, hi);
    return a;
}
fn is_sorted(a) {
    let i = 0;
    while (i < len(a) - 1) {
        if (a[i] > a[i + 1]) { return false; }
        i = i + 1;
    }
    return true;
}
fn arr_eq(a, b) {
    if (len(a) != len(b)) { return false; }
    let i = 0;
    while (i < len(a)) {
        if (a[i] != b[i]) { return false; }
        i = i + 1;
    }
    return true;
}

check("sort/bubble/empty",     is_sorted(arr_bubble_sort([])));
check("sort/bubble/single",    is_sorted(arr_bubble_sort([42])));
check("sort/bubble/random",    is_sorted(arr_bubble_sort([3, 1, 4, 1, 5, 9, 2, 6, 5, 3])));
check("sort/bubble/sorted",    is_sorted(arr_bubble_sort([1, 2, 3, 4, 5])));
check("sort/bubble/reverse",   is_sorted(arr_bubble_sort([5, 4, 3, 2, 1])));
check("sort/insert/random",    is_sorted(arr_insertion_sort([3, 1, 4, 1, 5, 9, 2, 6])));
check("sort/insert/empty",     is_sorted(arr_insertion_sort([])));
check("sort/select/random",    is_sorted(arr_selection_sort([5, 2, 8, 1, 9, 3])));
check("sort/quick/random",     is_sorted(arr_quick_sort([5, 2, 8, 1, 9, 3, 7, 4, 6], 0, 8)));
check("sort/quick/empty",      is_sorted(arr_quick_sort([], 0, -1)));
check("sort/quick/sorted",     is_sorted(arr_quick_sort([1, 2, 3, 4, 5], 0, 4)));

# =====================================================
# Searching
# =====================================================
fn arr_binary_search(a, target) {
    let lo = 0;
    let hi = len(a) - 1;
    while (lo <= hi) {
        let mid = int((lo + hi) / 2);
        if (a[mid] == target) { return mid; }
        if (a[mid] < target) { lo = mid + 1; } else { hi = mid - 1; }
    }
    return -1;
}

let s = arr_bubble_sort([3, 1, 4, 1, 5, 9, 2, 6, 5, 3]);
check("bsearch/found",   arr_binary_search(s, 5) >= 0);
check("bsearch/absent",  arr_binary_search(s, 100) == -1);
check("bsearch/first",   arr_binary_search([1, 2, 3, 4, 5], 1) == 0);
check("bsearch/last",    arr_binary_search([1, 2, 3, 4, 5], 5) == 4);
check("bsearch/middle",  arr_binary_search([1, 2, 3, 4, 5], 3) == 2);

