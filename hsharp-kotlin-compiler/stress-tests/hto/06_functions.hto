# T06 - Functions & return
fn add(a, b) { return a + b; }
fn mul(a, b, c) { return a * b * c; }
fn square(x) { return x * x; }
print(add(3, 4));
print(mul(2, 3, 4));
print(square(7));

# recursion
fn fact(n) {
    if (n <= 1) { return 1; }
    return n * fact(n - 1);
}
print(fact(0));
print(fact(5));
print(fact(6));
