{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "H#",
  "scopeName": "source.hsharp",
  "fileTypes": [".hto", ".hsi"],
  "patterns": [
    { "include": "#comments" },
    { "include": "#strings" },
    { "include": "#numbers" },
    { "include": "#keywords" },
    { "include": "#operators" },
    { "include": "#functions" },
    { "include": "#types" },
    { "include": "#constants" },
    { "include": "#punctuation" },
    { "include": "#identifiers" }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "name": "comment.line.hash.hsharp",
          "match": "#.*$"
        }
      ]
    },
    "strings": {
      "patterns": [
        {
          "name": "string.quoted.double.hsharp",
          "begin": "\"",
          "end": "\"",
          "patterns": [
            {
              "name": "constant.character.escape.hsharp",
              "match": "\\\\."
            }
          ]
        }
      ]
    },
    "numbers": {
      "patterns": [
        {
          "name": "constant.numeric.float.hsharp",
          "match": "\\b\\d+\\.\\d+\\b"
        },
        {
          "name": "constant.numeric.integer.hsharp",
          "match": "\\b\\d+\\b"
        }
      ]
    },
    "keywords": {
      "patterns": [
        {
          "name": "keyword.control.hsharp",
          "match": "\\b(if|else|while|for|in|return|break|continue|try|catch|throw|del|import|coro|asm)\\b"
        },
        {
          "name": "storage.type.hsharp",
          "match": "\\b(let|fn|class|union|interface|module|concept|auto|ptr|new|super|extends|implements|is|as|private|static|public|region|region_interface|3dsizepower|em3d)\\b"
        },
        {
          "name": "keyword.operator.logical.hsharp",
          "match": "\\b(and|or|not)\\b"
        },
        {
          "name": "support.function.builtin.hsharp",
          "match": "\\b(print|len|str|int|float|type|abs|min|max|range|typeof|curry|uncurry|arity|bound_n|is_partial|push|pop|keys|values|items|has_key|read_file|write_file|thread_spawn|thread_join)\\b"
        }
      ]
    },
    "operators": {
      "patterns": [
        {
          "name": "keyword.operator.comparison.hsharp",
          "match": "==|!=|>=|<=|>|<"
        },
        {
          "name": "keyword.operator.assignment.hsharp",
          "match": "=(?!=)"
        },
        {
          "name": "keyword.operator.arithmetic.hsharp",
          "match": "\\+|\\-|\\*|/|%"
        },
        {
          "name": "keyword.operator.bitwise.hsharp",
          "match": "&|\\||\\^|~|<<|>>"
        },
        {
          "name": "keyword.operator.nullable.hsharp",
          "match": "\\?\\^|\\?"
        }
      ]
    },
    "functions": {
      "patterns": [
        {
          "name": "meta.function.definition.hsharp",
          "begin": "\\b(fn)\\s+([a-zA-Z_][a-zA-Z0-9_]*)",
          "end": "(?=\\{)",
          "beginCaptures": {
            "1": { "name": "storage.type.function.hsharp" },
            "2": { "name": "entity.name.function.hsharp" }
          }
        },
        {
          "name": "meta.function.call.hsharp",
          "match": "\\b([a-zA-Z_][a-zA-Z0-9_]*)\\s*(?=\\()",
          "captures": {
            "1": { "name": "entity.name.function.hsharp" }
          }
        }
      ]
    },
    "types": {
      "patterns": [
        {
          "name": "support.type.hsharp",
          "match": "\\b(LinearRegression|LogisticRegression|XGBoost|RandomForest|SVM|KMeans|PCA|LDA|tSNE|NeuralNetwork|CNN|RNN|LSTM|GRU|Transformer|GAN|VAE|Autoencoder|DecisionTree|GradientBoosting|AdaBoost|NaiveBayes|KNN|DBSCAN|AgglomerativeClustering|Birch|MeanShift|SpectralClustering|GaussianMixture|IsolationForest|OneClassSVM|LocalOutlierFactor|EllipticEnvelope|Ridge|Lasso|ElasticNet|BayesianRidge|ARDRegression|SGDRegressor|PassiveAggressiveRegressor|TheilSenRegressor|RANSACRegressor|HuberRegressor|QuantileRegressor|PoissonRegressor|GammaRegressor|TweedieRegressor|Perceptron|MLPClassifier|MLPRegressor|BaggingClassifier|BaggingRegressor|ExtraTreesClassifier|ExtraTreesRegressor|GradientBoostingClassifier|GradientBoostingRegressor|HistGradientBoostingClassifier|HistGradientBoostingRegressor|VotingClassifier|VotingRegressor|StackingClassifier|StackingRegressor|CalibratedClassifierCV|LabelPropagation|LabelSpreading|SemiSupervisedForest|SelfTrainingClassifier|BayesianOptimization|GridSearchCV|RandomizedSearchCV|HalvingGridSearchCV|HalvingRandomSearchCV|OptunaSearch|HyperbandSearch|PopulationBasedTraining|DifferentialEvolution|SimulatedAnnealing|GeneticAlgorithm|ParticleSwarm|AntColony|BeetleAntennae|GreyWolfOptimizer|WhaleOptimization|BatAlgorithm|FireflyAlgorithm|CuckooSearch|FlowerPollination|ArtificialBeeColony|CatSwarmOptimization|LionOptimizer|ElephantHerding|DragonflyAlgorithm|GrasshopperOptimization|MothFlameOptimization|SalpSwarm|SineCosineAlgorithm|MultiVerseOptimizer|AtomSearch|EquilibriumOptimizer|MarinePredators|AquilaOptimizer|AfricanVultures|ArtificialGorillaTroops|DwarfMongoose|KomodoMlipir|ReptileSearch|RedFoxOptimization|GoldenEagle|BaldEagleSearch|BlackWidow|Pathfinder|SeagullOptimization|TunicateSwarm|SpottedHyena|EmperorPenguin|ButterflyOptimization|HarrisHawks|HungerGames|RungeKutta|WeightedMeanOfVectors|CrestedPorcupine|SnowAblation|LiverCancer|Crayfish|GolfOptimization|ZebraOptimization|Osprey|Pelican|Goose|TasmanianDevil|Orangutan|Coati|Mongoose|Lyrebird|Kookaburra|Dingo|SecretaryBird|HoneyBadger|Puma|ArcticFox|Sidewinder|EyelashViper|Genet|Mara|Quokka|Wombat|Platypus|Echidna|SugarGlider|Kiwi|Kea|Kakapo|Takahe|Weka|Tuatara|TorchModel|TensorFlowModel|ONNXModel|CoreMLModel|TFLiteModel|FeatureHasher|KBinsDiscretizer|KernelCenterer|MaxAbsScaler|MinMaxScaler|Normalizer|PowerTransformer|QuantileTransformer|RobustScaler|StandardScaler|VarianceThreshold|Binarizer|FunctionTransformer|ColumnTransformer|TransformedTargetRegressor|SelectFromModel|SelectKBest|SelectPercentile|RFE|RFECV|SequentialFeatureSelector|VarianceInflationFactor|MutualInformation|ANOVA|FRegression|FClassification|Chi2|GenericUnivariateSelect|Binarizer|LabelBinarizer|LabelEncoder|MultiLabelBinarizer|OneHotEncoder|OrdinalEncoder|PolynomialFeatures|SplineTransformer|TargetEncoder|CatBoost|LightGBM)\\b"
        }
      ]
    },
    "constants": {
      "patterns": [
        {
          "name": "constant.language.boolean.hsharp",
          "match": "\\b(true|false)\\b"
        },
        {
          "name": "constant.language.null.hsharp",
          "match": "\\bnullptr\\b"
        }
      ]
    },
    "punctuation": {
      "patterns": [
        {
          "name": "punctuation.separator.hsharp",
          "match": "[,\\.:;]"
        },
        {
          "name": "punctuation.section.braces.hsharp",
          "match": "[\\{\\}]"
        },
        {
          "name": "punctuation.section.parens.hsharp",
          "match": "[\\(\\)]"
        },
        {
          "name": "punctuation.section.brackets.hsharp",
          "match": "[\\[\\]]"
        }
      ]
    },
    "identifiers": {
      "patterns": [
        {
          "name": "variable.other.hsharp",
          "match": "\\b[a-zA-Z_][a-zA-Z0-9_]*\\b"
        }
      ]
    }
  }
}